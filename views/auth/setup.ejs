<!DOCTYPE html>
<html lang="es">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= title %> - TuFerIA</title>
  <script src="https://cdn.tailwindcss.com"></script>
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800&display=swap" rel="stylesheet">
  <style>
    body { font-family: 'Inter', sans-serif; }
    .auth-gradient { background: linear-gradient(135deg, #0f0f1a 0%, #1a1a2e 50%, #0f0f1a 100%); }
    .glow { box-shadow: 0 0 40px rgba(99, 102, 241, 0.15); }
    .preview-card {
      transition: all 0.3s ease;
    }
    .preview-card:hover {
      transform: translateY(-4px);
    }
    .preview-card.selected {
      border-color: #6366f1;
      box-shadow: 0 0 30px rgba(99, 102, 241, 0.2);
    }
  </style>
</head>
<body class="auth-gradient min-h-screen flex items-center justify-center p-4">
  <div class="w-full max-w-2xl">
    <a href="/" class="flex items-center justify-center gap-2 mb-8">
      <div class="w-10 h-10 rounded-xl bg-gradient-to-br from-indigo-500 to-purple-600 flex items-center justify-center">
        <svg class="w-6 h-6 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 10V3L4 14h7v7l9-11h-7z"/>
        </svg>
      </div>
      <span class="text-2xl font-bold text-white">TuFerIA</span>
    </a>

    <div class="bg-[#1a1a2e]/80 backdrop-blur-xl rounded-2xl p-8 border border-gray-700/30 glow">
      <h1 class="text-2xl font-bold text-white text-center mb-2">Creá tu Tienda Online</h1>
      <p class="text-gray-400 text-center text-sm mb-8">Configurá los datos básicos de tu tienda</p>

      <% if (typeof error !== 'undefined' && error) { %>
        <div class="mb-6 p-4 bg-red-500/10 border border-red-500/20 rounded-xl text-red-400 text-sm">
          <%= error %>
        </div>
      <% } %>

      <form method="POST" action="/dashboard/setup" class="space-y-6">
        <div>
          <label class="block text-sm font-medium text-gray-300 mb-2">Nombre de tu Tienda</label>
          <input type="text" name="name" required
            class="w-full px-4 py-3 bg-[#0f0f1a] border border-gray-700/50 rounded-xl text-white placeholder-gray-500 focus:outline-none focus:border-indigo-500/50 focus:ring-1 focus:ring-indigo-500/30 transition-colors"
            placeholder="Ej: Mi Tienda Online" id="storeName">
        </div>

        <div>
          <label class="block text-sm font-medium text-gray-300 mb-2">URL de tu Tienda</label>
          <div class="flex items-center gap-2 bg-[#0f0f1a] border border-gray-700/50 rounded-xl px-4 py-3 focus-within:border-indigo-500/50 focus-within:ring-1 focus-within:ring-indigo-500/30 transition-colors">
            <span class="text-gray-500 text-sm">tuferia.com/</span>
            <input type="text" name="slug" required id="storeSlug"
              class="flex-1 bg-transparent text-white placeholder-gray-500 focus:outline-none"
              placeholder="mi-tienda">
          </div>
          <p class="text-xs text-gray-500 mt-1">Solo letras, números y guiones</p>
        </div>

        <div>
          <label class="block text-sm font-medium text-gray-300 mb-4">Elegí un Diseño</label>
          <div class="grid grid-cols-3 gap-4">
            <label class="preview-card cursor-pointer relative p-4 rounded-xl bg-[#0f0f1a] border-2 border-gray-700/50 has-[:checked]:border-indigo-500 has-[:checked]:bg-indigo-500/10 text-center">
              <input type="radio" name="template" value="template1" class="sr-only" checked>
              <div class="w-10 h-10 mx-auto rounded-lg bg-gradient-to-br from-blue-500/20 to-cyan-500/20 flex items-center justify-center mb-2">
                <svg class="w-5 h-5 text-blue-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6a2 2 0 012-2h2a2 2 0 012 2v2a2 2 0 01-2 2H6a2 2 0 01-2-2V6z"/>
                </svg>
              </div>
              <span class="text-sm font-medium text-white block">Clásico</span>
              <span class="text-xs text-gray-500">Moderno y limpio</span>
            </label>
            <label class="preview-card cursor-pointer relative p-4 rounded-xl bg-[#0f0f1a] border-2 border-gray-700/50 has-[:checked]:border-indigo-500 has-[:checked]:bg-indigo-500/10 text-center">
              <input type="radio" name="template" value="template2" class="sr-only">
              <div class="w-10 h-10 mx-auto rounded-lg bg-gradient-to-br from-purple-500/20 to-pink-500/20 flex items-center justify-center mb-2">
                <svg class="w-5 h-5 text-purple-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 8h14M5 8a2 2 0 110-4h14a2 2 0 110 4M5 8v10a2 2 0 002 2h10a2 2 0 002-2V8m-9 4h4"/>
                </svg>
              </div>
              <span class="text-sm font-medium text-white block">Moderno</span>
              <span class="text-xs text-gray-500">Grid y categorías</span>
            </label>
            <label class="preview-card cursor-pointer relative p-4 rounded-xl bg-[#0f0f1a] border-2 border-gray-700/50 has-[:checked]:border-indigo-500 has-[:checked]:bg-indigo-500/10 text-center">
              <input type="radio" name="template" value="template3" class="sr-only">
              <div class="w-10 h-10 mx-auto rounded-lg bg-gradient-to-br from-emerald-500/20 to-teal-500/20 flex items-center justify-center mb-2">
                <svg class="w-5 h-5 text-emerald-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 17V7m0 10a2 2 0 01-2 2H5a2 2 0 01-2-2V7a2 2 0 012-2h2a2 2 0 012 2m0 10a2 2 0 002 2h2a2 2 0 002-2M9 7a2 2 0 012-2h2a2 2 0 012 2m0 10V7m0 10a2 2 0 002 2h2a2 2 0 002-2V7a2 2 0 00-2-2h-2a2 2 0 00-2 2"/>
                </svg>
              </div>
              <span class="text-sm font-medium text-white block">Minimal</span>
              <span class="text-xs text-gray-500">Simple y elegante</span>
            </label>
          </div>
        </div>

        <button type="submit"
          class="w-full py-3 px-6 bg-gradient-to-r from-indigo-600 to-purple-600 text-white font-semibold rounded-xl hover:from-indigo-500 hover:to-purple-500 transition-all duration-200 shadow-lg shadow-indigo-600/25">
          Crear mi Tienda
        </button>
      </form>
    </div>
  </div>

  <script>
    document.getElementById('storeName').addEventListener('input', function() {
      const slug = this.value.toLowerCase()
        .replace(/[^a-z0-9\s-]/g, '')
        .replace(/\s+/g, '-')
        .replace(/-+/g, '-')
        .replace(/^-|-$/g, '');
      document.getElementById('storeSlug').value = slug;
    });
  </script>
</body>
</html>
