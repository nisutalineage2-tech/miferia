<%
  let storeMethods = [];
  try { storeMethods = JSON.parse(store.payment_methods || '[]'); } catch(e) {}
  const minPurchase = parseFloat(store.min_purchase || 0);
  const hasPickup = store.local_pickup == 1;
  const pickupDiscount = parseFloat(store.pickup_discount || 0);
  const storeDiscounts = {};
  try { Object.assign(storeDiscounts, JSON.parse(store.payment_discounts || '{}')); } catch(e) {}
  let paymentMethod = null;
  
  // Calculate effective total with pickup discount
  let effectiveTotal = cartTotal;
  let discountLine = 0;
  if (pickupDiscount > 0) {
    discountLine = Math.min(pickupDiscount, effectiveTotal);
  }
%>

<div class="max-w-4xl mx-auto px-4 py-8">
  <h1 class="text-3xl font-bold text-gray-900 mb-8">Finalizar Compra</h1>

  <% if (minPurchase > 0 && cartTotal < minPurchase) { %>
    <div class="mb-6 p-4 bg-red-50 border border-red-200 rounded-xl">
      <div class="flex items-center gap-3">
        <svg class="w-5 h-5 text-red-500 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-2.5L13.732 4c-.77-.833-1.964-.833-2.732 0L4.082 16.5c-.77.833.192 2.5 1.732 2.5z"/>
        </svg>
        <div>
          <p class="text-sm font-semibold text-red-800">Compra mínima no alcanzada</p>
          <p class="text-sm text-red-600">El monto mínimo de compra es <strong>$<%= minPurchase.toFixed(2) %></strong>. Te faltan <strong>$<%= (minPurchase - cartTotal).toFixed(2) %></strong>.</p>
        </div>
      </div>
    </div>
  <% } %>

  <div class="grid lg:grid-cols-2 gap-8">
    <!-- Form -->
    <div>
      <div class="p-6 bg-white rounded-2xl border border-gray-100 shadow-sm">
        <h2 class="text-lg font-semibold text-gray-900 mb-6">Datos de contacto</h2>
        <form id="checkoutForm" class="space-y-4">
          <input type="hidden" name="store_id" value="<%= store.id %>">
          <input type="hidden" name="local_pickup" id="localPickupInput" value="0">
          
          <h3 class="text-sm font-semibold text-gray-900 -mb-2">Datos del cliente</h3>
          <div class="grid grid-cols-2 gap-3">
            <div>
              <label class="block text-sm font-medium text-gray-700 mb-1">Nombre *</label>
              <input type="text" name="customer_name" required
                class="w-full px-4 py-3 border border-gray-200 rounded-xl text-gray-900 placeholder-gray-400 focus:outline-none focus:border-gray-900 transition-colors"
                placeholder="Tu nombre">
            </div>
            <div>
              <label class="block text-sm font-medium text-gray-700 mb-1">Apellido</label>
              <input type="text" name="customer_lastname"
                class="w-full px-4 py-3 border border-gray-200 rounded-xl text-gray-900 placeholder-gray-400 focus:outline-none focus:border-gray-900 transition-colors"
                placeholder="Tu apellido">
            </div>
          </div>
          <div>
            <label class="block text-sm font-medium text-gray-700 mb-1">Email *</label>
            <input type="email" name="customer_email" required
              class="w-full px-4 py-3 border border-gray-200 rounded-xl text-gray-900 placeholder-gray-400 focus:outline-none focus:border-gray-900 transition-colors"
              placeholder="tu@email.com">
          </div>
          <div class="grid grid-cols-2 gap-3">
            <div>
              <label class="block text-sm font-medium text-gray-700 mb-1">Teléfono <span class="text-gray-400 font-normal">(opcional)</span></label>
              <input type="tel" name="customer_phone"
                class="w-full px-4 py-3 border border-gray-200 rounded-xl text-gray-900 placeholder-gray-400 focus:outline-none focus:border-gray-900 transition-colors"
                placeholder="+54 11 1234-5678">
            </div>
            <div>
              <label class="block text-sm font-medium text-gray-700 mb-1">DNI o CUIL <span class="text-gray-400 font-normal">(opcional)</span></label>
              <input type="text" name="customer_dni"
                class="w-full px-4 py-3 border border-gray-200 rounded-xl text-gray-900 placeholder-gray-400 focus:outline-none focus:border-gray-900 transition-colors"
                placeholder="XX.XXX.XXX">
            </div>
          </div>

          <!-- Local Pickup Option -->
          <% if (hasPickup) { %>
            <div class="p-4 bg-indigo-50 rounded-xl border border-indigo-200">
              <label class="flex items-center gap-3 cursor-pointer">
                <input type="checkbox" id="pickupCheckbox" onchange="togglePickup(this.checked)"
                  class="w-4 h-4 rounded border-indigo-300 text-indigo-600 focus:ring-indigo-500">
                <div>
                  <span class="text-sm font-medium text-indigo-900">Retiro en el local</span>
                  <p class="text-xs text-indigo-700 mt-0.5"><%= store.local_pickup_address || 'Consultar dirección' %></p>
                </div>
              </label>
              <% if (pickupDiscount > 0) { %>
                <p class="text-xs text-green-700 mt-2 pl-7">
                  🎉 <strong>$<%= pickupDiscount.toFixed(2) %></strong> de descuento por retirar en el local
                </p>
              <% } %>
            </div>
          <% } %>

          <!-- Address -->
          <div id="addressField" class="space-y-3">
            <h3 class="text-sm font-semibold text-gray-900">Dirección de entrega</h3>
            <div class="grid grid-cols-[2fr_1fr] gap-3">
              <div>
                <label class="block text-sm font-medium text-gray-700 mb-1">Calle</label>
                <input type="text" name="address_street" id="addressStreet"
                  class="w-full px-4 py-3 border border-gray-200 rounded-xl text-gray-900 placeholder-gray-400 focus:outline-none focus:border-gray-900 transition-colors"
                  placeholder="Calle">
              </div>
              <div>
                <label class="block text-sm font-medium text-gray-700 mb-1">Número</label>
                <input type="text" name="address_number"
                  class="w-full px-4 py-3 border border-gray-200 rounded-xl text-gray-900 placeholder-gray-400 focus:outline-none focus:border-gray-900 transition-colors"
                  placeholder="123">
              </div>
            </div>
            <div>
              <label class="block text-sm font-medium text-gray-700 mb-1">Piso / Dpto. <span class="text-gray-400 font-normal">(opcional)</span></label>
              <input type="text" name="address_floor"
                class="w-full px-4 py-3 border border-gray-200 rounded-xl text-gray-900 placeholder-gray-400 focus:outline-none focus:border-gray-900 transition-colors"
                placeholder="Piso 3, Dpto B">
            </div>
            <div class="grid grid-cols-2 gap-3">
              <div>
                <label class="block text-sm font-medium text-gray-700 mb-1">Código postal</label>
                <input type="text" name="address_zip"
                  class="w-full px-4 py-3 border border-gray-200 rounded-xl text-gray-900 placeholder-gray-400 focus:outline-none focus:border-gray-900 transition-colors"
                  placeholder="C1425">
              </div>
              <div>
                <label class="block text-sm font-medium text-gray-700 mb-1">Barrio</label>
                <input type="text" name="address_neighborhood"
                  class="w-full px-4 py-3 border border-gray-200 rounded-xl text-gray-900 placeholder-gray-400 focus:outline-none focus:border-gray-900 transition-colors"
                  placeholder="Barrio">
              </div>
            </div>
            <div class="grid grid-cols-2 gap-3">
              <div>
                <label class="block text-sm font-medium text-gray-700 mb-1">Ciudad</label>
                <input type="text" name="address_city"
                  class="w-full px-4 py-3 border border-gray-200 rounded-xl text-gray-900 placeholder-gray-400 focus:outline-none focus:border-gray-900 transition-colors"
                  placeholder="Ciudad">
              </div>
              <div>
                <label class="block text-sm font-medium text-gray-700 mb-1">Provincia</label>
                <input type="text" name="address_province"
                  class="w-full px-4 py-3 border border-gray-200 rounded-xl text-gray-900 placeholder-gray-400 focus:outline-none focus:border-gray-900 transition-colors"
                  placeholder="Provincia">
              </div>
            </div>
          </div>

          <div>
            <label class="block text-sm font-medium text-gray-700 mb-1">Notas del pedido</label>
            <textarea name="notes" rows="2"
              class="w-full px-4 py-3 border border-gray-200 rounded-xl text-gray-900 placeholder-gray-400 focus:outline-none focus:border-gray-900 transition-colors"
              placeholder="Alguna instrucción especial..."></textarea>
          </div>

          <!-- Payment Methods with Discounts -->
          <% if (storeMethods.length > 0) { %>
            <div class="border-t border-gray-100 pt-4">
              <h3 class="text-sm font-semibold text-gray-900 mb-3">Medios de pago</h3>
              <div class="space-y-2">
                <% storeMethods.forEach(m => { %>
                  <label class="flex items-center gap-3 p-3 rounded-xl border <%= paymentMethod === m ? 'border-gray-900 bg-gray-50' : 'border-gray-200' %> cursor-pointer hover:border-gray-400 transition-colors">
                    <input type="radio" name="payment_method" value="<%= m %>" class="w-4 h-4 text-gray-900 border-gray-300 focus:ring-gray-900"
                      onchange="updatePaymentDiscount('<%= m %>')">
                    <div class="flex-1 flex items-center justify-between">
                      <span class="text-sm font-medium text-gray-900"><%= m %></span>
                      <% if (storeDiscounts[m] && storeDiscounts[m] > 0) { %>
                        <span class="text-xs font-bold text-green-600 bg-green-100 px-2.5 py-1 rounded-full"><%= storeDiscounts[m] %>% DESCUENTO</span>
                      <% } %>
                    </div>
                  </label>
                <% }); %>
              </div>
            </div>
          <% } %>

          <button type="submit" id="placeOrderBtn"
            class="w-full px-8 py-4 text-base font-bold text-white rounded-xl transition-all hover:opacity-90 disabled:opacity-50 disabled:cursor-not-allowed"
            style="background: linear-gradient(135deg, var(--primary, #4f46e5), var(--accent, #7c3aed));"
            <%= minPurchase > 0 && cartTotal < minPurchase ? 'disabled' : '' %>>
            <%= minPurchase > 0 && cartTotal < minPurchase ? 'Compra mínima no alcanzada' : 'Confirmar Pedido' %>
          </button>
        </form>
      </div>
    </div>

    <!-- Order Summary -->
    <div>
      <div class="p-6 bg-white rounded-2xl border border-gray-100 shadow-sm">
        <h2 class="text-lg font-semibold text-gray-900 mb-4">Resumen del pedido</h2>
        <div class="space-y-3 mb-6">
          <% cartItems.forEach(item => { %>
            <div class="flex items-center justify-between py-2">
              <div class="flex items-center gap-3">
                <div class="w-10 h-10 rounded-lg bg-gray-50 overflow-hidden shrink-0">
                  <% if (item.image) { %>
                    <img src="<%= item.image %>" alt="" class="w-full h-full object-cover">
                  <% } else { %>
                    <div class="w-full h-full flex items-center justify-center text-gray-300">
                      <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M2.25 15.75l5.159-5.159a2.25 2.25 0 013.182 0l5.159 5.159m-1.5-1.5l1.409-1.409a2.25 2.25 0 013.182 0l2.909 2.909M3.75 21h16.5A2.25 2.25 0 0022.5 18.75V5.25A2.25 2.25 0 0020.25 3H3.75A2.25 2.25 0 001.5 5.25v13.5A2.25 2.25 0 003.75 21z"/>
                      </svg>
                    </div>
                  <% } %>
                </div>
                <div>
                  <p class="text-sm font-medium text-gray-900"><%= item.quantity %>x <%= item.name %></p>
                  <p class="text-xs text-gray-500">$<%= item.price.toFixed(2) %> c/u</p>
                </div>
              </div>
              <span class="text-sm font-bold text-gray-900">$<%= (item.price * item.quantity).toFixed(2) %></span>
            </div>
          <% }); %>
        </div>
        
        <div class="border-t border-gray-100 pt-4 space-y-2">
          <div class="flex justify-between text-sm text-gray-600">
            <span>Subtotal</span>
            <span>$<%= cartTotal.toFixed(2) %></span>
          </div>
          <% if (pickupDiscount > 0) { %>
            <div class="flex justify-between text-sm text-green-700" id="pickupDiscountLine" style="display: none;">
              <span>Descuento retiro en local</span>
              <span>-$<%= pickupDiscount.toFixed(2) %></span>
            </div>
          <% } %>
          <% if (minPurchase > 0) { %>
            <div class="flex justify-between text-xs text-gray-400">
              <span>Compra mínima</span>
              <span>$<%= minPurchase.toFixed(2) %></span>
            </div>
          <% } %>
          <div class="flex justify-between text-lg font-bold text-gray-900 pt-2 border-t border-gray-100">
            <span>Total</span>
            <span id="totalDisplay">$<%= cartTotal.toFixed(2) %></span>
          </div>
        </div>
      </div>
    </div>
  </div>
</div>

<script>
  const minPurchase = <%= minPurchase %>;
  const cartTotal = <%= cartTotal %>;
  const pickupDiscount = <%= pickupDiscount %>;
  const storeDiscounts = <%- JSON.stringify(storeDiscounts || {}) %>;
  let selectedPaymentDiscount = 0;

  function updatePaymentDiscount(method) {
    selectedPaymentDiscount = storeDiscounts[method] || 0;
    updateTotal();
  }

  function updateTotal() {
    let total = cartTotal;
    if (document.getElementById('pickupCheckbox')?.checked && pickupDiscount > 0) {
      total = Math.max(0, total - pickupDiscount);
    }
    if (selectedPaymentDiscount > 0) {
      total = total * (1 - selectedPaymentDiscount / 100);
    }
    document.getElementById('totalDisplay').textContent = '$' + total.toFixed(2);
  }

  function togglePickup(checked) {
    document.getElementById('localPickupInput').value = checked ? '1' : '0';
    document.getElementById('addressField').style.display = checked ? 'none' : 'block';
    
    // Update total with discount
    const discountLine = document.getElementById('pickupDiscountLine');
    const totalDisplay = document.getElementById('totalDisplay');
    if (checked && pickupDiscount > 0) {
      discountLine.style.display = 'flex';
      totalDisplay.textContent = '$' + Math.max(0, cartTotal - pickupDiscount).toFixed(2);
    } else {
      discountLine.style.display = 'none';
      totalDisplay.textContent = '$' + cartTotal.toFixed(2);
    }
  }

  document.getElementById('checkoutForm')?.addEventListener('submit', async (e) => {
    e.preventDefault();
    const btn = document.getElementById('placeOrderBtn');
    if (btn.disabled) return;
    
    btn.disabled = true;
    btn.textContent = 'Procesando...';

    const form = new FormData(e.target);
    const data = Object.fromEntries(form.entries());

    const res = await fetch('/api/order/place', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify(data)
    });
    const result = await res.json();

    if (result.success) {
      window.location.href = '/<%= store.slug %>?order=' + result.orderId;
    } else {
      alert('Error: ' + (result.error || 'No se pudo procesar el pedido'));
      btn.disabled = false;
      btn.textContent = 'Confirmar Pedido';
    }
  });
</script>
