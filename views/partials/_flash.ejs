<% if (typeof order !== 'undefined' && order) { %>
  <div class="bg-green-50 border-b border-green-200">
    <div class="max-w-7xl mx-auto px-4 py-4 text-center">
      <p class="text-green-800 font-medium">✅ Pedido confirmado! Tu número de orden es: <strong><%= order %></strong></p>
      <p class="text-green-600 text-sm mt-1">Te contactaremos a la brevedad para coordinar la entrega.</p>
    </div>
  </div>
<% } %>
