<% const imgs = typeof heroImages !== 'undefined' && heroImages && heroImages.length > 0 ? heroImages : (store.banner ? [store.banner] : []); %>
<% if (imgs.length > 0) { %>
<div class="banner-carousel relative w-full overflow-hidden bg-gray-100" data-interval="5000" style="height: 500px;">
  <div class="banner-carousel-track flex transition-transform duration-700 ease-in-out h-full">
    <% imgs.forEach((img, i) => { %>
      <div class="banner-carousel-slide w-full h-full shrink-0 <%= i === 0 ? 'active' : '' %>">
        <img src="<%= img %>" alt="" class="w-full h-full object-cover" loading="<%= i === 0 ? 'eager' : 'lazy' %>">
      </div>
    <% }); %>
  </div>
  <% if (imgs.length > 1) { %>
  <div class="banner-carousel-dots absolute bottom-4 left-1/2 -translate-x-1/2 flex gap-2 z-10">
    <% imgs.forEach((_, i) => { %>
      <button class="banner-dot w-3 h-3 rounded-full transition-all duration-300 <%= i === 0 ? 'bg-white scale-110' : 'bg-white/40 hover:bg-white/70' %>" data-index="<%= i %>" aria-label="Slide <%= i + 1 %>"></button>
    <% }); %>
  </div>
  <button class="banner-prev absolute left-4 top-1/2 -translate-y-1/2 w-10 h-10 rounded-full bg-black/20 hover:bg-black/40 text-white flex items-center justify-center transition-all z-10 backdrop-blur-sm" aria-label="Anterior">
    <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7"/></svg>
  </button>
  <button class="banner-next absolute right-4 top-1/2 -translate-y-1/2 w-10 h-10 rounded-full bg-black/20 hover:bg-black/40 text-white flex items-center justify-center transition-all z-10 backdrop-blur-sm" aria-label="Siguiente">
    <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/></svg>
  </button>
  <% } %>
</div>
<script>
(function(){if(window.__bannerCarouselLoaded)return;window.__bannerCarouselLoaded=true;
function initBanner(container){const track=container.querySelector('.banner-carousel-track');const slides=container.querySelectorAll('.banner-carousel-slide');const dots=container.querySelectorAll('.banner-dot');const prevBtn=container.querySelector('.banner-prev');const nextBtn=container.querySelector('.banner-next');if(!track||slides.length<2)return;let current=0;const total=slides.length;let interval=parseInt(container.dataset.interval)||5000;let timer=null;
function goTo(index){if(index<0)index=total-1;if(index>=total)index=0;current=index;track.style.transform='translateX(-'+(current*100)+'%)';dots.forEach((d,i)=>{d.classList.toggle('bg-white',i===current);d.classList.toggle('scale-110',i===current);d.classList.toggle('bg-white/40',i!==current);});resetTimer();}
function nextSlide(){goTo(current+1);}
function prevSlide(){goTo(current-1);}
function resetTimer(){if(timer)clearInterval(timer);timer=setInterval(nextSlide,interval);}
if(prevBtn)prevBtn.addEventListener('click',prevSlide);if(nextBtn)nextBtn.addEventListener('click',nextSlide);dots.forEach(d=>d.addEventListener('click',()=>goTo(parseInt(d.dataset.index))));
container.addEventListener('mouseenter',()=>{if(timer)clearInterval(timer);});container.addEventListener('mouseleave',resetTimer);
let startX=0;container.addEventListener('touchstart',(e)=>{startX=e.touches[0].clientX;},{passive:true});container.addEventListener('touchend',(e)=>{const diff=startX-e.changedTouches[0].clientX;if(Math.abs(diff)>50){if(diff>0)nextSlide();else prevSlide();}},{passive:true});
resetTimer();}
document.querySelectorAll('.banner-carousel').forEach(initBanner);})();
</script>
<% } %>