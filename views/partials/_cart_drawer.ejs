<!-- Cart Drawer -->
<div id="cartDrawer" class="fixed inset-0 z-50 hidden" role="dialog" aria-modal="true">
  <div class="absolute inset-0 bg-black/40 transition-opacity" onclick="toggleCartDrawer()"></div>
  <div class="absolute top-0 right-0 h-full w-full max-w-md bg-white shadow-2xl transform transition-transform duration-300 flex flex-col">
    <!-- Header -->
    <div class="flex items-center justify-between px-5 py-4 border-b border-gray-100 shrink-0">
      <h2 class="text-lg font-bold text-gray-900">Tu Pedido</h2>
      <button onclick="toggleCartDrawer()" class="p-1.5 hover:bg-gray-100 rounded-lg transition-colors">
        <svg class="w-5 h-5 text-gray-500" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"/>
        </svg>
      </button>
    </div>

    <% if (cartItems.length > 0) { %>
      <!-- Ticket-style items -->
      <div class="flex-1 overflow-y-auto px-5 py-4 space-y-3">
        <div class="border-2 border-dashed border-gray-200 rounded-2xl p-4 bg-gray-50/50">
          <div class="text-center mb-4">
            <p class="text-xs font-mono text-gray-400 uppercase tracking-widest">Ticket</p>
            <p class="text-sm font-bold text-gray-900"><%= store.name %></p>
          </div>
          <div class="space-y-3">
            <% cartItems.forEach(item => { %>
              <div class="flex items-start gap-3 pb-3 border-b border-dashed border-gray-200 last:border-0 last:pb-0">
                <div class="w-12 h-12 rounded-xl bg-white overflow-hidden shrink-0 shadow-sm">
                  <% if (item.image) { %>
                    <img src="<%= item.image %>" alt="" class="w-full h-full object-cover">
                  <% } else { %>
                    <div class="w-full h-full flex items-center justify-center text-gray-300 text-xs">📦</div>
                  <% } %>
                </div>
                <div class="flex-1 min-w-0">
                  <p class="text-sm font-semibold text-gray-900 truncate"><%= item.name %></p>
                  <p class="text-xs text-gray-500">$<%= item.price.toFixed(2) %> c/u</p>
                  <div class="flex items-center gap-2 mt-1">
                    <button onclick="drawerUpdateCart('<%= item.id %>', <%= item.quantity - 1 %>)" class="w-6 h-6 rounded-full border border-gray-300 flex items-center justify-center text-gray-500 hover:border-gray-900 hover:text-gray-900 text-sm transition-colors">−</button>
                    <span class="text-sm font-bold text-gray-900 min-w-[20px] text-center"><%= item.quantity %></span>
                    <button onclick="drawerUpdateCart('<%= item.id %>', <%= item.quantity + 1 %>)" class="w-6 h-6 rounded-full border border-gray-300 flex items-center justify-center text-gray-500 hover:border-gray-900 hover:text-gray-900 text-sm transition-colors">+</button>
                  </div>
                </div>
                <div class="text-right shrink-0">
                  <p class="text-sm font-bold text-gray-900">$<%= (item.price * item.quantity).toFixed(2) %></p>
                  <button onclick="drawerRemoveItem('<%= item.id %>')" class="text-xs text-red-400 hover:text-red-600 mt-0.5 block">Eliminar</button>
                </div>
              </div>
            <% }); %>
          </div>
          <!-- Total -->
          <div class="mt-4 pt-3 border-t-2 border-double border-gray-300">
            <div class="flex items-center justify-between">
              <span class="text-sm font-mono text-gray-500 uppercase tracking-wide">Total</span>
              <span class="text-xl font-bold text-gray-900" id="drawerTotal">$<%= cartTotal.toFixed(2) %></span>
            </div>
          </div>
        </div>
      </div>

      <!-- Actions -->
      <div class="px-5 py-4 border-t border-gray-100 shrink-0 space-y-2">
        <a href="<%=storeBaseUrl%>/checkout"
          class="block w-full text-center px-6 py-3.5 text-sm font-bold text-white rounded-xl transition-all hover:opacity-90"
          style="background: linear-gradient(135deg, var(--primary, #4f46e5), var(--accent, #7c3aed));">
          Finalizar Compra
        </a>
        <button onclick="toggleCartDrawer()"
          class="block w-full text-center px-6 py-3 text-sm font-medium text-gray-600 bg-gray-100 rounded-xl hover:bg-gray-200 transition-colors">
          Seguir comprando
        </button>
      </div>
    <% } else { %>
      <!-- Empty cart -->
      <div class="flex-1 flex flex-col items-center justify-center px-5">
        <div class="w-20 h-20 rounded-full bg-gray-100 flex items-center justify-center mb-4">
          <svg class="w-10 h-10 text-gray-300" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M2.25 3h1.386c.51 0 .955.343 1.087.835l.383 1.437M7.5 14.25a3 3 0 00-3 3h15.75m-12.75-3h11.218c1.121-2.3 2.1-4.684 2.924-7.138a60.114 60.114 0 00-16.536-1.84M7.5 14.25L5.106 5.272M6 20.25a.75.75 0 11-1.5 0 .75.75 0 011.5 0zm12.75 0a.75.75 0 11-1.5 0 .75.75 0 011.5 0z"/>
          </svg>
        </div>
        <h3 class="text-lg font-bold text-gray-900 mb-1">Carrito vacío</h3>
        <p class="text-sm text-gray-500 mb-6 text-center">Agregá productos para empezar a comprar</p>
        <button onclick="toggleCartDrawer()"
          class="px-8 py-3 text-sm font-bold text-white rounded-xl transition-all hover:opacity-90"
          style="background: linear-gradient(135deg, var(--primary, #4f46e5), var(--accent, #7c3aed));">
          Ver productos
        </button>
      </div>
    <% } %>
  </div>
</div>

<script>
  function toggleCartDrawer() {
    document.getElementById('cartDrawer').classList.toggle('hidden');
    document.body.style.overflow = document.getElementById('cartDrawer').classList.contains('hidden') ? '' : 'hidden';
  }

  async function drawerUpdateCart(itemId, qty) {
    if (qty <= 0) return drawerRemoveItem(itemId);
    const res = await fetch('/api/cart/update', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({ item_id: itemId, quantity: qty, store_id: '<%= store.id %>' })
    });
    const data = await res.json();
    if (data.success) location.reload();
  }

  async function drawerRemoveItem(itemId) {
    const res = await fetch('/api/cart/remove', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({ item_id: itemId, store_id: '<%= store.id %>' })
    });
    const data = await res.json();
    if (data.success) location.reload();
  }
</script>
