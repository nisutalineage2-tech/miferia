<div class="max-w-4xl mx-auto px-4 py-8">
  <h1 class="text-3xl font-bold text-gray-900 mb-8">Carrito de Compras</h1>

  <% if (cartItems.length > 0) { %>
    <%
      const minPurchase = parseFloat(store.min_purchase || 0);
      const hasPickup = store.local_pickup == 1;
      let storeMethods = [];
      try { storeMethods = JSON.parse(store.payment_methods || '[]'); } catch(e) {}
    %>

    <% if (minPurchase > 0) { %>
      <div class="mb-6 p-4 rounded-xl <%= cartTotal >= minPurchase ? 'bg-green-50 border border-green-200' : 'bg-amber-50 border border-amber-200' %>">
        <div class="flex items-center gap-3">
          <svg class="w-5 h-5 <%= cartTotal >= minPurchase ? 'text-green-500' : 'text-amber-500' %> shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <% if (cartTotal >= minPurchase) { %>
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"/>
            <% } else { %>
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4m0 4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/>
            <% } %>
          </svg>
          <div>
            <% if (cartTotal >= minPurchase) { %>
              <p class="text-sm font-semibold text-green-800">✅ Compra mínima alcanzada</p>
            <% } else { %>
              <p class="text-sm font-semibold text-amber-800">Compra mínima: <strong>$<%= minPurchase.toFixed(2) %></strong></p>
              <p class="text-xs text-amber-600">Te faltan <strong>$<%= (minPurchase - cartTotal).toFixed(2) %></strong> para completar el pedido.</p>
            <% } %>
          </div>
        </div>
        <div class="mt-3 w-full bg-gray-200 rounded-full h-2 overflow-hidden">
          <div class="h-full rounded-full transition-all duration-500 <%= cartTotal >= minPurchase ? 'bg-green-500' : 'bg-amber-500' %>"
            style="width: <%= Math.min(100, (cartTotal / minPurchase) * 100) %>%"></div>
        </div>
      </div>
    <% } %>

    <div class="space-y-4 mb-8">
      <% cartItems.forEach(item => { %>
        <div class="flex items-center gap-4 p-4 lg:p-6 bg-white rounded-2xl border border-gray-100 shadow-sm">
          <div class="w-16 h-16 rounded-xl bg-gray-50 overflow-hidden shrink-0">
            <% if (item.image) { %>
              <img src="<%= item.image %>" alt="" class="w-full h-full object-cover">
            <% } else { %>
              <div class="w-full h-full flex items-center justify-center text-gray-300">
                <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M2.25 15.75l5.159-5.159a2.25 2.25 0 013.182 0l5.159 5.159m-1.5-1.5l1.409-1.409a2.25 2.25 0 013.182 0l2.909 2.909M3.75 21h16.5A2.25 2.25 0 0022.5 18.75V5.25A2.25 2.25 0 0020.25 3H3.75A2.25 2.25 0 001.5 5.25v13.5A2.25 2.25 0 003.75 21z"/>
                </svg>
              </div>
            <% } %>
          </div>
          <div class="flex-1 min-w-0">
            <h3 class="font-medium text-gray-900 truncate"><%= item.name %></h3>
            <p class="text-sm text-gray-500">$<%= item.price.toFixed(2) %> c/u</p>
          </div>
          <div class="flex items-center gap-3">
            <div class="flex items-center border border-gray-200 rounded-lg">
              <button onclick="updateCart('<%= item.id %>', <%= item.quantity - 1 %>)" class="px-3 py-1.5 text-gray-500 hover:text-gray-900 text-sm">−</button>
              <span class="px-3 py-1.5 text-sm font-medium text-gray-900"><%= item.quantity %></span>
              <button onclick="updateCart('<%= item.id %>', <%= item.quantity + 1 %>)" class="px-3 py-1.5 text-gray-500 hover:text-gray-900 text-sm">+</button>
            </div>
            <p class="text-lg font-bold text-gray-900 min-w-[80px] text-right">$<%= (item.price * item.quantity).toFixed(2) %></p>
            <button onclick="removeFromCart('<%= item.id %>')" class="p-2 text-gray-400 hover:text-red-500 transition-colors">
              <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16"/>
              </svg>
            </button>
          </div>
        </div>
      <% }); %>
    </div>

    <!-- Total -->
    <div class="p-6 bg-white rounded-2xl border border-gray-100 shadow-sm">
      <div class="flex items-center justify-between mb-2">
        <span class="text-gray-600">Subtotal</span>
        <span class="font-medium text-gray-900">$<%= cartTotal.toFixed(2) %></span>
      </div>
      <div class="flex items-center justify-between mb-4">
        <span class="text-gray-600">Envío</span>
        <span class="font-medium text-gray-900">A calcular</span>
      </div>
      <div class="flex items-center justify-between pt-4 border-t border-gray-100">
        <span class="text-xl font-bold text-gray-900">Total</span>
        <span class="text-2xl font-bold" style="color: var(--primary, #4f46e5)">$<%= cartTotal.toFixed(2) %></span>
      </div>
    </div>

    <a href="/<%= store.slug %>/checkout"
      class="mt-6 block w-full text-center px-8 py-4 text-base font-bold text-white rounded-xl transition-all hover:opacity-90 <%= minPurchase > 0 && cartTotal < minPurchase ? 'opacity-50 cursor-not-allowed pointer-events-none' : 'hover:opacity-90' %>"
      style="background: linear-gradient(135deg, var(--primary, #4f46e5), var(--accent, #7c3aed));">
      <%= minPurchase > 0 && cartTotal < minPurchase ? 'Compra mínima: $' + minPurchase.toFixed(2) : 'Finalizar Compra' %>
    </a>

    <a href="/<%= store.slug %>" class="mt-4 block text-center text-sm text-gray-500 hover:text-gray-700">← Seguir comprando</a>

  <% } else { %>
    <div class="text-center py-20">
      <svg class="w-24 h-24 text-gray-200 mx-auto mb-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1" d="M2.25 3h1.386c.51 0 .955.343 1.087.835l.383 1.437M7.5 14.25a3 3 0 00-3 3h15.75m-12.75-3h11.218c1.121-2.3 2.1-4.684 2.924-7.138a60.114 60.114 0 00-16.536-1.84M7.5 14.25L5.106 5.272M6 20.25a.75.75 0 11-1.5 0 .75.75 0 011.5 0zm12.75 0a.75.75 0 11-1.5 0 .75.75 0 011.5 0z"/>
      </svg>
      <h2 class="text-2xl font-bold text-gray-900 mb-2">Tu carrito está vacío</h2>
      <p class="text-gray-500 mb-8">Agregá productos para empezar a comprar</p>
      <a href="/<%= store.slug %>"
        class="inline-flex items-center gap-2 px-8 py-3.5 text-sm font-bold text-white rounded-xl transition-all hover:opacity-90"
        style="background: linear-gradient(135deg, var(--primary, #4f46e5), var(--accent, #7c3aed));">
        Ver Productos
      </a>
    </div>
  <% } %>
</div>

<script>
  async function updateCart(itemId, qty) {
    if (qty <= 0) return removeFromCart(itemId);
    const res = await fetch('/api/cart/update', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({ item_id: itemId, quantity: qty, store_id: '<%= store.id %>' })
    });
    const data = await res.json();
    if (data.success) location.reload();
  }

  async function removeFromCart(itemId) {
    if (!confirm('¿Eliminar este producto del carrito?')) return;
    const res = await fetch('/api/cart/remove', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({ item_id: itemId, store_id: '<%= store.id %>' })
    });
    const data = await res.json();
    if (data.success) location.reload();
  }
</script>
