<%# Shared home page content - used by all templates for consistent layout %>
<%# Sections: Hero → Categories → Featured → All Products → Combos → Instagram → WhatsApp CTA %>

<%# === HERO === %>
<div class="relative" style="background:var(--bg)">
  <div class="max-w-7xl mx-auto px-4 py-16 lg:py-20 text-center">
    <h1 class="text-4xl lg:text-6xl mb-4" style="color:var(--title)"><%=store.name%></h1>
    <p class="text-lg mb-8 max-w-2xl mx-auto opacity-70"><%=store.description%></p>
    <div class="flex flex-wrap justify-center gap-3">
      <a href="<%=storeBaseUrl%>/tienda" class="btn-primary inline-block px-8 py-3 text-base">Ver Tienda</a>
      <%if(store.whatsapp){%><a href="https://wa.me/<%=store.whatsapp%>?text=Hola%2C%20estoy%20interesad%40%20en%20tu%20tienda%2C%20quiero%20tener%20m%C3%A1s%20informaci%C3%B3n%20sobre%20ustedes" target="_blank" class="inline-block px-8 py-3 rounded-lg text-sm font-semibold border-2 transition-all hover:opacity-80" style="border-color:var(--primary);color:var(--primary)">WhatsApp</a><%}%>
    </div>
  </div>
</div>

<%# === CATEGORIES === %>
<%if(categories && categories.length > 0){%>
<div class="py-10 lg:py-14" style="background:var(--bg)">
  <div class="max-w-7xl mx-auto px-4">
    <h2 class="text-2xl font-bold text-center mb-8 section-title">Categorías</h2>
    <div class="grid grid-cols-2 md:grid-cols-3 lg:grid-cols-4 gap-4 lg:gap-6">
      <%categories.forEach(c=>{%>
        <a href="<%=storeBaseUrl%>/categoria/<%=c.name.toLowerCase().replace(/ /g,'-')%>" class="group block rounded-xl overflow-hidden border border-gray-100 shadow-sm hover:shadow-md transition-all">
          <%if(c.image){%>
            <div class="aspect-[4/3] overflow-hidden"><img src="<%=c.image%>" alt="<%=c.name%>" class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-500"></div>
          <%}else{%>
            <div class="aspect-[4/3] flex items-center justify-center" style="background:var(--primary);opacity:0.1"><span class="text-4xl">📦</span></div>
          <%}%>
          <div class="p-3 text-center"><h3 class="text-sm font-semibold" style="color:var(--title)"><%=c.name%></h3></div>
        </a>
      <%})%>
    </div>
  </div>
</div>
<%}%>

<%# === FEATURED / ESTRELLA === %>
<%if(featured.length > 0){%>
<div class="py-10 lg:py-14" style="background:var(--bg)">
  <div class="max-w-7xl mx-auto px-4">
    <h2 class="text-2xl font-bold text-center mb-8 section-title">⭐ Productos Estrella</h2>
    <div class="grid grid-cols-2 md:grid-cols-3 lg:grid-cols-4 gap-4 lg:gap-6">
      <%featured.forEach(p=>{%><%-include('_product_card',{product:p,store,locals})%><%})%>
    </div>
  </div>
</div>
<%}%>

<%# === ALL PRODUCTS === %>
<div class="py-10 lg:py-14" style="background:var(--bg)">
  <div class="max-w-7xl mx-auto px-4">
    <h2 class="text-2xl font-bold text-center mb-8 section-title">Todos los Productos</h2>
    <%if(products.length > 0){%>
      <div class="grid grid-cols-2 md:grid-cols-3 lg:grid-cols-4 gap-4 lg:gap-6">
        <%products.forEach(p=>{%><%-include('_product_card',{product:p,store,locals})%><%})%>
      </div>
    <%}else{%>
      <div class="text-center py-16 opacity-50"><p>Próximamente estaremos agregando nuestros productos.</p></div>
    <%}%>
  </div>
</div>

<%# === COMBOS === %>
<%if(combos.length > 0){%>
<div class="py-10 lg:py-14" style="background:var(--bg)">
  <div class="max-w-7xl mx-auto px-4">
    <h2 class="text-2xl font-bold text-center mb-8 section-title">Combos Especiales</h2>
    <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-6">
      <%combos.forEach(combo=>{%>
        <div class="p-6 rounded-2xl border-2 border-dashed" style="border-color:var(--primary)">
          <h3 class="text-lg font-bold"><%=combo.name%></h3>
          <p class="text-sm opacity-70 mb-3"><%=combo.description%></p>
          <p class="text-2xl font-bold" style="color:var(--primary)">$<%=combo.price.toFixed(2)%></p>
          <button onclick="addComboToCart('<%=combo.id%>')" class="mt-3 w-full px-4 py-2.5 text-sm font-semibold text-white btn-primary">Agregar al Carrito</button>
        </div>
      <%})%>
    </div>
  </div>
</div>
<%}%>

<%# === INSTAGRAM === %>
<div class="py-10 lg:py-14" style="background:var(--bg)">
  <div class="max-w-7xl mx-auto px-4 text-center">
    <h2 class="text-2xl font-bold mb-3 section-title">Seguinos en Instagram</h2>
    <%if(store.instagram){%><p class="text-sm opacity-60 mb-6">@<%=store.instagram.replace('@','')%></p><%}%>
    <div class="grid grid-cols-3 md:grid-cols-6 gap-2">
      <%[1,2,3,4,5,6].forEach(i=>{%>
        <div class="aspect-square rounded-lg overflow-hidden" style="background:linear-gradient(135deg,var(--primary),transparent);opacity:0.15">
          <svg class="w-full h-full p-6" fill="currentColor" viewBox="0 0 24 24"><path d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069z"/></svg>
        </div>
      <%})%>
    </div>
    <%if(store.instagram){%><a href="https://instagram.com/<%=store.instagram.replace('@','')%>" target="_blank" class="inline-block mt-4 text-sm font-semibold" style="color:var(--primary)">Ver perfil →</a><%}%>
  </div>
</div>

<%# === WHATSAPP CTA === %>
<%if(store.whatsapp){%>
<div class="py-12 lg:py-16" style="background:var(--primary)">
  <div class="max-w-3xl mx-auto px-4 text-center">
    <h2 class="text-2xl font-bold mb-3" style="color:#fff">¿Tenés preguntas?</h2>
    <p class="mb-6 opacity-90" style="color:#fff">Escribinos por WhatsApp y te respondemos al instante.</p>
    <a href="https://wa.me/<%=store.whatsapp%>?text=Hola%2C%20estoy%20interesad%40%20en%20tu%20tienda%2C%20quiero%20tener%20m%C3%A1s%20informaci%C3%B3n%20sobre%20ustedes" target="_blank" class="inline-block px-8 py-3 rounded-lg text-sm font-semibold" style="background:#fff;color:var(--primary)">💬 Chateá con nosotros</a>
  </div>
</div>
<%}%>