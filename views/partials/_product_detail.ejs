<div class="max-w-7xl mx-auto px-4 py-8">
  <a href="<%=storeBaseUrl%>" class="text-sm text-gray-500 hover:text-gray-700 mb-6 inline-block">← Volver</a>
  
  <div class="grid lg:grid-cols-2 gap-8 lg:gap-12">
    <!-- Images -->
    <div>
      <div class="aspect-square rounded-2xl bg-gray-100 overflow-hidden mb-4 relative group">
        <% if (product.image) { %>
          <img src="<%= product.image %>" alt="<%= product.name %>" class="w-full h-full object-cover transition-opacity duration-300" id="mainImage">
        <% } else { %>
          <div class="w-full h-full flex items-center justify-center text-gray-300">
            <svg class="w-24 h-24" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1" d="M2.25 15.75l5.159-5.159a2.25 2.25 0 013.182 0l5.159 5.159m-1.5-1.5l1.409-1.409a2.25 2.25 0 013.182 0l2.909 2.909M3.75 21h16.5A2.25 2.25 0 0022.5 18.75V5.25A2.25 2.25 0 0020.25 3H3.75A2.25 2.25 0 001.5 5.25v13.5A2.25 2.25 0 003.75 21z"/>
            </svg>
          </div>
        <% } %>
        <% if (productImages.length > 1) { %>
          <div class="absolute bottom-2 right-2 bg-black/60 text-white text-xs px-2 py-1 rounded-lg" id="imageCounter">
            1 / <%= productImages.length %>
          </div>
        <% } %>
      </div>
      <% if (productImages.length > 1) { %>
        <div class="flex gap-2 overflow-x-auto pb-2 scrollbar-thin">
          <% productImages.forEach((img, i) => { %>
            <button onclick="switchImage('<%= img %>', <%= i+1 %>, <%= productImages.length %>)" 
              class="gallery-thumb w-16 h-16 rounded-xl overflow-hidden border-2 shrink-0 transition-all duration-200 <%= i === 0 ? 'border-gray-900 ring-1 ring-gray-900' : 'border-gray-200 hover:border-gray-400' %>">
              <img src="<%= img %>" alt="" class="w-full h-full object-cover">
            </button>
          <% }); %>
        </div>
      <% } %>
    </div>

    <!-- Info -->
    <div>
      <% if (category) { %>
        <p class="text-sm text-gray-500 mb-1"><%= category.name %></p>
      <% } %>
      <h1 class="text-3xl lg:text-4xl font-bold text-gray-900 mb-4"><%= product.name %></h1>
      
      <div class="flex items-baseline gap-3 mb-6">
        <span class="text-3xl font-bold" style="color: var(--primary)">$<%= product.price.toFixed(2) %></span>
        <% if (product.compare_price) { %>
          <span class="text-lg text-gray-400 line-through">$<%= product.compare_price.toFixed(2) %></span>
          <span class="text-sm font-semibold text-green-600 bg-green-100 px-2.5 py-1 rounded-full">
            -<%= Math.round((1 - product.price / product.compare_price) * 100) %>% OFF
          </span>
        <% } %>
      </div>

      <p class="text-gray-600 leading-relaxed mb-8"><%= product.description || 'Sin descripción' %></p>

      <!-- Variants -->
      <% if (variants && variants.length > 0) { %>
        <div class="mb-6">
          <label class="text-sm font-medium text-gray-900 block mb-3">Variantes:</label>
          <div class="flex flex-wrap gap-2">
            <% variants.forEach(v => { %>
              <button onclick="selectVariant('<%= v.id %>', '<%= v.price || product.price %>', this)"
                class="variant-btn px-4 py-2.5 text-sm font-medium rounded-xl border-2 border-gray-200 hover:border-gray-400 transition-colors"
                data-price="<%= v.price || product.price %>">
                <%= v.name %>
                <% if (v.price) { %> - $<%= v.price.toFixed(2) %><% } %>
              </button>
            <% }); %>
          </div>
        </div>
      <% } %>

      <!-- Volume Discounts -->
      <% if (typeof volumeDiscounts !== 'undefined' && volumeDiscounts.length > 0) { %>
        <div class="mb-6 p-4 bg-green-50 rounded-xl border border-green-200">
          <h3 class="text-sm font-semibold text-green-800 mb-3">📦 Descuentos por Cantidad</h3>
          <div class="space-y-2">
            <% volumeDiscounts.forEach(d => { %>
              <div class="flex items-center justify-between text-sm">
                <span class="text-green-700 font-medium"><%= d.min_qty %>+ unidades</span>
                <span class="text-green-800 font-bold">$<%= d.discount_value.toFixed(2) %> c/u</span>
              </div>
              <% if (d.discount_value < product.price) { %>
                <% const savings = product.price - d.discount_value; %>
                <div class="flex items-center justify-between text-xs text-green-600 pl-4 mb-1">
                  <span>Ahorrás</span>
                  <span>$<%= savings.toFixed(2) %> por unidad</span>
                </div>
              <% } %>
            <% }); %>
          </div>
        </div>
      <% } %>

      <!-- Stock info -->
      <% if (product.stock > 0) { %>
        <p class="text-sm text-green-600 mb-4"><%= product.stock > 10 ? '✔ En stock' : '✔ Solo quedan ' + product.stock %></p>
      <% } else { %>
        <p class="text-sm text-red-500 mb-4">✖ Sin stock</p>
      <% } %>

      <!-- Add to Cart -->
      <div class="flex items-center gap-4 mb-8">
        <div class="flex items-center border border-gray-200 rounded-xl">
          <button onclick="changeQty(-1)" class="px-4 py-3 text-gray-500 hover:text-gray-900 transition-colors">−</button>
          <span id="qty" class="px-4 py-3 text-sm font-medium text-gray-900 min-w-[3rem] text-center">1</span>
          <button onclick="changeQty(1)" class="px-4 py-3 text-gray-500 hover:text-gray-900 transition-colors">+</button>
        </div>
        <button id="addToCartBtn"
          class="flex-1 px-8 py-3.5 text-sm font-bold text-white rounded-xl transition-all hover:opacity-90 disabled:opacity-50 disabled:cursor-not-allowed"
          style="background-color: var(--primary);"
          <%= product.stock === 0 ? 'disabled' : '' %>>
          Agregar al Carrito
        </button>
      </div>

      <!-- Stock/SKU -->
      <div class="text-sm text-gray-400 space-y-1">
        <% if (product.sku) { %><p>SKU: <%= product.sku %></p><% } %>
      </div>

      <!-- WhatsApp -->
      <% if (store.whatsapp) { %>
        <a href="https://wa.me/<%= store.whatsapp %>?text=Hola! Quiero consultar sobre <%= product.name %>"
          target="_blank"
          class="inline-flex items-center gap-2 mt-4 px-5 py-3 text-sm font-medium text-green-700 bg-green-50 rounded-xl hover:bg-green-100 transition-colors">
          <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/></svg>
          Consultar por WhatsApp
        </a>
      <% } %>
    </div>
  </div>

  <!-- Related Products -->
  <% if (typeof related !== 'undefined' && related.length > 0) { %>
    <section class="mt-16">
      <h2 class="text-2xl font-bold text-gray-900 mb-6">Productos Relacionados</h2>
      <div class="grid grid-cols-2 md:grid-cols-4 gap-4 lg:gap-6">
        <% related.forEach(p => { %>
          <%- include('_product_card', { product: p, store, locals }); %>
        <% }); %>
      </div>
    </section>
  <% } %>
</div>

<script>
  let selectedVariantId = null;
  let currentPrice = <%= product.price %>;
  let qty = 1;

  function selectVariant(id, price, btn) {
    selectedVariantId = id;
    currentPrice = parseFloat(price);
    document.querySelectorAll('.variant-btn').forEach(b => b.classList.remove('border-gray-900', 'bg-gray-50'));
    btn.classList.add('border-gray-900', 'bg-gray-50');
  }

  function changeQty(delta) {
    qty = Math.max(1, qty + delta);
    document.getElementById('qty').textContent = qty;
  }

  document.getElementById('addToCartBtn')?.addEventListener('click', async () => {
    await addToCart('<%= product.id %>', selectedVariantId, qty);
  });

  function switchImage(url, current, total) {
    document.getElementById('mainImage').src = url;
    document.getElementById('imageCounter').textContent = current + ' / ' + total;
    document.querySelectorAll('.gallery-thumb').forEach(t => t.classList.remove('border-gray-900', 'ring-1', 'ring-gray-900'));
    document.querySelectorAll('.gallery-thumb')[current-1]?.classList.add('border-gray-900', 'ring-1', 'ring-gray-900');
  }
</script>
