<div class="flex items-center justify-between mb-6">
  <div>
    <h1 class="text-2xl font-bold text-white">Categorías</h1>
    <p class="text-gray-400 text-sm">Organizá tus productos en categorías</p>
  </div>
</div>

<div class="grid lg:grid-cols-3 gap-6">
  <!-- New Category Form -->
  <div class="p-6 rounded-2xl bg-[#0f0f1a] border border-gray-800/50">
    <h2 class="text-lg font-semibold text-white mb-4">Nueva Categoría</h2>
    <form method="POST" action="/dashboard/categorias/nueva" class="space-y-4">
      <div>
        <input type="text" name="name" required
          class="w-full px-4 py-3 bg-[#1a1a2e] border border-gray-700/50 rounded-xl text-white placeholder-gray-500 focus:outline-none focus:border-indigo-500/50 transition-colors"
          placeholder="Nombre de la categoría">
      </div>
      <div>
        <textarea name="description" rows="2" placeholder="Descripción (opcional)"
          class="w-full px-4 py-3 bg-[#1a1a2e] border border-gray-700/50 rounded-xl text-white placeholder-gray-500 focus:outline-none focus:border-indigo-500/50 transition-colors"></textarea>
      </div>
      <button type="submit"
        class="w-full py-3 bg-gradient-to-r from-indigo-600 to-purple-600 text-white font-medium rounded-xl hover:from-indigo-500 hover:to-purple-500 transition-all shadow-lg shadow-indigo-600/25">
        Crear Categoría
      </button>
    </form>
  </div>

  <!-- Categories List -->
  <div class="lg:col-span-2 space-y-3">
    <% if (categories.length > 0) { %>
      <form method="POST" action="/dashboard/categorias/eliminar-lote" id="catBulkForm">
        <div class="flex items-center justify-between mb-3">
          <label class="flex items-center gap-2 text-sm text-gray-400 cursor-pointer">
            <input type="checkbox" id="catSelectAll" class="w-4 h-4 rounded border-gray-600 bg-[#1a1a2e] text-indigo-500 focus:ring-indigo-500">
            Seleccionar todo
          </label>
          <div id="catBulkActions" class="hidden">
            <button type="submit" onclick="return confirm('¿Eliminar las categorías seleccionadas?')"
              class="px-3 py-1.5 text-sm font-medium text-red-400 bg-red-500/10 rounded-xl hover:bg-red-500/20 transition-colors">
              Eliminar seleccionadas
            </button>
          </div>
        </div>

        <% categories.forEach(c => { %>
          <div class="p-5 rounded-2xl bg-[#0f0f1a] border border-gray-800/50 hover:border-gray-700 transition-all">
            <div class="flex items-center justify-between">
              <div class="flex items-center gap-4">
                <input type="checkbox" name="category_ids" value="<%= c.id %>" class="cat-checkbox w-4 h-4 rounded border-gray-600 bg-[#1a1a2e] text-indigo-500 focus:ring-indigo-500">
                <div class="w-10 h-10 rounded-xl bg-gradient-to-br from-indigo-500/20 to-purple-500/20 flex items-center justify-center">
                  <svg class="w-5 h-5 text-indigo-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 11H5m14 0a2 2 0 012 2v6a2 2 0 01-2 2H5a2 2 0 01-2-2v-6a2 2 0 012-2m14 0V9a2 2 0 00-2-2M5 11V9a2 2 0 012-2m0 0V5a2 2 0 012-2h6a2 2 0 012 2v2M7 7h10"/>
                  </svg>
                </div>
                <div>
                  <h3 class="font-medium text-white"><%= c.name %></h3>
                  <p class="text-xs text-gray-500"><%= c.description || 'Sin descripción' %> · <%= c.products_count %> productos</p>
                </div>
              </div>
              <div class="flex items-center gap-2">
                <button onclick="editCategory('<%= c.id %>', '<%= c.name.replace(/'/g, "\\'") %>', '<%= (c.description || '').replace(/'/g, "\\'") %>')"
                  class="px-3 py-2 text-xs font-medium text-gray-300 bg-white/5 rounded-lg hover:bg-white/10 transition-colors">
                  Editar
                </button>
                <form method="POST" action="/dashboard/categorias/eliminar/<%= c.id %>" onsubmit="return confirm('¿Eliminar esta categoría?')">
                  <button type="submit" class="px-3 py-2 text-xs font-medium text-red-400 bg-red-500/5 rounded-lg hover:bg-red-500/10 transition-colors">
                    Eliminar
                  </button>
                </form>
              </div>
            </div>
          </div>
        <% }); %>
      </form>
    <% } else { %>
      <div class="text-center py-12 bg-[#0f0f1a] border border-gray-800/50 rounded-2xl">
        <svg class="w-12 h-12 text-gray-600 mx-auto mb-3" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 11H5m14 0a2 2 0 012 2v6a2 2 0 01-2 2H5a2 2 0 01-2-2v-6a2 2 0 012-2m14 0V9a2 2 0 00-2-2M5 11V9a2 2 0 012-2m0 0V5a2 2 0 012-2h6a2 2 0 012 2v2M7 7h10"/>
        </svg>
        <p class="text-gray-500 text-sm">No hay categorías todavía. Creá tu primera categoría.</p>
      </div>
    <% } %>
  </div>
</div>

<!-- Edit Category Modal -->
<div id="editModal" class="fixed inset-0 z-50 hidden">
  <div class="absolute inset-0 bg-black/50" onclick="closeEditModal()"></div>
  <div class="relative max-w-md mx-auto mt-20 p-6 rounded-2xl bg-[#0f0f1a] border border-gray-800/50">
    <h2 class="text-lg font-semibold text-white mb-4">Editar Categoría</h2>
    <form method="POST" action="" id="editForm" class="space-y-4">
      <div>
        <input type="text" name="name" id="editName" required
          class="w-full px-4 py-3 bg-[#1a1a2e] border border-gray-700/50 rounded-xl text-white focus:outline-none focus:border-indigo-500/50 transition-colors">
      </div>
      <div>
        <textarea name="description" id="editDescription" rows="2"
          class="w-full px-4 py-3 bg-[#1a1a2e] border border-gray-700/50 rounded-xl text-white focus:outline-none focus:border-indigo-500/50 transition-colors"></textarea>
      </div>
      <div class="flex gap-3">
        <button type="submit" class="flex-1 py-3 bg-gradient-to-r from-indigo-600 to-purple-600 text-white font-medium rounded-xl hover:from-indigo-500 hover:to-purple-500 transition-all">Guardar</button>
        <button type="button" onclick="closeEditModal()" class="flex-1 py-3 text-gray-400 bg-white/5 rounded-xl hover:bg-white/10 transition-colors">Cancelar</button>
      </div>
    </form>
  </div>
</div>

<script>
  function editCategory(id, name, description) {
    document.getElementById('editForm').action = '/dashboard/categorias/editar/' + id;
    document.getElementById('editName').value = name;
    document.getElementById('editDescription').value = description;
    document.getElementById('editModal').classList.remove('hidden');
  }
  function closeEditModal() {
    document.getElementById('editModal').classList.add('hidden');
  }

  const catSelectAll = document.getElementById('catSelectAll');
  const catCheckboxes = document.querySelectorAll('.cat-checkbox');
  const catBulkActions = document.getElementById('catBulkActions');

  catSelectAll?.addEventListener('change', function() {
    catCheckboxes.forEach(cb => cb.checked = this.checked);
    updateCatBulkActions();
  });
  catCheckboxes.forEach(cb => { cb.addEventListener('change', updateCatBulkActions); });
  function updateCatBulkActions() {
    const checked = document.querySelectorAll('.cat-checkbox:checked');
    catSelectAll.checked = checked.length === catCheckboxes.length;
    catBulkActions.classList.toggle('hidden', checked.length === 0);
  }
</script>