<div class="flex items-center justify-between mb-6">
  <div>
    <h1 class="text-2xl font-bold text-white">Productos</h1>
    <p class="text-gray-400 text-sm">Gestioná los productos de tu tienda</p>
  </div>
  <a href="/dashboard/productos/nuevo"
    class="inline-flex items-center gap-2 px-4 py-2.5 text-sm font-medium text-white bg-gradient-to-r from-indigo-600 to-purple-600 rounded-xl hover:from-indigo-500 hover:to-purple-500 transition-all shadow-lg shadow-indigo-600/25">
    <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 6v6m0 0v6m0-6h6m-6 0H6"/>
    </svg>
    Nuevo Producto
  </a>
</div>

<% if (products.length > 0) { %>
  <form method="POST" action="/dashboard/productos/eliminar-lote" id="bulkForm">
    <div class="flex items-center justify-between mb-4">
      <label class="flex items-center gap-2 text-sm text-gray-400 cursor-pointer">
        <input type="checkbox" id="selectAll" class="w-4 h-4 rounded border-gray-600 bg-[#1a1a2e] text-indigo-500 focus:ring-indigo-500">
        Seleccionar todo
      </label>
      <div id="bulkActions" class="hidden">
        <button type="submit" onclick="return confirm('¿Eliminar los productos seleccionados?')"
          class="px-4 py-2 text-sm font-medium text-red-400 bg-red-500/10 rounded-xl hover:bg-red-500/20 transition-colors">
          Eliminar seleccionados
        </button>
      </div>
    </div>

    <div class="grid sm:grid-cols-2 lg:grid-cols-3 xl:grid-cols-4 gap-4 lg:gap-6">
      <% products.forEach(p => { %>
        <div class="group relative rounded-2xl bg-[#0f0f1a] border border-gray-800/50 hover:border-gray-700 transition-all overflow-hidden">
          <div class="absolute top-2 left-2 z-10">
            <input type="checkbox" name="product_ids" value="<%= p.id %>" class="product-checkbox w-4 h-4 rounded border-gray-600 bg-[#1a1a2e] text-indigo-500 focus:ring-indigo-500">
          </div>
          <div class="aspect-square bg-gradient-to-br from-gray-800/50 to-gray-900/50 flex items-center justify-center overflow-hidden">
            <% if (p.image) { %>
              <img src="<%= p.image %>" alt="<%= p.name %>" class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-300">
            <% } else { %>
              <svg class="w-12 h-12 text-gray-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 16l4.586-4.586a2 2 0 012.828 0L16 16m-2-2l1.586-1.586a2 2 0 012.828 0L20 14m-6-6h.01M6 20h12a2 2 0 002-2V6a2 2 0 00-2-2H6a2 2 0 00-2 2v12a2 2 0 002 2z"/>
              </svg>
            <% } %>
            <span class="absolute top-2 right-2 px-2 py-1 text-xs font-medium rounded-full <%= p.status === 'active' ? 'bg-green-500/20 text-green-400' : 'bg-gray-500/20 text-gray-400' %>">
              <%= p.status === 'active' ? 'Activo' : 'Inactivo' %>
            </span>
          </div>
          <div class="p-4">
            <h3 class="font-medium text-white text-sm truncate mb-1"><%= p.name %></h3>
            <% if (p.category_name) { %>
              <p class="text-xs text-gray-500 mb-2"><%= p.category_name %></p>
            <% } %>
            <div class="flex items-center justify-between">
              <div>
                <span class="text-lg font-bold text-white">$<%= p.price.toFixed(2) %></span>
                <% if (p.compare_price) { %>
                  <span class="text-xs text-gray-500 line-through ml-1">$<%= p.compare_price.toFixed(2) %></span>
                <% } %>
              </div>
              <span class="text-xs text-gray-500">Stock: <%= p.stock %></span>
            </div>
            <div class="flex gap-2 mt-3 pt-3 border-t border-gray-800/30">
              <a href="/dashboard/productos/editar/<%= p.id %>"
                class="flex-1 text-center px-3 py-2 text-xs font-medium text-gray-300 bg-white/5 rounded-lg hover:bg-white/10 transition-colors">
                Editar
              </a>
              <form method="POST" action="/dashboard/productos/eliminar/<%= p.id %>" class="flex-1" onsubmit="return confirm('¿Eliminar este producto?')">
                <button type="submit"
                  class="w-full px-3 py-2 text-xs font-medium text-red-400 bg-red-500/5 rounded-lg hover:bg-red-500/10 transition-colors">
                  Eliminar
                </button>
              </form>
            </div>
          </div>
        </div>
      <% }); %>
    </div>
  </form>
<% } else { %>
  <div class="text-center py-20">
    <svg class="w-16 h-16 text-gray-600 mx-auto mb-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M20 7l-8-4-8 4m16 0l-8 4m8-4v10l-8 4m0-10L4 7m8 4v10M4 7v10l8 4"/>
    </svg>
    <h3 class="text-xl font-semibold text-gray-300 mb-2">Aún no tenés productos</h3>
    <p class="text-gray-500 mb-6">Agregá tu primer producto para empezar a vender</p>
    <a href="/dashboard/productos/nuevo"
      class="inline-flex items-center gap-2 px-6 py-3 text-sm font-medium text-white bg-gradient-to-r from-indigo-600 to-purple-600 rounded-xl hover:from-indigo-500 hover:to-purple-500 transition-all shadow-lg shadow-indigo-600/25">
      <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 6v6m0 0v6m0-6h6m-6 0H6"/>
      </svg>
      Crear Primer Producto
    </a>
  </div>
<% } %>

<script>
  const selectAll = document.getElementById('selectAll');
  const checkboxes = document.querySelectorAll('.product-checkbox');
  const bulkActions = document.getElementById('bulkActions');

  selectAll?.addEventListener('change', function() {
    checkboxes.forEach(cb => cb.checked = this.checked);
    updateBulkActions();
  });

  checkboxes.forEach(cb => {
    cb.addEventListener('change', updateBulkActions);
  });

  function updateBulkActions() {
    const checked = document.querySelectorAll('.product-checkbox:checked');
    selectAll.checked = checked.length === checkboxes.length;
    bulkActions.classList.toggle('hidden', checked.length === 0);
  }
</script>