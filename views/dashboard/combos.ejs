<div class="flex items-center justify-between mb-6">
  <div>
    <h1 class="text-2xl font-bold text-white">Combos y Paquetes</h1>
    <p class="text-gray-400 text-sm">Creá combos con múltiples productos</p>
  </div>
  <button onclick="toggleComboForm()"
    class="inline-flex items-center gap-2 px-4 py-2.5 text-sm font-medium text-white bg-gradient-to-r from-indigo-600 to-purple-600 rounded-xl hover:from-indigo-500 hover:to-purple-500 transition-all shadow-lg shadow-indigo-600/25">
    <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 6v6m0 0v6m0-6h6m-6 0H6"/>
    </svg>
    Nuevo Combo
  </button>
</div>

<!-- New Combo Form -->
<div id="comboForm" class="hidden mb-6 p-6 rounded-2xl bg-[#0f0f1a] border border-indigo-500/30">
  <h2 class="text-lg font-semibold text-white mb-4">Nuevo Combo</h2>
  <form method="POST" action="/dashboard/combos/nuevo" class="space-y-4">
    <div class="grid grid-cols-2 gap-4">
      <div>
        <label class="block text-sm font-medium text-gray-300 mb-2">Nombre del Combo</label>
        <input type="text" name="name" required
          class="w-full px-4 py-3 bg-[#1a1a2e] border border-gray-700/50 rounded-xl text-white placeholder-gray-500 focus:outline-none focus:border-indigo-500/50 transition-colors"
          placeholder="Ej: Pack Ahorro Verano">
      </div>
      <div>
        <label class="block text-sm font-medium text-gray-300 mb-2">Precio del Combo</label>
        <div class="relative">
          <span class="absolute left-4 top-1/2 -translate-y-1/2 text-gray-500">$</span>
          <input type="number" step="0.01" min="0" name="price" required
            class="w-full pl-8 pr-4 py-3 bg-[#1a1a2e] border border-gray-700/50 rounded-xl text-white placeholder-gray-500 focus:outline-none focus:border-indigo-500/50 transition-colors"
            placeholder="0.00">
        </div>
      </div>
    </div>
    <div>
      <label class="block text-sm font-medium text-gray-300 mb-2">Descripción</label>
      <textarea name="description" rows="2"
        class="w-full px-4 py-3 bg-[#1a1a2e] border border-gray-700/50 rounded-xl text-white placeholder-gray-500 focus:outline-none focus:border-indigo-500/50 transition-colors"
        placeholder="Describí el combo..."></textarea>
    </div>
    <div>
      <label class="block text-sm font-medium text-gray-300 mb-2">Productos incluidos</label>
      <div id="comboProducts" class="space-y-2">
        <p class="text-xs text-gray-500">Los productos se cargarán automáticamente cuando tengas productos activos.</p>
      </div>
    </div>
    <input type="hidden" name="products" id="comboProductsInput" value="">
    <div class="flex gap-3">
      <button type="submit"
        class="px-6 py-3 bg-gradient-to-r from-indigo-600 to-purple-600 text-white font-medium rounded-xl hover:from-indigo-500 hover:to-purple-500 transition-all shadow-lg shadow-indigo-600/25">
        Crear Combo
      </button>
      <button type="button" onclick="toggleComboForm()" class="px-6 py-3 text-gray-400 hover:text-white transition-colors">Cancelar</button>
    </div>
  </form>
</div>

<!-- Combos List -->
<% if (combos.length > 0) { %>
  <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-4">
    <% combos.forEach(combo => {
      let comboProducts = [];
      try { comboProducts = JSON.parse(combo.products || '[]'); } catch(e) {}
    %>
      <div class="p-6 rounded-2xl bg-[#0f0f1a] border border-gray-800/50 hover:border-gray-700 transition-all">
        <div class="w-12 h-12 rounded-xl bg-gradient-to-br from-amber-500/20 to-orange-500/20 flex items-center justify-center mb-4">
          <svg class="w-6 h-6 text-amber-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M11 3.055A9.001 9.001 0 1020.945 13H11V3.055z"/>
          </svg>
        </div>
        <h3 class="font-semibold text-white mb-1"><%= combo.name %></h3>
        <p class="text-sm text-gray-500 mb-3"><%= combo.description || 'Sin descripción' %></p>
        <p class="text-2xl font-bold text-white mb-4">$<%= combo.price.toFixed(2) %></p>
        <% if (comboProducts.length > 0) { %>
          <div class="mb-4 p-3 rounded-xl bg-white/[0.02] border border-white/[0.05]">
            <p class="text-xs font-medium text-gray-400 mb-2">Productos en combo:</p>
            <% comboProducts.forEach(pid => { %>
              <p class="text-sm text-gray-300 py-0.5">• <%= pid %></p>
            <% }); %>
          </div>
        <% } %>
        <form method="POST" action="/dashboard/combos/eliminar/<%= combo.id %>" onsubmit="return confirm('¿Eliminar este combo?')">
          <button type="submit" class="w-full px-4 py-2 text-sm font-medium text-red-400 bg-red-500/5 rounded-xl hover:bg-red-500/10 transition-colors">
            Eliminar
          </button>
        </form>
      </div>
    <% }); %>
  </div>
<% } else { %>
  <div class="text-center py-20">
    <svg class="w-16 h-16 text-gray-600 mx-auto mb-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M11 3.055A9.001 9.001 0 1020.945 13H11V3.055z"/>
    </svg>
    <h3 class="text-xl font-semibold text-gray-300 mb-2">Aún no tenés combos</h3>
    <p class="text-gray-500 mb-6">Creá combos de productos para ofrecer descuentos</p>
    <button onclick="toggleComboForm()"
      class="inline-flex items-center gap-2 px-6 py-3 text-sm font-medium text-white bg-gradient-to-r from-indigo-600 to-purple-600 rounded-xl hover:from-indigo-500 hover:to-purple-500 transition-all">
      Crear Primer Combo
    </button>
  </div>
<% } %>

<script>
  function toggleComboForm() {
    document.getElementById('comboForm').classList.toggle('hidden');
  }

  // Load products for combo selector
  fetch('/api/products/<%= store.id %>')
    .then(r => r.json())
    .then(products => {
      const container = document.getElementById('comboProducts');
      if (products.length === 0) {
        container.innerHTML = '<p class="text-sm text-gray-500">Creá productos primero para agregarlos a un combo</p>';
        return;
      }
      container.innerHTML = products.map(p => `
        <label class="flex items-center gap-3 p-2 rounded-lg hover:bg-white/5 cursor-pointer">
          <input type="checkbox" value="${p.id}" class="combo-product-checkbox w-4 h-4 rounded border-gray-600 bg-gray-700 text-indigo-600">
          <span class="text-sm text-gray-300">${p.name} - <span class="text-indigo-400">$${parseFloat(p.price).toFixed(2)}</span></span>
        </label>
      `).join('');
    });
</script>
