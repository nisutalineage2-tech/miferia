<div class="max-w-2xl mx-auto">
  <div class="mb-8">
    <h1 class="text-2xl font-bold text-white mb-2">Dominios</h1>
    <p class="text-gray-400">Gestioná el subdominio de tu tienda en Cloudflare.</p>
  </div>

  <div id="domainApp">
    <!-- Loading -->
    <div id="loading" class="bg-gray-900/50 border border-gray-800/50 rounded-2xl p-8 text-center">
      <div class="animate-spin w-8 h-8 border-2 border-indigo-500 border-t-transparent rounded-full mx-auto"></div>
      <p class="text-gray-400 mt-3 text-sm">Cargando estado del dominio...</p>
    </div>

    <!-- Not configured -->
    <div id="notConfigured" class="hidden bg-yellow-900/20 border border-yellow-500/30 rounded-2xl p-6">
      <div class="flex items-start gap-3">
        <svg class="w-5 h-5 text-yellow-400 mt-0.5 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-2.5L13.732 4c-.77-.833-1.964-.833-2.732 0L4.082 16.5c-.77.833.192 2.5 1.732 2.5z"/>
        </svg>
        <div>
          <h3 class="text-yellow-400 font-medium">Cloudflare no está configurado</h3>
          <p class="text-gray-400 text-sm mt-1">Las variables de entorno <code class="bg-gray-800 px-1.5 py-0.5 rounded text-xs">CF_API_TOKEN</code> y <code class="bg-gray-800 px-1.5 py-0.5 rounded text-xs">CF_ZONE_ID</code> no están definidas.</p>
        </div>
      </div>
    </div>

    <!-- No subdomain yet -->
    <div id="noSubdomain" class="hidden">
      <div class="bg-gray-900/50 border border-gray-800/50 rounded-2xl p-6 mb-4">
        <div class="flex items-center gap-3 mb-4">
          <div class="w-10 h-10 rounded-xl bg-indigo-500/20 flex items-center justify-center">
            <svg class="w-5 h-5 text-indigo-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 12a9 9 0 01-9 9m9-9a9 9 0 00-9-9m9 9H3m9 9a9 9 0 01-9-9m9 9c1.657 0 3-4.03 3-9s-1.343-9-3-9m0 18c-1.657 0-3-4.03-3-9s1.343-9 3-9m-9 9a9 9 0 019-9"/>
            </svg>
          </div>
          <div>
            <h3 class="text-white font-medium">Sin subdominio asignado</h3>
            <p class="text-gray-400 text-sm">Creá un subdominio para que tu tienda sea accesible directamente.</p>
          </div>
        </div>

        <div class="flex items-center gap-2">
          <input
            id="subdomainInput"
            type="text"
            placeholder="mi-tienda"
            class="flex-1 bg-gray-800 border border-gray-700 rounded-xl px-4 py-2.5 text-white text-sm focus:outline-none focus:border-indigo-500 transition-colors"
            maxlength="63"
          >
          <span class="text-gray-500 text-sm whitespace-nowrap">.<%= store.custom_domain || 'hausetienda.com.ar' %></span>
          <button
            onclick="createSubdomain()"
            class="bg-indigo-600 hover:bg-indigo-700 text-white px-5 py-2.5 rounded-xl text-sm font-medium transition-colors whitespace-nowrap"
          >
            Crear
          </button>
        </div>
        <p id="createError" class="text-red-400 text-xs mt-2 hidden"></p>
      </div>
    </div>

    <!-- Active subdomain -->
    <div id="activeSubdomain" class="hidden">
      <div class="bg-gray-900/50 border border-green-500/20 rounded-2xl p-6 mb-4">
        <div class="flex items-center justify-between mb-4">
          <div class="flex items-center gap-3">
            <div class="w-10 h-10 rounded-xl bg-green-500/20 flex items-center justify-center">
              <svg class="w-5 h-5 text-green-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"/>
              </svg>
            </div>
            <div>
              <h3 class="text-white font-medium">Subdominio activo</h3>
              <p class="text-gray-400 text-sm">Tu tienda está disponible en el subdominio configurado.</p>
            </div>
          </div>
        </div>

        <div class="bg-gray-800/50 rounded-xl p-4 mb-4">
          <div class="flex items-center gap-2">
            <span class="text-gray-400 text-sm">URL:</span>
            <a id="domainLink" href="#" target="_blank" class="text-indigo-400 hover:text-indigo-300 text-sm font-medium" id="domainUrl"></a>
            <svg class="w-3.5 h-3.5 text-gray-500" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14"/>
            </svg>
          </div>
        </div>

        <div class="flex items-center gap-2">
          <button
            onclick="deleteSubdomain()"
            class="bg-red-600/20 hover:bg-red-600/30 text-red-400 border border-red-500/30 px-4 py-2 rounded-xl text-sm font-medium transition-colors"
          >
            Eliminar subdominio
          </button>
          <span class="text-gray-600 text-xs">Esto eliminará el registro DNS de Cloudflare</span>
        </div>
        <p id="deleteError" class="text-red-400 text-xs mt-2 hidden"></p>
      </div>
    </div>

    <!-- Info -->
    <div class="bg-gray-900/30 border border-gray-800/30 rounded-2xl p-6">
      <h4 class="text-white font-medium text-sm mb-3">¿Cómo funciona?</h4>
      <ul class="space-y-2 text-gray-400 text-xs">
        <li class="flex items-start gap-2">
          <svg class="w-4 h-4 text-gray-600 mt-0.5 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/></svg>
          <span>Tu tienda se accede tanto por <strong class="text-gray-300">hausetienda.com.ar/tu-slug</strong> como por <strong class="text-gray-300">tu-subdominio.hausetienda.com.ar</strong></span>
        </li>
        <li class="flex items-start gap-2">
          <svg class="w-4 h-4 text-gray-600 mt-0.5 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/></svg>
          <span>Se crea automáticamente un registro CNAME en Cloudflare apuntando a <strong class="text-gray-300">hausetienda.com.ar</strong></span>
        </li>
        <li class="flex items-start gap-2">
          <svg class="w-4 h-4 text-gray-600 mt-0.5 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/></svg>
          <span>El SSL/TLS se gestiona automáticamente por Cloudflare</span>
        </li>
      </ul>
    </div>
  </div>
</div>

<script>
  const BASE_DOMAIN = '<%= store.custom_domain ? "" : "hausetienda.com.ar" %>';

  async function loadStatus() {
    try {
      const res = await fetch('/api/dns/status');
      const data = await res.json();

      document.getElementById('loading').classList.add('hidden');

      if (!data.configured) {
        document.getElementById('notConfigured').classList.remove('hidden');
        return;
      }

      if (data.subdomain) {
        const fullDomain = `${data.subdomain}.${data.domain}`;
        document.getElementById('domainLink').href = `https://${fullDomain}`;
        document.getElementById('domainLink').textContent = fullDomain;
        document.getElementById('activeSubdomain').classList.remove('hidden');
      } else {
        document.getElementById('noSubdomain').classList.remove('hidden');
      }
    } catch (e) {
      document.getElementById('loading').innerHTML = '<p class="text-red-400 text-sm">Error al cargar el estado.</p>';
    }
  }

  async function createSubdomain() {
    const input = document.getElementById('subdomainInput');
    const errorEl = document.getElementById('createError');
    const subdomain = input.value.trim().toLowerCase();

    errorEl.classList.add('hidden');

    if (!subdomain) {
      errorEl.textContent = 'Ingresá un subdominio.';
      errorEl.classList.remove('hidden');
      return;
    }

    if (!/^[a-z0-9]([a-z0-9-]{0,61}[a-z0-9])?$/.test(subdomain)) {
      errorEl.textContent = 'Solo letras minúsculas, números y guiones.';
      errorEl.classList.remove('hidden');
      return;
    }

    try {
      const res = await fetch('/api/dns/create', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ subdomain })
      });
      const data = await res.json();

      if (!res.ok) {
        errorEl.textContent = data.error;
        errorEl.classList.remove('hidden');
        return;
      }

      document.getElementById('noSubdomain').classList.add('hidden');
      document.getElementById('domainLink').href = `https://${data.fullDomain}`;
      document.getElementById('domainLink').textContent = data.fullDomain;
      document.getElementById('activeSubdomain').classList.remove('hidden');
    } catch (e) {
      errorEl.textContent = 'Error de conexión.';
      errorEl.classList.remove('hidden');
    }
  }

  async function deleteSubdomain() {
    const errorEl = document.getElementById('deleteError');
    errorEl.classList.add('hidden');

    if (!confirm('¿Eliminar el subdominio? Esto quitará el registro DNS de Cloudflare.')) return;

    try {
      const res = await fetch('/api/dns/delete', { method: 'DELETE' });
      const data = await res.json();

      if (!res.ok) {
        errorEl.textContent = data.error;
        errorEl.classList.remove('hidden');
        return;
      }

      document.getElementById('activeSubdomain').classList.add('hidden');
      document.getElementById('noSubdomain').classList.remove('hidden');
      document.getElementById('subdomainInput').value = '';
    } catch (e) {
      errorEl.textContent = 'Error de conexión.';
      errorEl.classList.remove('hidden');
    }
  }

  loadStatus();
</script>
