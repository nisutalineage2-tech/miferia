          <a href="/dashboard/editor/instagram" class="flex items-center gap-3 px-4 py-2.5 rounded-xl text-sm font-medium transition-all pl-9 <%= section === 'editor' && sub === 'instagram' ? 'sidebar-active text-white' : 'text-gray-400 hover:text-white hover:bg-white/5' %>">Instagram</a>
          <a href="/dashboard/editor/facebook" class="flex items-center gap-3 px-4 py-2.5 rounded-xl text-sm font-medium transition-all pl-9 <%= section === 'editor' && sub === 'facebook' ? 'sidebar-active text-white' : 'text-gray-400 hover:text-white hover:bg-white/5' %>">Facebook</a>
          <a href="/dashboard/editor/css" class="flex items-center gap-3 px-4 py-2.5 rounded-xl text-sm font-medium transition-all pl-9 <%= section === 'editor' && sub === 'css' ? 'sidebar-active text-white' : 'text-gray-400 hover:text-white hover:bg-white/5' %>">CSS</a>

