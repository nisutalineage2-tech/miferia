        <a href="/dashboard/editor/plantilla" class="flex items-center gap-3 px-4 py-2.5 rounded-xl text-sm font-medium transition-all pl-9 <%= section === 'editor' && sub === 'plantilla' ? 'sidebar-active text-white' : 'text-gray-400 hover:text-white hover:bg-white/5' %>">
          <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 5a1 1 0 011-1h14a1 1 0 011 1v2a1 1 0 01-1 1H5a1 1 0 01-1-1V5zM4 13a1 1 0 011-1h6a1 1 0 011 1v6a1 1 0 01-1 1H5a1 1 0 01-1-1v-6zM16 13a1 1 0 011-1h2a1 1 0 011 1v6a1 1 0 01-1 1h-2a1 1 0 01-1-1v-6z"/></svg>
          Plantilla
        </a>
        <a href="/dashboard/editor/colores" class="flex items-center gap-3 px-4 py-2.5 rounded-xl text-sm font-medium transition-all pl-9 <%= section === 'editor' && sub === 'colores' ? 'sidebar-active text-white' : 'text-gray-400 hover:text-white hover:bg-white/5' %>">
          <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M7 21a4 4 0 01-4-4V5a2 2 0 012-2h4a2 2 0 012 2v12a4 4 0 01-4 4zm0 0h12a2 2 0 002-2v-4a2 2 0 00-2-2h-2.343M11 7.343l1.657-1.657a2 2 0 012.828 0l2.829 2.829a2 2 0 010 2.828l-8.486 8.485M7 17h.01"/></svg>
          Colores
        </a>
        <a href="/dashboard/editor/anuncio" class="flex items-center gap-3 px-4 py-2.5 rounded-xl text-sm font-medium transition-all pl-9 <%= section === 'editor' && sub === 'anuncio' ? 'sidebar-active text-white' : 'text-gray-400 hover:text-white hover:bg-white/5' %>">
          <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M11 5.882V19.24a1.76 1.76 0 01-3.417.592l-2.147-6.15M18 13a3 3 0 100-6M5.436 13.683A4.001 4.001 0 017 6h1.832c4.1 0 7.625-1.234 9.168-3v14c-1.543-1.766-5.067-3-9.168-3H7a3.988 3.988 0 01-1.564-.317z"/></svg>
          Anuncio
        </a>
        <a href="/dashboard/editor/carrusel" class="flex items-center gap-3 px-4 py-2.5 rounded-xl text-sm font-medium transition-all pl-9 <%= section === 'editor' && sub === 'carrusel' ? 'sidebar-active text-white' : 'text-gray-400 hover:text-white hover:bg-white/5' %>">
          <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 16l4.586-4.586a2 2 0 012.828 0L16 16m-2-2l1.586-1.586a2 2 0 012.828 0L20 14m-6-6h.01M6 20h12a2 2 0 002-2V6a2 2 0 00-2-2H6a2 2 0 00-2 2v12a2 2 0 002 2z"/></svg>
          Carrusel
        </a>
        <a href="/dashboard/editor/logo" class="flex items-center gap-3 px-4 py-2.5 rounded-xl text-sm font-medium transition-all pl-9 <%= section === 'editor' && sub === 'logo' ? 'sidebar-active text-white' : 'text-gray-400 hover:text-white hover:bg-white/5' %>">
          <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 16l4.586-4.586a2 2 0 012.828 0L16 16m-2-2l1.586-1.586a2 2 0 012.828 0L20 14m-6-6h.01M6 20h12a2 2 0 002-2V6a2 2 0 00-2-2H6a2 2 0 00-2 2v12a2 2 0 002 2z"/></svg>
          Logo
        </a>
        <a href="/dashboard/editor/navegacion" class="flex items-center gap-3 px-4 py-2.5 rounded-xl text-sm font-medium transition-all pl-9 <%= section === 'editor' && sub === 'navegacion' ? 'sidebar-active text-white' : 'text-gray-400 hover:text-white hover:bg-white/5' %>">
          <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16"/></svg>
          Navegación
        </a>
        <a href="/dashboard/editor/tienda" class="flex items-center gap-3 px-4 py-2.5 rounded-xl text-sm font-medium transition-all pl-9 <%= section === 'editor' && sub === 'tienda' ? 'sidebar-active text-white' : 'text-gray-400 hover:text-white hover:bg-white/5' %>">
          <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 21V5a2 2 0 00-2-2H7a2 2 0 00-2 2v16m14 0h2m-2 0h-5m-9 0H3m2 0h5M9 7h1m-1 4h1m4-4h1m-1 4h1m-5 10v-5a1 1 0 011-1h2a1 1 0 011 1v5m-4 0h4"/></svg>
          Tienda
        </a>
        <a href="/dashboard/editor/secciones" class="flex items-center gap-3 px-4 py-2.5 rounded-xl text-sm font-medium transition-all pl-9 <%= section === 'editor' && sub === 'secciones' ? 'sidebar-active text-white' : 'text-gray-400 hover:text-white hover:bg-white/5' %>">
          <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 17V7m0 10a2 2 0 01-2 2H5a2 2 0 01-2-2V7a2 2 0 012-2h2a2 2 0 012 2m0 10a2 2 0 002 2h2a2 2 0 002-2M9 7a2 2 0 012-2h2a2 2 0 012 2m0 10V7m0 10a2 2 0 002 2h2a2 2 0 002-2V7a2 2 0 00-2-2h-2a2 2 0 00-2 2"/></svg>
          Secciones
        </a>
        <a href="/dashboard/editor/filtros" class="flex items-center gap-3 px-4 py-2.5 rounded-xl text-sm font-medium transition-all pl-9 <%= section === 'editor' && sub === 'filtros' ? 'sidebar-active text-white' : 'text-gray-400 hover:text-white hover:bg-white/5' %>">
          <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 4a1 1 0 011-1h16a1 1 0 011 1v2.586a1 1 0 01-.293.707l-6.414 6.414a1 1 0 00-.293.707V17l-4 4v-6.586a1 1 0 00-.293-.707L3.293 7.293A1 1 0 013 6.586V4z"/></svg>
          Filtros
        </a>
        <a href="/dashboard/editor/whatsapp" class="flex items-center gap-3 px-4 py-2.5 rounded-xl text-sm font-medium transition-all pl-9 <%= section === 'editor' && sub === 'whatsapp' ? 'sidebar-active text-white' : 'text-gray-400 hover:text-white hover:bg-white/5' %>">
          <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/></svg>
