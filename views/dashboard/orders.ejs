<div class="flex items-center justify-between mb-6">
  <div>
    <h1 class="text-2xl font-bold text-white">Pedidos</h1>
    <p class="text-gray-400 text-sm">Gestioná los pedidos de tus clientes</p>
  </div>
</div>

<% if (orders.length > 0) { %>
  <div class="space-y-4">
    <% orders.forEach(order => { 
      let items = [];
      try { items = JSON.parse(order.items || '[]'); } catch(e) {}
      const paymentStatus = order.payment_status || 'unpaid';
    %>
      <div class="p-6 rounded-2xl bg-[#0f0f1a] border border-gray-800/50 hover:border-gray-700 transition-all">
        <!-- Header -->
        <div class="flex flex-col lg:flex-row lg:items-center justify-between gap-4 mb-5">
          <div class="flex items-center gap-4">
            <div class="w-10 h-10 rounded-xl bg-gradient-to-br from-indigo-500/20 to-purple-500/20 flex items-center justify-center text-indigo-400 font-bold shrink-0">
              <%= (order.customer_name || '?').charAt(0).toUpperCase() %><%= (order.customer_lastname || '').charAt(0).toUpperCase() %>
            </div>
            <div>
              <h3 class="font-semibold text-white"><%= order.customer_name %> <%= order.customer_lastname || '' %></h3>
              <p class="text-sm text-gray-500">
                <%= order.customer_email %>
                <% if (order.customer_phone) { %> | <%= order.customer_phone %><% } %>
              </p>
              <p class="text-xs text-gray-600"><%= new Date(order.created_at).toLocaleString('es-AR') %></p>
            </div>
          </div>
          <div class="flex items-center gap-3">
            <span class="text-2xl font-bold text-white">$<%= order.total.toFixed(2) %></span>
          </div>
        </div>

        <!-- Status Badges -->
        <div class="flex flex-wrap gap-2 mb-5">
          <!-- Order Status -->
          <span class="inline-flex items-center gap-1.5 px-3 py-1.5 text-xs font-medium rounded-lg <%= 
            order.status === 'completed' ? 'bg-green-500/10 text-green-400' : 
            order.status === 'cancelled' ? 'bg-red-500/10 text-red-400' : 
            order.status === 'processing' ? 'bg-blue-500/10 text-blue-400' : 
            'bg-amber-500/10 text-amber-400' %>">
            <span class="w-1.5 h-1.5 rounded-full <%= 
              order.status === 'completed' ? 'bg-green-400' : 
              order.status === 'cancelled' ? 'bg-red-400' : 
              order.status === 'processing' ? 'bg-blue-400' : 
              'bg-amber-400' %>"></span>
            <%= 
              order.status === 'pending' ? 'Pendiente' : 
              order.status === 'processing' ? 'Procesando' : 
              order.status === 'completed' ? 'Completado' : 
              order.status === 'cancelled' ? 'Cancelado' : order.status 
            %>
          </span>
          <!-- Payment Status -->
          <span class="inline-flex items-center gap-1.5 px-3 py-1.5 text-xs font-medium rounded-lg <%= 
            paymentStatus === 'paid' ? 'bg-green-500/10 text-green-400' : 
            paymentStatus === 'pending' ? 'bg-blue-500/10 text-blue-400' : 
            'bg-gray-500/10 text-gray-400' %>">
            <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <% if (paymentStatus === 'paid') { %>
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"/>
              <% } else { %>
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8c-1.657 0-3 .895-3 2s1.343 2 3 2 3 .895 3 2-1.343 2-3 2m0-8c1.11 0 2.08.402 2.599 1M12 8V7m0 1v8m0 0v1m0-1c-1.11 0-2.08-.402-2.599-1M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/>
              <% } %>
            </svg>
            <%= 
              paymentStatus === 'paid' ? 'Pagado' : 
              paymentStatus === 'pending' ? 'Pago pendiente' : 
              'Pago no realizado'
            %>
          </span>
          <% if (order.local_pickup) { %>
            <span class="inline-flex items-center gap-1.5 px-3 py-1.5 text-xs font-medium rounded-lg bg-indigo-500/10 text-indigo-400">
              <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"/>
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"/>
              </svg>
              Retiro en local
            </span>
          <% } %>
        </div>

        <!-- Customer Info Grid -->
        <div class="grid lg:grid-cols-2 gap-4 mb-4">
          <!-- Customer Data -->
          <div class="p-4 rounded-xl bg-white/[0.02] border border-white/[0.05]">
            <p class="text-xs font-medium text-gray-400 uppercase tracking-wider mb-3">Datos del cliente</p>
            <div class="space-y-2 text-sm">
              <div class="flex justify-between">
                <span class="text-gray-500">Nombre</span>
                <span class="text-gray-300"><%= order.customer_name %> <%= order.customer_lastname || '' %></span>
              </div>
              <div class="flex justify-between">
                <span class="text-gray-500">Email</span>
                <span class="text-gray-300"><%= order.customer_email %></span>
              </div>
              <% if (order.customer_phone) { %>
                <div class="flex justify-between">
                  <span class="text-gray-500">Teléfono</span>
                  <span class="text-gray-300"><%= order.customer_phone %></span>
                </div>
              <% } %>
              <% if (order.customer_dni) { %>
                <div class="flex justify-between">
                  <span class="text-gray-500">DNI / CUIL</span>
                  <span class="text-gray-300"><%= order.customer_dni %></span>
                </div>
              <% } %>
            </div>
          </div>

          <!-- Address -->
          <% if (order.local_pickup) { %>
            <div class="p-4 rounded-xl bg-indigo-500/5 border border-indigo-500/10">
              <p class="text-xs font-medium text-indigo-400 uppercase tracking-wider mb-2">📍 Retiro en el local</p>
              <p class="text-sm text-gray-300"><%= order.pickup_address || order.customer_address %></p>
            </div>
          <% } else if (order.address_street) { %>
            <div class="p-4 rounded-xl bg-white/[0.02] border border-white/[0.05]">
              <p class="text-xs font-medium text-gray-400 uppercase tracking-wider mb-3">Dirección de entrega</p>
              <div class="space-y-2 text-sm">
                <div>
                  <span class="text-gray-500">Calle </span>
                  <span class="text-gray-300"><%= order.address_street %> <%= order.address_number || '' %> <%= order.address_floor ? '- ' + order.address_floor : '' %></span>
                </div>
                <% if (order.address_neighborhood) { %>
                  <div><span class="text-gray-500">Barrio </span><span class="text-gray-300"><%= order.address_neighborhood %></span></div>
                <% } %>
                <div class="flex gap-3">
                  <% if (order.address_city) { %><span class="text-gray-300"><%= order.address_city %></span><% } %>
                  <% if (order.address_province) { %><span class="text-gray-500">- <%= order.address_province %></span><% } %>
                </div>
                <% if (order.address_zip) { %>
                  <div><span class="text-gray-500">CP </span><span class="text-gray-300"><%= order.address_zip %></span></div>
                <% } %>
              </div>
            </div>
          <% } else if (order.customer_address) { %>
            <div class="p-4 rounded-xl bg-white/[0.02] border border-white/[0.05]">
              <p class="text-xs font-medium text-gray-400 uppercase tracking-wider mb-2">Dirección</p>
              <p class="text-sm text-gray-300"><%= order.customer_address %></p>
            </div>
          <% } %>
        </div>

        <!-- Items -->
        <div class="mb-4 p-4 rounded-xl bg-white/[0.02] border border-white/[0.05]">
          <p class="text-xs font-medium text-gray-400 uppercase tracking-wider mb-3">Productos</p>
          <div class="space-y-2">
            <% items.forEach(item => { %>
              <div class="flex items-center justify-between py-1.5 border-b border-white/[0.03] last:border-0">
                <div class="flex items-center gap-3">
                  <% if (item.image) { %>
                    <img src="<%= item.image %>" class="w-8 h-8 rounded-lg object-cover bg-gray-800">
                  <% } else { %>
                    <div class="w-8 h-8 rounded-lg bg-gray-800 flex items-center justify-center text-gray-600">
                      <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M20 7l-8-4-8 4m16 0l-8 4m8-4v10l-8 4m0-10L4 7m8 4v10M4 7v10l8 4"/></svg>
                    </div>
                  <% } %>
                  <span class="text-sm text-gray-300"><%= item.quantity %>x <%= item.name %></span>
                </div>
                <span class="text-sm text-gray-300 font-medium">$<%= (item.price * item.quantity).toFixed(2) %></span>
              </div>
            <% }); %>
          </div>
        </div>

        <% if (order.notes) { %>
          <div class="mb-4 p-3 rounded-xl bg-amber-500/5 border border-amber-500/10">
            <p class="text-xs text-amber-400 font-medium mb-1">Notas del cliente:</p>
            <p class="text-sm text-gray-300"><%= order.notes %></p>
          </div>
        <% } %>

        <!-- Status Update -->
        <div class="grid grid-cols-2 gap-3">
          <form method="POST" action="/dashboard/pedidos/status/<%= order.id %>" class="flex items-center gap-3">
            <select name="status"
              class="px-3 py-2 bg-[#1a1a2e] border border-gray-700/50 rounded-xl text-white text-sm focus:outline-none focus:border-indigo-500/50 transition-colors">
              <option value="pending" <%= order.status === 'pending' ? 'selected' : '' %>>Pendiente</option>
              <option value="processing" <%= order.status === 'processing' ? 'selected' : '' %>>Procesando</option>
              <option value="completed" <%= order.status === 'completed' ? 'selected' : '' %>>Completado</option>
              <option value="cancelled" <%= order.status === 'cancelled' ? 'selected' : '' %>>Cancelado</option>
            </select>
            <button type="submit"
              class="px-4 py-2 text-sm font-medium text-white bg-indigo-600 rounded-xl hover:bg-indigo-500 transition-colors">
              Actualizar
            </button>
          </form>
          <form method="POST" action="/dashboard/pedidos/pago/<%= order.id %>" class="flex items-center gap-3">
            <select name="payment_status"
              class="px-3 py-2 bg-[#1a1a2e] border border-gray-700/50 rounded-xl text-white text-sm focus:outline-none focus:border-indigo-500/50 transition-colors">
              <option value="unpaid" <%= paymentStatus === 'unpaid' ? 'selected' : '' %>>No realizado</option>
              <option value="pending" <%= paymentStatus === 'pending' ? 'selected' : '' %>>Pendiente</option>
              <option value="paid" <%= paymentStatus === 'paid' ? 'selected' : '' %>>Recibido</option>
            </select>
            <button type="submit"
              class="px-4 py-2 text-sm font-medium text-white <%= paymentStatus === 'paid' ? 'bg-green-600' : 'bg-gray-600' %> rounded-xl hover:opacity-80 transition-colors">
              Actualizar Pago
            </button>
          </form>
        </div>
        <% if (order.payment_status === 'paid') { %>
          <div class="mt-3 p-3 rounded-xl bg-green-500/5 border border-green-500/10 flex items-center gap-2">
            <svg class="w-4 h-4 text-green-400 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 16h-1v-4h-1m1-4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/>
            </svg>
            <p class="text-xs text-green-400">Pago recibido — el stock se descuenta automáticamente</p>
          </div>
        <% } else if (order.payment_status === 'pending') { %>
          <div class="mt-3 p-3 rounded-xl bg-blue-500/5 border border-blue-500/10 flex items-center gap-2">
            <svg class="w-4 h-4 text-blue-400 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4m0 4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/>
            </svg>
            <p class="text-xs text-blue-400">Pago pendiente — el stock está reservado para el cliente</p>
          </div>
        <% } else { %>
          <div class="mt-3 p-3 rounded-xl bg-gray-500/5 border border-gray-500/10 flex items-center gap-2">
            <svg class="w-4 h-4 text-gray-500 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M20 12H4"/>
            </svg>
            <p class="text-xs text-gray-500">Pago no realizado — el stock no se ve afectado</p>
          </div>
        <% } %>
      </div>
    <% }); %>
  </div>
<% } else { %>
  <div class="text-center py-20">
    <svg class="w-16 h-16 text-gray-600 mx-auto mb-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2"/>
    </svg>
    <h3 class="text-xl font-semibold text-gray-300 mb-2">Aún no tenés pedidos</h3>
    <p class="text-gray-500">Cuando un cliente realice una compra, aparecerá aquí</p>
  </div>
<% } %>