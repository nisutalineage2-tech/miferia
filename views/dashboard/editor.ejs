<% const t = theme || {}; const c = t.colors || {}; const fonts = t.fonts || {}; const hdr = t.header || {}; const hp = t.homepage || {}; const sc = t.social || {}; const ft = t.footer || {}; const ibs = (t.product_detail && t.product_detail.info_blocks) || []; const ct2 = t.cart || {}; const sc2 = t.social || {}; const fl = t.filtros || {}; const subs = { plantilla:1, colores:1, anuncio:1, carrusel:1, logo:1, navegacion:1, tienda:1, secciones:1, filtros:1, whatsapp:1, instagram:1, facebook:1, css:1 }; const cur = subs[sub] ? sub : 'plantilla'; %>
<div class="flex gap-4 p-4" style="height: calc(100vh - 73px);">
  <!-- LEFT: Form -->
  <form id="editorForm" method="POST" action="/dashboard/editor" class="w-[42%] flex flex-col rounded-2xl border border-gray-800/50 overflow-hidden" style="background: #0a0a12;">
    <div class="flex items-center justify-between p-3 border-b border-gray-800/50 shrink-0" style="background: #0a0a12;">
      <h1 class="text-sm font-bold text-white capitalize"><%= cur %></h1>
      <div class="flex items-center gap-2">
        <button type="submit" class="py-1.5 px-3 bg-gradient-to-r from-indigo-600 to-purple-600 text-white text-xs font-semibold rounded-lg hover:from-indigo-500 hover:to-purple-500 transition-all shadow-lg shadow-indigo-600/25 flex items-center gap-1.5">
          <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/></svg>
          Guardar
        </button>
        <button type="button" onclick="refreshPreview()" class="py-1.5 px-3 bg-white/5 border border-gray-700/50 text-gray-300 text-xs rounded-lg hover:bg-white/10 transition-all flex items-center gap-1.5">
          <svg class="w-3 h-3" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 4v5h.582m15.356 2A8.001 8.001 0 004.582 9m0 0H9m11 11v-5h-.581m0 0a8.003 8.003 0 01-15.357-2m15.357 2H15"/></svg>
          Preview
        </button>
      </div>
    </div>
    <div class="flex-1 overflow-y-auto p-3 space-y-2">

      <!-- PLANTILLA -->
      <% if (cur === 'plantilla') { %>
        <p class="text-xs text-gray-500 mb-3">Elegí la plantilla para tu tienda</p>
        <% const tmpls = [
          { v:'template1', label:'Minimal', desc:'Ultra limpio, whitespace masivo' },
          { v:'template2', label:'Bold', desc:'Editorial, menu fullscreen' },
          { v:'template3', label:'Luxury', desc:'Dark premium, dorado, serif' },
          { v:'template4', label:'Fresh', desc:'Organico, bordes redondos' },
          { v:'template5', label:'Urban', desc:'Industrial, diagonal, neon' },
          { v:'template6', label:'Retro', desc:'Pop colorido, animaciones' },
          { v:'template7', label:'Elegant', desc:'Clasico serif, decorativo' },
          { v:'template8', label:'Glass', desc:'Glassmorphism, futuristic' }
        ]; const curTmpl = store.template || 'template1'; %>
        <div class="grid grid-cols-3 gap-2">
          <% tmpls.forEach(tm => { %>
            <label class="cursor-pointer relative rounded-lg bg-[#1a1a2e] border-2 overflow-hidden <%= curTmpl === tm.v ? 'border-indigo-500 ring-2 ring-indigo-500/30' : 'border-gray-700/50 hover:border-gray-500' %> transition-all" onclick="switchTemplate('<%= tm.v %>')">
              <input type="radio" name="template" value="<%= tm.v %>" class="sr-only" <%= curTmpl === tm.v ? 'checked' : '' %>>
              <div class="aspect-[4/3] bg-[#0f0f1a] overflow-hidden">
                <img src="/uploads/templates/<%= tm.v %>.jpg" alt="<%= tm.label %>" class="w-full h-full object-cover" loading="lazy" onerror="this.style.display='none';this.nextSibling.style.display='flex'"><div class="hidden w-full h-full items-center justify-center text-gray-600 text-xs" style="display:none;background:#1a1a2e;">Sin preview</div>
              </div>
              <div class="px-1.5 py-1 text-center" style="background: #0f0f1a;">
                <span class="text-[10px] font-semibold text-white block leading-tight"><%= tm.label %></span>
                <span class="text-[8px] text-gray-500 block"><%= tm.desc %></span>
              </div>
              <% if (curTmpl === tm.v) { %>
                <div class="absolute top-0.5 right-0.5 w-3.5 h-3.5 rounded-full bg-indigo-500 flex items-center justify-center">
                  <svg class="w-2 h-2 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="3" d="M5 13l4 4L19 7"/></svg>
                </div>
              <% } %>
            </label>
          <% }); %>
        </div>
      <% } %>

      <!-- COLORES -->
      <% if (cur === 'colores') { %>
        <div class="p-3 rounded-xl bg-[#0f0f1a] border border-gray-800/50">
          <div class="grid grid-cols-2 gap-3">
            <div>
              <label class="text-[10px] text-gray-500 block mb-1">Color Primario</label>
              <input type="color" name="color_btn_primary_bg" value="<%= c.btn_primary_bg || store.primary_color || '#4f46e5' %>" class="w-full h-10 rounded-lg border border-gray-700/50 cursor-pointer bg-[#1a1a2e]" onchange="scheduleSave()">
              <input type="hidden" name="primary_color" value="<%= store.primary_color || '#4f46e5' %>">
            </div>
            <div>
              <label class="text-[10px] text-gray-500 block mb-1">Color Acento</label>
              <input type="color" name="color_btn_secondary_bg" value="<%= c.btn_secondary_bg || store.accent_color || '#e5e7eb' %>" class="w-full h-10 rounded-lg border border-gray-700/50 cursor-pointer bg-[#1a1a2e]" onchange="scheduleSave()">
              <input type="hidden" name="accent_color" value="<%= store.accent_color || '#e5e7eb' %>">
            </div>
            <div>
              <label class="text-[10px] text-gray-500 block mb-1">Fondo de página</label>
              <input type="color" name="color_body_bg" value="<%= c.body_bg || '#f9fafb' %>" class="w-full h-10 rounded-lg border border-gray-700/50 cursor-pointer bg-[#1a1a2e]" onchange="scheduleSave()">
            </div>
            <div>
              <label class="text-[10px] text-gray-500 block mb-1">Texto</label>
              <input type="color" name="color_body_text" value="<%= c.body_text || '#374151' %>" class="w-full h-10 rounded-lg border border-gray-700/50 cursor-pointer bg-[#1a1a2e]" onchange="scheduleSave()">
            </div>
            <div>
              <label class="text-[10px] text-gray-500 block mb-1">Títulos</label>
              <input type="color" name="color_title_text" value="<%= c.title_text || c.body_text || '#111827' %>" class="w-full h-10 rounded-lg border border-gray-700/50 cursor-pointer bg-[#1a1a2e]" onchange="scheduleSave()">
            </div>
            <div>
              <label class="text-[10px] text-gray-500 block mb-1">Fondo del footer</label>
              <input type="color" name="color_footer_bg" value="<%= c.footer_bg || '#111827' %>" class="w-full h-10 rounded-lg border border-gray-700/50 cursor-pointer bg-[#1a1a2e]" onchange="scheduleSave()">
            </div>
            <div>
              <label class="text-[10px] text-gray-500 block mb-1">Texto del footer</label>
              <input type="color" name="color_footer_text" value="<%= c.footer_text || '#9ca3af' %>" class="w-full h-10 rounded-lg border border-gray-700/50 cursor-pointer bg-[#1a1a2e]" onchange="scheduleSave()">
            </div>
            <div>
              <label class="text-[10px] text-gray-500 block mb-1">Botón primario (texto)</label>
              <input type="color" name="color_btn_primary_text" value="<%= c.btn_primary_text || '#ffffff' %>" class="w-full h-10 rounded-lg border border-gray-700/50 cursor-pointer bg-[#1a1a2e]" onchange="scheduleSave()">
            </div>
          </div>
        </div>
      <% } %>

      <!-- ANUNCIO -->
      <% if (cur === 'anuncio') { %>
        <div class="p-3 rounded-xl bg-[#0f0f1a] border border-gray-800/50">
          <div class="flex items-center gap-2 mb-2">
            <label class="flex items-center gap-2 cursor-pointer">
              <input type="checkbox" name="header_announcement_show" <%= hdr.announcement_show ? 'checked' : '' %> class="w-3.5 h-3.5 rounded border-gray-700 bg-[#1a1a2e] text-indigo-500" onchange="scheduleSave()">
              <span class="text-[10px] text-gray-400">Mostrar barra de anuncio</span>
            </label>
          </div>
          <input type="text" name="header_announcement_text" value="<%= hdr.announcement_text || '' %>" placeholder="Texto del anuncio" class="w-full px-2 py-1 bg-[#1a1a2e] border border-gray-700/50 rounded-lg text-white text-[11px]" oninput="scheduleSave()">
        </div>
      <% } %>

      <!-- CARRUSEL -->
      <% if (cur === 'carrusel') { %>
        <div class="p-3 rounded-xl bg-[#0f0f1a] border border-gray-800/50">
          <div class="flex items-center justify-between mb-2">
            <h3 class="text-xs font-semibold text-white">Hero Carrusel</h3>
            <label class="flex items-center gap-2 cursor-pointer">
              <input type="hidden" name="homepage_hero" value="off">
              <input type="checkbox" name="homepage_hero" <%= hp.hero !== false ? 'checked' : '' %> class="w-3.5 h-3.5 rounded border-gray-700 bg-[#1a1a2e] text-indigo-500" onchange="scheduleSave()">
              <span class="text-[10px] text-gray-400">Mostrar</span>
            </label>
          </div>
          <% const heroImgs = typeof store.hero_images !== 'undefined' && store.hero_images ? (() => { try { return JSON.parse(typeof store.hero_images === 'string' ? store.hero_images : '[]'); } catch(e) { return []; } })() : []; %>
          <div class="grid grid-cols-5 gap-1.5">
            <% for (let i = 0; i < 5; i++) { %>
              <div>
                <div id="heroPreview<%= i %>" class="w-full aspect-[16/9] rounded-lg bg-[#0f0f1a] border-2 border-dashed border-gray-700/50 flex items-center justify-center overflow-hidden cursor-pointer hover:border-indigo-500/30 transition-colors" onclick="document.getElementById('heroInput<%= i %>').click()">
                  <% const hi = heroImgs[i]; if (hi) { %><img src="<%= hi %>" class="w-full h-full object-cover"><% } else { %><svg class="w-4 h-4 text-gray-600" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 6v6m0 0v6m0-6h6m-6 0H6"/></svg><% } %>
                </div>
                <input type="file" class="hidden" id="heroInput<%= i %>" accept="image/*">
                <input type="hidden" name="hero_image_<%= i %>" id="heroUrl<%= i %>" value="<%= hi || '' %>">
              </div>
            <% } %>
          </div>
        </div>
      <% } %>

      <!-- LOGO -->
      <% if (cur === 'logo') { %>
        <div class="flex items-center gap-3 px-3 py-2.5 bg-[#0f0f1a] border border-gray-800/50 rounded-xl">
          <span class="text-xs text-gray-300 font-medium w-16 shrink-0">Logo</span>
          <div id="brandLogoPreview" class="w-10 h-10 rounded-lg bg-[#1a1a2e] border-2 border-dashed border-gray-700/50 flex items-center justify-center overflow-hidden cursor-pointer hover:border-indigo-500/30 shrink-0" onclick="document.getElementById('brandLogoInput').click()">
            <% if (t.brand && t.brand.logo) { %><img src="<%= t.brand.logo %>" class="w-full h-full object-contain"><% } else if (store.logo) { %><img src="<%= store.logo %>" class="w-full h-full object-contain"><% } else { %><svg class="w-4 h-4 text-gray-600" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 16l4.586-4.586a2 2 0 012.828 0L16 16m-2-2l1.586-1.586a2 2 0 012.828 0L20 14m-6-6h.01M6 20h12a2 2 0 002-2V6a2 2 0 00-2-2H6a2 2 0 00-2 2v12a2 2 0 002 2z"/></svg><% } %>
          </div>
          <input type="file" class="hidden" id="brandLogoInput">
          <input type="hidden" name="brand_logo" id="brandLogoUrl" value="<%= (t.brand && t.brand.logo) || store.logo || '' %>">
        </div>
        <div class="flex items-center gap-3 px-3 py-2.5 bg-[#0f0f1a] border border-gray-800/50 rounded-xl">
          <span class="text-xs text-gray-300 font-medium w-16 shrink-0">Favicon</span>
          <div id="faviconPreview" class="w-10 h-10 rounded-lg bg-[#1a1a2e] border-2 border-dashed border-gray-700/50 flex items-center justify-center overflow-hidden cursor-pointer hover:border-indigo-500/30 shrink-0" onclick="document.getElementById('faviconInput').click()">
            <% if (t.brand && t.brand.favicon) { %><img src="<%= t.brand.favicon %>" class="w-full h-full object-contain"><% } else { %><svg class="w-4 h-4 text-gray-600" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 16l4.586-4.586a2 2 0 012.828 0L16 16m-2-2l1.586-1.586a2 2 0 012.828 0L20 14m-6-6h.01M6 20h12a2 2 0 002-2V6a2 2 0 00-2-2H6a2 2 0 00-2 2v12a2 2 0 002 2z"/></svg><% } %>
          </div>
          <input type="file" class="hidden" id="faviconInput">
          <input type="hidden" name="brand_favicon" id="faviconUrl" value="<%= (t.brand && t.brand.favicon) || '' %>">
        </div>
        <div class="flex items-center gap-3 px-3 py-2.5 bg-[#0f0f1a] border border-gray-800/50 rounded-xl">
          <span class="text-xs text-gray-300 font-medium w-16 shrink-0">Banner</span>
          <div id="bannerPreview" class="w-20 h-10 rounded-lg bg-[#1a1a2e] border-2 border-dashed border-gray-700/50 flex items-center justify-center overflow-hidden cursor-pointer hover:border-indigo-500/30 shrink-0" onclick="document.getElementById('bannerInput').click()">
            <% if (store.banner) { %><img src="<%= store.banner %>" class="w-full h-full object-cover"><% } else { %><svg class="w-4 h-4 text-gray-600" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 16l4.586-4.586a2 2 0 012.828 0L16 16m-2-2l1.586-1.586a2 2 0 012.828 0L20 14m-6-6h.01M6 20h12a2 2 0 002-2V6a2 2 0 00-2-2H6a2 2 0 00-2 2v12a2 2 0 002 2z"/></svg><% } %>
          </div>
          <input type="file" class="hidden" id="bannerInput">
          <input type="hidden" name="banner" id="bannerUrl" value="<%= store.banner || '' %>">
        </div>
      <% } %>

      <!-- NAVEGACIÓN -->
      <% if (cur === 'navegacion') { %>
        <div class="p-3 rounded-xl bg-[#0f0f1a] border border-gray-800/50">
          <div class="space-y-2">
            <div class="flex items-center justify-between">
              <span class="text-xs text-gray-300">Header sticky</span>
              <label><input type="hidden" name="header_sticky" value="off"><input type="checkbox" name="header_sticky" <%= hdr.sticky ? 'checked' : '' %> class="w-3.5 h-3.5 rounded border-gray-700 bg-[#1a1a2e] text-indigo-500" onchange="scheduleSave()"></label>
            </div>
            <div class="flex items-center justify-between">
              <span class="text-xs text-gray-300">Búsqueda en móvil</span>
              <label><input type="hidden" name="header_search_mobile" value="off"><input type="checkbox" name="header_search_mobile" <%= hdr.search_mobile ? 'checked' : '' %> class="w-3.5 h-3.5 rounded border-gray-700 bg-[#1a1a2e] text-indigo-500" onchange="scheduleSave()"></label>
            </div>
          </div>
        </div>
      <% } %>

      <!-- TIENDA -->
      <% if (cur === 'tienda') { %>
        <div class="flex items-center gap-3 px-3 py-2.5 bg-[#0f0f1a] border border-gray-800/50 rounded-xl">
          <span class="text-xs text-gray-300 font-medium w-16 shrink-0">Nombre</span>
          <input type="text" name="name" value="<%= store.name %>" placeholder="Nombre de la tienda" class="flex-1 px-2 py-1 bg-[#1a1a2e] border border-gray-700/50 rounded-lg text-white text-xs" oninput="scheduleSave()">
        </div>
        <div class="flex items-center gap-3 px-3 py-2.5 bg-[#0f0f1a] border border-gray-800/50 rounded-xl">
          <span class="text-xs text-gray-300 font-medium w-16 shrink-0">Descripción</span>
          <input type="text" name="description" value="<%= store.description || '' %>" placeholder="Descripción breve" class="flex-1 px-2 py-1 bg-[#1a1a2e] border border-gray-700/50 rounded-lg text-white text-xs" oninput="scheduleSave()">
        </div>
        <div class="flex items-start gap-3 px-3 py-2.5 bg-[#0f0f1a] border border-gray-800/50 rounded-xl">
          <span class="text-xs text-gray-300 font-medium w-16 shrink-0 mt-1">Sobre Nosotros</span>
          <textarea name="about_text" rows="2" placeholder="Texto sobre la tienda" class="flex-1 px-2 py-1 bg-[#1a1a2e] border border-gray-700/50 rounded-lg text-white text-xs" oninput="scheduleSave()"><%= store.about_text || '' %></textarea>
        </div>
      <% } %>

      <!-- SECCIONES -->
      <% if (cur === 'secciones') { %>
        <div class="p-3 rounded-xl bg-[#0f0f1a] border border-gray-800/50">
          <div class="grid grid-cols-2 gap-x-4 gap-y-1">
            <% ['featured_products','main_categories','promo_banners','institutional_msg','instagram_posts','newsletter','video','shipping_info'].forEach(s => { %>
              <label class="flex items-center gap-2 cursor-pointer py-1">
                <input type="hidden" name="homepage_<%= s %>" value="off">
                <input type="checkbox" name="homepage_<%= s %>" <%= hp[s] !== false ? 'checked' : '' %> class="w-3.5 h-3.5 rounded border-gray-700 bg-[#1a1a2e] text-indigo-500" onchange="scheduleSave()">
                <span class="text-xs text-gray-300 capitalize"><%= s.replace(/_/g, ' ') %></span>
              </label>
            <% }); %>
          </div>
        </div>
      <% } %>

      <!-- FILTROS -->
      <% if (cur === 'filtros') { %>
        <div class="p-3 rounded-xl bg-[#0f0f1a] border border-gray-800/50">
          <% const filterDefs = [{key:'categories',label:'Categorías'},{key:'price_range',label:'Rango de precio'},{key:'search',label:'Búsqueda'},{key:'sort',label:'Ordenar'},{key:'brands',label:'Marcas'},{key:'colors_sizes',label:'Colores / Talles'},{key:'gender',label:'Género'},{key:'free_shipping',label:'Envío gratis'}]; %>
          <div class="grid grid-cols-2 gap-x-4 gap-y-1">
            <% filterDefs.forEach(fd => { %>
              <label class="flex items-center gap-2 cursor-pointer py-1">
                <input type="checkbox" name="filter_<%= fd.key %>" <%= fl[fd.key] !== false ? 'checked' : '' %> class="w-3.5 h-3.5 rounded border-gray-700 bg-[#1a1a2e] text-indigo-500" onchange="scheduleSave()">
                <span class="text-xs text-gray-300"><%= fd.label %></span>
              </label>
            <% }); %>
          </div>
        </div>
      <% } %>

      <!-- WHATSAPP -->
      <% if (cur === 'whatsapp') { %>
        <div class="flex items-center gap-3 px-3 py-2.5 bg-[#0f0f1a] border border-gray-800/50 rounded-xl">
          <span class="text-xs text-gray-300 font-medium w-16 shrink-0">WhatsApp</span>
          <input type="text" name="social_whatsapp" value="<%= sc.whatsapp || store.whatsapp || '' %>" placeholder="5491123456789" class="flex-1 px-2 py-1 bg-[#1a1a2e] border border-gray-700/50 rounded-lg text-white text-xs" oninput="scheduleSave()">
        </div>
      <% } %>

      <!-- INSTAGRAM -->
      <% if (cur === 'instagram') { %>
        <div class="flex items-center gap-3 px-3 py-2.5 bg-[#0f0f1a] border border-gray-800/50 rounded-xl">
          <span class="text-xs text-gray-300 font-medium w-16 shrink-0">Instagram</span>
          <input type="text" name="social_instagram" value="<%= sc.instagram || store.instagram || '' %>" placeholder="@tutienda" class="flex-1 px-2 py-1 bg-[#1a1a2e] border border-gray-700/50 rounded-lg text-white text-xs" oninput="scheduleSave()">
        </div>
      <% } %>

      <!-- FACEBOOK -->
      <% if (cur === 'facebook') { %>
        <div class="flex items-center gap-3 px-3 py-2.5 bg-[#0f0f1a] border border-gray-800/50 rounded-xl">
          <span class="text-xs text-gray-300 font-medium w-16 shrink-0">Facebook</span>
          <input type="text" name="social_facebook" value="<%= sc.facebook || store.facebook || '' %>" placeholder="URL de Facebook" class="flex-1 px-2 py-1 bg-[#1a1a2e] border border-gray-700/50 rounded-lg text-white text-xs" oninput="scheduleSave()">
        </div>
      <% } %>

      <!-- CSS -->
      <% if (cur === 'css') { %>
        <div class="p-3 rounded-xl bg-[#0f0f1a] border border-gray-800/50">
          <div class="flex items-center gap-3 mb-3">
            <span class="text-xs text-gray-300 font-medium w-20 shrink-0">Tipografía</span>
            <select name="font_body" onchange="scheduleSave()" class="flex-1 px-2 py-1 bg-[#1a1a2e] border border-gray-700/50 rounded-lg text-white text-xs">
              <% ['Inter','System UI','Arial','Helvetica','Georgia','Montserrat','Poppins','Open Sans','Roboto','Playfair Display'].forEach(fo => { %>
                <option value="<%= fo %>" <%= (fonts.body || 'Inter') === fo ? 'selected' : '' %>><%= fo %></option>
              <% }); %>
            </select>
          </div>
          <div class="flex items-center gap-3 mb-3">
            <span class="text-xs text-gray-300 font-medium w-20 shrink-0">Títulos</span>
            <select name="font_headings" onchange="scheduleSave()" class="flex-1 px-2 py-1 bg-[#1a1a2e] border border-gray-700/50 rounded-lg text-white text-xs">
              <% ['Inter','Playfair Display','Lora','Nunito','Oswald','Quicksand','Fredoka','Montserrat','Poppins'].forEach(fo => { %>
                <option value="<%= fo %>" <%= (fonts.headings || 'Inter') === fo ? 'selected' : '' %>><%= fo %></option>
              <% }); %>
            </select>
          </div>
          <div>
            <span class="text-xs text-gray-300 mb-2 block">CSS Avanzado</span>
            <textarea name="advanced_css" rows="8" placeholder="/* Tu CSS personalizado aquí */" class="w-full px-3 py-2 bg-[#1a1a2e] border border-gray-700/50 rounded-lg text-white text-xs font-mono" oninput="scheduleSave()"><%= store.advanced_css || '' %></textarea>
          </div>
        </div>
      <% } %>

      <!-- Hidden fields needed for full save -->
      <% ['cart_show_view_more','cart_quick_cart','cart_recommendations','cart_coupons','cart_shipping_calculator','footer_show_contact','footer_show_social','footer_show_payment','homepage_carousel','homepage_category_banners','homepage_horizontal_banner','homepage_modules','homepage_sale_products'].forEach(k => { %>
        <input type="hidden" name="<%= k %>" value="<%= (t.cart && t.cart[k.replace('cart_','')] !== false) || (!k.startsWith('cart') && !k.startsWith('footer') && !k.startsWith('homepage')) ? 'on' : 'off' %>">
      <% }); %>
      <input type="hidden" name="cart_min_amount" value="<%= ct2.min_amount || 0 %>">
      <input type="hidden" name="cart_quick_cart_action" value="<%= ct2.quick_cart_action || 'drawer' %>">
      <input type="hidden" name="color_preset" value="<%= c.preset || '' %>">

    </div>
  </form>

  <!-- RIGHT: Preview -->
  <div class="flex-1 flex flex-col rounded-2xl overflow-hidden border border-gray-800/50" style="background: #0a0a12;">
    <div class="flex items-center justify-between px-5 py-3 border-b border-gray-800/50" style="background: #0a0a12;">
      <div class="flex items-center gap-2">
        <svg class="w-3 h-3 text-green-400" fill="currentColor" viewBox="0 0 8 8"><circle cx="4" cy="4" r="4"/></svg>
        <span class="text-xs text-gray-500">Preview</span>
      </div>
      <div class="flex items-center gap-2">
        <a href="https://<%= store.custom_domain %>/" target="_blank" class="text-xs text-indigo-400 hover:text-indigo-300">Ver tienda ↗</a>
      </div>
    </div>
    <div class="flex-1 relative bg-[#0f0f1a]">
      <div class="absolute inset-4 rounded-xl overflow-hidden shadow-2xl shadow-black/40">
        <iframe id="previewFrame" src="/dashboard/preview" class="w-full h-full border-0" style="background: #fff;"></iframe>
        <div id="previewLoading" class="absolute inset-0 flex items-center justify-center bg-[#0f0f1a]/80 hidden" style="z-index: 10;">
          <div class="w-8 h-8 border-2 border-indigo-500 border-t-transparent rounded-full animate-spin"></div>
        </div>
      </div>
    </div>
  </div>
</div>

<script>
let previewTimer;
let pendingTemplate = null;

function switchTemplate(val) {
  pendingTemplate = val;
  document.querySelectorAll('[onclick^="switchTemplate"]').forEach(el => {
    el.classList.remove('border-indigo-500', 'ring-2', 'ring-indigo-500/30');
    el.classList.add('border-gray-700/50');
  });
  const el = document.querySelector('input[name="template"][value="' + val + '"]');
  if (el) {
    el.checked = true;
    const label = el.closest('label');
    if (label) { label.classList.remove('border-gray-700/50'); label.classList.add('border-indigo-500', 'ring-2', 'ring-indigo-500/30'); }
  }
  clearTimeout(previewTimer);
  previewTimer = setTimeout(async () => {
    await fetch('/dashboard/editor', { method: 'POST', body: new URLSearchParams({ template: val }), headers: { 'Content-Type': 'application/x-www-form-urlencoded' } });
    refreshPreview();
  }, 300);
}

async function refreshPreview() {
  const loading = document.getElementById('previewLoading');
  const frame = document.getElementById('previewFrame');
  loading.classList.remove('hidden');
  let url = '/dashboard/preview';
  if (pendingTemplate) url += '?template=' + pendingTemplate;
  url += (url.includes('?') ? '&' : '?') + '_=' + Date.now();
  frame.src = url;
  frame.onload = () => loading.classList.add('hidden');
}

function scheduleSave() {
  clearTimeout(previewTimer);
  previewTimer = setTimeout(async () => {
    const form = document.getElementById('editorForm');
    if (!form) return;
    const fd = new FormData(form);
    ['color_btn_primary_bg','color_btn_secondary_bg','color_body_bg','color_body_text','color_title_text','primary_color','accent_color'].forEach(name => {
      const el = document.querySelector(`[name="${name}"]`);
      if (el) fd.set(name, el.value);
    });
    await fetch('/dashboard/editor', { method: 'POST', body: new URLSearchParams(fd), headers: { 'Content-Type': 'application/x-www-form-urlencoded' } });
    refreshPreview();
  }, 800);
}

// ---- Logo upload ----
['brandLogo','favicon'].forEach(t => {
  const input = document.getElementById(t + 'Input');
  if (input) input.addEventListener('change', function(e) {
    if (this.files?.[0]) {
      const fd = new FormData(); fd.append('file', this.files[0]); fd.append('store_id', '<%= store.id %>');
      fetch('/api/upload/logo', { method: 'POST', body: fd }).then(r => r.json()).then(d => {
        if (d.url) {
          document.getElementById(t === 'brandLogo' ? 'brandLogoUrl' : 'faviconUrl').value = d.url;
          document.getElementById(t === 'brandLogo' ? 'brandLogoPreview' : 'faviconPreview').innerHTML = `<img src="${d.url}" class="w-full h-full object-contain">`;
          scheduleSave();
        }
      });
    }
  });
});
document.getElementById('bannerInput')?.addEventListener('change', function(e) {
  if (this.files?.[0]) {
    const fd = new FormData(); fd.append('file', this.files[0]); fd.append('store_id', '<%= store.id %>');
    fetch('/api/upload/logo', { method: 'POST', body: fd }).then(r => r.json()).then(d => {
      if (d.url) { document.getElementById('bannerUrl').value = d.url; document.getElementById('bannerPreview').innerHTML = `<img src="${d.url}" class="w-full h-full object-cover">`; scheduleSave(); }
    });
  }
});
for (let i = 0; i < 5; i++) {
  const input = document.getElementById('heroInput' + i);
  if (input) input.addEventListener('change', function(e) {
    if (this.files?.[0]) {
      const fd = new FormData(); fd.append('file', this.files[0]); fd.append('store_id', '<%= store.id %>');
      fetch('/api/upload/logo', { method: 'POST', body: fd }).then(r => r.json()).then(d => {
        if (d.url) { document.getElementById('heroUrl' + i).value = d.url; document.getElementById('heroPreview' + i).innerHTML = `<img src="${d.url}" class="w-full h-full object-cover">`; scheduleSave(); }
      });
    }
  });
}
</script>
