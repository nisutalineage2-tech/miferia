<% const t = store.theme_settings ? JSON.parse(store.theme_settings) : {}; const c = t.colors || {}; %>
<% const isHome = !page || page === 'home'; %>
<% const isShop = page === 'shop'; %>
<% const isProduct = page === 'product'; %>
<% const isCart = page === 'cart'; %>
<% const isCheckout = page === 'checkout'; %>
<% const isCategory = page === 'category'; %>
<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= store.name || 'Store' %><%= typeof pageTitle !== 'undefined' ? ' — ' + pageTitle : '' %></title>
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Noto+Serif:wght@300;400;500;600;700&family=Lora:wght@300;400;500;600;700&display=swap" rel="stylesheet">
  <script src="https://cdn.tailwindcss.com"></script>
  <script>
    tailwind.config = {
      theme: {
        extend: {
          fontFamily: {
            'noto-serif': ['"Noto Serif"', 'serif'],
            lora: ['Lora', 'serif']
          },
          colors: {
            primary: 'var(--primary)',
            bg: 'var(--bg)',
            text: 'var(--text)',
            navy: '#1e3a5f',
            ivory: '#faf8f5',
            burgundy: '#8b2252'
          }
        }
      }
    }
  </script>
  <style>
    :root {
      --primary: <%= c.btn_primary_bg || '#8b2252' %>;
      --bg: <%= c.page_bg || '#faf8f5' %>;
      --text: <%= c.text || '#3d3d3d' %>;
      --footer-bg: <%= c.footer_bg || '#1e3a5f' %>;
      --footer-text: <%= c.footer_text || '#c8c0b8' %>;
      --title: <%= c.heading_color || '#1e3a5f' %>;
      --label-bg: <%= c.label_bg || '#8b2252' %>;
    }
    * { font-family: 'Lora', serif; }
    h1,h2,h3,h4,h5,h6 { font-family: 'Noto Serif', serif; color: var(--title); }
    body { background: var(--bg); color: var(--text); }
    .decorative-line {
      border-top: 1px solid #d4cfc8;
    }
    .decorative-line-accent {
      border-top: 1px solid var(--primary);
      width: 60px;
    }
    .elegant-card {
      background: white;
      border: 1px solid #e8e3dc;
      box-shadow: 0 2px 8px rgba(0,0,0,0.06);
      border-radius: 2px;
      transition: box-shadow 0.3s ease, opacity 0.3s ease;
    }
    .elegant-card:hover {
      opacity: 0.92;
      box-shadow: 0 4px 16px rgba(0,0,0,0.1);
    }
    .top-bar {
      font-size: 0.7rem;
      letter-spacing: 0.08em;
      text-transform: uppercase;
    }
  </style>
</head>
<body class="antialiased min-h-screen flex flex-col">
  <%- include('../../partials/_flash', { locals }); %>
  <%- include('../../partials/_cart_drawer', { store, storeBaseUrl }); %>
  <%- include('../../partials/_order_success', { locals }); %>

  <!-- NAV — Two-row: thin top bar, logo, category tabs -->
  <header class="sticky top-0 z-40" style="background: var(--bg);">
    <!-- Thin top bar -->
    <div class="decorative-line" style="background: #1e3a5f; padding: 5px 0;">
      <div class="max-w-7xl mx-auto px-6 flex items-center justify-between top-bar" style="color: #c8c0b8;">
        <span class="hidden md:inline">Welcome to <%= store.name || 'Store' %></span>
        <div class="flex items-center gap-4">
          <%- include('../../partials/_nav_links', { store, storeBaseUrl, locals: { navLinkClass: 'hover:text-white transition-colors' } }); %>
        </div>
      </div>
    </div>
    <!-- Logo row -->
    <div class="decorative-line py-6 text-center">
      <a href="<%= storeBaseUrl || '/' %>" class="font-noto-serif text-3xl font-bold tracking-wide" style="color: var(--title);">
        <%= store.name || 'Store' %>
      </a>
    </div>
    <!-- Cart row -->
    <div class="decorative-line py-2 flex justify-center">
      <a href="<%= storeBaseUrl %>/carrito" class="relative" style="color: var(--text);">
        <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
          <path stroke-linecap="round" stroke-linejoin="round" d="M3 3h2l.4 2M7 13h10l4-8H5.4M7 13L5.4 5M7 13l-2.3 2.3c-.4.4-.1 1.1.5 1.1H17m0 0a2 2 0 100 4 2 2 0 000-4zm-8 2a2 2 0 100 4 2 2 0 000-4z"/>
        </svg>
        <span class="cart-count absolute -top-2 -right-2 text-white text-[10px] w-4 h-4 rounded-full flex items-center justify-center font-bold" style="background: var(--primary);"><%= cartCount || 0 %></span>
      </a>
    </div>
  </header>

  <!-- MAIN -->
  <main class="flex-1">
    <% if (isHome) { %>
      <%- include('../../partials/_banner_carousel', { heroImages, store, storeBaseUrl }); %>
      <%- include('../../partials/_home_content', { store, storeBaseUrl, categories, products, featured, combos, locals }); %>
    <% } else if (isProduct) { %>
      <div class="max-w-7xl mx-auto px-6 py-14">
        <%- include('../../partials/_product_detail', { product, productImages, variants, volumeDiscounts, category, related, store, storeBaseUrl, locals }); %>
      </div>
    <% } else if (isCart) { %>
      <div class="max-w-4xl mx-auto px-6 py-14">
        <%- include('../../partials/_cart', { cartItems, cartTotal, store, storeBaseUrl, locals }); %>
      </div>
    <% } else if (isCheckout) { %>
      <div class="max-w-4xl mx-auto px-6 py-14">
        <%- include('../../partials/_checkout', { cartItems, cartTotal, store, storeBaseUrl, locals }); %>
      </div>
    <% } else if (isCategory) { %>
      <div class="max-w-7xl mx-auto px-6 py-14">
        <div class="decorative-line pb-6 mb-6">
          <h1 class="text-3xl font-bold"><%= category.name %></h1>
        </div>
        <div class="grid grid-cols-2 md:grid-cols-3 lg:grid-cols-4 gap-5">
          <% products.forEach(p => { %>
            <div class="elegant-card p-0 overflow-hidden">
              <%- include('../../partials/_product_card', { product: p, store, locals }); %>
            </div>
          <% }); %>
        </div>
      </div>
    <% } else if (isShop) { %>
      <div class="max-w-7xl mx-auto px-6 py-14">
        <div class="decorative-line pb-6 mb-6">
          <h1 class="text-3xl font-bold">Shop</h1>
        </div>
        <div class="grid grid-cols-2 md:grid-cols-3 lg:grid-cols-4 gap-5">
          <% (products || []).forEach(p => { %>
            <div class="elegant-card p-0 overflow-hidden">
              <%- include('../../partials/_product_card', { product: p, store, locals }); %>
            </div>
          <% }); %>
        </div>
      </div>
    <% } else { %>
      <%- include('../../partials/_page_content', { page, store, storeBaseUrl, categories, products, featured, combos, locals }); %>
    <% } %>
  </main>

  <!-- FOOTER — 4-column, refined, decorative lines -->
  <footer class="mt-20 pt-14 pb-10 decorative-line" style="background: #1e3a5f;">
    <div class="max-w-7xl mx-auto px-6">
      <div class="grid grid-cols-1 md:grid-cols-4 gap-10">
        <div>
          <div class="decorative-line-accent mb-4" style="border-top-color: #8b2252;"></div>
          <h3 class="font-noto-serif text-lg font-bold text-white mb-2"><%= store.name || 'Store' %></h3>
          <p class="text-xs leading-relaxed" style="color: #c8c0b8;">Timeless quality, classic elegance.</p>
        </div>
        <div>
          <div class="decorative-line-accent mb-4" style="border-top-color: #8b2252;"></div>
          <h3 class="font-noto-serif text-sm font-bold uppercase tracking-widest text-white mb-3">Navigation</h3>
          <div class="flex flex-col gap-2 text-xs" style="color: #c8c0b8;">
            <%- include('../../partials/_nav_links', { store, storeBaseUrl, locals: { navLinkClass: 'hover:text-white transition-colors' } }); %>
          </div>
        </div>
        <div>
          <div class="decorative-line-accent mb-4" style="border-top-color: #8b2252;"></div>
          <h3 class="font-noto-serif text-sm font-bold uppercase tracking-widest text-white mb-3">Service</h3>
          <div class="flex flex-col gap-2 text-xs" style="color: #c8c0b8;">
            <span>Shipping & Returns</span>
            <span>Privacy Policy</span>
            <span>Terms of Service</span>
          </div>
        </div>
        <div>
          <div class="decorative-line-accent mb-4" style="border-top-color: #8b2252;"></div>
          <h3 class="font-noto-serif text-sm font-bold uppercase tracking-widest text-white mb-3">Contact</h3>
          <p class="text-xs" style="color: #c8c0b8;">&copy; <%= new Date().getFullYear() %> <%= store.name || 'Store' %>. All rights reserved.</p>
        </div>
      </div>
    </div>
  </footer>

  <!-- MOBILE MENU -->
  <%- include('../../partials/_mobile_menu', { store, storeBaseUrl, locals: { iconColor: '#1e3a5f' } }); %>

  <script>
    function addToCart(productId, qty) {
      fetch((window.storeBaseUrl || '') + '/api/cart/add', {
        method: 'POST', headers: {'Content-Type':'application/x-www-form-urlencoded'},
        body: 'product_id=' + productId + '&qty=' + (qty||1)
      }).then(r=>r.json()).then(d=>{
        if(d.cartCount!==undefined) document.querySelectorAll('.cart-count').forEach(e=>e.textContent=d.cartCount);
        if(typeof toggleCartDrawer==='function') toggleCartDrawer();
      });
    }
    function addComboToCart(comboId) {
      fetch((window.storeBaseUrl || '') + '/api/combo/add', {
        method: 'POST', headers: {'Content-Type':'application/x-www-form-urlencoded'},
        body: 'combo_id=' + comboId + '&qty=1'
      }).then(r=>r.json()).then(d=>{
        if(d.cartCount!==undefined) document.querySelectorAll('.cart-count').forEach(e=>e.textContent=d.cartCount);
        if(typeof toggleCartDrawer==='function') toggleCartDrawer();
      });
    }
    window.storeBaseUrl = '<%= storeBaseUrl %>';
  </script>
</body>
</html>
