<!DOCTYPE html><html lang="es"><head><meta charset="UTF-8"><meta name="viewport" content="width=device-width,initial-scale=1.0"><title><%= (title||store.name||'') %></title><script src="https://cdn.tailwindcss.com"></script><link rel="preconnect" href="https://fonts.googleapis.com"><link rel="preconnect" href="https://fonts.gstatic.com" crossorigin><% let _t={};try{_t=JSON.parse(store.theme_settings||'{}');}catch(e){}const _c=_t.colors||{};const _f=_t.fonts||{};const _gf={"Inter":"Inter:wght@300;400;500;600;700","Playfair Display":"Playfair+Display:ital,wght@0,400;0,600;0,700;1,400","Lora":"Lora:wght@400;500;600;700","Nunito":"Nunito:wght@300;400;600;700;800","Quicksand":"Quicksand:wght@300;400;500;600;700","Oswald":"Oswald:wght@300;400;500;600;700","Fredoka":"Fredoka:wght@300;400;500;600;700","Noto Serif":"Noto+Serif:wght@400;600;700","Poppins":"Poppins:wght@300;400;500;600;700;800"};const _fb=_f.body||'Inter';const _fh=_f.headings||'Inter';const _fl=[...new Set([_gf[_fb],_gf[_fh]].filter(Boolean))];%><link href="https://fonts.googleapis.com/css2?family=<%=_fl.join('&family=')%>&display=swap" rel="stylesheet"><style>body{font-family:'<%=_fb%>',sans-serif}h1,h2,h3{font-family:'<%=_fh%>',serif;font-weight:600}:root{--primary:<%=_c.btn_primary_bg||'#06b6d4'%>;--bg:<%=_c.body_bg||'#0f172a'%>;--text:<%=_c.body_text||'#cbd5e1'%>;--footer-bg:<%=_c.footer_bg||'#020617'%>;--footer-text:<%=_c.footer_text||'#64748b'%>;--title:<%=_c.title_text||_c.body_text||'#e2e8f0'%>;--label-bg:<%=_c.label_bg||'#06b6d4'%>}body{background:var(--bg);color:var(--text)}h1,h2,h3,h4,h5,h6{color:var(--title)!important}.product-badge{background:var(--label-bg);color:#fff}.section-title{font-family:'<%=_fh%>',serif;font-weight:600}.nav-link{color:#cbd5e1;transition:color .2s}.nav-link:hover{color:var(--primary)}footer{background:var(--footer-bg)!important;color:var(--footer-text)!important}footer a,footer p,footer span{color:var(--footer-text)!important}<%if(store.advanced_css){%><%=store.advanced_css%><%}%></style></head><body>
<body>
<nav class="sticky top-0 z-40" style="background:rgba(15,23,42,0.95);border-bottom:1px solid #1e293b;backdrop-filter:blur(12px)"><div class="max-w-7xl mx-auto px-4"><div class="flex items-center justify-between h-16"><a href="<%=storeBaseUrl || '/'%>" class="flex items-center gap-2 shrink-0"><%if(store.logo){%><img src="<%=store.logo%>" alt="<%=store.name%>" class="h-8 w-auto"><%}else{%><span class="text-xl font-bold" style="color:var(--primary)"><%=store.name%></span><%}%></a><div class="hidden md:flex items-center gap-6 nav-links"><%-include('../../partials/_nav_links',{locals:{navLinkClass:'nav-link text-sm font-medium'}})%></div><button type="button" onclick="toggleCartDrawer()" class="relative p-2"><svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M16 11V7a4 4 0 00-8 0v4M5 9h14l1 12H4L5 9z"/></svg><%if(cartCount>0){%><span class="absolute -top-1 -right-1 w-5 h-5 rounded-full text-xs font-bold text-white flex items-center justify-center" style="background:var(--primary)"><%=cartCount%></span><%}%></button><%-include('../../partials/_mobile_menu',{locals:{}})%></div></div></nav>
<%-include("../../partials/_banner_carousel",{heroImages:typeof heroImages!=='undefined'?heroImages:[],store})%>
<main><%-include('../../partials/_flash',{locals})%>
<%if(page==='home'){%>
<div class="py-12" style="background:#0f172a"><div class="max-w-5xl mx-auto px-4"><div class="rounded-3xl shadow-2xl overflow-hidden" style="background:#1e293b;border:1px solid #334155"><div class="p-8 lg:p-12 text-center"><span class="inline-block px-3 py-1 rounded-full text-xs font-semibold mb-4 product-badge">Bienvenido</span><h1 class="text-4xl lg:text-5xl mb-4" style="font-family:'Inter',serif"><%=store.name%></h1><p class="text-lg mb-6 opacity-80"><%=store.description%></p><div class="flex flex-wrap justify-center gap-3 mb-8"><a href="<%=storeBaseUrl%>/shop" class="btn-primary inline-block px-8 py-3 text-base">Ver Catálogo</a></div><%-include('../../partials/_hero_carousel',{images:typeof heroImages!=='undefined'?heroImages:[],fallback:store.banner,className:'rounded-xl shadow-lg',height:'h-48 lg:h-64'})%></div></div></div></div>
