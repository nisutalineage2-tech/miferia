<!DOCTYPE html><html lang="es"><head><meta charset="UTF-8"><meta name="viewport" content="width=device-width,initial-scale=1.0"><title><%= (title||store.name||'') %></title><script src="https://cdn.tailwindcss.com"></script><link rel="preconnect" href="https://fonts.googleapis.com"><link rel="preconnect" href="https://fonts.gstatic.com" crossorigin><% let _t={};try{_t=JSON.parse(store.theme_settings||'{}');}catch(e){}const _c=_t.colors||{};const _f=_t.fonts||{};const _gf={"Inter":"Inter:wght@300;400;500;600;700","Playfair Display":"Playfair+Display:ital,wght@0,400;0,600;0,700;1,400","Lora":"Lora:wght@400;500;600;700","Nunito":"Nunito:wght@300;400;600;700;800","Quicksand":"Quicksand:wght@300;400;500;600;700","Oswald":"Oswald:wght@300;400;500;600;700","Fredoka":"Fredoka:wght@300;400;500;600;700","Noto Serif":"Noto+Serif:wght@400;600;700","Poppins":"Poppins:wght@300;400;500;600;700;800"};const _fb=_f.body||'Inter';const _fh=_f.headings||'Inter';const _fl=[...new Set([_gf[_fb],_gf[_fh]].filter(Boolean))];%><link href="https://fonts.googleapis.com/css2?family=<%=_fl.join('&family=')%>&display=swap" rel="stylesheet"><style>body{font-family:'<%=_fb%>',sans-serif}h1,h2,h3{font-family:'<%=_fh%>',serif;font-weight:600}:root{--primary:<%=_c.btn_primary_bg||'#22d3ee'%>;--bg:<%=_c.body_bg||'#050505'%>;--text:<%=_c.body_text||'#e5e7eb'%>;--footer-bg:<%=_c.footer_bg||'#000000'%>;--footer-text:<%=_c.footer_text||'#4b5563'%>;--title:<%=_c.title_text||_c.body_text||'#e5e7eb'%>;--label-bg:<%=_c.label_bg||'#22d3ee'%>}body{background:var(--bg);color:var(--text)}h1,h2,h3,h4,h5,h6{color:var(--title)!important}.product-badge{background:var(--label-bg);color:#fff}.section-title{font-family:'<%=_fh%>',serif;font-weight:600}.nav-link{color:#e5e7eb;transition:color .2s}.nav-link:hover{color:var(--primary)}footer{background:var(--footer-bg)!important;color:var(--footer-text)!important}footer a,footer p,footer span{color:var(--footer-text)!important}nav.sticky{background:transparent!important;border-bottom-color:transparent!important}<%if(store.advanced_css){%><%=store.advanced_css%><%}%></style></head><body>
<body>
<nav class="absolute top-0 left-0 right-0 z-50"><div class="max-w-7xl mx-auto px-4"><div class="flex items-center justify-between h-16"><a href="<%=storeBaseUrl || '/'%>" class="flex items-center gap-2 shrink-0"><%if(store.logo){%><img src="<%=store.logo%>" alt="<%=store.name%>" class="h-8 w-auto"><%}else{%><span class="text-xl font-bold" style="color:var(--primary)"><%=store.name%></span><%}%></a><div class="hidden md:flex items-center gap-6 nav-links"><%-include('../../partials/_nav_links',{locals:{navLinkClass:'text-sm font-medium text-white/80 hover:text-white transition-colors'}})%></div><button type="button" onclick="toggleCartDrawer()" class="relative p-2"><svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M16 11V7a4 4 0 00-8 0v4M5 9h14l1 12H4L5 9z"/></svg><%if(cartCount>0){%><span class="absolute -top-1 -right-1 w-5 h-5 rounded-full text-xs font-bold text-white flex items-center justify-center" style="background:var(--primary)"><%=cartCount%></span><%}%></button><%-include('../../partials/_mobile_menu',{locals:{}})%></div></div></nav>
<%-include("../../partials/_banner_carousel",{heroImages:typeof heroImages!=='undefined'?heroImages:[],store})%>
<main><%-include('../../partials/_flash',{locals})%>
<%if(page==='home'){%>
<div class="relative" style="background:linear-gradient(135deg,rgb(20,20,20),#050505,rgb(0,0,0))"><div class="max-w-7xl mx-auto px-4 py-20 lg:py-28 text-center"><div class="max-w-4xl mx-auto bg-white/10 backdrop-blur-md rounded-3xl p-8 lg:p-12 border border-white/20 shadow-2xl"><span class="inline-block px-4 py-1.5 rounded-full bg-white/80 text-xs font-semibold mb-4">Bienvenido</span><h1 class="text-4xl lg:text-6xl mb-4 leading-tight" style="font-family:'Inter',serif"><%=store.name%></h1><p class="text-lg mb-8 opacity-90 max-w-2xl mx-auto"><%=store.description%></p><div class="flex flex-wrap justify-center gap-3"><a href="<%=storeBaseUrl%>/shop" class="btn-primary inline-block px-8 py-3 text-base">Ver Catálogo</a><a href="<%=storeBaseUrl%>/tienda" class="inline-block px-8 py-3 rounded-lg text-sm font-semibold border-2 border-white/40 text-white transition-all hover:bg-white/10">Explorar</a></div></div></div></div>
<div class="py-16" style="background:linear-gradient(135deg,#22d3ee,rgb(4,181,208))"><div class="max-w-4xl mx-auto px-4 text-center"><span class="inline-block px-3 py-1 rounded-full text-xs font-semibold mb-4" style="background:rgba(255,255,255,0.2);color:#fff">OFERTA POR TIEMPO LIMITADO</span><h2 class="text-3xl lg:text-5xl font-bold mb-4" style="color:#fff;font-family:'Inter',serif">Hasta 50% OFF</h2><p class="text-lg mb-8 opacity-90" style="color:#fff">En toda la tienda. No esperes más, el tiempo se acaba!</p><div class="flex justify-center gap-4 mb-8" id="countdown"><%['Días','Horas','Min','Seg'].forEach((l,i)=>{if(i===0){%><div class="bg-white/15 backdrop-blur rounded-xl p-4 min-w-[80px]"><div class="text-3xl font-bold text-white" id="cd-<%=i%>">00</div><div class="text-xs text-white/70 mt-1"><%=l%></div></div><%}else{%><div class="bg-white/15 backdrop-blur rounded-xl p-4 min-w-[80px]"><div class="text-3xl font-bold text-white" id="cd-<%=i%>">00</div><div class="text-xs text-white/70 mt-1"><%=l%></div></div><%}})%></div><a href="<%=storeBaseUrl%>/shop" class="inline-block px-10 py-4 rounded-xl font-bold text-lg transition-all hover:scale-105" style="background:#fff;color:#22d3ee">Aprovechar Oferta</a></div><script>!function(){const t=7*24*60*60*1000;function r(){const r=Math.max(0,t-(Date.now()-s)),n=Math.floor(r/864e5),a=Math.floor((r%864e5)/36e5),o=Math.floor((r%36e5)/6e4),i=Math.floor((r%6e4)/1e3);document.getElementById('cd-0')&&(document.getElementById('cd-0').textContent=String(n).padStart(2,'0')),document.getElementById('cd-1')&&(document.getElementById('cd-1').textContent=String(a).padStart(2,'0')),document.getElementById('cd-2')&&(document.getElementById('cd-2').textContent=String(o).padStart(2,'0')),document.getElementById('cd-3')&&(document.getElementById('cd-3').textContent=String(i).padStart(2,'0'))}const s=Date.now();r(),setInterval(r,1e3)}();</script></div>
<div class="py-12 lg:py-16" style="background:rgb(51,61,75)"><div class="max-w-7xl mx-auto px-4"><div class="grid grid-cols-2 md:grid-cols-4 gap-8 text-center"><div><span class="text-3xl font-bold" style="color:#22d3ee;font-family:'Inter',serif">10K+</span><p class="text-sm mt-1 opacity-70">Clientes felices</p></div><div><span class="text-3xl font-bold" style="color:#22d3ee;font-family:'Inter',serif">500+</span><p class="text-sm mt-1 opacity-70">Productos</p></div><div><span class="text-3xl font-bold" style="color:#22d3ee;font-family:'Inter',serif">99%</span><p class="text-sm mt-1 opacity-70">Satisfacción</p></div><div><span class="text-3xl font-bold" style="color:#22d3ee;font-family:'Inter',serif">24/7</span><p class="text-sm mt-1 opacity-70">Soporte</p></div></div></div></div>
<div class="py-12 lg:py-16" style="background:#22d3ee"><div class="max-w-3xl mx-auto px-4 text-center"><h2 class="text-2xl font-bold mb-3" style="color:#fff;font-family:'Inter',serif">No te pierdas nada</h2><p class="mb-6 opacity-90" style="color:#fff">Suscribite y recibí 10% OFF en tu primera compra + novedades exclusivas.</p><form class="flex flex-col sm:flex-row gap-3 max-w-md mx-auto" onsubmit="event.preventDefault();alert('Gracias por suscribirte!')"><input type="email" placeholder="tu@email.com" class="flex-1 px-4 py-3 rounded-lg border-0 text-sm" style="background:rgba(255,255,255,0.9);color:#111"><button type="submit" class="px-6 py-3 rounded-lg text-sm font-semibold whitespace-nowrap" style="background:#111;color:#fff">Quiero mi 10% OFF</button></form></div></div>
<div class="max-w-7xl mx-auto px-4 py-8 lg:py-12">
<%if(featured.length>0){%><h2 class="text-2xl font-bold mb-6 section-title">Destacados</h2>
<div class="grid grid-cols-2 md:grid-cols-3 lg:grid-cols-3 gap-4 lg:gap-6 mb-12">
<%featured.forEach(p=>{%><%-include('../../partials/_product_card',{product:p,store,locals})%><%})%></div><%}%>
<h2 class="text-2xl font-bold mb-6 section-title">Todos los Productos</h2>
<%if(products.length>0){%><div class="grid grid-cols-2 md:grid-cols-3 lg:grid-cols-3 gap-4 lg:gap-6">
<%products.forEach(p=>{%><%-include('../../partials/_product_card',{product:p,store,locals})%><%})%></div>
<%}else{%><div class="text-center py-16 opacity-50"><p>Proximamente estaremos agregando nuestros productos.</p></div><%}%>
<%if(combos.length>0){%><h2 class="text-2xl font-bold mb-6 mt-12 section-title">Combos Especiales</h2>
<div class="grid md:grid-cols-2 lg:grid-cols-3 gap-6">
<%combos.forEach(combo=>{%><div class="p-6 rounded-2xl border-2 border-dashed" style="border-color:var(--primary)"><h3 class="text-lg font-bold"><%=combo.name%></h3><p class="text-sm opacity-70 mb-3"><%=combo.description%></p><p class="text-2xl font-bold" style="color:var(--primary)">$$<%=combo.price.toFixed(2)%></p>
<button onclick="addComboToCart('<%=combo.id%>')" class="mt-3 w-full px-4 py-2.5 text-sm font-semibold text-white transition-all btn-primary">Agregar al Carrito</button></div><%})%></div><%}%>
</div>
<%}else if(page==='category'){%><div class="max-w-7xl mx-auto px-4 py-8"><div class="mb-6"><a href="<%=storeBaseUrl || '/'%>" class="text-sm opacity-60 hover:opacity-100">← Todos los productos</a><h1 class="text-3xl font-bold mt-2 section-title"><%=category.name%></h1><%if(category.description){%><p class="opacity-70 mt-1"><%=category.description%></p><%}%></div>
<%if(products.length>0){%><div class="grid grid-cols-2 md:grid-cols-3 lg:grid-cols-3 gap-4 lg:gap-6">
<%products.forEach(p=>{%><%-include('../../partials/_product_card',{product:p,store,locals})%><%})%></div><%}else{%><div class="text-center py-16 opacity-60"><p>No hay productos en esta categoria todavia.</p></div><%}%></div>
<%}else if(page==='product'){%><%-include('../../partials/_product_detail',{store,product,variants,productImages,categories,related,cartCount,cartTotal,locals})%>
<%}else if(page==='cart'){%><%-include('../../partials/_cart',{store,categories,cartItems,cartCount,cartTotal,locals})%>
<%}else if(page==='checkout'){%><%-include('../../partials/_checkout',{store,categories,cartItems,cartCount,cartTotal,locals})%>
<%}else if(['shop','subscriptions','about','contact','login','register','account'].includes(page)){%><%-include('../../partials/_page_content',{page,store,categories,products,featured,combos,cartItems,cartCount,cartTotal,query:typeof query!=='undefined'?query:{},priceRange:typeof priceRange!=='undefined'?priceRange:null,filterSettings:typeof filterSettings!=='undefined'?filterSettings:{},filterData:typeof filterData!=='undefined'?filterData:{},error:typeof error!=='undefined'?error:null,msg:typeof msg!=='undefined'?msg:null,customer:typeof customer!=='undefined'?customer:null,orders:typeof orders!=='undefined'?orders:null})%>
<%}%></main>
<footer class="mt-16"><div class="max-w-7xl mx-auto px-4 py-8"><div class="text-center text-sm opacity-50">&copy; 2026 <%=store.name%>. Powered by TuFerIA.</div></div></footer>
<style>.product-card{background:#111111;border:1px solid #1f2937;border-radius:0.5rem;box-shadow:0 10px 15px -3px rgba(34,211,238,0.15);transition:.3s;overflow:hidden}.product-card:hover{transform:translateY(-4px);border-color:var(--primary)}.btn-primary{background:var(--primary);color:#fff;border-radius:.5rem;font-weight:600;padding:.625rem 1.25rem;transition:.2s}.btn-primary:hover{opacity:.9}</style>
<script>
async function addToCart(pid,vid,qty){const r=await fetch('/api/cart/add',{method:'POST',headers:{'Content-Type':'application/json'},body:JSON.stringify({store_id:'<%=store.id%>',product_id:pid,variant_id:vid,quantity:qty||1})});const d=await r.json();if(d.success)location.reload()}
async function addComboToCart(cid){const r=await fetch('/api/cart/add',{method:'POST',headers:{'Content-Type':'application/json'},body:JSON.stringify({store_id:'<%=store.id%>',combo_id:cid,quantity:1})});const d=await r.json();if(d.success)location.reload()}
</script>
<%-include('../../partials/_cart_drawer',{store,cartItems,cartCount,cartTotal,locals})%>
<%-include('../../partials/_order_success',{order:typeof order!=='undefined'?order:null,whatsappLink:typeof whatsappLink!=='undefined'?whatsappLink:null})%>
</body></html>