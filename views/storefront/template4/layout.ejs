<% const t = store.theme_settings ? JSON.parse(store.theme_settings) : {}; const c = t.colors || {}; %>
<% const isHome = !page || page === 'home'; %>
<% const isShop = page === 'shop'; %>
<% const isProduct = page === 'product'; %>
<% const isCart = page === 'cart'; %>
<% const isCheckout = page === 'checkout'; %>
<% const isCategory = page === 'category'; %>
<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= store.name || 'Store' %><%= typeof pageTitle !== 'undefined' ? ' — ' + pageTitle : '' %></title>
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Nunito:wght@300;400;500;600;700&display=swap" rel="stylesheet">
  <script src="https://cdn.tailwindcss.com"></script>
  <script>
    tailwind.config = {
      theme: {
        extend: {
          fontFamily: { nunito: ['Nunito', 'sans-serif'] },
          colors: {
            primary: 'var(--primary)',
            sage: '#5a7247',
            cream: '#faf7f2',
            earth: '#6b5b47',
            bg: 'var(--bg)',
            text: 'var(--text)',
          }
        }
      }
    }
  </script>
  <style>
    :root {
      --primary: <%= c.btn_primary_bg || '#5a7247' %>;
      --bg: <%= c.page_bg || '#faf7f2' %>;
      --text: <%= c.text || '#6b5b47' %>;
      --footer-bg: <%= c.footer_bg || '#5a7247' %>;
      --footer-text: <%= c.footer_text || '#f0ebe3' %>;
      --title: <%= c.heading_color || '#3d4a32' %>;
      --label-bg: <%= c.label_bg || '#e8e0d0' %>;
    }
    * { font-family: 'Nunito', sans-serif; }
    h1,h2,h3,h4,h5,h6 { color: var(--title); }
    body { background: var(--bg); color: var(--text); }
    .organic-card {
      border-radius: 9999px; border: 1px solid #d4c9b8;
      box-shadow: 0 4px 15px rgba(107,91,71,0.06);
      transition: box-shadow 0.3s, transform 0.3s;
    }
    .organic-card:hover { box-shadow: 0 8px 25px rgba(90,114,71,0.12); transform: translateY(-2px); }
    .pill-btn {
      border-radius: 9999px; padding: 0.5rem 1.5rem;
      background: var(--primary); color: #fff; font-weight: 600;
      transition: opacity 0.2s;
    }
    .pill-btn:hover { opacity: 0.85; }
    .nav-pill { border-radius: 9999px; background: #fff; border: 1px solid #d4c9b8; }
  </style>
</head>
<body class="antialiased min-h-screen flex flex-col">
  <%- include('../../partials/_flash', { locals }); %>
  <%- include('../../partials/_cart_drawer', { store, storeBaseUrl }); %>
  <%- include('../../partials/_order_success', { locals }); %>

  <!-- NAV -->
  <nav class="sticky top-0 z-40 px-4 py-3">
    <div class="max-w-6xl mx-auto nav-pill px-6 py-3 flex items-center justify-between bg-white/90 backdrop-blur-md">
      <a href="<%= storeBaseUrl || '/' %>" class="text-lg font-bold" style="color: var(--title)">
        <%= store.name || 'Store' %>
      </a>
      <div class="hidden md:flex items-center gap-6 text-sm font-medium" style="color: var(--text)">
        <%- include('../../partials/_nav_links', { store, storeBaseUrl, locals: { navLinkClass: 'hover:text-[#5a7247] transition-colors' } }); %>
      </div>
      <div class="flex items-center gap-4">
        <a href="<%= storeBaseUrl %>/carrito" class="relative" style="color: var(--text)">
          <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M3 3h2l.4 2M7 13h10l4-8H5.4M7 13L5.4 5M7 13l-2.3 2.3c-.4.4-.1 1.1.5 1.1H17m0 0a2 2 0 100 4 2 2 0 000-4zm-8 2a2 2 0 100 4 2 2 0 000-4z"/>
          </svg>
          <span class="cart-count absolute -top-2 -right-2 bg-[#5a7247] text-white text-[10px] w-4 h-4 rounded-full flex items-center justify-center"><%= cartCount || 0 %></span>
        </a>
      </div>
    </div>
  </nav>

  <!-- MAIN -->
  <main class="flex-1">
    <% if (isHome) { %>
      <%- include('../../partials/_banner_carousel', { heroImages, store, storeBaseUrl }); %>
      <%- include('../../partials/_home_content', { store, storeBaseUrl, categories, products, featured, combos, locals }); %>
    <% } else if (isProduct) { %>
      <div class="max-w-6xl mx-auto px-6 py-12">
        <%- include('../../partials/_product_detail', { product, productImages, variants, volumeDiscounts, category, related, store, storeBaseUrl, locals }); %>
      </div>
    <% } else if (isCart) { %>
      <div class="max-w-4xl mx-auto px-6 py-12">
        <%- include('../../partials/_cart', { cartItems, cartTotal, store, storeBaseUrl, locals }); %>
      </div>
    <% } else if (isCheckout) { %>
      <div class="max-w-4xl mx-auto px-6 py-12">
        <%- include('../../partials/_checkout', { cartItems, cartTotal, store, storeBaseUrl, locals }); %>
      </div>
    <% } else if (isCategory) { %>
      <div class="max-w-6xl mx-auto px-6 py-12">
        <h1 class="text-2xl font-bold mb-6" style="color: var(--title)"><%= category.name %></h1>
        <div class="grid grid-cols-2 md:grid-cols-3 lg:grid-cols-4 gap-6">
          <% products.forEach(p => { %>
            <div class="organic-card overflow-hidden">
              <%- include('../../partials/_product_card', { product: p, store, locals }); %>
            </div>
          <% }); %>
        </div>
      </div>
    <% } else if (isShop) { %>
      <div class="max-w-6xl mx-auto px-6 py-12">
        <h1 class="text-2xl font-bold mb-6" style="color: var(--title)">Shop</h1>
        <div class="grid grid-cols-2 md:grid-cols-3 lg:grid-cols-4 gap-6">
          <% (products || []).forEach(p => { %>
            <div class="organic-card overflow-hidden">
              <%- include('../../partials/_product_card', { product: p, store, locals }); %>
            </div>
          <% }); %>
        </div>
      </div>
    <% } else { %>
      <%- include('../../partials/_page_content', { page, store, storeBaseUrl, categories, products, featured, combos, locals }); %>
    <% } %>
  </main>

  <!-- FOOTER -->
  <footer class="mt-20 py-14 rounded-t-3xl" style="background: var(--footer-bg)">
    <div class="max-w-6xl mx-auto px-6 text-center">
      <h3 class="text-xl font-bold mb-4" style="color: #fff"><%= store.name || 'Store' %></h3>
      <div class="flex justify-center gap-6 text-sm mb-6" style="color: var(--footer-text)">
        <%- include('../../partials/_nav_links', { store, storeBaseUrl, locals: { navLinkClass: 'hover:text-white transition-colors' } }); %>
      </div>
      <p class="text-xs" style="color: var(--footer-text)">&copy; <%= new Date().getFullYear() %> <%= store.name || 'Store' %>. All rights reserved.</p>
    </div>
  </footer>

  <!-- MOBILE MENU -->
  <%- include('../../partials/_mobile_menu', { store, storeBaseUrl, locals: { iconColor: '#5a7247' } }); %>

  <script>
    function addToCart(productId, qty) {
      fetch((window.storeBaseUrl || '') + '/api/cart/add', {
        method: 'POST', headers: {'Content-Type':'application/x-www-form-urlencoded'},
        body: 'product_id=' + productId + '&qty=' + (qty||1)
      }).then(r=>r.json()).then(d=>{
        if(d.cartCount!==undefined) document.querySelectorAll('.cart-count').forEach(e=>e.textContent=d.cartCount);
        if(typeof toggleCartDrawer==='function') toggleCartDrawer();
      });
    }
    function addComboToCart(comboId) {
      fetch((window.storeBaseUrl || '') + '/api/combo/add', {
        method: 'POST', headers: {'Content-Type':'application/x-www-form-urlencoded'},
        body: 'combo_id=' + comboId + '&qty=1'
      }).then(r=>r.json()).then(d=>{
        if(d.cartCount!==undefined) document.querySelectorAll('.cart-count').forEach(e=>e.textContent=d.cartCount);
        if(typeof toggleCartDrawer==='function') toggleCartDrawer();
      });
    }
    window.storeBaseUrl = '<%= storeBaseUrl %>';
  </script>
</body>
</html>
