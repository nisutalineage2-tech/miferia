<%
const ts = store.theme_settings ? (typeof store.theme_settings === 'string' ? JSON.parse(store.theme_settings) : store.theme_settings) : {};
const gfMap = { 'Nunito': 'Nunito:wght@300;400;500;600;700;800&display=swap' };
const gf = gfMap[ts.heading_font] || 'Nunito:wght@300;400;500;600;700;800&display=swap';
const hFont = ts.heading_font || 'Nunito';
const bFont = ts.body_font || 'Nunito';
const isHome = !page || page === 'home';
const isShop = page === 'shop';
const isProduct = page === 'product';
const isCart = page === 'cart';
const isCheckout = page === 'checkout';
%><!DOCTYPE html>
<html lang="es">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width,initial-scale=1.0">
<meta name="description" content="<%=store.description%>">
<title><%=store.name%><%=page&&page!=='home'?' | '+page:''%></title>
<script src="https://cdn.tailwindcss.com"></script>
<link rel="preconnect" href="https://fonts.googleapis.com">
<link href="https://fonts.googleapis.com/css2?family=<%=gf%>&display=swap" rel="stylesheet">
<script>tailwind.config={theme:{extend:{fontFamily:{sans:['Nunito','sans-serif'],body:['Nunito','sans-serif']}}}}</script>
<style>
:root {
  --primary: <%=store.primary_color||'#5a7247'%>;
  --bg: <%=store.bg_color||'#faf7f2'%>;
  --text: <%=store.text_color||'#5c4a3a'%>;
  --footer-bg: <%=store.footer_bg||'#3d4f30'%>;
  --footer-text: <%=store.footer_text||'#e8e0d6'%>;
  --title: <%=store.title_color||'#3d4f30'%>;
  --label-bg: <%=store.label_bg||'#e8e0d6'%>;
}
*{margin:0;padding:0;box-sizing:border-box}
body{font-family:'Nunito',sans-serif;background:var(--bg);color:var(--text);font-weight:400;line-height:1.8}
h1,h2,h3,h4,h5,h6{font-family:'Nunito',sans-serif;font-weight:700;color:var(--title);letter-spacing:-0.01em}
.section-title{font-size:1.75rem;font-weight:700;text-align:center;margin-bottom:1.5rem;color:var(--title)}
.btn-primary{display:inline-flex;align-items:center;justify-content:center;font-family:'Nunito',sans-serif;font-weight:700;font-size:0.9rem;padding:1rem 2.5rem;background:var(--primary);color:#fff;border-radius:999px;transition:all 0.3s ease}
.btn-primary:hover{transform:translateY(-2px);box-shadow:0 8px 25px rgba(90,114,71,0.3)}
.product-card{background:#fff!important;border-radius:999px!important;overflow:hidden;box-shadow:0 4px 20px rgba(0,0,0,0.04)!important;border:none!important;transition:all 0.4s ease}
.product-card:hover{transform:translateY(-4px);box-shadow:0 12px 40px rgba(0,0,0,0.08)!important}
.product-card .aspect-square{border-radius:999px 999px 0 0}
.product-card h3{font-weight:600;font-size:0.9rem}
.product-card .p-3{padding:1rem 1.25rem!important}
.fresh-hero{background:linear-gradient(135deg,var(--primary) 0%,#e8f0e0 50%,var(--bg) 100%);position:relative;overflow:hidden}
.fresh-hero::before{content:'';position:absolute;top:-50%;left:-50%;width:200%;height:200%;background:radial-gradient(circle at 30% 40%,rgba(90,114,71,0.08) 0%,transparent 50%);pointer-events:none}
.rounded-card{background:rgba(255,255,255,0.7);backdrop-filter:blur(10px);border-radius:999px}
.leaf-deco{position:absolute;width:120px;height:120px;border-radius:50%;background:radial-gradient(circle,var(--primary) 0%,transparent 70%);opacity:0.08;pointer-events:none}
.nav-pill{background:rgba(90,114,71,0.08);backdrop-filter:blur(8px);border:1px solid rgba(90,114,71,0.1);border-radius:999px}
.organic-border{border:2px solid rgba(90,114,71,0.12);border-radius:999px}
@media(min-width:768px){.product-card{border-radius:40px!important}}
</style>
</head>
<body>
<%-include('../../partials/_flash',{order:locals.order||null})%>

<!-- Fresh Nav: pill-shaped -->
<nav class="sticky top-4 z-50 px-2 lg:px-8">
  <div class="nav-pill max-w-5xl mx-auto flex items-center justify-between h-14 lg:h-16 px-6">
    <a href="<%=storeBaseUrl%>" class="text-base lg:text-lg font-bold" style="color:var(--title);text-decoration:none"><%=store.name%></a>
    <div class="hidden md:flex items-center gap-6">
      <%- include('../../partials/_nav_links', {locals:{navLinkClass:'text-sm font-medium opacity-70 hover:opacity-100 transition-opacity'}}); %>
    </div>
    <div class="flex items-center gap-2">
      <button onclick="toggleCartDrawer()" class="p-2 relative">
        <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24" style="color:var(--title)"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M2.25 3h1.386c.51 0 .955.343 1.087.835l.383 1.437M7.5 14.25a3 3 0 00-3 3h15.75m-12.75-3h11.218c1.121-2.3 2.1-4.684 2.924-7.138a60.114 60.114 0 00-16.536-1.84M7.5 14.25L5.106 5.272"/></svg>
        <% if (cartCount > 0) { %><span class="absolute -top-0 -right-0 w-5 h-5 rounded-full flex items-center justify-center text-[10px] font-bold text-white" style="background:var(--primary)"><%= cartCount %></span><% } %>
      </button>
      <%- include('../../partials/_mobile_menu', { locals: { iconColor: 'text-gray-600' } }); %>
    </div>
  </div>
</nav>

<main>
  <% if (isHome) { %>
    <!-- Fresh Hero -->
    <div class="fresh-hero pt-10 pb-0">
      <div class="leaf-deco" style="top:10%;right:5%"></div>
      <div class="leaf-deco" style="bottom:20%;left:10%;width:80px;height:80px"></div>
      <div class="max-w-4xl mx-auto px-6 py-16 lg:py-24 text-center relative z-10">
        <h1 class="text-5xl lg:text-7xl font-extrabold mb-4" style="color:var(--title);line-height:1.1"><%=store.name%></h1>
        <p class="text-lg lg:text-xl mb-8 max-w-xl mx-auto opacity-70 font-light"><%=store.description%></div>
        <a href="<%=storeBaseUrl%>/tienda" class="btn-primary">Explorar productos</a>
      </div>
      <svg class="w-full h-auto" viewBox="0 0 1200 80" preserveAspectRatio="none" style="display:block">
        <path d="M0,40 C300,80 600,0 1200,40 L1200,80 L0,80 Z" fill="var(--bg)"></path>
      </svg>
    </div>
    <%- include('../../partials/_banner_carousel', { heroImages, store, storeBaseUrl }); %>
    <%- include('../../partials/_home_content', { store, storeBaseUrl, categories, products, featured, combos, locals }); %>
  <% } else if (isCategory) { %>
    <div class="max-w-7xl mx-auto px-4 lg:px-8 py-12">
      <h1 class="text-3xl font-bold mb-8" style="color:var(--title)"><%= category.name %></h1>
      <div class="grid grid-cols-2 lg:grid-cols-4 gap-6 lg:gap-8">
        <% products.forEach(p => { %>
          <%- include('../../partials/_product_card', { product: p, store, locals }); %>
        <% }); %>
      </div>
    </div>
  <% } else if (isProduct) { %>
    <%- include('../../partials/_product_detail', { product, productImages, category, variants, volumeDiscounts, related, store, storeBaseUrl, locals }); %>
  <% } else if (isCart) { %>
    <%- include('../../partials/_cart', { cartItems, cartTotal, store, storeBaseUrl, locals }); %>
  <% } else if (isCheckout) { %>
    <%- include('../../partials/_checkout', { cartItems, cartTotal, store, storeBaseUrl, locals }); %>
  <% } else { %>
    <%- include('../../partials/_page_content', { page, store, storeBaseUrl, categories, products, featured, combos, query, priceRange, filterData, customer, orders, error, msg, locals }); %>
  <% } %>
</main>

<!-- Fresh Footer -->
<footer style="background:var(--footer-bg);color:var(--footer-text)">
  <svg class="w-full h-8 lg:h-16" viewBox="0 0 1200 80" preserveAspectRatio="none" style="display:block;margin-top:-2px">
    <path d="M0,40 C200,80 400,20 600,40 C800,60 1000,10 1200,40 L1200,80 L0,80 Z" fill="var(--bg)"></path>
  </svg>
  <div class="max-w-7xl mx-auto px-4 lg:px-8 py-10 lg:py-8">
    <div class="grid lg:grid-cols-3 gap-10">
      <div>
        <h3 class="text-lg font-bold mb-4" style="color:var(--title)"><%=store.name%></h3>
        <p class="text-sm opacity-70 font-light"><%=store.description%></p>
      </div>
      <div>
        <h4 class="text-sm font-bold uppercase tracking-wider mb-4 opacity-60">Navegar</h4>
        <div class="flex flex-col gap-2">
          <%- include('../../partials/_nav_links', {locals:{navLinkClass:'text-sm opacity-80 hover:opacity-100 transition-opacity text-white'}}); %>
        </div>
        <a href="<%=storeBaseUrl%>" class="text-sm opacity-80 hover:opacity-100 transition-opacity mt-2 inline-block">Inicio</a>
      </div>
      <div>
        <h4 class="text-sm font-bold uppercase tracking-wider mb-4 opacity-60">Contacto</h4>
        <div class="flex flex-col gap-2">
          <% if (store.whatsapp) { %><a href="https://wa.me/<%=store.whatsapp%>" class="text-sm opacity-80 hover:opacity-100 transition-opacity text-white">WhatsApp</a><% } %>
          <% if (store.instagram) { %><a href="https://instagram.com/<%=store.instagram.replace('@','')%>" class="text-sm opacity-80 hover:opacity-100 transition-opacity text-white">Instagram: @<%=store.instagram.replace('@','')%></a><% } %>
        </div>
      </div>
    </div>
    <div class="mt-8 pt-6 text-center text-xs opacity-40 font-light" style="border-top:1px solid rgba(232,224,214,0.15)">
      &copy; <%= new Date().getFullYear() %> <%= store.name %> - Con cariño
    </div>
  </div>
</footer>

<script>
async function addToCart(productId, variantId, qty) {
  const res = await fetch('/api/cart/add', {
    method: 'POST',
    headers: { 'Content-Type': 'application/json' },
    body: JSON.stringify({ product_id: productId, variant_id: variantId || null, quantity: qty || 1, store_id: '<%= store.id %>' })
  });
  const data = await res.json();
  if (data.success) { toggleCartDrawer(); } else { alert(data.error || 'Error'); }
}
async function addComboToCart(comboId) {
  const res = await fetch('/api/cart/add-combo', {
    method: 'POST',
    headers: { 'Content-Type': 'application/json' },
    body: JSON.stringify({ combo_id: comboId, store_id: '<%= store.id %>' })
  });
  const data = await res.json();
  if (data.success) { toggleCartDrawer(); } else { alert(data.error || 'Error'); }
}
</script>

<%- include('../../partials/_cart_drawer', { cartItems, cartTotal, store, storeBaseUrl }); %>
<%- include('../../partials/_order_success', { order: locals.order, whatsappLink: locals.whatsappLink, store, storeBaseUrl, locals }); %>
</body>
</html>
