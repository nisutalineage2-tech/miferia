<!DOCTYPE html>
<html lang="es">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= (title || store.name || '') %></title>
  <script src="https://cdn.tailwindcss.com"></script>
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&family=Space+Grotesk:wght@400;500;600;700&family=JetBrains+Mono:wght@400;500&display=swap" rel="stylesheet">
  <style>
    <% let _col4 = {}; let hdr = {}; try { const _t4 = JSON.parse(store.theme_settings || '{}'); _col4 = _t4.colors || {}; hdr = _t4.header || {}; } catch(e) {} %>
    body { font-family: 'Inter', sans-serif; background: <%= _col4.body_bg || '#090a0f' %>; color: <%= _col4.body_text || '#e2e8f0' %>; }
    h1,h2,h3 { font-family: 'Space Grotesk', sans-serif; font-weight: 700; letter-spacing: -0.02em; }
    .mono { font-family: 'JetBrains Mono', monospace; }
    :root { --primary: <%= _col4.btn_primary_bg || store.primary_color || '#06b6d4' %>; --accent: <%= _col4.btn_secondary_bg || store.accent_color || '#3b82f6' %>; --footer-bg: <%= _col4.footer_bg || '#0f0f1a' %>; --footer-text: <%= _col4.footer_text || '#9ca3af' %>; }
    .product-card { background: #111827; border: 1px solid #1f2937; transition: all 0.3s cubic-bezier(0.4,0,0.2,1); border-radius: 12px; overflow: hidden; }
    .product-card:hover { transform: translateY(-6px); border-color: #06b6d4; box-shadow: 0 20px 60px rgba(6,182,212,0.15); }
    .btn-primary { background: linear-gradient(135deg, #06b6d4, #3b82f6); color: #fff; border-radius: 8px; font-weight: 600; }
    .section-title { font-family: 'Space Grotesk', sans-serif; font-weight: 700; letter-spacing: -0.02em; }
    .tech-glow { text-shadow: 0 0 40px rgba(6,182,212,0.3); }
  </style>
</head>
<body>
  <!-- Announcement Bar -->
  <% if (hdr.announcement_show) { %>
    <div class="announcement-bar text-center py-2.5 text-sm font-medium" style="background-color: <%= hdr.announcement_bg || '#4f46e5' %>; color: #fff;">
      <%= hdr.announcement_text || '¡Bienvenido!' %>
      <% if (hdr.announcement_link) { %>
        <a href="<%= hdr.announcement_link %>" class="underline ml-1 opacity-80 hover:opacity-100">Ver más</a>
      <% } %>
    </div>
  <% } %>

  <!-- Nav -->
  <nav class="sticky top-0 z-50 bg-[#090a0f]/90 backdrop-blur-xl border-b border-cyan-900/30">
    <div class="max-w-7xl mx-auto px-4 lg:px-8">
      <div class="flex items-center justify-between h-16 lg:h-20">
        <a href="/<%= store.slug %>" class="flex items-center gap-3">
          <% if (store.logo) { %><img src="<%= store.logo %>" alt="<%= store.name %>" class="h-8 lg:h-10 w-auto"><% } else { %><span class="text-2xl font-black text-white tech-glow"><%= store.name %></span><% } %>
        </a>
        <div class="hidden lg:flex items-center gap-8">
          <%- include('../../partials/_nav_links', { locals: { navLinkClass: 'text-sm font-medium text-gray-400 hover:text-cyan-400 transition-colors' } }) %>
        </div>
        <div class="flex items-center gap-4">
          <a href="/<%= store.slug %>/carrito" class="relative p-2">
            <svg class="w-6 h-6" style="color: var(--menu-link);" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M16 11V7a4 4 0 00-8 0v4M5 9h14l1 12H4L5 9z"/>
            </svg>
            <% if (cartCount > 0) { %>
              <span class="absolute -top-1 -right-1 w-5 h-5 rounded-full text-xs font-bold text-white flex items-center justify-center" style="background: linear-gradient(135deg, var(--primary), var(--accent));"><%= cartCount %></span>
            <% } %>
          </a>
        
            <%- include('../../partials/_mobile_menu', { locals: { iconColor: 'text-cyan-400' } }) %>
</div>
      </div>
    </div>
  </nav>

  <main>
    <%- include('../../partials/_flash', { locals }); %>
    <% if (page === 'home') { %>
      <% const _tc4 = (() => { try { return JSON.parse(store.theme_settings || '{}'); } catch(e) { return {}; } })(); const hp = _tc4.homepage || {}; const sectionsOrder = hp.sections_order || ['hero', 'categories', 'featured', 'products', 'combos', 'testimonials', 'newsletter', 'contact']; %>
      <!-- Sections loop -->
      <% sectionsOrder.forEach(section => { %>
        <% if (section === 'hero') { %>
          <!-- HERO -->
          <section class="relative min-h-[60vh] lg:min-h-[80vh] flex items-center overflow-hidden group">
            <div class="absolute inset-0">
              <%- include('../../partials/_hero_carousel', { images: heroImages, fallback: store.banner, className: 'w-full h-full', height: 'h-full' }); %>
              <div class="absolute inset-0" style="background: linear-gradient(135deg, rgba(10,10,15,0.95) 0%, rgba(10,10,15,0.6) 50%, transparent 100%);"></div>
            </div>
            <div class="relative max-w-7xl mx-auto px-4 lg:px-8 py-20 lg:py-32">
              <h1 class="text-5xl sm:text-6xl lg:text-8xl font-black leading-none mb-6" style="color: #fff; letter-spacing: -0.03em;">
                <%= store.name %>
              </h1>
              <p class="text-lg lg:text-xl max-w-xl mb-8" style="color: rgba(255,255,255,0.7);"><%= store.description %></p>
              <a href="#productos" class="btn-primary inline-flex items-center gap-2 px-8 py-4 rounded-full text-sm font-bold uppercase tracking-wider">
                Explorar <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"/></svg>
              </a>
            </div>
          </section>
        <% } %>

        <% if (section === 'categories' && hp.categories !== false && categories.length > 0) { %>
          <!-- CATEGORIES -->
          <section class="py-16 lg:py-24">
            <div class="max-w-7xl mx-auto px-4 lg:px-8">
              <h2 class="section-title text-3xl lg:text-4xl text-white mb-10">Categorías</h2>
              <div class="grid grid-cols-2 sm:grid-cols-3 md:grid-cols-5 gap-3">
                <% categories.forEach(c => { %>
                  <a href="/<%= store.slug %>/categoria/<%= c.name.toLowerCase().replace(/ /g, '-') %>"
                    class="group relative p-6 rounded-2xl text-center overflow-hidden" style="background: #1a1a2e; border: 1px solid #2a2a3e;">
                    <div class="text-3xl mb-2">
                      <% const icons = {'Remeras Deportivas':'👕','Buzos y Hoodies':'🧥','Pantalones y Joggers':'👖','Shorts y Bermudas':'🩳','Camperas':'🧥','Calzado Deportivo':'👟','Accesorios':'🧢','Fitness y Yoga':'🧘','Fútbol':'⚽','Natación':'🏊'}; %>
                      <%= icons[c.name] || '🛍️' %>
                    </div>
                    <span class="text-sm font-semibold text-white"><%= c.name %></span>
                  </a>
                <% }); %>
              </div>
            </div>
          </section>
        <% } %>

        <% if (section === 'featured' && hp.featured_products !== false && featured.length > 0) { %>
          <!-- FEATURED -->
          <section class="py-16 lg:py-24" style="background: #0f0f1a;">
            <div class="max-w-7xl mx-auto px-4 lg:px-8">
              <div class="flex items-center justify-between mb-10">
                <h2 class="section-title text-3xl lg:text-4xl text-white">Destacados</h2>
                <span class="px-4 py-1.5 rounded-full text-xs font-bold uppercase tracking-wider" style="background: linear-gradient(135deg, var(--primary), var(--accent)); color: #fff;">🔥</span>
              </div>
              <div class="grid grid-cols-2 md:grid-cols-3 lg:grid-cols-4 gap-4 lg:gap-6">
                <% featured.forEach(p => { %>
                  <%- include('../../partials/_product_card', { product: p, store, locals }); %>
                <% }); %>
              </div>
            </div>
          </section>
        <% } %>

        <% if (section === 'products' && hp.products !== false) { %>
          <!-- ALL PRODUCTS -->
          <section id="productos" class="py-16 lg:py-24">
            <div class="max-w-7xl mx-auto px-4 lg:px-8">
              <h2 class="section-title text-3xl lg:text-4xl text-white mb-10">Todos los Productos</h2>
              <% if (products.length > 0) { %>
                <div class="grid grid-cols-2 md:grid-cols-3 lg:grid-cols-4 gap-4 lg:gap-6">
                  <% products.forEach(p => { %>
                    <%- include('../../partials/_product_card', { product: p, store, locals }); %>
                  <% }); %>
                </div>
              <% } else { %>
                <div class="text-center py-16" style="color: rgba(255,255,255,0.3);">Próximamente</div>
              <% } %>
            </div>
          </section>
        <% } %>

        <% if (section === 'combos' && hp.combos !== false && combos.length > 0) { %>
          <!-- COMBOS -->
          <section class="py-16 lg:py-24" style="background: #0f0f1a;">
            <div class="max-w-7xl mx-auto px-4 lg:px-8">
              <h2 class="section-title text-3xl lg:text-4xl text-white mb-10">Combos Especiales</h2>
              <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-6">
                <% combos.forEach(combo => { %>
                  <div class="p-8 rounded-2xl" style="background: linear-gradient(135deg, #1a1a3e, #1a1a2e); border: 1px solid rgba(255,255,255,0.05);">
                    <div class="text-4xl mb-4">🔥</div>
                    <h3 class="text-xl font-bold text-white mb-2"><%= combo.name %></h3>
                    <p class="text-sm mb-4" style="color: rgba(255,255,255,0.5);"><%= combo.description %></p>
                    <p class="text-3xl font-black mb-4" style="color: var(--primary);">$<%= combo.price.toFixed(2) %></p>
                    <button onclick="addComboToCart('<%= combo.id %>')" class="btn-primary w-full px-4 py-3 rounded-xl text-sm font-bold">
                      Agregar
                    </button>
                  </div>
                <% }); %>
              </div>
            </div>
          </section>
        <% } %>

        <% if (section === 'testimonials' && hp.testimonials !== false) { %>
          <!-- TESTIMONIALS -->
          <section class="py-16 lg:py-24">
            <div class="max-w-7xl mx-auto px-4 lg:px-8 text-center">
              <h2 class="section-title text-3xl lg:text-4xl text-white mb-4">Lo que dicen nuestros clientes</h2>
              <p class="mb-12" style="color: rgba(255,255,255,0.4);">Sumá reseñas y testimonios desde el editor de tienda</p>
              <div class="grid md:grid-cols-3 gap-6">
                <div class="p-6 rounded-2xl" style="background: #1a1a2e;">
                  <div class="text-yellow-400 text-lg mb-2">★★★★★</div>
                  <p class="text-sm mb-4" style="color: rgba(255,255,255,0.6);">"Excelente calidad y rápida entrega. Volveré a comprar!"</p>
                  <p class="text-sm font-semibold text-white">— Cliente</p>
                </div>
                <div class="p-6 rounded-2xl" style="background: #1a1a2e;">
                  <div class="text-yellow-400 text-lg mb-2">★★★★★</div>
                  <p class="text-sm mb-4" style="color: rgba(255,255,255,0.6);">"Los productos superaron mis expectativas. Muy recomendable."</p>
                  <p class="text-sm font-semibold text-white">— Cliente</p>
                </div>
                <div class="p-6 rounded-2xl" style="background: #1a1a2e;">
                  <div class="text-yellow-400 text-lg mb-2">★★★★★</div>
                  <p class="text-sm mb-4" style="color: rgba(255,255,255,0.6);">"Atención personalizada y productos de primera calidad."</p>
                  <p class="text-sm font-semibold text-white">— Cliente</p>
                </div>
              </div>
            </div>
          </section>
        <% } %>

        <% if (section === 'newsletter' && hp.newsletter !== false) { %>
          <!-- NEWSLETTER -->
          <section class="py-16 lg:py-20" style="background: linear-gradient(135deg, #0f0f1a, #1a1a3e);">
            <div class="max-w-xl mx-auto px-4 text-center">
              <h2 class="section-title text-3xl text-white mb-4">Newsletter</h2>
              <p class="mb-8" style="color: rgba(255,255,255,0.5);">Suscribite para recibir ofertas exclusivas</p>
              <form class="flex gap-3" onsubmit="event.preventDefault(); alert('¡Gracias por suscribirte!');">
                <input type="email" placeholder="tu@email.com" class="flex-1 px-5 py-3 rounded-xl bg-white/10 border border-white/10 text-white placeholder-gray-500 focus:outline-none focus:border-white/30">
                <button type="submit" class="btn-primary px-6 py-3 rounded-xl text-sm font-bold uppercase">Suscribir</button>
              </form>
            </div>
          </section>
        <% } %>

        <% if (section === 'contact' && hp.contact !== false) { %>
          <!-- CONTACT -->
          <section class="py-16 lg:py-24">
            <div class="max-w-2xl mx-auto px-4">
              <h2 class="section-title text-3xl lg:text-4xl text-white text-center mb-4">Contacto</h2>
              <p class="text-center mb-10" style="color: rgba(255,255,255,0.4);">Escribinos y te respondemos a la brevedad</p>
              <form class="space-y-4" onsubmit="event.preventDefault(); alert('Mensaje enviado correctamente');">
                <div class="grid grid-cols-2 gap-4">
                  <input type="text" placeholder="Nombre" class="w-full px-4 py-3 rounded-xl bg-white/5 border border-white/10 text-white placeholder-gray-500 focus:outline-none focus:border-white/30">
                  <input type="email" placeholder="Email" class="w-full px-4 py-3 rounded-xl bg-white/5 border border-white/10 text-white placeholder-gray-500 focus:outline-none focus:border-white/30">
                </div>
                <textarea rows="4" placeholder="Mensaje" class="w-full px-4 py-3 rounded-xl bg-white/5 border border-white/10 text-white placeholder-gray-500 focus:outline-none focus:border-white/30"></textarea>
                <button type="submit" class="btn-primary w-full py-3 rounded-xl text-sm font-bold uppercase tracking-wider">Enviar Mensaje</button>
              </form>
            </div>
          </section>
        <% } %>
      <% }); %>
    <% } else if (page === 'category') { %>
      <div class="max-w-7xl mx-auto px-4 lg:px-8 py-12">
        <a href="/<%= store.slug %>" class="text-sm" style="color: rgba(255,255,255,0.4);">← Volver</a>
        <h1 class="text-4xl font-black text-white mt-6 mb-8"><%= category.name %></h1>
        <% if (products.length > 0) { %>
          <div class="grid grid-cols-2 md:grid-cols-3 lg:grid-cols-4 gap-4 lg:gap-6">
            <% products.forEach(p => { %>
              <%- include('../../partials/_product_card', { product: p, store, locals }); %>
            <% }); %>
          </div>
        <% } else { %>
          <div class="text-center py-16" style="color: rgba(255,255,255,0.3);">Sin productos</div>
        <% } %>
      </div>
    <% } else if (page === 'product') { %>
      <%- include('../../partials/_product_detail', { store, product, variants, productImages, categories, related, cartCount, cartTotal, locals }); %>
    <% } else if (page === 'cart') { %>
      <%- include('../../partials/_cart', { store, categories, cartItems, cartCount, cartTotal, locals }); %>
    <% } else if (page === 'checkout') { %>
      <%- include('../../partials/_checkout', { store, categories, cartItems, cartCount, cartTotal, locals }); %>
    <% } else if (['shop','subscriptions','about','contact','login','register','account'].includes(page)) { %>
      <%- include('../../partials/_page_content', { page, store, categories, products, featured, combos, cartItems, cartCount, cartTotal, query: typeof query !== 'undefined' ? query : {}, priceRange: typeof priceRange !== 'undefined' ? priceRange : null, filterSettings: typeof filterSettings !== 'undefined' ? filterSettings : {}, filterData: typeof filterData !== 'undefined' ? filterData : {}, error: typeof error !== 'undefined' ? error : null, msg: typeof msg !== 'undefined' ? msg : null, customer: typeof customer !== 'undefined' ? customer : null, orders: typeof orders !== 'undefined' ? orders : null }); %>
    <% } %>
  </main>

  <!-- Footer -->
  <footer class="py-16" style="background: var(--footer-bg);">
    <div class="max-w-7xl mx-auto px-4 lg:px-8">
      <div class="grid md:grid-cols-4 gap-8 mb-12">
        <div class="md:col-span-2">
          <h3 class="text-xl font-bold text-white mb-3"><%= store.name %></h3>
          <p class="text-sm" style="color: var(--footer-text);"><%= store.description %></p>
          <% if (store.whatsapp) { %>
            <a href="https://wa.me/<%= store.whatsapp %>" target="_blank" class="inline-flex items-center gap-2 mt-4 text-sm font-medium text-green-400 hover:text-green-300">
              <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/></svg>
              <%= store.whatsapp %>
            </a>
          <% } %>
        </div>
        <div>
          <h4 class="text-white font-semibold mb-4">Categorías</h4>
          <ul class="space-y-2">
            <% categories.forEach(c => { %>
              <li><a href="/<%= store.slug %>/categoria/<%= c.name.toLowerCase().replace(/ /g, '-') %>" class="text-sm" style="color: var(--footer-text);"><%= c.name %></a></li>
            <% }); %>
          </ul>
        </div>
        <div>
          <h4 class="text-white font-semibold mb-4">Redes</h4>
          <div class="flex gap-3">
            <% if (store.instagram) { %>
              <a href="https://instagram.com/<%= store.instagram.replace('@', '') %>" target="_blank" class="p-2 rounded-lg bg-white/5 hover:bg-white/10 transition-colors" style="color: var(--footer-text);">
                <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24"><path d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zm0-2.163c-3.259 0-3.667.014-4.947.072-4.358.2-6.78 2.618-6.98 6.98-.059 1.281-.073 1.689-.073 4.948 0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98 1.281.058 1.689.072 4.948.072 3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98-1.281-.059-1.69-.073-4.949-.073zm0 5.838c-3.403 0-6.162 2.759-6.162 6.162s2.759 6.163 6.162 6.163 6.162-2.759 6.162-6.163c0-3.403-2.759-6.162-6.162-6.162zm0 10.162c-2.209 0-4-1.79-4-4 0-2.209 1.791-4 4-4s4 1.791 4 4c0 2.21-1.791 4-4 4zm6.406-11.845c-.796 0-1.441.645-1.441 1.44s.645 1.44 1.441 1.44c.795 0 1.439-.645 1.439-1.44s-.644-1.44-1.439-1.44z"/></svg>
              </a>
            <% } %>
            <% if (store.whatsapp) { %>
              <a href="https://wa.me/<%= store.whatsapp %>" target="_blank" class="p-2 rounded-lg bg-white/5 hover:bg-white/10 transition-colors" style="color: var(--footer-text);">
