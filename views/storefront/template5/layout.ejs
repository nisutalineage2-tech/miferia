<% const t = store.theme_settings ? JSON.parse(store.theme_settings) : {}; const c = t.colors || {}; %>
<% const isHome = !page || page === 'home'; %>
<% const isShop = page === 'shop'; %>
<% const isProduct = page === 'product'; %>
<% const isCart = page === 'cart'; %>
<% const isCheckout = page === 'checkout'; %>
<% const isCategory = page === 'category'; %>
<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= store.name || 'Store' %><%= typeof pageTitle !== 'undefined' ? ' — ' + pageTitle : '' %></title>
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Oswald:wght@300;400;500;600;700&family=Quicksand:wght@300;400;500;600;700&display=swap" rel="stylesheet">
  <script src="https://cdn.tailwindcss.com"></script>
  <script>
    tailwind.config = {
      theme: {
        extend: {
          fontFamily: {
            oswald: ['Oswald', 'sans-serif'],
            quicksand: ['Quicksand', 'sans-serif']
          },
          colors: {
            primary: 'var(--primary)',
            neon: '#00ff88',
            charcoal: '#1a1a1a',
            bg: 'var(--bg)',
            text: 'var(--text)',
          }
        }
      }
    }
  </script>
  <style>
    :root {
      --primary: <%= c.btn_primary_bg || '#00ff88' %>;
      --bg: <%= c.page_bg || '#111111' %>;
      --text: <%= c.text || '#d4d4d4' %>;
      --footer-bg: <%= c.footer_bg || '#0d0d0d' %>;
      --footer-text: <%= c.footer_text || '#737373' %>;
      --title: <%= c.heading_color || '#ffffff' %>;
      --label-bg: <%= c.label_bg || '#262626' %>;
    }
    * { font-family: 'Quicksand', sans-serif; }
    h1,h2,h3,h4,h5,h6 { font-family: 'Oswald', sans-serif; text-transform: uppercase; letter-spacing: 0.04em; color: var(--title); }
    body { background: var(--bg); color: var(--text); }
    .urban-card {
      border: 2px solid #333; border-radius: 0; box-shadow: 6px 6px 0 #333;
      transition: transform 0.2s, box-shadow 0.2s;
    }
    .urban-card:hover { transform: translate(-2px, -2px); box-shadow: 8px 8px 0 var(--primary); border-color: var(--primary); }
    .diagonal-top { clip-path: polygon(0 8%, 100% 0, 100% 100%, 0 100%); }
    .neon-glow { text-shadow: 0 0 10px rgba(0,255,136,0.4); }
  </style>
</head>
<body class="antialiased min-h-screen flex flex-col">
  <%- include('../../partials/_flash', { locals }); %>
  <%- include('../../partials/_cart_drawer', { store, storeBaseUrl }); %>
  <%- include('../../partials/_order_success', { locals }); %>

  <!-- NAV -->
  <nav class="bg-[#1a1a1a] sticky top-0 z-40 border-b-2 border-[#00ff88]">
    <div class="max-w-7xl mx-auto px-6 py-4 flex items-center justify-between">
      <a href="<%= storeBaseUrl || '/' %>" class="font-oswald text-xl uppercase tracking-widest font-bold" style="color: #00ff88">
        <%= store.name || 'Store' %>
      </a>
      <div class="hidden md:flex items-center gap-8 text-sm font-semibold uppercase tracking-wider" style="color: var(--text)">
        <%- include('../../partials/_nav_links', { store, storeBaseUrl, locals: { navLinkClass: 'hover:text-[#00ff88] transition-colors' } }); %>
      </div>
      <div class="flex items-center gap-5">
        <a href="<%= storeBaseUrl %>/carrito" class="relative" style="color: var(--text)">
          <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M3 3h2l.4 2M7 13h10l4-8H5.4M7 13L5.4 5M7 13l-2.3 2.3c-.4.4-.1 1.1.5 1.1H17m0 0a2 2 0 100 4 2 2 0 000-4zm-8 2a2 2 0 100 4 2 2 0 000-4z"/>
          </svg>
          <span class="cart-count absolute -top-2 -right-2 text-[#1a1a1a] text-[10px] w-4 h-4 rounded-full flex items-center justify-center font-bold" style="background: #00ff88"><%= cartCount || 0 %></span>
        </a>
      </div>
    </div>
  </nav>

  <!-- MAIN -->
  <main class="flex-1">
    <% if (isHome) { %>
      <%- include('../../partials/_banner_carousel', { heroImages, store, storeBaseUrl }); %>
      <%- include('../../partials/_home_content', { store, storeBaseUrl, categories, products, featured, combos, locals }); %>
    <% } else if (isProduct) { %>
      <div class="max-w-7xl mx-auto px-6 py-16">
        <%- include('../../partials/_product_detail', { product, productImages, variants, volumeDiscounts, category, related, store, storeBaseUrl, locals }); %>
      </div>
    <% } else if (isCart) { %>
      <div class="max-w-4xl mx-auto px-6 py-16">
        <%- include('../../partials/_cart', { cartItems, cartTotal, store, storeBaseUrl, locals }); %>
      </div>
    <% } else if (isCheckout) { %>
      <div class="max-w-4xl mx-auto px-6 py-16">
        <%- include('../../partials/_checkout', { cartItems, cartTotal, store, storeBaseUrl, locals }); %>
      </div>
    <% } else if (isCategory) { %>
      <div class="max-w-7xl mx-auto px-6 py-16">
        <h1 class="text-3xl font-bold mb-8"><%= category.name %></h1>
        <div class="grid grid-cols-2 md:grid-cols-3 lg:grid-cols-4 gap-6">
          <% products.forEach(p => { %>
            <div class="urban-card p-0">
              <%- include('../../partials/_product_card', { product: p, store, locals }); %>
            </div>
          <% }); %>
        </div>
      </div>
    <% } else if (isShop) { %>
      <div class="max-w-7xl mx-auto px-6 py-16">
        <h1 class="text-3xl font-bold mb-8">Shop</h1>
        <div class="grid grid-cols-2 md:grid-cols-3 lg:grid-cols-4 gap-6">
          <% (products || []).forEach(p => { %>
            <div class="urban-card p-0">
              <%- include('../../partials/_product_card', { product: p, store, locals }); %>
            </div>
          <% }); %>
        </div>
      </div>
    <% } else { %>
      <%- include('../../partials/_page_content', { page, store, storeBaseUrl, categories, products, featured, combos, locals }); %>
    <% } %>
  </main>

  <!-- FOOTER -->
  <footer class="mt-20 pt-16 pb-10 bg-[#0d0d0d]" style="clip-path: polygon(0 4%, 100% 0, 100% 100%, 0 100%);">
    <div class="max-w-7xl mx-auto px-6 grid grid-cols-1 md:grid-cols-3 gap-12">
      <div>
        <h3 class="text-xl uppercase tracking-widest font-bold neon-glow mb-4" style="color: #00ff88"><%= store.name || 'Store' %></h3>
        <p class="text-sm leading-relaxed" style="color: var(--footer-text)">Built different. Built better.</p>
      </div>
      <div>
        <h3 class="text-lg uppercase tracking-widest font-bold mb-4" style="color: var(--title)">Links</h3>
        <div class="flex flex-col gap-2 text-sm font-medium" style="color: var(--footer-text)">
          <%- include('../../partials/_nav_links', { store, storeBaseUrl, locals: { navLinkClass: 'hover:text-[#00ff88] transition-colors uppercase tracking-wider' } }); %>
        </div>
      </div>
      <div>
        <h3 class="text-lg uppercase tracking-widest font-bold mb-4" style="color: var(--title)">Legal</h3>
        <p class="text-xs tracking-wider" style="color: var(--footer-text)">&copy; <%= new Date().getFullYear() %> <%= store.name || 'Store' %>. All rights reserved.</p>
      </div>
    </div>
  </footer>

  <!-- MOBILE MENU -->
  <%- include('../../partials/_mobile_menu', { store, storeBaseUrl, locals: { iconColor: '#00ff88' } }); %>

  <script>
    function addToCart(productId, qty) {
      fetch((window.storeBaseUrl || '') + '/api/cart/add', {
        method: 'POST', headers: {'Content-Type':'application/x-www-form-urlencoded'},
        body: 'product_id=' + productId + '&qty=' + (qty||1)
      }).then(r=>r.json()).then(d=>{
        if(d.cartCount!==undefined) document.querySelectorAll('.cart-count').forEach(e=>e.textContent=d.cartCount);
        if(typeof toggleCartDrawer==='function') toggleCartDrawer();
      });
    }
    function addComboToCart(comboId) {
      fetch((window.storeBaseUrl || '') + '/api/combo/add', {
        method: 'POST', headers: {'Content-Type':'application/x-www-form-urlencoded'},
        body: 'combo_id=' + comboId + '&qty=1'
      }).then(r=>r.json()).then(d=>{
        if(d.cartCount!==undefined) document.querySelectorAll('.cart-count').forEach(e=>e.textContent=d.cartCount);
        if(typeof toggleCartDrawer==='function') toggleCartDrawer();
      });
    }
    window.storeBaseUrl = '<%= storeBaseUrl %>';
  </script>
</body>
</html>
