<!DOCTYPE html><html lang="es"><head><meta charset="UTF-8"><meta name="viewport" content="width=device-width,initial-scale=1.0"><title><%= (title||store.name||'') %></title><script src="https://cdn.tailwindcss.com"></script><link rel="preconnect" href="https://fonts.googleapis.com"><link rel="preconnect" href="https://fonts.gstatic.com" crossorigin><% let _t={};try{_t=JSON.parse(store.theme_settings||'{}');}catch(e){}const _c=_t.colors||{};const _f=_t.fonts||{};const _gf={"Inter":"Inter:wght@300;400;500;600;700","Playfair Display":"Playfair+Display:ital,wght@0,400;0,600;0,700;1,400","Lora":"Lora:wght@400;500;600;700","Nunito":"Nunito:wght@300;400;600;700;800","Quicksand":"Quicksand:wght@300;400;500;600;700","Oswald":"Oswald:wght@300;400;500;600;700","Fredoka":"Fredoka:wght@300;400;500;600;700","Noto Serif":"Noto+Serif:wght@400;600;700","Poppins":"Poppins:wght@300;400;500;600;700;800"};const _fb=_f.body||'Inter';const _fh=_f.headings||'Lora';const _fl=[...new Set([_gf[_fb],_gf[_fh]].filter(Boolean))];%><link href="https://fonts.googleapis.com/css2?family=<%=_fl.join('&family=')%>&display=swap" rel="stylesheet"><style>body{font-family:'<%=_fb%>',sans-serif}h1,h2,h3{font-family:'<%=_fh%>',serif;font-weight:600}:root{--primary:<%=_c.btn_primary_bg||'#92400e'%>;--bg:<%=_c.body_bg||'#fefce8'%>;--text:<%=_c.body_text||'#422006'%>;--footer-bg:<%=_c.footer_bg||'#292524'%>;--footer-text:<%=_c.footer_text||'#a8a29e'%>;--title:<%=_c.title_text||_c.body_text||'#292524'%>;--label-bg:<%=_c.label_bg||'#92400e'%>}body{background:var(--bg);color:var(--text)}h1,h2,h3,h4,h5,h6{color:var(--title)!important}.product-badge{background:var(--label-bg);color:#fff}.section-title{font-family:'<%=_fh%>',serif;font-weight:600}.nav-link{color:#422006;transition:color .2s}.nav-link:hover{color:var(--primary)}footer{background:var(--footer-bg)!important;color:var(--footer-text)!important}footer a,footer p,footer span{color:var(--footer-text)!important}<%if(store.advanced_css){%><%=store.advanced_css%><%}%></style></head><body>
<body>
<nav class="sticky top-0 z-40" style="background:rgba(255,255,255,0.9);border-bottom:1px solid #d6d3d1;backdrop-filter:blur(12px)"><div class="max-w-7xl mx-auto px-4"><div class="flex items-center justify-between h-16"><a href="<%=storeBaseUrl || '/'%>" class="flex items-center gap-2 shrink-0"><%if(store.logo){%><img src="<%=store.logo%>" alt="<%=store.name%>" class="h-8 w-auto"><%}else{%><span class="text-xl font-bold" style="color:var(--primary)"><%=store.name%></span><%}%></a><div class="hidden md:flex items-center gap-6 nav-links"><%-include('../../partials/_nav_links',{locals:{navLinkClass:'nav-link text-sm font-medium'}})%></div><button type="button" onclick="toggleCartDrawer()" class="relative p-2"><svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M16 11V7a4 4 0 00-8 0v4M5 9h14l1 12H4L5 9z"/></svg><%if(cartCount>0){%><span class="absolute -top-1 -right-1 w-5 h-5 rounded-full text-xs font-bold text-white flex items-center justify-center" style="background:var(--primary)"><%=cartCount%></span><%}%></button><%-include('../../partials/_mobile_menu',{locals:{}})%></div></div></nav>
<%-include("../../partials/_banner_carousel",{heroImages:typeof heroImages!=='undefined'?heroImages:[],store})%>
<main><%-include('../../partials/_flash',{locals})%>
<%if(page==='home'){%>
<div class="relative" style="background:linear-gradient(135deg,rgb(255,255,247),#fefce8,rgb(244,242,222))"><div class="max-w-7xl mx-auto px-4 py-12 lg:py-16"><div class="text-center max-w-3xl mx-auto"><span class="inline-block px-3 py-1 rounded-full bg-white/60 text-xs font-semibold mb-4">Bienvenido</span><h1 class="text-4xl lg:text-5xl mb-4" style="font-family:'Lora',serif"><%=store.name%></h1><p class="text-lg mb-6 opacity-80"><%=store.description%></p><div class="flex flex-wrap justify-center gap-3 mb-8"><a href="<%=storeBaseUrl%>/shop" class="btn-primary inline-block px-8 py-3 text-base">Ver Catálogo</a></div><%-include('../../partials/_hero_carousel',{images:typeof heroImages!=='undefined'?heroImages:[],fallback:store.banner,className:'rounded-2xl shadow-lg',height:'h-48 lg:h-64'})%></div></div></div>

<div class="py-12 lg:py-16" style="background:rgb(234,231,229)"><div class="max-w-7xl mx-auto px-4"><h2 class="text-2xl font-bold text-center mb-8 section-title">Galería</h2><div class="grid grid-cols-2 md:grid-cols-4 gap-3"><%const glSvgs=['<svg class="w-8 h-8" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M20 7l-8-4-8 4m16 0l-8 4m8-4v10l-8 4m0-10L4 7m8 4v10M4 7v10l8 4"/></svg>','<svg class="w-8 h-8" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M3 9a2 2 0 012-2h.93a2 2 0 001.664-.89l.812-1.22A2 2 0 0110.07 4h3.86a2 2 0 011.664.89l.812 1.22A2 2 0 0018.07 7H19a2 2 0 012 2v9a2 2 0 01-2 2H5a2 2 0 01-2-2V9z"/></svg>','<svg class="w-8 h-8" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M11.049 2.927c.3-.921 1.603-.921 1.902 0l1.519 4.674a1 1 0 00.95.69h4.915c.969 0 1.371 1.24.588 1.81l-3.976 2.888a1 1 0 00-.363 1.118l1.518 4.674c.3.922-.755 1.688-1.538 1.118l-3.976-2.888a1 1 0 00-1.176 0l-3.976 2.888c-.783.57-1.838-.197-1.538-1.118l1.518-4.674a1 1 0 00-.363-1.118l-3.976-2.888c-.784-.57-.38-1.81.588-1.81h4.914a1 1 0 00.951-.69l1.519-4.674z"/></svg>','<svg class="w-8 h-8" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M5 3v4M3 5h4M6 17v4m-2-2h4m5-16l2.286 6.857L21 12l-5.714 2.143L13 21l-2.286-6.857L5 12l5.714-2.143L13 3z"/></svg>','<svg class="w-8 h-8" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M5 3v4M3 5h4m6 0v4m0-4h4m-4 4a2 2 0 100-4 2 2 0 000 4zM5 15v4m-2-2h4m6 0v4m0-4h4m-4 4a2 2 0 100-4 2 2 0 000 4z"/></svg>','<svg class="w-8 h-8" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M4 16v1a3 3 0 003 3h10a3 3 0 003-3v-1m-4-8l-4-4m0 0L8 8m4-4v12"/></svg>','<svg class="w-8 h-8" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M12 3v1m0 16v1m9-9h-1M4 12H3m15.364 6.364l-.707-.707M6.343 6.343l-.707-.707m12.728 0l-.707.707M6.343 17.657l-.707.707M16 12a4 4 0 11-8 0 4 4 0 018 0z"/></svg>','<svg class="w-8 h-8" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M17.657 18.657A8 8 0 016.343 7.343S7 9 9 10c0-2 .5-5 2.986-7C14 5 16.09 5.777 17.656 7.343A7.975 7.975 0 0120 13a7.975 7.975 0 01-2.343 5.657z"/></svg>'];%><%[1,2,3,4,5,6,7,8].forEach(i=>{%><div class="aspect-square rounded-xl overflow-hidden relative group cursor-pointer" style="background:rgb(224,221,219)"><div class="absolute inset-0 flex items-center justify-center opacity-40" style="color:#92400e"><%=glSvgs[i-1]%></div><div class="absolute inset-0 bg-gradient-to-t from-black/40 to-transparent opacity-0 group-hover:opacity-100 transition-opacity flex items-end p-3"><span class="text-white text-xs font-semibold">Ver más</span></div></div><%})%></div></div></div>
<div class="py-12 lg:py-16" style="background:rgb(229,226,224)"><div class="max-w-7xl mx-auto px-4"><div class="flex items-center gap-3 mb-8"><div class="flex text-yellow-400"><%[1,2,3,4,5].forEach(i=>{%><svg class="w-6 h-6" fill="currentColor" viewBox="0 0 20 20"><path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z"/></svg><%})%></div><span class="text-lg font-bold">4.8</span><span class="text-sm opacity-60">(128 reseñas en Google)</span></div><div class="grid grid-cols-1 md:grid-cols-3 gap-4"><%[1,2,3].forEach(i=>{%><div class="p-5 rounded-xl" style="background:#fff7ed;border:1px solid #d6d3d1"><div class="flex items-center gap-3 mb-3"><div class="w-10 h-10 rounded-full flex items-center justify-center text-sm font-bold text-white" style="background:#92400e"><%=['JD','MG','CR'][i-1]%></div><div><p class="text-sm font-semibold"><%=['Juan Díaz','María García','Carlos Ruiz'][i-1]%></p><div class="flex text-yellow-400"><%[1,2,3,4,5].forEach(j=>{%><svg class="w-3.5 h-3.5" fill="currentColor" viewBox="0 0 20 20"><path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z"/></svg><%})%></div></div></div><p class="text-sm opacity-80"><%=i===1?'"Excelente tienda, muy buena atención y productos de calidad. Recomendada!"':i===2?'"Compré varias veces y siempre todo perfecto. El envío muy rápido."':'"La mejor experiencia de compra online. Volveré a comprar sin dudas."'%></p></div><%})%></div></div></div>
<div class="py-12 lg:py-16" style="background:#92400e"><div class="max-w-3xl mx-auto px-4 text-center"><h2 class="text-2xl font-bold mb-3" style="color:#fff;font-family:'Lora',serif">No te pierdas nada</h2><p class="mb-6 opacity-90" style="color:#fff">Suscribite y recibí 10% OFF en tu primera compra + novedades exclusivas.</p><form class="flex flex-col sm:flex-row gap-3 max-w-md mx-auto" onsubmit="event.preventDefault();alert('Gracias por suscribirte!')"><input type="email" placeholder="tu@email.com" class="flex-1 px-4 py-3 rounded-lg border-0 text-sm" style="background:rgba(255,255,255,0.9);color:#111"><button type="submit" class="px-6 py-3 rounded-lg text-sm font-semibold whitespace-nowrap" style="background:#111;color:#fff">Quiero mi 10% OFF</button></form></div></div>
<div class="max-w-7xl mx-auto px-4 py-8 lg:py-12">
<%if(featured.length>0){%><h2 class="text-2xl font-bold mb-6 section-title">Destacados</h2>
<div class="grid grid-cols-2 md:grid-cols-3 lg:grid-cols-4 gap-4 lg:gap-6 mb-12">
<%featured.forEach(p=>{%><%-include('../../partials/_product_card',{product:p,store,locals})%><%})%></div><%}%>
<h2 class="text-2xl font-bold mb-6 section-title">Todos los Productos</h2>
<%if(products.length>0){%><div class="grid grid-cols-2 md:grid-cols-3 lg:grid-cols-4 gap-4 lg:gap-6">
<%products.forEach(p=>{%><%-include('../../partials/_product_card',{product:p,store,locals})%><%})%></div>
<%}else{%><div class="text-center py-16 opacity-50"><p>Proximamente estaremos agregando nuestros productos.</p></div><%}%>
<%if(combos.length>0){%><h2 class="text-2xl font-bold mb-6 mt-12 section-title">Combos Especiales</h2>
<div class="grid md:grid-cols-2 lg:grid-cols-3 gap-6">
<%combos.forEach(combo=>{%><div class="p-6 rounded-2xl border-2 border-dashed" style="border-color:var(--primary)"><h3 class="text-lg font-bold"><%=combo.name%></h3><p class="text-sm opacity-70 mb-3"><%=combo.description%></p><p class="text-2xl font-bold" style="color:var(--primary)">$$<%=combo.price.toFixed(2)%></p>
<button onclick="addComboToCart('<%=combo.id%>')" class="mt-3 w-full px-4 py-2.5 text-sm font-semibold text-white transition-all btn-primary">Agregar al Carrito</button></div><%})%></div><%}%>
</div>
<%}else if(page==='category'){%><div class="max-w-7xl mx-auto px-4 py-8"><div class="mb-6"><a href="<%=storeBaseUrl || '/'%>" class="text-sm opacity-60 hover:opacity-100">← Todos los productos</a><h1 class="text-3xl font-bold mt-2 section-title"><%=category.name%></h1><%if(category.description){%><p class="opacity-70 mt-1"><%=category.description%></p><%}%></div>
<%if(products.length>0){%><div class="grid grid-cols-2 md:grid-cols-3 lg:grid-cols-4 gap-4 lg:gap-6">
<%products.forEach(p=>{%><%-include('../../partials/_product_card',{product:p,store,locals})%><%})%></div><%}else{%><div class="text-center py-16 opacity-60"><p>No hay productos en esta categoria todavia.</p></div><%}%></div>
<%}else if(page==='product'){%><%-include('../../partials/_product_detail',{store,product,variants,productImages,categories,related,cartCount,cartTotal,locals})%>
<%}else if(page==='cart'){%><%-include('../../partials/_cart',{store,categories,cartItems,cartCount,cartTotal,locals})%>
<%}else if(page==='checkout'){%><%-include('../../partials/_checkout',{store,categories,cartItems,cartCount,cartTotal,locals})%>
<%}else if(['shop','subscriptions','about','contact','login','register','account'].includes(page)){%><%-include('../../partials/_page_content',{page,store,categories,products,featured,combos,cartItems,cartCount,cartTotal,query:typeof query!=='undefined'?query:{},priceRange:typeof priceRange!=='undefined'?priceRange:null,filterSettings:typeof filterSettings!=='undefined'?filterSettings:{},filterData:typeof filterData!=='undefined'?filterData:{},error:typeof error!=='undefined'?error:null,msg:typeof msg!=='undefined'?msg:null,customer:typeof customer!=='undefined'?customer:null,orders:typeof orders!=='undefined'?orders:null})%>
<%}%></main>
<footer class="mt-16"><div class="max-w-7xl mx-auto px-4 py-12"><div class="grid grid-cols-1 md:grid-cols-4 gap-8"><div class="md:col-span-2"><p class="text-lg font-semibold mb-2"><%=store.name%></p><p class="text-sm opacity-70 mb-4"><%=store.description%></p><div class="flex gap-3"><%if(store.whatsapp){%><a href="https://wa.me/<%=store.whatsapp%>" target="_blank" class="opacity-70 hover:opacity-100 transition-opacity"><svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347"/></svg></a><%}%><%if(store.instagram){%><a href="https://instagram.com/<%=store.instagram.replace('@','')%>" target="_blank" class="opacity-70 hover:opacity-100 transition-opacity"><svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24"><path d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069z"/></svg></a><%}%></div></div><div><p class="text-xs font-semibold mb-3 uppercase tracking-widest opacity-60">Links</p><%-include('../../partials/_nav_links',{locals:{navLinkClass:'block text-sm opacity-70 hover:opacity-100 mb-2 transition-opacity'}})%></div></div><div class="border-t mt-8 pt-8 text-center text-sm opacity-50" style="border-color:currentColor">&copy; 2026 <%=store.name%>. Powered by TuFerIA.</div></div></footer>
<style>.product-card{background:#fff7ed;border:2px solid #d6d3d1;border-radius:0.5rem;transition:.3s;overflow:hidden}.product-card:hover{transform:translateY(-2px);border-color:var(--primary)}.btn-primary{background:var(--primary);color:#fff;border-radius:0;font-weight:600;padding:.625rem 1.25rem;transition:.2s}.btn-primary:hover{background:#111}</style>
<script>
async function addToCart(pid,vid,qty){const r=await fetch('/api/cart/add',{method:'POST',headers:{'Content-Type':'application/json'},body:JSON.stringify({store_id:'<%=store.id%>',product_id:pid,variant_id:vid,quantity:qty||1})});const d=await r.json();if(d.success)location.reload()}
async function addComboToCart(cid){const r=await fetch('/api/cart/add',{method:'POST',headers:{'Content-Type':'application/json'},body:JSON.stringify({store_id:'<%=store.id%>',combo_id:cid,quantity:1})});const d=await r.json();if(d.success)location.reload()}
</script>
<%-include('../../partials/_cart_drawer',{store,cartItems,cartCount,cartTotal,locals})%>
<%-include('../../partials/_order_success',{order:typeof order!=='undefined'?order:null,whatsappLink:typeof whatsappLink!=='undefined'?whatsappLink:null})%>
</body></html>