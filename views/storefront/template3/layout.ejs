<%
const ts = store.theme_settings ? (typeof store.theme_settings === 'string' ? JSON.parse(store.theme_settings) : store.theme_settings) : {};
const gfMap = { 'Playfair Display': 'Playfair+Display:wght@400;500;600;700&display=swap', 'Lora': 'Lora:wght@400;500;600;700&display=swap' };
const headFont = ts.heading_font || 'Playfair Display';
const bFont = ts.body_font || 'Lora';
const gf = gfMap[headFont] || 'Playfair+Display:wght@400;500;600;700&display=swap';
const isHome = !page || page === 'home';
const isShop = page === 'shop';
const isProduct = page === 'product';
const isCart = page === 'cart';
const isCheckout = page === 'checkout';
const isCategory = page === 'category';
%><!DOCTYPE html>
<html lang="es">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width,initial-scale=1.0">
<meta name="description" content="<%=store.description%>">
<title><%=store.name%><%=page&&page!=='home'?' | '+page:''%></title>
<script src="https://cdn.tailwindcss.com"></script>
<link rel="preconnect" href="https://fonts.googleapis.com">
<link href="https://fonts.googleapis.com/css2?family=<%=gf%>&family=Lora:wght@400;500;600;700&display=swap" rel="stylesheet">
<script>tailwind.config={theme:{extend:{fontFamily:{sans:['"<%=headFont%>"','serif'],body:['"<%=bFont%>"','serif']}}}}</script>
<style>
:root {
  --primary: <%=store.primary_color||'#d4a574'%>;
  --bg: <%=store.bg_color||'#0a0a0a'%>;
  --text: <%=store.text_color||'#c9c9c9'%>;
  --footer-bg: <%=store.footer_bg||'#050505'%>;
  --footer-text: <%=store.footer_text||'#8a8a8a'%>;
  --title: <%=store.title_color||'#f5f0eb'%>;
  --label-bg: <%=store.label_bg||'#1a1a1a'%>;
}
*{margin:0;padding:0;box-sizing:border-box}
body{font-family:'Lora',serif;background:var(--bg);color:var(--text);font-weight:400;line-height:1.8}
h1,h2,h3,h4,h5,h6{font-family:'Playfair Display',serif;font-weight:600;color:var(--title);letter-spacing:0.01em}
.section-title{font-size:1.75rem;text-align:center;margin-bottom:2.5rem;font-weight:500;font-style:italic;color:var(--primary)}
.btn-primary{display:inline-flex;align-items:center;justify-content:center;font-family:'Lora',serif;font-weight:500;font-size:0.85rem;letter-spacing:0.03em;padding:0.875rem 2.5rem;background:var(--primary);color:#0a0a0a;border-radius:0;border:1px solid var(--primary);transition:all 0.4s ease;text-transform:uppercase}
.btn-primary:hover{background:transparent;color:var(--primary)}
.product-card{background:#111!important;border:1px solid #222!important;border-radius:0!important;box-shadow:none!important;transition:all 0.4s ease;overflow:hidden}
.product-card:hover{border-color:var(--primary)!important;box-shadow:0 0 30px rgba(212,165,116,0.08)!important}
.product-card img{filter:brightness(0.9);transition:all 0.5s ease}
.product-card:hover img{filter:brightness(1);transform:scale(1.03)}
.product-card .p-3{background:#111}
.product-card h3{color:var(--title)}
.dark-hero{position:relative;background:linear-gradient(180deg,var(--bg) 0%,#111 50%,var(--bg) 100%);overflow:hidden}
.dark-hero::before{content:'';position:absolute;inset:0;background:radial-gradient(circle at 50% 50%,rgba(212,165,116,0.06) 0%,transparent 70%);pointer-events:none}
.border-gold{border-color:rgba(212,165,116,0.25)}
@keyframes fadeInUp{from{opacity:0;transform:translateY(20px)}to{opacity:1;transform:translateY(0)}}
.animate-fade-in{animation:fadeInUp 0.8s ease-out forwards}
</style>
</head>
<body>
<%-include('../../partials/_flash',{order:locals.order||null})%>

<!-- Luxury Nav -->
<nav class="sticky top-0 z-50" style="background:rgba(10,10,10,0.95);backdrop-filter:blur(12px);border-bottom:1px solid rgba(212,165,116,0.15)">
  <div class="max-w-7xl mx-auto px-4 lg:px-8">
    <div class="flex items-center justify-between h-16 lg:h-20">
      <div class="hidden lg:flex items-center gap-8">
        <%- include('../../partials/_nav_links', {locals:{navLinkClass:'text-xs uppercase tracking-[0.2em] text-gray-400 hover:text-[var(--primary)] transition-colors'}}); %>
      </div>
      <a href="<%=storeBaseUrl%>" class="text-xl lg:text-2xl" style="font-family:'Playfair Display',serif;color:var(--title);text-decoration:none;letter-spacing:0.08em"><%=store.name%></a>
      <div class="flex items-center gap-4">
        <button onclick="toggleCartDrawer()" class="p-2 relative transition-opacity hover:opacity-70">
          <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24" style="color:var(--text)"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M2.25 3h1.386c.51 0 .955.343 1.087.835l.383 1.437M7.5 14.25a3 3 0 00-3 3h15.75m-12.75-3h11.218c1.121-2.3 2.1-4.684 2.924-7.138a60.114 60.114 0 00-16.536-1.84M7.5 14.25L5.106 5.272"/></svg>
          <% if (cartCount > 0) { %><span class="absolute -top-0.5 -right-0.5 w-4 h-4 rounded-full flex items-center justify-center text-[9px] font-bold" style="background:var(--primary);color:#0a0a0a"><%= cartCount %></span><% } %>
        </button>
        <%- include('../../partials/_mobile_menu', { locals: { iconColor: 'text-gray-400' } }); %>
      </div>
    </div>
  </div>
</nav>

<main>
  <% if (isHome) { %>
    <!-- Luxury Hero -->
    <div class="dark-hero">
      <div class="max-w-7xl mx-auto px-4 lg:px-8 py-20 lg:py-32 text-center relative z-10">
        <h1 class="text-5xl lg:text-7xl mb-6 animate-fade-in" style="font-family:'Playfair Display',serif;color:var(--title);font-weight:600"><%=store.name%></h1>
        <p class="text-lg mb-10 max-w-xl mx-auto animate-fade-in" style="color:var(--text);opacity:0.7;animation-delay:0.2s"><%=store.description%></p>
        <div class="animate-fade-in" style="animation-delay:0.4s">
          <a href="<%=storeBaseUrl%>/tienda" class="btn-primary">Explorar Colección</a>
        </div>
      </div>
    </div>
    <%- include('../../partials/_banner_carousel', { heroImages, store, storeBaseUrl }); %>
    <%- include('../../partials/_home_content', { store, storeBaseUrl, categories, products, featured, combos, locals }); %>
  <% } else if (isCategory) { %>
    <div class="max-w-7xl mx-auto px-4 lg:px-8 py-16">
      <h1 class="text-4xl lg:text-5xl mb-12" style="font-family:'Playfair Display',serif;color:var(--title)"><%= category.name %></h1>
      <div class="grid grid-cols-2 lg:grid-cols-4 gap-6">
        <% products.forEach(p => { %>
          <%- include('../../partials/_product_card', { product: p, store, locals }); %>
        <% }); %>
      </div>
    </div>
  <% } else if (isProduct) { %>
    <%- include('../../partials/_product_detail', { product, productImages, category, variants, volumeDiscounts, related, store, storeBaseUrl, locals }); %>
  <% } else if (isCart) { %>
    <%- include('../../partials/_cart', { cartItems, cartTotal, store, storeBaseUrl, locals }); %>
  <% } else if (isCheckout) { %>
    <%- include('../../partials/_checkout', { cartItems, cartTotal, store, storeBaseUrl, locals }); %>
  <% } else { %>
    <%- include('../../partials/_page_content', { page, store, storeBaseUrl, categories, products, featured, combos, locals }); %>
  <% } %>
</main>

<!-- Luxury Footer -->
<footer style="background:var(--footer-bg);color:var(--footer-text);border-top:1px solid rgba(212,165,116,0.15)">
  <div class="max-w-7xl mx-auto px-4 lg:px-8 py-16 lg:py-20">
    <div class="grid lg:grid-cols-4 gap-8 lg:gap-12">
      <div class="lg:col-span-2">
        <h3 class="text-2xl mb-4" style="font-family:'Playfair Display',serif;color:var(--title)"><%=store.name%></h3>
        <p class="text-sm leading-relaxed opacity-60 max-w-md"><%=store.description%></p>
      </div>
      <div>
        <h4 class="text-sm uppercase tracking-[0.2em] mb-6" style="color:var(--primary)">Enlaces</h4>
        <div class="flex flex-col gap-3">
          <%- include('../../partials/_nav_links', {locals:{navLinkClass:'text-sm text-gray-500 hover:text-[var(--primary)] transition-colors'}}); %>
        </div>
      </div>
      <div>
        <h4 class="text-sm uppercase tracking-[0.2em] mb-6" style="color:var(--primary)">Contacto</h4>
        <div class="flex flex-col gap-3">
          <% if (store.whatsapp) { %><a href="https://wa.me/<%=store.whatsapp%>" class="text-sm text-gray-500 hover:text-[var(--primary)] transition-colors">WhatsApp</a><% } %>
          <% if (store.instagram) { %><a href="https://instagram.com/<%=store.instagram.replace('@','')%>" class="text-sm text-gray-500 hover:text-[var(--primary)] transition-colors">Instagram</a><% } %>
        </div>
      </div>
    </div>
    <div class="mt-12 pt-8 text-center text-xs opacity-30 tracking-wider" style="border-top:1px solid rgba(212,165,116,0.12)">
      &copy; <%= new Date().getFullYear() %> <%= store.name %>. All rights reserved.
    </div>
  </div>
</footer>

<script>
async function addToCart(productId, variantId, qty) {
  const res = await fetch('/api/cart/add', {
    method: 'POST',
    headers: { 'Content-Type': 'application/json' },
    body: JSON.stringify({ product_id: productId, variant_id: variantId || null, quantity: qty || 1, store_id: '<%= store.id %>' })
  });
  const data = await res.json();
  if (data.success) { toggleCartDrawer(); } else { alert(data.error || 'Error'); }
}
async function addComboToCart(comboId) {
  const res = await fetch('/api/cart/add-combo', {
    method: 'POST',
    headers: { 'Content-Type': 'application/json' },
    body: JSON.stringify({ combo_id: comboId, store_id: '<%= store.id %>' })
  });
  const data = await res.json();
  if (data.success) { toggleCartDrawer(); } else { alert(data.error || 'Error'); }
}
</script>

<%- include('../../partials/_cart_drawer', { cartItems, cartTotal, store, storeBaseUrl }); %>
<%- include('../../partials/_order_success', { order: locals.order, whatsappLink: locals.whatsappLink, store, storeBaseUrl, locals }); %>
</body>
</html>
