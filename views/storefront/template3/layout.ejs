<% const t = store.theme_settings ? JSON.parse(store.theme_settings) : {}; const c = t.colors || {}; %>
<% const isHome = !page || page === 'home'; %>
<% const isShop = page === 'shop'; %>
<% const isProduct = page === 'product'; %>
<% const isCart = page === 'cart'; %>
<% const isCheckout = page === 'checkout'; %>
<% const isCategory = page === 'category'; %>
<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= store.name || 'Store' %><%= typeof pageTitle !== 'undefined' ? ' — ' + pageTitle : '' %></title>
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Playfair+Display:wght@300;400;500;600;700&family=Lora:wght@300;400;500;600;700&display=swap" rel="stylesheet">
  <script src="https://cdn.tailwindcss.com"></script>
  <script>
    tailwind.config = {
      theme: {
        extend: {
          fontFamily: {
            playfair: ['"Playfair Display"', 'serif'],
            lora: ['Lora', 'serif']
          },
          colors: {
            primary: 'var(--primary)',
            gold: '#d4a574',
            bg: 'var(--bg)',
            text: 'var(--text)',
          }
        }
      }
    }
  </script>
  <style>
    :root {
      --primary: <%= c.btn_primary_bg || '#d4a574' %>;
      --bg: <%= c.page_bg || '#0a0a0a' %>;
      --text: <%= c.text || '#e8e0d4' %>;
      --footer-bg: <%= c.footer_bg || '#0a0a0a' %>;
      --footer-text: <%= c.footer_text || '#a89a8a' %>;
      --title: <%= c.heading_color || '#f5f0ea' %>;
      --label-bg: <%= c.label_bg || '#1a1a1a' %>;
    }
    * { font-family: 'Lora', serif; }
    h1,h2,h3,h4,h5,h6 { font-family: 'Playfair Display', serif; color: var(--title); }
    body { background: var(--bg); color: var(--text); }
    .luxury-card {
      background: #111; border: 1px solid #222; border-radius: 0.25rem;
      transition: border-color 0.4s ease, box-shadow 0.4s ease;
    }
    .luxury-card:hover { border-color: #d4a574; box-shadow: 0 0 30px rgba(212,165,116,0.08); }
    .gold-border-top { border-top: 1px solid #d4a574; }
  </style>
</head>
<body class="antialiased min-h-screen flex flex-col">
  <%- include('../../partials/_flash', { locals }); %>
  <%- include('../../partials/_cart_drawer', { store, storeBaseUrl }); %>
  <%- include('../../partials/_order_success', { locals }); %>

  <!-- NAV -->
  <nav class="bg-[#0a0a0a] border-b border-[#222] sticky top-0 z-40">
    <div class="max-w-7xl mx-auto px-6 py-5 flex items-center justify-between">
      <div class="hidden md:flex items-center gap-8 text-sm" style="color: var(--text)">
        <%- include('../../partials/_nav_links', { store, storeBaseUrl, locals: { navLinkClass: 'hover:text-[#d4a574] transition-colors tracking-wide' } }); %>
      </div>
      <a href="<%= storeBaseUrl || '/' %>" class="font-playfair text-2xl font-semibold tracking-wide" style="color: #d4a574">
        <%= store.name || 'Store' %>
      </a>
      <div class="hidden md:flex items-center gap-6">
        <a href="<%= storeBaseUrl %>/cart" class="relative" style="color: var(--text)">
          <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
            <path stroke-linecap="round" stroke-linejoin="round" d="M3 3h2l.4 2M7 13h10l4-8H5.4M7 13L5.4 5M7 13l-2.3 2.3c-.4.4-.1 1.1.5 1.1H17m0 0a2 2 0 100 4 2 2 0 000-4zm-8 2a2 2 0 100 4 2 2 0 000-4z"/>
          </svg>
          <span class="cart-count absolute -top-2 -right-2 bg-[#d4a574] text-[#0a0a0a] text-[10px] w-4 h-4 rounded-full flex items-center justify-center font-medium"><%= cartCount || 0 %></span>
        </a>
      </div>
    </div>
  </nav>

  <!-- MAIN -->
  <main class="flex-1">
    <% if (isHome) { %>
      <%- include('../../partials/_banner_carousel', { heroImages, store, storeBaseUrl }); %>
      <%- include('../../partials/_home_content', { store, storeBaseUrl, categories, products, featured, combos, locals }); %>
    <% } else if (isProduct) { %>
      <div class="max-w-7xl mx-auto px-6 py-20">
        <%- include('../../partials/_product_detail', { product, productImages, variants, volumeDiscounts, category, related, store, storeBaseUrl, locals }); %>
      </div>
    <% } else if (isCart) { %>
      <div class="max-w-4xl mx-auto px-6 py-20">
        <%- include('../../partials/_cart', { cartItems, cartTotal, store, storeBaseUrl, locals }); %>
      </div>
    <% } else if (isCheckout) { %>
      <div class="max-w-4xl mx-auto px-6 py-20">
        <%- include('../../partials/_checkout', { cartItems, cartTotal, store, storeBaseUrl, locals }); %>
      </div>
    <% } else if (isCategory) { %>
      <div class="max-w-7xl mx-auto px-6 py-20">
        <h1 class="text-3xl font-playfair font-semibold mb-8" style="color: var(--title)"><%= category.name %></h1>
        <div class="grid grid-cols-2 md:grid-cols-3 lg:grid-cols-4 gap-6">
          <% products.forEach(p => { %>
            <div class="luxury-card p-0">
              <%- include('../../partials/_product_card', { product: p, store, locals }); %>
            </div>
          <% }); %>
        </div>
      </div>
    <% } else if (isShop) { %>
      <div class="max-w-7xl mx-auto px-6 py-20">
        <h1 class="text-3xl font-playfair font-semibold mb-8" style="color: var(--title)">Shop</h1>
        <div class="grid grid-cols-2 md:grid-cols-3 lg:grid-cols-4 gap-6">
          <% (products || []).forEach(p => { %>
            <div class="luxury-card p-0">
              <%- include('../../partials/_product_card', { product: p, store, locals }); %>
            </div>
          <% }); %>
        </div>
      </div>
    <% } else { %>
      <%- include('../../partials/_page_content', { page, store, storeBaseUrl, categories, products, featured, combos, locals }); %>
    <% } %>
  </main>

  <!-- FOOTER -->
  <footer class="gold-border-top bg-[#0a0a0a] mt-20 py-16">
    <div class="max-w-7xl mx-auto px-6 text-center">
      <h3 class="font-playfair text-xl mb-4" style="color: #d4a574"><%= store.name || 'Store' %></h3>
      <div class="flex justify-center gap-8 text-sm mb-6" style="color: var(--footer-text)">
        <%- include('../../partials/_nav_links', { store, storeBaseUrl, locals: { navLinkClass: 'hover:text-[#d4a574] transition-colors' } }); %>
      </div>
      <p class="text-xs tracking-widest uppercase" style="color: var(--footer-text)">&copy; <%= new Date().getFullYear() %> <%= store.name || 'Store' %>. All rights reserved.</p>
    </div>
  </footer>

  <!-- MOBILE MENU -->
  <%- include('../../partials/_mobile_menu', { store, storeBaseUrl, locals: { iconColor: '#d4a574' } }); %>

  <script>
    function addToCart(productId, qty) {
      fetch((window.storeBaseUrl || '') + '/api/cart/add', {
        method: 'POST', headers: {'Content-Type':'application/x-www-form-urlencoded'},
        body: 'product_id=' + productId + '&qty=' + (qty||1)
      }).then(r=>r.json()).then(d=>{
        if(d.cartCount!==undefined) document.querySelectorAll('.cart-count').forEach(e=>e.textContent=d.cartCount);
        if(typeof toggleCartDrawer==='function') toggleCartDrawer();
      });
    }
    function addComboToCart(comboId) {
      fetch((window.storeBaseUrl || '') + '/api/combo/add', {
        method: 'POST', headers: {'Content-Type':'application/x-www-form-urlencoded'},
        body: 'combo_id=' + comboId + '&qty=1'
      }).then(r=>r.json()).then(d=>{
        if(d.cartCount!==undefined) document.querySelectorAll('.cart-count').forEach(e=>e.textContent=d.cartCount);
        if(typeof toggleCartDrawer==='function') toggleCartDrawer();
      });
    }
    window.storeBaseUrl = '<%= storeBaseUrl %>';
  </script>
</body>
</html>
