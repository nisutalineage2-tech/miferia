<!DOCTYPE html>
<html lang="es">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= (title || store.name || '') %></title>
  <script src="https://cdn.tailwindcss.com"></script>
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&family=Playfair+Display:ital,wght@0,400;0,600;0,700;1,400&display=swap" rel="stylesheet">
  <style>
    <% let _tc3 = {}; try { _tc3 = JSON.parse(store.theme_settings || '{}'); } catch(e) {} const _col3 = _tc3.colors || {}; %>
    body { font-family: 'Inter', sans-serif; background: <%= _col3.body_bg || '#faf7f2' %>; color: <%= _col3.body_text || '#292524' %>; }
    h1,h2,h3 { font-family: 'Playfair Display', Georgia, serif; font-weight: 600; }
    :root { --primary: <%= _col3.btn_primary_bg || store.primary_color || '#d97706' %>; --accent: <%= _col3.btn_secondary_bg || store.accent_color || '#fef3c7' %>; --footer-bg: <%= _col3.footer_bg || '#292524' %>; --footer-text: <%= _col3.footer_text || '#a8a29e' %>; }
    .product-card { background: #fff; border: 1px solid #e7e5e4; transition: all 0.3s ease; border-radius: 12px; overflow: hidden; }
    .product-card:hover { box-shadow: 0 12px 40px rgba(217,119,6,0.08); border-color: #d97706; }
    .btn-home { background: #292524; color: #fff; border-radius: 9999px; font-weight: 500; padding: 0.6rem 1.5rem; transition: all 0.2s; }
    .btn-home:hover { background: #d97706; }
    .minimal-nav a { position: relative; }
    .minimal-nav a::after { content: ''; position: absolute; bottom: -2px; left: 0; width: 0; height: 1px; background: #d97706; transition: width 0.3s ease; }
    .minimal-nav a:hover::after { width: 100%; }
  </style>
</head>
<body class="min-h-screen">
  <!-- Nav -->
  <nav class="bg-white/95 backdrop-blur-sm border-b border-amber-100 sticky top-0 z-40">
    <div class="max-w-6xl mx-auto px-6">
      <div class="flex items-center justify-between h-16">
        <a href="/<%= store.slug %>" class="flex items-center gap-2">
          <% if (store.logo) { %><img src="<%= store.logo %>" alt="<%= store.name %>" class="h-7 w-auto"><% } else { %><span class="text-lg font-semibold text-amber-900"><%= store.name %></span><% } %>
        </a>
        <div class="hidden md:flex items-center gap-8 minimal-nav">
          <%- include('../../partials/_nav_links', { locals: { navLinkClass: 'text-sm text-amber-700/70 hover:text-amber-900' } }) %>
        </div>
        <a href="/<%= store.slug %>/carrito" class="relative"><svg class="w-5 h-5 text-amber-800" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M15.75 10.5V6a3.75 3.75 0 10-7.5 0v4.5m11.356-1.993l1.263 12c.07.665-.45 1.243-1.119 1.243H4.25a1.125 1.125 0 01-1.12-1.243l1.264-12A1.125 1.125 0 015.513 7.5h12.974c.576 0 1.059.435 1.119 1.007zM8.625 10.5a.375.375 0 11-.75 0 .375.375 0 01.75 0zm7.5 0a.375.375 0 11-.75 0 .375.375 0 01.75 0z"/></svg><% if (cartCount > 0) { %><span class="absolute -top-2 -right-2 w-4 h-4 rounded-full text-[10px] font-bold text-white flex items-center justify-center" style="background: var(--primary)"><%= cartCount %></span><% } %></a>
      
            <%- include('../../partials/_mobile_menu', { locals: { iconColor: 'text-amber-700/70' } }) %>
</div>
    </div>
  </nav>

  <main>
    <%- include('../../partials/_flash', { locals }); %>
    <% if (page === 'home') { %>
      <!-- HERO HOME DECO -->
      <div class="max-w-6xl mx-auto px-6 py-16 lg:py-24 group">
        <div class="max-w-2xl">
          <span class="text-xs font-semibold tracking-widest uppercase text-amber-500 mb-3 block">🏡 Hogar y Decoración</span>
          <h1 class="text-5xl lg:text-6xl text-amber-900 tracking-tight mb-4" style="font-family: 'Playfair Display', serif;"><%= store.name %></h1>
          <p class="text-lg text-amber-700/60 mb-6"><%= store.description %></p>
          <%- include('../../partials/_hero_carousel', { images: heroImages, fallback: store.banner, className: 'rounded-2xl shadow-lg mb-6', height: 'h-48 sm:h-64' }); %>
          <a href="/<%= store.slug %>/tienda" class="btn-home inline-flex items-center gap-2 text-sm">Ver Colección <span>→</span></a>
        </div>
      </div>

      <div class="max-w-6xl mx-auto px-6 py-16 lg:py-24">
        <!-- About -->
        <% if (store.about_text) { %>
          <div class="mb-12 max-w-2xl">
            <p class="text-gray-600 leading-relaxed"><%= store.about_text %></p>
          </div>
        <% } %>

        <!-- Category Tabs -->
        <% if (categories.length > 0) { %>
          <div class="mb-12 flex flex-wrap gap-2">
            <a href="/<%= store.slug %>" class="px-5 py-2 text-sm rounded-full border border-gray-200 text-gray-700 hover:border-gray-900 transition-colors">Todos</a>
            <% categories.forEach(c => { %>
              <a href="/<%= store.slug %>/categoria/<%= c.name.toLowerCase().replace(/ /g, '-') %>"
                class="px-5 py-2 text-sm rounded-full border border-gray-200 text-gray-500 hover:border-gray-900 hover:text-gray-700 transition-colors">
                <%= c.name %>
              </a>
            <% }); %>
          </div>
        <% } %>

        <!-- Products -->
        <% if (products.length > 0) { %>
          <div class="grid grid-cols-2 md:grid-cols-3 lg:grid-cols-4 gap-6 lg:gap-8">
            <% products.forEach(p => { %>
              <%- include('../../partials/_product_card', { product: p, store, locals }); %>
            <% }); %>
          </div>
        <% } else { %>
          <div class="text-center py-16 text-gray-300 font-light text-lg">Próximamente...</div>
        <% } %>

        <!-- Combos -->
        <% if (combos.length > 0) { %>
          <div class="mt-16">
            <h2 class="text-2xl font-light text-gray-900 mb-6">Combos</h2>
            <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-6">
              <% combos.forEach(combo => { %>
                <div class="p-6 rounded-2xl bg-white border border-gray-100">
                  <h3 class="font-medium text-gray-900"><%= combo.name %></h3>
                  <p class="text-sm text-gray-400 mt-1"><%= combo.description %></p>
                  <p class="text-xl font-semibold mt-3" style="color: var(--primary)">$<%= combo.price.toFixed(2) %></p>
                  <button onclick="addComboToCart('<%= combo.id %>')" class="mt-3 text-sm font-medium text-white px-4 py-2 rounded-lg transition-opacity hover:opacity-80" style="background-color: var(--primary);">
                    Agregar
                  </button>
                </div>
              <% }); %>
            </div>
          </div>
        <% } %>
      </div>

    <% } else if (page === 'category') { %>
      <div class="max-w-6xl mx-auto px-6 py-12">
        <a href="/<%= store.slug %>" class="text-sm text-gray-400 hover:text-gray-700">← Volver</a>
        <h1 class="text-3xl font-light text-gray-900 mt-6 mb-8"><%= category.name %></h1>
        <% if (products.length > 0) { %>
          <div class="grid grid-cols-2 md:grid-cols-3 lg:grid-cols-4 gap-6">
            <% products.forEach(p => { %>
              <%- include('../../partials/_product_card', { product: p, store, locals }); %>
            <% }); %>
          </div>
        <% } else { %>
          <div class="text-center py-16 text-gray-300 font-light">Sin productos</div>
        <% } %>
      </div>

    <% } else if (page === 'product') { %>
      <%- include('../../partials/_product_detail', { store, product, variants, productImages, categories, related, cartCount, cartTotal, locals }); %>

    <% } else if (page === 'cart') { %>
      <%- include('../../partials/_cart', { store, categories, cartItems, cartCount, cartTotal, locals }); %>

    <% } else if (page === 'checkout') { %>
      <%- include('../../partials/_checkout', { store, categories, cartItems, cartCount, cartTotal, locals }); %>
    <% } else if (['shop','subscriptions','about','contact','login','register','account'].includes(page)) { %>
      <%- include('../../partials/_page_content', { page, store, categories, products, featured, combos, cartItems, cartCount, cartTotal, query: typeof query !== 'undefined' ? query : {}, priceRange: typeof priceRange !== 'undefined' ? priceRange : null, filterSettings: typeof filterSettings !== 'undefined' ? filterSettings : {}, filterData: typeof filterData !== 'undefined' ? filterData : {}, error: typeof error !== 'undefined' ? error : null, msg: typeof msg !== 'undefined' ? msg : null, customer: typeof customer !== 'undefined' ? customer : null, orders: typeof orders !== 'undefined' ? orders : null }); %>
    <% } %>
  </main>

  <!-- Footer -->
  <footer class="bg-amber-900 text-amber-200 mt-24">
    <div class="max-w-6xl mx-auto px-6 py-10">
      <div class="flex flex-col md:flex-row items-center justify-between gap-4">
        <p class="text-sm text-gray-400"><%= store.name %> © 2026</p>
        <div class="flex items-center gap-4">
          <% if (store.instagram) { %>
            <a href="https://instagram.com/<%= store.instagram.replace('@', '') %>" target="_blank" class="text-gray-400 hover:text-gray-600"><svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24"><path d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zm0-2.163c-3.259 0-3.667.014-4.947.072-4.358.2-6.78 2.618-6.98 6.98-.059 1.281-.073 1.689-.073 4.948 0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98 1.281.058 1.689.072 4.948.072 3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98-1.281-.059-1.69-.073-4.949-.073zm0 5.838c-3.403 0-6.162 2.759-6.162 6.162s2.759 6.163 6.162 6.163 6.162-2.759 6.162-6.163c0-3.403-2.759-6.162-6.162-6.162zm0 10.162c-2.209 0-4-1.79-4-4 0-2.209 1.791-4 4-4s4 1.791 4 4c0 2.21-1.791 4-4 4zm6.406-11.845c-.796 0-1.441.645-1.441 1.44s.645 1.44 1.441 1.44c.795 0 1.439-.645 1.439-1.44s-.644-1.44-1.439-1.44z"/></svg></a>
          <% } %>
          <% if (store.whatsapp) { %>
            <a href="https://wa.me/<%= store.whatsapp %>" target="_blank" class="text-gray-400 hover:text-gray-600"><svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/></svg></a>
          <% } %>
          <span class="text-xs text-gray-300">Powered by TuFerIA</span>
        </div>
      </div>
    </div>
  </footer>

  <script>
    async function addToCart(productId, variantId = null, quantity = 1) {
      const res = await fetch('/api/cart/add', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ store_id: '<%= store.id %>', product_id: productId, variant_id: variantId, quantity })
      });
      const data = await res.json();
      if (data.success) location.reload();
    }
    async function addComboToCart(comboId) {
      const res = await fetch('/api/cart/add', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ store_id: '<%= store.id %>', combo_id: comboId, quantity: 1 })
      });
      const data = await res.json();
      if (data.success) location.reload();
    }
  </script>
</body>
</html>
