<!DOCTYPE html>
<html lang="es">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= (title || store.name || '') %></title>
  <script src="https://cdn.tailwindcss.com"></script>
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Anton&family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet">
  <style>
    <% let tc = {}; try { tc = JSON.parse(store.theme_settings || '{}'); } catch(e) {} const col = tc.colors || {}; const fonts = tc.fonts || {}; const hdr = tc.header || {}; %>
    body { font-family: '<%= fonts.body || 'Inter' %>', sans-serif; background: <%= col.body_bg || '#fefce8' %>; color: <%= col.body_text || '#422006' %>; }
    h1,h2,h3 { font-family: 'Anton', sans-serif; font-weight: 400; text-transform: uppercase; letter-spacing: 0.02em; }
    :root { --primary: <%= col.btn_primary_bg || '#d97706' %>; --accent: <%= col.btn_secondary_bg || '#fed7aa' %>; --footer-bg: <%= col.footer_bg || '#422006' %>; --footer-text: <%= col.footer_text || '#a16207' %>; }
    .product-card { background: #fff; border: 2px solid #fed7aa; border-radius: 0; transition: all 0.2s ease; overflow: hidden; }
    .product-card:hover { border-color: #d97706; box-shadow: 4px 4px 0 #d97706; transform: translate(-2px, -2px); }
    .btn-primary { background: #d97706; color: #fff; border-radius: 0; font-weight: 700; text-transform: uppercase; letter-spacing: 0.03em; padding: 0.75rem 2rem; box-shadow: 3px 3px 0 #92400e; }
    .btn-primary:hover { transform: translate(-1px, -1px); box-shadow: 4px 4px 0 #92400e; }
    .section-title { font-family: 'Anton', sans-serif; font-weight: 400; text-transform: uppercase; letter-spacing: 0.02em; font-size: 2.5rem; }
    .retro-stripe { background: repeating-linear-gradient(45deg, #fefce8 0px, #fefce8 10px, #fed7aa 10px, #fed7aa 12px); }
    .product-card .product-name { font-family: 'Anton', sans-serif; text-transform: uppercase; letter-spacing: 0.03em; }
    <% if (store.advanced_css) { %><%= store.advanced_css %><% } %>
  </style>
</head>
<body>
  <nav class="bg-[#fefce8] border-b-2 border-[#d97706] sticky top-0 z-40">
    <div class="max-w-7xl mx-auto px-4 lg:px-8">
      <div class="flex items-center justify-between h-16">
        <a href="/<%= store.slug %>" class="flex items-center gap-2">
          <% if (store.logo) { %><img src="<%= store.logo %>" alt="<%= store.name %>" class="h-8 w-auto"><% } else { %><span class="text-xl font-display uppercase tracking-wide text-[#422006]"><%= store.name %></span><% } %>
        </a>
        <div class="hidden md:flex items-center gap-6">
          <%- include('../../partials/_nav_links', { locals: { navLinkClass: 'text-sm font-bold uppercase tracking-wider text-[#a16207] hover:text-[#d97706] transition-colors' } }) %>
        </div>
        <a href="/<%= store.slug %>/carrito" class="relative p-2">
          <svg class="w-5 h-5 text-[#a16207]" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15.75 10.5V6a3.75 3.75 0 10-7.5 0v4.5m11.356-1.993l1.263 12c.07.665-.45 1.243-1.119 1.243H4.25a1.125 1.125 0 01-1.12-1.243l1.264-12A1.125 1.125 0 015.513 7.5h12.974c.576 0 1.059.435 1.119 1.007zM8.625 10.5a.375.375 0 11-.75 0 .375.375 0 01.75 0zm7.5 0a.375.375 0 11-.75 0 .375.375 0 01.75 0z"/></svg>
          <% if (cartCount > 0) { %><span class="absolute -top-1 -right-1 w-5 h-5 bg-[#d97706] text-white text-[10px] font-bold rounded-full flex items-center justify-center"><%= cartCount %></span><% } %>
        </a>
      
            <%- include('../../partials/_mobile_menu', { locals: { iconColor: 'text-[#a16207]' } }) %>
</div>
    </div>
  </nav>

  <main>
    <%- include('../../partials/_flash', { locals }); %>
    <% if (page === 'home') { %>
      <section class="retro-stripe py-20 lg:py-28">
        <div class="max-w-7xl mx-auto px-4 lg:px-8">
          <div class="flex flex-col lg:flex-row items-center gap-12">
            <div class="flex-1">
              <span class="text-xs font-bold uppercase tracking-[0.15em] text-[#d97706] mb-3 block">Vintage Sports</span>
              <h1 class="text-6xl lg:text-8xl font-display text-[#422006] mb-4 leading-[0.9]"><%= store.name %></h1>
              <p class="text-lg text-[#a16207] mb-8"><%= store.description %></p>
              <a href="/<%= store.slug %>/tienda" class="btn-primary inline-flex items-center gap-2">Shop Now <span>→</span></a>
            </div>
            <div class="flex-1"><%- include('../../partials/_hero_carousel', { images: heroImages, fallback: store.banner, className: 'rounded-none border-2 border-[#d97706]', height: 'h-64 sm:h-80' }); %></div>
          </div>
        </div>
      </section>

      <div class="max-w-7xl mx-auto px-4 lg:px-8 py-20">
        <% if (categories.length > 0) { %>
          <div class="flex flex-wrap gap-3 mb-16">
            <a href="/<%= store.slug %>" class="px-5 py-2 bg-[#d97706] text-white font-bold uppercase tracking-wider text-xs">Todos</a>
            <% categories.forEach(c => { %>
              <a href="/<%= store.slug %>/categoria/<%= c.name.toLowerCase().replace(/ /g, '-') %>" class="px-5 py-2 border-2 border-[#fed7aa] text-[#a16207] font-bold uppercase tracking-wider text-xs hover:bg-[#d97706] hover:text-white hover:border-[#d97706] transition-colors"><%= c.name %></a>
            <% }); %>
          </div>
        <% } %>

        <% if (store.about_text) { %>
          <div class="max-w-2xl mb-16">
            <p class="text-[#a16207] font-bold"><%= store.about_text %></p>
          </div>
        <% } %>

        <% if (products.length > 0) { %>
          <div class="grid grid-cols-2 md:grid-cols-3 lg:grid-cols-4 gap-6">
            <% products.forEach(p => { %><%- include('../../partials/_product_card', { product: p, store, locals }); %><% }); %>
          </div>
        <% } else { %>
          <div class="text-center py-16 text-[#a16207] font-display text-3xl tracking-wider">PRÓXIMAMENTE</div>
        <% } %>
      </div>
    <% } else if (page === 'category') { %>
      <div class="max-w-7xl mx-auto px-4 lg:px-8 py-12">
        <a href="/<%= store.slug %>" class="inline-flex items-center gap-2 text-xs font-bold uppercase tracking-widest text-[#d97706] hover:underline mb-8"><svg class="w-3 h-3" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 12H5m7-7l-7 7 7 7"/></svg> Volver</a>
        <h1 class="section-title text-[#422006] mb-8"><%= category.name %></h1>
        <div class="grid grid-cols-2 md:grid-cols-3 lg:grid-cols-4 gap-6"><% products.forEach(p => { %><%- include('../../partials/_product_card', { product: p, store, locals }); %><% }); %></div>
      </div>
    <% } else if (page === 'product') { %>
      <%- include('../../partials/_product_detail', { product, store, locals }); %>
    <% } else if (page === 'cart') { %>
      <%- include('../../partials/_cart', { store, locals }); %>
    <% } else if (page === 'checkout') { %>
      <%- include('../../partials/_checkout', { store, locals }); %>
    <% } else { %>
      <%- include('../../partials/_page_content', { store, locals }); %>
    <% } %>
  </main>

  <footer class="bg-[#422006] py-16 mt-20">
    <div class="max-w-7xl mx-auto px-4 lg:px-8">
      <div class="flex flex-col md:flex-row items-center justify-between gap-6">
        <div>
          <h3 class="text-xl font-display text-[#fed7aa]"><%= store.name %></h3>
          <% if (store.description) { %><p class="text-sm text-[#a16207] mt-2"><%= store.description %></p><% } %>
        </div>
        <div class="flex gap-6">
          <% if (store.instagram) { %><a href="https://instagram.com/<%= store.instagram %>" target="_blank" class="text-xs font-bold uppercase tracking-widest text-[#a16207] hover:text-[#fed7aa] transition-colors">Instagram</a><% } %>
          <% if (store.whatsapp) { %><a href="https://wa.me/<%= store.whatsapp %>" target="_blank" class="text-xs font-bold uppercase tracking-widest text-[#a16207] hover:text-[#fed7aa] transition-colors">WhatsApp</a><% } %>
        </div>
      </div>
      <p class="text-center text-xs text-[#a16207] mt-10 uppercase tracking-widest">Powered by TuFerIA</p>
    </div>
  </footer>

  <script>
  async function addToCart(productId, variantId, quantity) {
    const q = quantity || 1; const v = variantId || null;
    const r = await fetch('/api/cart/add', { method: 'POST', headers: { 'Content-Type': 'application/json' }, body: JSON.stringify({ store_id: '<%= store.id %>', product_id: productId, variant_id: v, quantity: q }) });
    const d = await r.json(); if (d.success) { location.reload(); } else { alert(d.error || 'Error'); }
  }
  async function addComboToCart(comboId) {
    const r = await fetch('/api/cart/combo', { method: 'POST', headers: { 'Content-Type': 'application/json' }, body: JSON.stringify({ store_id: '<%= store.id %>', combo_id: comboId }) });
    const d = await r.json(); if (d.success) { location.reload(); } else { alert(d.error || 'Error'); }
  }
  </script>
</body>
</html>