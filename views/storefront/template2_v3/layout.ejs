<!DOCTYPE html>
<html lang="es">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= (title || store.name || '') %></title>
  <script src="https://cdn.tailwindcss.com"></script>
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Archivo+Black&family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet">
  <style>
    <% let tc = {}; try { tc = JSON.parse(store.theme_settings || '{}'); } catch(e) {} const col = tc.colors || {}; const fonts = tc.fonts || {}; const hdr = tc.header || {}; %>
    body { font-family: '<%= fonts.body || 'Inter' %>', sans-serif; background: <%= col.body_bg || '#fafafa' %>; color: <%= col.body_text || '#0f0f0f' %>; }
    h1,h2,h3 { font-family: 'Archivo Black', sans-serif; font-weight: 400; letter-spacing: -0.03em; text-transform: uppercase; }
    :root { --primary: <%= col.btn_primary_bg || '#0f0f0f' %>; --accent: <%= col.btn_secondary_bg || '#e5e5e5' %>; --body-bg: <%= col.body_bg || '#fafafa' %>; --body-text: <%= col.body_text || '#0f0f0f' %>; --btn-primary-bg: <%= col.btn_primary_bg || '#0f0f0f' %>; --btn-primary-text: <%= col.btn_primary_text || '#ffffff' %>; --footer-bg: <%= col.footer_bg || '#0f0f0f' %>; --footer-text: <%= col.footer_text || '#737373' %>; }
    body { background-color: var(--body-bg); color: var(--body-text); }
    .product-card { background: #fff; border: 2px solid #e5e5e5; border-radius: 0; transition: all 0.2s ease; overflow: hidden; }
    .product-card:hover { border-color: #0f0f0f; transform: scale(0.98); }
    .btn-primary { background: #0f0f0f; color: #fff; border-radius: 0; font-weight: 700; text-transform: uppercase; letter-spacing: 0.05em; font-size: 0.75rem; padding: 0.875rem 1.75rem; }
    .btn-primary:hover { background: #333; }
    .section-title { font-family: 'Archivo Black', sans-serif; font-weight: 400; letter-spacing: -0.03em; text-transform: uppercase; font-size: 1.5rem; }
    .street-divider { height: 4px; width: 60px; background: #0f0f0f; }
    .grid-gap-1 { gap: 1px; }
    .bw-filter img { filter: grayscale(100%); transition: filter 0.3s ease; }
    .bw-filter:hover img { filter: grayscale(0%); }
    <% if (store.advanced_css) { %><%= store.advanced_css %><% } %>
  </style>
</head>
<body>
  <nav class="bg-white border-b-2 border-black sticky top-0 z-40">
    <div class="max-w-7xl mx-auto px-4 lg:px-8">
      <div class="flex items-center justify-between h-16">
        <a href="/<%= store.slug %>" class="flex items-center gap-2">
          <% if (store.logo) { %><img src="<%= store.logo %>" alt="<%= store.name %>" class="h-8 w-auto"><% } else { %><span class="text-lg font-black uppercase tracking-tight text-black"><%= store.name %></span><% } %>
        </a>
        <div class="hidden md:flex items-center gap-6">
          <%- include('../../partials/_nav_links', { locals: { navLinkClass: 'text-sm font-bold uppercase tracking-wide text-black hover:text-gray-500 transition-colors' } }) %>
        </div>
        <a href="/<%= store.slug %>/carrito" class="relative p-2">
          <svg class="w-5 h-5 text-black" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15.75 10.5V6a3.75 3.75 0 10-7.5 0v4.5m11.356-1.993l1.263 12c.07.665-.45 1.243-1.119 1.243H4.25a1.125 1.125 0 01-1.12-1.243l1.264-12A1.125 1.125 0 015.513 7.5h12.974c.576 0 1.059.435 1.119 1.007zM8.625 10.5a.375.375 0 11-.75 0 .375.375 0 01.75 0zm7.5 0a.375.375 0 11-.75 0 .375.375 0 01.75 0z"/></svg>
          <% if (cartCount > 0) { %><span class="absolute -top-1 -right-1 w-5 h-5 bg-black text-white text-[10px] font-bold rounded-full flex items-center justify-center"><%= cartCount %></span><% } %>
        </a>
      
            <%- include('../../partials/_mobile_menu', { locals: { iconColor: 'text-gray-600' } }) %>
</div>
    </div>
  </nav>

  <main>
    <%- include('../../partials/_flash', { locals }); %>
    <% if (page === 'home') { %>
      <section class="bg-black text-white py-20 lg:py-28">
        <div class="max-w-7xl mx-auto px-4 lg:px-8">
          <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 items-center">
            <div>
              <span class="text-xs font-bold uppercase tracking-widest text-gray-400 mb-4 block">Nueva Colección</span>
              <h1 class="text-6xl lg:text-7xl font-black uppercase tracking-tight leading-[0.9] mb-6"><%= store.name %></h1>
              <div class="street-divider bg-white mb-6"></div>
              <p class="text-gray-400 mb-8 text-lg"><%= store.description %></p>
              <a href="/<%= store.slug %>/tienda" class="btn-primary inline-flex items-center gap-2 bg-white text-black hover:bg-gray-200">Comprar <span>→</span></a>
            </div>
            <div class="bw-filter">
              <%- include('../../partials/_hero_carousel', { images: heroImages, fallback: store.banner, className: 'rounded-none', height: 'h-80' }); %>
            </div>
          </div>
        </div>
      </section>

      <div class="max-w-7xl mx-auto px-4 lg:px-8 py-20">
        <% if (categories.length > 0) { %>
          <div class="flex flex-wrap gap-2 mb-16 border-b-2 border-black pb-4">
            <a href="/<%= store.slug %>" class="text-xs font-bold uppercase tracking-widest text-black mr-3">Todos</a>
            <% categories.forEach(c => { %>
              <a href="/<%= store.slug %>/categoria/<%= c.name.toLowerCase().replace(/ /g, '-') %>" class="text-xs font-bold uppercase tracking-widest text-gray-400 hover:text-black transition-colors mr-3"><%= c.name %></a>
            <% }); %>
          </div>
        <% } %>

        <% if (store.about_text) { %>
          <div class="max-w-2xl mb-16">
            <div class="street-divider mb-4"></div>
            <p class="text-gray-600 text-lg leading-relaxed"><%= store.about_text %></p>
          </div>
        <% } %>

        <% if (products.length > 0) { %>
          <div class="grid grid-cols-2 md:grid-cols-3 lg:grid-cols-4 gap-6">
            <% products.forEach(p => { %><%- include('../../partials/_product_card', { product: p, store, locals }); %><% }); %>
          </div>
        <% } else { %>
          <div class="text-center py-16 text-gray-400 font-bold uppercase tracking-wider text-lg">Próximamente...</div>
        <% } %>
      </div>
    <% } else if (page === 'category') { %>
      <div class="max-w-7xl mx-auto px-4 lg:px-8 py-12">
        <a href="/<%= store.slug %>" class="inline-flex items-center gap-2 text-xs font-bold uppercase tracking-widest text-gray-500 hover:text-black transition-colors mb-8"><svg class="w-3 h-3" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 12H5m7-7l-7 7 7 7"/></svg> Volver</a>
        <h1 class="text-4xl font-black uppercase tracking-tight text-black mb-8"><%= category.name %></h1>
        <div class="grid grid-cols-2 md:grid-cols-3 lg:grid-cols-4 gap-6"><% products.forEach(p => { %><%- include('../../partials/_product_card', { product: p, store, locals }); %><% }); %></div>
      </div>
    <% } else if (page === 'product') { %>
      <%- include('../../partials/_product_detail', { product, store, locals }); %>
    <% } else if (page === 'cart') { %>
      <%- include('../../partials/_cart', { store, locals }); %>
    <% } else if (page === 'checkout') { %>
      <%- include('../../partials/_checkout', { store, locals }); %>
    <% } else { %>
      <%- include('../../partials/_page_content', { store, locals }); %>
    <% } %>
  </main>

  <footer class="bg-black text-white py-16 mt-20">
    <div class="max-w-7xl mx-auto px-4 lg:px-8">
      <div class="flex flex-col md:flex-row items-center justify-between gap-6">
        <div>
          <h3 class="text-lg font-black uppercase tracking-tight"><%= store.name %></h3>
          <% if (store.description) { %><p class="text-sm text-gray-500 mt-2"><%= store.description %></p><% } %>
        </div>
        <div class="flex gap-6">
          <% if (store.instagram) { %><a href="https://instagram.com/<%= store.instagram %>" target="_blank" class="text-gray-500 hover:text-white transition-colors text-xs font-bold uppercase tracking-widest">Instagram</a><% } %>
          <% if (store.whatsapp) { %><a href="https://wa.me/<%= store.whatsapp %>" target="_blank" class="text-gray-500 hover:text-white transition-colors text-xs font-bold uppercase tracking-widest">WhatsApp</a><% } %>
        </div>
      </div>
      <p class="text-center text-xs text-gray-600 mt-10 uppercase tracking-widest">Powered by TuFerIA</p>
    </div>
  </footer>

  <script>
  async function addToCart(productId, variantId, quantity) {
    const q = quantity || 1; const v = variantId || null;
    const r = await fetch('/api/cart/add', { method: 'POST', headers: { 'Content-Type': 'application/json' }, body: JSON.stringify({ store_id: '<%= store.id %>', product_id: productId, variant_id: v, quantity: q }) });
    const d = await r.json(); if (d.success) { location.reload(); } else { alert(d.error || 'Error'); }
  }
  async function addComboToCart(comboId) {
    const r = await fetch('/api/cart/combo', { method: 'POST', headers: { 'Content-Type': 'application/json' }, body: JSON.stringify({ store_id: '<%= store.id %>', combo_id: comboId }) });
    const d = await r.json(); if (d.success) { location.reload(); } else { alert(d.error || 'Error'); }
  }
  </script>
</body>
</html>