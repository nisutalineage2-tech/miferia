<!DOCTYPE html>
<html lang="es">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= (title || store.name || '') %></title>
  <script src="https://cdn.tailwindcss.com"></script>
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800;900&family=Space+Grotesk:wght@400;500;600;700&display=swap" rel="stylesheet">
  <style>
    <% let _tc2 = {}; try { _tc2 = JSON.parse(store.theme_settings || '{}'); } catch(e) {} const _col2 = _tc2.colors || {}; %>
    body { font-family: 'Inter', sans-serif; background-color: <%= _col2.body_bg || '#fafafa' %>; color: <%= _col2.body_text || '#374151' %>; }
    h1,h2,h3,.fw-heading { font-family: 'Space Grotesk', sans-serif; font-weight: 700; letter-spacing: -0.02em; }
    :root { --primary: <%= _col2.btn_primary_bg || store.primary_color || '#171717' %>; --accent: <%= _col2.btn_secondary_bg || store.accent_color || '#fafafa' %>; --footer-bg: <%= _col2.footer_bg || '#111827' %>; --footer-text: <%= _col2.footer_text || '#9ca3af' %>; }
    .product-card { background: #fff; border: 1px solid #e5e5e5; transition: all 0.4s cubic-bezier(0.4,0,0.2,1); border-radius: 0; }
    .product-card:hover { transform: translateY(-8px); box-shadow: 0 30px 60px rgba(0,0,0,0.1); }
    .category-chip { transition: all 0.2s ease; border-radius: 0 !important; border: 1px solid #e5e5e5; }
    .category-chip:hover { border-color: #171717; }
    .btn-fashion { background: #171717; color: #fff; font-weight: 600; letter-spacing: 0.05em; text-transform: uppercase; font-size: 0.75rem; padding: 0.75rem 2rem; transition: all 0.2s; }
    .btn-fashion:hover { background: #404040; }
  </style>
</head>
<body class="bg-[#fafafa] text-gray-900">
  <!-- Navbar -->
  <nav class="bg-white border-b border-gray-100 sticky top-0 z-40">
    <div class="max-w-7xl mx-auto px-4">
      <div class="flex items-center justify-between h-16">
        <a href="/<%= store.slug %>" class="flex items-center gap-2 shrink-0">
          <% if (store.logo) { %><img src="<%= store.logo %>" alt="<%= store.name %>" class="h-8 w-auto"><% } else { %><span class="text-xl font-black tracking-tight" style="color: #171717;"><%= store.name %></span><% } %>
        </a>
        <div class="hidden md:flex items-center gap-6">
          <%- include('../../partials/_nav_links', { locals: { navLinkClass: 'text-xs font-semibold tracking-widest uppercase text-gray-600 hover:text-black transition-colors' } }) %>
        </div>
        <a href="/<%= store.slug %>/carrito" class="relative p-2"><svg class="w-5 h-5 text-gray-700" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M16 11V7a4 4 0 00-8 0v4M5 9h14l1 12H4L5 9z"/></svg><% if (cartCount > 0) { %><span class="absolute -top-1 -right-1 w-5 h-5 rounded-full text-xs font-bold text-white flex items-center justify-center" style="background: #000;"><%= cartCount %></span><% } %></a>
      
            <%- include('../../partials/_mobile_menu', { locals: { iconColor: 'text-gray-600' } }) %>
</div>
    </div>
  </nav>

  <main>
    <%- include('../../partials/_flash', { locals }); %>
    <% if (page === 'home') { %>
      <!-- HERO FASHION -->
      <div class="bg-white border-b border-gray-100">
        <div class="max-w-7xl mx-auto px-4 py-16 lg:py-24">
          <div class="flex flex-col lg:flex-row items-center gap-8 lg:gap-16">
            <div class="flex-1">
              <p class="text-xs font-semibold tracking-[0.2em] uppercase text-gray-400 mb-4">FW 2026</p>
              <h1 class="text-5xl lg:text-7xl font-black tracking-tight text-gray-900 leading-none mb-4 fw-heading"><%= store.name %></h1>
              <p class="text-gray-500 text-lg mb-8 max-w-md"><%= store.description %></p>
              <a href="/<%= store.slug %>/tienda" class="btn-fashion inline-flex items-center gap-2">Ver Colección <span>→</span></a>
            </div>
            <div class="flex-1"><%- include('../../partials/_hero_carousel', { images: heroImages, fallback: store.banner, className: '', height: 'h-64 lg:h-96' }); %></div>
          </div>
        </div>
      </div>

      <div class="max-w-7xl mx-auto px-4 py-8 lg:py-12">
        <!-- Categories Grid -->
        <% if (categories.length > 0) { %>
          <div class="grid grid-cols-2 sm:grid-cols-3 md:grid-cols-4 lg:grid-cols-6 gap-3 mb-12">
            <% categories.forEach(c => { %>
              <a href="/<%= store.slug %>/categoria/<%= c.name.toLowerCase().replace(/ /g, '-') %>"
                class="category-chip p-4 rounded-2xl bg-white border border-gray-100 shadow-sm text-center hover:shadow-md"
                style="--hover-color: var(--primary)">
                <div class="w-10 h-10 mx-auto rounded-xl flex items-center justify-center mb-2" style="background-color: color-mix(in srgb, var(--primary) 20%, white);">
                  <svg class="w-5 h-5" style="color: var(--primary)" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 11H5m14 0a2 2 0 012 2v6a2 2 0 01-2 2H5a2 2 0 01-2-2v-6a2 2 0 012-2m14 0V9a2 2 0 00-2-2M5 11V9a2 2 0 012-2m0 0V5a2 2 0 012-2h6a2 2 0 012 2v2M7 7h10"/>
                  </svg>
                </div>
                <span class="text-xs font-semibold text-gray-700 block leading-tight"><%= c.name %></span>
              </a>
            <% }); %>
          </div>
        <% } %>

        <!-- Featured -->
        <% if (featured.length > 0) { %>
          <section class="mb-12">
            <h2 class="text-2xl lg:text-3xl font-extrabold text-gray-900 mb-6">✨ Destacados</h2>
            <div class="grid grid-cols-2 md:grid-cols-3 lg:grid-cols-4 gap-4 lg:gap-6">
              <% featured.forEach(p => { %>
                <%- include('../../partials/_product_card', { product: p, store, locals }); %>
              <% }); %>
            </div>
          </section>
        <% } %>

        <!-- Products -->
        <section>
          <h2 class="text-2xl lg:text-3xl font-extrabold text-gray-900 mb-6">Catálogo</h2>
          <% if (products.length > 0) { %>
            <div class="grid grid-cols-2 md:grid-cols-3 lg:grid-cols-4 gap-4 lg:gap-6">
              <% products.forEach(p => { %>
                <%- include('../../partials/_product_card', { product: p, store, locals }); %>
              <% }); %>
            </div>
          <% } else { %>
            <div class="text-center py-16 text-gray-400 bg-white rounded-2xl">Próximamente</div>
          <% } %>
        </section>

        <!-- Combos -->
        <% if (combos.length > 0) { %>
          <section class="mt-12">
            <h2 class="text-2xl lg:text-3xl font-extrabold text-gray-900 mb-6">🔥 Combos</h2>
            <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-6">
              <% combos.forEach(combo => { %>
                <div class="p-6 rounded-2xl bg-white border-2 shadow-lg" style="border-color: color-mix(in srgb, var(--primary) 30%, transparent);">
                  <h3 class="text-lg font-bold"><%= combo.name %></h3>
                  <p class="text-sm text-gray-500 mb-3"><%= combo.description %></p>
                  <p class="text-2xl font-extrabold" style="color: var(--primary)">$<%= combo.price.toFixed(2) %></p>
                  <button onclick="addComboToCart('<%= combo.id %>')" class="mt-3 w-full px-4 py-3 text-sm font-bold text-white rounded-xl transition-all hover:opacity-90" style="background: linear-gradient(135deg, var(--primary), var(--accent));">
                    Agregar
                  </button>
                </div>
              <% }); %>
            </div>
          </section>
        <% } %>
      </div>

    <% } else if (page === 'category') { %>
      <div class="max-w-7xl mx-auto px-4 py-8">
        <a href="/<%= store.slug %>" class="text-sm text-gray-500 hover:text-gray-700">← Volver</a>
        <h1 class="text-3xl font-extrabold text-gray-900 mt-4 mb-8"><%= category.name %></h1>
        <% if (products.length > 0) { %>
          <div class="grid grid-cols-2 md:grid-cols-3 lg:grid-cols-4 gap-4 lg:gap-6">
            <% products.forEach(p => { %>
              <%- include('../../partials/_product_card', { product: p, store, locals }); %>
            <% }); %>
          </div>
        <% } else { %>
          <div class="text-center py-16 text-gray-400">No hay productos en esta categoría</div>
        <% } %>
      </div>

    <% } else if (page === 'product') { %>
      <%- include('../../partials/_product_detail', { store, product, variants, productImages, categories, related, cartCount, cartTotal, locals }); %>

    <% } else if (page === 'cart') { %>
      <%- include('../../partials/_cart', { store, categories, cartItems, cartCount, cartTotal, locals }); %>

    <% } else if (page === 'checkout') { %>
      <%- include('../../partials/_checkout', { store, categories, cartItems, cartCount, cartTotal, locals }); %>
    <% } else if (['shop','subscriptions','about','contact','login','register','account'].includes(page)) { %>
      <%- include('../../partials/_page_content', { page, store, categories, products, featured, combos, cartItems, cartCount, cartTotal, query: typeof query !== 'undefined' ? query : {}, priceRange: typeof priceRange !== 'undefined' ? priceRange : null, filterSettings: typeof filterSettings !== 'undefined' ? filterSettings : {}, filterData: typeof filterData !== 'undefined' ? filterData : {}, error: typeof error !== 'undefined' ? error : null, msg: typeof msg !== 'undefined' ? msg : null, customer: typeof customer !== 'undefined' ? customer : null, orders: typeof orders !== 'undefined' ? orders : null }); %>
    <% } %>
  </main>

  <!-- Footer -->
  <footer class="bg-gray-900 mt-16">
    <div class="max-w-7xl mx-auto px-4 py-12">
      <div class="grid md:grid-cols-3 gap-8">
        <div>
          <h3 class="text-white font-bold text-lg mb-2"><%= store.name %></h3>
          <p class="text-gray-400 text-sm"><%= store.description %></p>
        </div>
        <div>
          <h4 class="text-gray-300 font-semibold mb-3">Categorías</h4>
          <ul class="space-y-2">
            <% categories.forEach(c => { %>
              <li><a href="/<%= store.slug %>/categoria/<%= c.name.toLowerCase().replace(/ /g, '-') %>" class="text-sm text-gray-500 hover:text-gray-300"><%= c.name %></a></li>
            <% }); %>
          </ul>
        </div>
        <div>
          <h4 class="text-gray-300 font-semibold mb-3">Contacto</h4>
          <div class="flex gap-3">
            <% if (store.whatsapp) { %>
              <a href="https://wa.me/<%= store.whatsapp %>" target="_blank" class="text-gray-500 hover:text-green-400"><svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/></svg></a>
            <% } %>
            <% if (store.instagram) { %>
              <a href="https://instagram.com/<%= store.instagram.replace('@', '') %>" target="_blank" class="text-gray-500 hover:text-pink-400"><svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24"><path d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zm0-2.163c-3.259 0-3.667.014-4.947.072-4.358.2-6.78 2.618-6.98 6.98-.059 1.281-.073 1.689-.073 4.948 0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98 1.281.058 1.689.072 4.948.072 3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98-1.281-.059-1.69-.073-4.949-.073zm0 5.838c-3.403 0-6.162 2.759-6.162 6.162s2.759 6.163 6.162 6.163 6.162-2.759 6.162-6.163c0-3.403-2.759-6.162-6.162-6.162zm0 10.162c-2.209 0-4-1.79-4-4 0-2.209 1.791-4 4-4s4 1.791 4 4c0 2.21-1.791 4-4 4zm6.406-11.845c-.796 0-1.441.645-1.441 1.44s.645 1.44 1.441 1.44c.795 0 1.439-.645 1.439-1.44s-.644-1.44-1.439-1.44z"/></svg></a>
            <% } %>
          </div>
        </div>
      </div>
      <div class="border-t border-gray-800 mt-8 pt-8 text-center text-sm text-gray-600">© 2026 <%= store.name %>. TuFerIA</div>
    </div>
  </footer>

  <script>
    async function addToCart(productId, variantId = null, quantity = 1) {
      const res = await fetch('/api/cart/add', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ store_id: '<%= store.id %>', product_id: productId, variant_id: variantId, quantity })
      });
      const data = await res.json();
      if (data.success) location.reload();
    }
    async function addComboToCart(comboId) {
      const res = await fetch('/api/cart/add', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ store_id: '<%= store.id %>', combo_id: comboId, quantity: 1 })
      });
      const data = await res.json();
      if (data.success) location.reload();
    }
  </script>
</body>
</html>
