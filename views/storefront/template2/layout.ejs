<% const t = store.theme_settings ? JSON.parse(store.theme_settings) : {}; const c = t.colors || {}; %>
<% const isHome = !page || page === 'home'; %>
<% const isShop = page === 'shop'; %>
<% const isProduct = page === 'product'; %>
<% const isCart = page === 'cart'; %>
<% const isCheckout = page === 'checkout'; %>
<% const isCategory = page === 'category'; %>
<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= store.name || 'Store' %><%= typeof pageTitle !== 'undefined' ? ' — ' + pageTitle : '' %></title>
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Oswald:wght@300;400;500;600;700&family=Inter:wght@300;400;500;600;700&display=swap" rel="stylesheet">
  <script src="https://cdn.tailwindcss.com"></script>
  <script>
    tailwind.config = {
      theme: {
        extend: {
          fontFamily: {
            oswald: ['Oswald', 'sans-serif'],
            inter: ['Inter', 'sans-serif']
          },
          colors: {
            primary: 'var(--primary)',
            bg: 'var(--bg)',
            text: 'var(--text)',
          }
        }
      }
    }
  </script>
  <style>
    :root {
      --primary: <%= c.btn_primary_bg || '#e11d48' %>;
      --bg: <%= c.page_bg || '#ffffff' %>;
      --text: <%= c.text || '#1a1a1a' %>;
      --footer-bg: <%= c.footer_bg || '#0a0a0a' %>;
      --footer-text: <%= c.footer_text || '#a3a3a3' %>;
      --title: <%= c.heading_color || '#0a0a0a' %>;
      --label-bg: <%= c.label_bg || '#fee2e2' %>;
    }
    * { font-family: 'Inter', sans-serif; }
    h1,h2,h3,h4,h5,h6 { font-family: 'Oswald', sans-serif; text-transform: uppercase; letter-spacing: 0.02em; color: var(--title); }
    body { background: var(--bg); color: var(--text); }
    .editorial-card { box-shadow: 6px 6px 0 var(--primary); border: 1px solid #e5e7eb; transition: transform 0.2s; }
    .editorial-card:hover { transform: translate(-2px, -2px); box-shadow: 8px 8px 0 var(--primary); }
    .fullscreen-menu { position: fixed; inset: 0; z-index: 100; background: rgba(10,10,10,0.97); display: none; align-items: center; justify-content: center; }
    .fullscreen-menu.active { display: flex; }
    .fullscreen-menu a { font-family: 'Oswald', sans-serif; font-size: 3rem; text-transform: uppercase; color: #fff; letter-spacing: 0.05em; transition: color 0.2s; }
    .fullscreen-menu a:hover { color: var(--primary); }
    .asymmetric-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 1.5rem; }
    @media(min-width:1024px) { .asymmetric-grid > *:first-child { grid-column: span 2; } }
  </style>
</head>
<body class="antialiased min-h-screen flex flex-col">
  <%- include('../../partials/_flash', { locals }); %>
  <%- include('../../partials/_cart_drawer', { store, storeBaseUrl }); %>
  <%- include('../../partials/_order_success', { locals }); %>

  <!-- NAV -->
  <nav class="bg-black text-white sticky top-0 z-40">
    <div class="max-w-7xl mx-auto px-6 py-4 flex items-center justify-between">
      <a href="<%= storeBaseUrl || '/' %>" class="font-oswald text-xl uppercase tracking-widest font-semibold">
        <%= store.name || 'Store' %>
      </a>
      <div class="flex items-center gap-5">
        <a href="<%= storeBaseUrl %>/carrito" class="relative">
          <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M3 3h2l.4 2M7 13h10l4-8H5.4M7 13L5.4 5M7 13l-2.3 2.3c-.4.4-.1 1.1.5 1.1H17m0 0a2 2 0 100 4 2 2 0 000-4zm-8 2a2 2 0 100 4 2 2 0 000-4z"/>
          </svg>
          <span class="cart-count absolute -top-2 -right-2 bg-rose-600 text-white text-[10px] w-4 h-4 rounded-full flex items-center justify-center"><%= cartCount || 0 %></span>
        </a>
        <button id="menuToggle" class="text-white" onclick="document.getElementById('fullscreenMenu').classList.add('active')">
          <svg xmlns="http://www.w3.org/2000/svg" class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M4 6h16M4 12h16M4 18h16"/>
          </svg>
        </button>
      </div>
    </div>
  </nav>

  <!-- FULLSCREEN OVERLAY MENU -->
  <div id="fullscreenMenu" class="fullscreen-menu">
    <button class="absolute top-6 right-6 text-white text-3xl" onclick="this.parentElement.classList.remove('active')">&times;</button>
    <div class="flex flex-col items-center gap-8">
      <a href="<%= storeBaseUrl || '/' %>" onclick="this.parentElement.parentElement.classList.remove('active')">Home</a>
      <%- include('../../partials/_nav_links', { store, storeBaseUrl, locals: { navLinkClass: '' } }); %>
    </div>
  </div>

  <!-- MAIN -->
  <main class="flex-1">
    <% if (isHome) { %>
      <%- include('../../partials/_banner_carousel', { heroImages, store, storeBaseUrl }); %>
      <%- include('../../partials/_home_content', { store, storeBaseUrl, categories, products, featured, combos, locals }); %>
    <% } else if (isProduct) { %>
      <div class="max-w-7xl mx-auto px-6 py-16">
        <%- include('../../partials/_product_detail', { product, productImages, variants, volumeDiscounts, category, related, store, storeBaseUrl, locals }); %>
      </div>
    <% } else if (isCart) { %>
      <div class="max-w-4xl mx-auto px-6 py-16">
        <%- include('../../partials/_cart', { cartItems, cartTotal, store, storeBaseUrl, locals }); %>
      </div>
    <% } else if (isCheckout) { %>
      <div class="max-w-4xl mx-auto px-6 py-16">
        <%- include('../../partials/_checkout', { cartItems, cartTotal, store, storeBaseUrl, locals }); %>
      </div>
    <% } else if (isCategory) { %>
      <div class="max-w-7xl mx-auto px-6 py-16">
        <h1 class="text-4xl font-bold mb-8"><%= category.name %></h1>
        <div class="asymmetric-grid">
          <% products.forEach(p => { %>
            <div class="editorial-card p-0">
              <%- include('../../partials/_product_card', { product: p, store, locals }); %>
            </div>
          <% }); %>
        </div>
      </div>
    <% } else if (isShop) { %>
      <div class="max-w-7xl mx-auto px-6 py-16">
        <h1 class="text-4xl font-bold mb-8">Shop</h1>
        <div class="asymmetric-grid">
          <% (products || []).forEach(p => { %>
            <div class="editorial-card p-0">
              <%- include('../../partials/_product_card', { product: p, store, locals }); %>
            </div>
          <% }); %>
        </div>
      </div>
    <% } else { %>
      <%- include('../../partials/_page_content', { page, store, storeBaseUrl, categories, products, featured, combos, locals }); %>
    <% } %>
  </main>

  <!-- FOOTER -->
  <footer class="bg-black text-white mt-20 py-16">
    <div class="max-w-7xl mx-auto px-6 grid grid-cols-1 md:grid-cols-3 gap-12">
      <div>
        <h3 class="text-lg uppercase tracking-widest mb-4"><%= store.name || 'Store' %></h3>
        <p class="text-gray-400 text-sm leading-relaxed">Quality products, delivered with care.</p>
      </div>
      <div>
        <h3 class="text-lg uppercase tracking-widest mb-4">Quick Links</h3>
        <div class="flex flex-col gap-2 text-gray-400 text-sm">
          <%- include('../../partials/_nav_links', { store, storeBaseUrl, locals: { navLinkClass: 'hover:text-white transition-colors' } }); %>
        </div>
      </div>
      <div>
        <h3 class="text-lg uppercase tracking-widest mb-4">Contact</h3>
        <p class="text-gray-400 text-sm">&copy; <%= new Date().getFullYear() %> <%= store.name || 'Store' %></p>
      </div>
    </div>
  </footer>

  <!-- MOBILE MENU -->
  <%- include('../../partials/_mobile_menu', { store, storeBaseUrl, locals: { iconColor: '#ffffff' } }); %>

  <script>
    function addToCart(productId, qty) {
      fetch((window.storeBaseUrl || '') + '/api/cart/add', {
        method: 'POST', headers: {'Content-Type':'application/x-www-form-urlencoded'},
        body: 'product_id=' + productId + '&qty=' + (qty||1)
      }).then(r=>r.json()).then(d=>{
        if(d.cartCount!==undefined) document.querySelectorAll('.cart-count').forEach(e=>e.textContent=d.cartCount);
        if(typeof toggleCartDrawer==='function') toggleCartDrawer();
      });
    }
    function addComboToCart(comboId) {
      fetch((window.storeBaseUrl || '') + '/api/combo/add', {
        method: 'POST', headers: {'Content-Type':'application/x-www-form-urlencoded'},
        body: 'combo_id=' + comboId + '&qty=1'
      }).then(r=>r.json()).then(d=>{
        if(d.cartCount!==undefined) document.querySelectorAll('.cart-count').forEach(e=>e.textContent=d.cartCount);
        if(typeof toggleCartDrawer==='function') toggleCartDrawer();
      });
    }
    window.storeBaseUrl = '<%= storeBaseUrl %>';
  </script>
</body>
</html>
