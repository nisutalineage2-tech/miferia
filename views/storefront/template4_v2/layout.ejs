<!DOCTYPE html>
<html lang="es">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= (title || store.name || '') %></title>
  <script src="https://cdn.tailwindcss.com"></script>
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@700;800;900&family=JetBrains+Mono:wght@400;500&family=Plus+Jakarta+Sans:wght@400;500;600&display=swap" rel="stylesheet">
  <style>
    <% let _col4 = {}; let hdr = {}; try { const _t4 = JSON.parse(store.theme_settings || '{}'); _col4 = _t4.colors || {}; hdr = _t4.header || {}; } catch(e) {} %>
    body { font-family: 'Plus Jakarta Sans', sans-serif; background: <%= _col4.body_bg || '#0d0f13' %>; color: <%= _col4.body_text || '#e0e6ed' %>; }
    h1,h2,h3 { font-family: 'Inter', sans-serif; font-weight: 900; letter-spacing: -0.03em; }
    .mono { font-family: 'JetBrains Mono', monospace; }
    :root { --primary: <%= _col4.btn_primary_bg || '#00ff88' %>; --accent: <%= _col4.btn_secondary_bg || '#ff0066' %>; --footer-bg: <%= _col4.footer_bg || '#0d0f13' %>; --footer-text: <%= _col4.footer_text || '#6b7280' %>; }
    .product-card { background: #15181e; border: 1px solid #1f2937; border-radius: 16px; transition: all 0.2s ease; overflow: hidden; }
    .product-card:hover { border-color: #00ff88; box-shadow: 0 0 30px rgba(0,255,136,0.1); transform: translateY(-2px); }
    .btn-primary { background: linear-gradient(135deg, #00ff88, #00cc66); color: #0d0f13; border-radius: 100px; font-weight: 700; }
    .btn-primary:hover { box-shadow: 0 0 30px rgba(0,255,136,0.3); }
    .section-title { font-family: 'Inter', sans-serif; font-weight: 900; letter-spacing: -0.03em; }
    .glow-text { text-shadow: 0 0 30px rgba(0,255,136,0.2); }
    .tech-border { border: 1px solid #1f2937; }
    .neon-glow { box-shadow: 0 0 20px rgba(0,255,136,0.05); }
    .product-card img { transition: transform 0.3s ease; }
    .product-card:hover img { transform: scale(1.02); }
    <% if (store.advanced_css) { %><%= store.advanced_css %><% } %>
  </style>
</head>
<body>
  <nav class="bg-[#0d0f13]/90 backdrop-blur-md border-b border-[#1f2937] sticky top-0 z-40">
    <div class="max-w-7xl mx-auto px-4 lg:px-8">
      <div class="flex items-center justify-between h-16">
        <a href="/<%= store.slug %>" class="flex items-center gap-2">
          <% if (store.logo) { %><img src="<%= store.logo %>" alt="<%= store.name %>" class="h-7 w-auto"><% } else { %><span class="text-lg font-black tracking-tight text-white mono"><%= store.name %></span><% } %>
        </a>
        <div class="hidden md:flex items-center gap-6">
          <%- include('../../partials/_nav_links', { locals: { navLinkClass: 'text-xs font-bold uppercase tracking-widest text-gray-400 hover:text-[#00ff88] transition-colors' } }) %>
        </div>
        <a href="/<%= store.slug %>/carrito" class="relative p-2">
          <svg class="w-5 h-5 text-gray-400" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M15.75 10.5V6a3.75 3.75 0 10-7.5 0v4.5m11.356-1.993l1.263 12c.07.665-.45 1.243-1.119 1.243H4.25a1.125 1.125 0 01-1.12-1.243l1.264-12A1.125 1.125 0 015.513 7.5h12.974c.576 0 1.059.435 1.119 1.007zM8.625 10.5a.375.375 0 11-.75 0 .375.375 0 01.75 0zm7.5 0a.375.375 0 11-.75 0 .375.375 0 01.75 0z"/></svg>
          <% if (cartCount > 0) { %><span class="absolute -top-1 -right-1 w-4 h-4 rounded-full text-[10px] font-bold text-black bg-[#00ff88] flex items-center justify-center"><%= cartCount %></span><% } %>
        </a>
      
            <%- include('../../partials/_mobile_menu', { locals: { iconColor: 'text-gray-600' } }) %>
</div>
    </div>
  </nav>

  <main>
    <%- include('../../partials/_flash', { locals }); %>
    <% if (page === 'home') { %>
      <section class="relative min-h-[80vh] flex items-center overflow-hidden">
        <div class="absolute inset-0">
          <%- include('../../partials/_hero_carousel', { images: heroImages, fallback: store.banner, className: 'w-full h-full', height: 'h-full' }); %>
          <div class="absolute inset-0" style="background: linear-gradient(135deg, rgba(13,15,19,0.95) 0%, rgba(13,15,19,0.6) 60%, transparent 100%);"></div>
        </div>
        <div class="relative max-w-7xl mx-auto px-4 lg:px-8 py-24">
          <div class="max-w-2xl">
            <span class="text-xs font-bold uppercase tracking-[0.25em] text-[#00ff88] mb-4 block mono">Next Gen Tech</span>
            <h1 class="text-6xl lg:text-8xl font-black text-white mb-6 leading-[0.9] glow-text"><%= store.name %></h1>
            <p class="text-lg text-gray-400 mb-10 max-w-lg"><%= store.description %></p>
            <a href="/<%= store.slug %>/tienda" class="btn-primary inline-flex items-center gap-2 px-8 py-4 text-sm uppercase tracking-wider">Explorar <span>→</span></a>
          </div>
        </div>
      </section>

      <% const _tc4 = (() => { try { return JSON.parse(store.theme_settings || '{}'); } catch(e) { return {}; } })(); const hp = _tc4.homepage || {}; const sectionsOrder = hp.sections_order || ['hero', 'categories', 'featured', 'products', 'combos', 'testimonials', 'newsletter', 'contact']; %>
      <% sectionsOrder.forEach(section => { %>

        <% if (section === 'categories' && hp.categories !== false && categories.length > 0) { %>
          <section class="py-16 lg:py-24">
            <div class="max-w-7xl mx-auto px-4 lg:px-8">
              <h2 class="section-title text-2xl text-white mb-8">Categorías</h2>
              <div class="flex flex-wrap gap-3">
                <a href="/<%= store.slug %>" class="px-6 py-3 rounded-full tech-border text-sm font-mono text-[#00ff88] hover:bg-[#00ff88] hover:text-black transition-all">// Todos</a>
                <% categories.forEach(c => { %>
                  <a href="/<%= store.slug %>/categoria/<%= c.name.toLowerCase().replace(/ /g, '-') %>" class="px-6 py-3 rounded-full tech-border text-sm font-mono text-gray-400 hover:border-[#00ff88] hover:text-[#00ff88] transition-all">// <%= c.name.toLowerCase() %></a>
                <% }); %>
              </div>
            </div>
          </section>
        <% } %>

        <% if (section === 'about' && store.about_text) { %>
          <section class="py-16">
            <div class="max-w-7xl mx-auto px-4 lg:px-8">
              <div class="max-w-2xl tech-border rounded-2xl p-8 neon-glow">
                <p class="text-gray-400 leading-relaxed text-lg"><%= store.about_text %></p>
              </div>
            </div>
          </section>
        <% } %>

        <% if (section === 'featured' && hp.featured !== false && featured.length > 0) { %>
          <section class="py-16 lg:py-24">
            <div class="max-w-7xl mx-auto px-4 lg:px-8">
              <h2 class="section-title text-2xl text-white mb-8">Destacados</h2>
              <div class="grid grid-cols-2 md:grid-cols-3 lg:grid-cols-4 gap-4"><% featured.forEach(p => { %><%- include('../../partials/_product_card', { product: p, store, locals }); %><% }); %></div>
            </div>
          </section>
        <% } %>

        <% if (section === 'products' && hp.products !== false && products.length > 0) { %>
          <section class="py-16 lg:py-24">
            <div class="max-w-7xl mx-auto px-4 lg:px-8">
              <h2 class="section-title text-2xl text-white mb-8">Productos</h2>
              <div class="grid grid-cols-2 md:grid-cols-3 lg:grid-cols-4 gap-4"><% products.forEach(p => { %><%- include('../../partials/_product_card', { product: p, store, locals }); %><% }); %></div>
            </div>
          </section>
        <% } %>

        <% if (section === 'combos' && hp.combos !== false && combos.length > 0) { %>
          <section class="py-16">
            <div class="max-w-7xl mx-auto px-4 lg:px-8">
              <h2 class="section-title text-2xl text-white mb-8">Combos</h2>
              <div class="grid grid-cols-2 md:grid-cols-3 lg:grid-cols-4 gap-4"><% combos.forEach(co => { %><%- include('../../partials/_combo_card', { combo: co, store, locals }); %><% }); %></div>
            </div>
          </section>
        <% } %>

        <% if (section === 'testimonials' && hp.testimonials !== false) { %>
          <section class="py-16 lg:py-24">
            <div class="max-w-7xl mx-auto px-4 lg:px-8 text-center">
              <h2 class="section-title text-2xl text-white mb-8 mono">&gt;&gt; TESTIMONIOS</h2>
              <p class="text-gray-500 italic">Sección disponible próximamente</p>
            </div>
          </section>
        <% } %>

      <% }); %>
    <% } else if (page === 'category') { %>
      <div class="max-w-7xl mx-auto px-4 lg:px-8 py-12">
        <a href="/<%= store.slug %>" class="inline-flex items-center gap-2 text-xs font-mono text-[#00ff88] hover:underline mb-8"><svg class="w-3 h-3" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 12H5m7-7l-7 7 7 7"/></svg> // Volver</a>
        <h1 class="text-4xl font-black text-white mb-8"><%= category.name %></h1>
        <div class="grid grid-cols-2 md:grid-cols-3 lg:grid-cols-4 gap-4"><% products.forEach(p => { %><%- include('../../partials/_product_card', { product: p, store, locals }); %><% }); %></div>
      </div>
    <% } else if (page === 'product') { %>
      <%- include('../../partials/_product_detail', { product, store, locals }); %>
    <% } else if (page === 'cart') { %>
      <%- include('../../partials/_cart', { store, locals }); %>
    <% } else if (page === 'checkout') { %>
      <%- include('../../partials/_checkout', { store, locals }); %>
    <% } else { %>
      <%- include('../../partials/_page_content', { store, locals }); %>
    <% } %>
  </main>

  <footer class="border-t border-[#1f2937] py-12 mt-20">
    <div class="max-w-7xl mx-auto px-4 lg:px-8">
      <div class="flex flex-col md:flex-row items-center justify-between gap-6">
        <div>
          <h3 class="text-lg font-black text-white mono"><%= store.name %></h3>
          <% if (store.description) { %><p class="text-sm text-gray-500 mt-2"><%= store.description %></p><% } %>
        </div>
        <div class="flex gap-6">
          <% if (store.instagram) { %><a href="https://instagram.com/<%= store.instagram %>" target="_blank" class="text-xs font-mono text-gray-500 hover:text-[#00ff88] transition-colors">[instagram]</a><% } %>
          <% if (store.whatsapp) { %><a href="https://wa.me/<%= store.whatsapp %>" target="_blank" class="text-xs font-mono text-gray-500 hover:text-[#00ff88] transition-colors">[whatsapp]</a><% } %>
        </div>
      </div>
      <p class="text-center text-xs text-gray-600 mt-8 font-mono">// Powered by TuFerIA</p>
    </div>
  </footer>

  <script>
  async function addToCart(productId, variantId, quantity) {
    const q = quantity || 1; const v = variantId || null;
    const r = await fetch('/api/cart/add', { method: 'POST', headers: { 'Content-Type': 'application/json' }, body: JSON.stringify({ store_id: '<%= store.id %>', product_id: productId, variant_id: v, quantity: q }) });
    const d = await r.json(); if (d.success) { location.reload(); } else { alert(d.error || 'Error'); }
  }
  async function addComboToCart(comboId) {
    const r = await fetch('/api/cart/combo', { method: 'POST', headers: { 'Content-Type': 'application/json' }, body: JSON.stringify({ store_id: '<%= store.id %>', combo_id: comboId }) });
    const d = await r.json(); if (d.success) { location.reload(); } else { alert(d.error || 'Error'); }
  }
  </script>
</body>
</html>