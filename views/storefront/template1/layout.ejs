<!DOCTYPE html>
<html lang="es">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= (title || store.name || '') %></title>
  <script src="https://cdn.tailwindcss.com"></script>
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&family=Playfair+Display:ital,wght@0,400;0,600;0,700;1,400&display=swap" rel="stylesheet">
  <style>
    <% 
      let tc = {};
      try { tc = JSON.parse(store.theme_settings || '{}'); } catch(e) {}
      const col = tc.colors || {};
      const fonts = tc.fonts || {};
      const hdr = tc.header || {};
      const sbg = tc.site_bg || {};
    %>
    body { font-family: '<%= fonts.body || 'Inter' %>', sans-serif; background: #fff5f5; color: #831843; }
    h1,h2,h3 { font-family: 'Playfair Display', Georgia, serif; font-weight: 600; }
    :root {
      --primary: #db2777; --accent: #fdf2f8;
      --body-bg: <%= col.body_bg || '#fff5f5' %>;
      --body-text: <%= col.body_text || '#831843' %>;
      --btn-primary-bg: <%= col.btn_primary_bg || '#db2777' %>;
      --btn-primary-text: <%= col.btn_primary_text || '#ffffff' %>;
      --footer-bg: <%= col.footer_bg || '#831843' %>;
      --footer-text: <%= col.footer_text || '#fbcfe8' %>;
    }
    body { background-color: var(--body-bg); color: var(--body-text); }
    .product-card { background: #fff; border: 1px solid #fce7f3; border-radius: 16px; transition: all 0.3s ease; overflow: hidden; }
    .product-card:hover { transform: translateY(-4px); box-shadow: 0 12px 40px rgba(219,39,119,0.1); border-color: #db2777; }
    .btn-primary { background: linear-gradient(135deg, #db2777, #be185d); color: #fff; border-radius: 9999px; font-weight: 600; }
    .section-title-serif { font-family: 'Playfair Display', serif; font-weight: 600; letter-spacing: -0.01em; }
    <% if (store.advanced_css) { %><%= store.advanced_css %><% } %>
  </style>
</head>
<body class="bg-gray-50 text-gray-900">
  <!-- Navbar -->
  <nav class="bg-white/90 backdrop-blur-sm shadow-sm sticky top-0 z-40 border-b border-pink-100">
    <div class="max-w-7xl mx-auto px-4">
      <div class="flex items-center justify-between h-16">
        <a href="/<%= store.slug %>" class="flex items-center gap-2 shrink-0">
          <% if (store.logo) { %><img src="<%= store.logo %>" alt="<%= store.name %>" class="h-8 w-auto"><% } else { %><span class="text-xl font-bold" style="color: var(--primary)"><%= store.name %></span><% } %>
        </a>
        <div class="hidden md:flex items-center gap-6">
          <%- include('../../partials/_nav_links', { locals: { navLinkClass: 'text-sm font-medium text-pink-700/70 hover:text-pink-900 transition-colors' } }) %>
        </div>
        <a href="/<%= store.slug %>/carrito" class="relative p-2"><svg class="w-5 h-5 text-pink-700" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M16 11V7a4 4 0 00-8 0v4M5 9h14l1 12H4L5 9z"/></svg><% if (cartCount > 0) { %><span class="absolute -top-1 -right-1 w-5 h-5 rounded-full text-xs font-bold text-white flex items-center justify-center" style="background: var(--primary)"><%= cartCount %></span><% } %></a>
      
            <%- include('../../partials/_mobile_menu', { locals: { iconColor: 'text-pink-700/70' } }) %>
</div>
    </div>
  </nav>

  <main>
    <%- include('../../partials/_flash', { locals }); %>
    
    <% if (page === 'home') { %>
      <!-- HERO BEAUTY -->
      <div class="relative overflow-hidden group" style="background: linear-gradient(135deg, #fdf2f8, #fce7f3, #fbcfe8);">
        <div class="max-w-7xl mx-auto px-4 py-12 lg:py-16">
          <div class="text-center max-w-2xl mx-auto">
            <span class="inline-block px-3 py-1 rounded-full bg-white/60 text-pink-700 text-xs font-semibold mb-4">✨ Belleza y Bienestar</span>
            <h1 class="text-4xl lg:text-5xl text-pink-900 mb-4" style="font-family: 'Playfair Display', serif;"><%= store.name %></h1>
            <p class="text-pink-700/70 text-lg mb-6"><%= store.description %></p>
            <%- include('../../partials/_hero_carousel', { images: heroImages, fallback: store.banner, className: 'rounded-2xl shadow-lg', height: 'h-48 lg:h-64' }); %>
          </div>
        </div>
      </div>

      <div class="max-w-7xl mx-auto px-4 py-8 lg:py-12">

        <!-- Categories Grid -->
        <% if (categories.length > 0) { %>
          <div class="flex flex-wrap justify-center gap-2 mb-10">
            <% categories.forEach(c => { %>
              <a href="/<%= store.slug %>/categoria/<%= c.name.toLowerCase().replace(/ /g, '-') %>"
                class="px-5 py-2.5 rounded-full text-sm font-medium bg-gray-100 text-gray-700 hover:bg-gray-200 transition-colors">
                <%= c.name %>
              </a>
            <% }); %>
          </div>
        <% } %>

        <!-- Featured Products -->
        <% if (featured.length > 0) { %>
          <h2 class="text-2xl font-bold text-gray-900 mb-6">🌟 Destacados</h2>
          <div class="grid grid-cols-2 md:grid-cols-3 lg:grid-cols-4 gap-4 lg:gap-6 mb-12">
            <% featured.forEach(p => { %>
              <%- include('../../partials/_product_card', { product: p, store, locals }); %>
            <% }); %>
          </div>
        <% } %>

        <!-- All Products -->
        <h2 class="text-2xl font-bold text-gray-900 mb-6">Todos los Productos</h2>
        <% if (products.length > 0) { %>
          <div class="grid grid-cols-2 md:grid-cols-3 lg:grid-cols-4 gap-4 lg:gap-6">
            <% products.forEach(p => { %>
              <%- include('../../partials/_product_card', { product: p, store, locals }); %>
            <% }); %>
          </div>
        <% } else { %>
          <div class="text-center py-16 text-gray-500">
            <p>Próximamente estaremos agregando nuestros productos.</p>
          </div>
        <% } %>

        <!-- Combos -->
        <% if (combos.length > 0) { %>
          <h2 class="text-2xl font-bold text-gray-900 mb-6 mt-12">🔥 Combos Especiales</h2>
          <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-6">
            <% combos.forEach(combo => { %>
              <div class="p-6 rounded-2xl border-2 border-dashed" style="border-color: var(--primary);">
                <h3 class="text-lg font-bold text-gray-900"><%= combo.name %></h3>
                <p class="text-sm text-gray-600 mb-3"><%= combo.description %></p>
                <p class="text-2xl font-bold" style="color: var(--primary)">$<%= combo.price.toFixed(2) %></p>
                <button onclick="addComboToCart('<%= combo.id %>')" class="mt-3 w-full px-4 py-2.5 text-sm font-semibold text-white rounded-xl transition-all" style="background-color: var(--primary);">
                  Agregar al Carrito
                </button>
              </div>
            <% }); %>
          </div>
        <% } %>
      </div>

    <% } else if (page === 'category') { %>
      <div class="max-w-7xl mx-auto px-4 py-8">
        <div class="mb-6">
          <a href="/<%= store.slug %>" class="text-sm text-gray-500 hover:text-gray-700">← Todos los productos</a>
          <h1 class="text-3xl font-bold text-gray-900 mt-2"><%= category.name %></h1>
          <% if (category.description) { %>
            <p class="text-gray-600 mt-1"><%= category.description %></p>
          <% } %>
        </div>
        <% if (products.length > 0) { %>
          <div class="grid grid-cols-2 md:grid-cols-3 lg:grid-cols-4 gap-4 lg:gap-6">
            <% products.forEach(p => { %>
              <%- include('../../partials/_product_card', { product: p, store, locals }); %>
            <% }); %>
          </div>
        <% } else { %>
          <div class="text-center py-16 text-gray-500">
            <p>No hay productos en esta categoría todavía.</p>
          </div>
        <% } %>
      </div>

    <% } else if (page === 'product') { %>
      <%- include('../../partials/_product_detail', { store, product, variants, productImages, categories, related, cartCount, cartTotal, locals }); %>

    <% } else if (page === 'cart') { %>
      <%- include('../../partials/_cart', { store, categories, cartItems, cartCount, cartTotal, locals }); %>

    <% } else if (page === 'checkout') { %>
      <%- include('../../partials/_checkout', { store, categories, cartItems, cartCount, cartTotal, locals }); %>
    <% } else if (['shop','subscriptions','about','contact','login','register','account'].includes(page)) { %>
      <%- include('../../partials/_page_content', { page, store, categories, products, featured, combos, cartItems, cartCount, cartTotal, query: typeof query !== 'undefined' ? query : {}, priceRange: typeof priceRange !== 'undefined' ? priceRange : null, filterSettings: typeof filterSettings !== 'undefined' ? filterSettings : {}, filterData: typeof filterData !== 'undefined' ? filterData : {}, error: typeof error !== 'undefined' ? error : null, msg: typeof msg !== 'undefined' ? msg : null, customer: typeof customer !== 'undefined' ? customer : null, orders: typeof orders !== 'undefined' ? orders : null }); %>
    <% } %>
  </main>

  <!-- Footer -->
  <footer class="bg-gray-900 text-gray-400 mt-16">
    <div class="max-w-7xl mx-auto px-4 py-12">
      <div class="flex flex-col md:flex-row items-center justify-between gap-6">
        <div>
          <p class="text-white font-semibold text-lg"><%= store.name %></p>
          <p class="text-sm mt-1"><%= store.description %></p>
        </div>
        <div class="flex items-center gap-4">
          <% if (store.whatsapp) { %>
            <a href="https://wa.me/<%= store.whatsapp %>" target="_blank" class="text-gray-400 hover:text-green-400 transition-colors">
              <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/></svg>
            </a>
          <% } %>
          <% if (store.instagram) { %>
            <a href="https://instagram.com/<%= store.instagram.replace('@', '') %>" target="_blank" class="text-gray-400 hover:text-pink-400 transition-colors">
              <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24"><path d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zm0-2.163c-3.259 0-3.667.014-4.947.072-4.358.2-6.78 2.618-6.98 6.98-.059 1.281-.073 1.689-.073 4.948 0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98 1.281.058 1.689.072 4.948.072 3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98-1.281-.059-1.69-.073-4.949-.073zm0 5.838c-3.403 0-6.162 2.759-6.162 6.162s2.759 6.163 6.162 6.163 6.162-2.759 6.162-6.163c0-3.403-2.759-6.162-6.162-6.162zm0 10.162c-2.209 0-4-1.79-4-4 0-2.209 1.791-4 4-4s4 1.791 4 4c0 2.21-1.791 4-4 4zm6.406-11.845c-.796 0-1.441.645-1.441 1.44s.645 1.44 1.441 1.44c.795 0 1.439-.645 1.439-1.44s-.644-1.44-1.439-1.44z"/></svg>
            </a>
          <% } %>
        </div>
      </div>
      <div class="border-t border-gray-800 mt-8 pt-8 text-center text-sm text-gray-600">
        © 2026 <%= store.name %>. Powered by TuFerIA.
      </div>
    </div>
  </footer>

  <script>
    async function addToCart(productId, variantId = null, quantity = 1) {
      const res = await fetch('/api/cart/add', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ store_id: '<%= store.id %>', product_id: productId, variant_id: variantId, quantity })
      });
      const data = await res.json();
      if (data.success) location.reload();
    }

    async function addComboToCart(comboId) {
      const res = await fetch('/api/cart/add', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ store_id: '<%= store.id %>', combo_id: comboId, quantity: 1 })
      });
      const data = await res.json();
      if (data.success) location.reload();
    }
  </script>
</body>
</html>
