<%
const ts = store.theme_settings ? (typeof store.theme_settings === 'string' ? JSON.parse(store.theme_settings) : store.theme_settings) : {};
const fonts = { 'Inter': 'Inter:wght@300;400;500;600;700&display=swap' };
const gf = fonts[ts.heading_font] || fonts[ts.body_font] || 'Inter:wght@300;400;500;600;700&display=swap';
const bodyFont = ts.body_font || 'Inter';
const headingFont = ts.heading_font || 'Inter';
const isHome = !page || page === 'home';
const isShop = page === 'shop';
const isProduct = page === 'product';
const isCart = page === 'cart';
const isCheckout = page === 'checkout';
const isCategory = page === 'category';
%><!DOCTYPE html>
<html lang="es" style="scroll-behavior:smooth">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width,initial-scale=1.0">
<meta name="description" content="<%=store.description%>">
<title><%=store.name%><%=page&&page!=='home'?' | '+page:''%></title>
<script src="https://cdn.tailwindcss.com"></script>
<link rel="preconnect" href="https://fonts.googleapis.com">
<link href="https://fonts.googleapis.com/css2?family=<%=gf%>" rel="stylesheet">
<script>tailwind.config={theme:{extend:{fontFamily:{sans:['"<%=headingFont%>"','"<%=bodyFont%>"','sans-serif'],body:['"<%=bodyFont%>"','sans-serif']}}}}</script>
<style>
:root {
  --primary: <%=store.primary_color||'#6b7280'%>;
  --bg: <%=store.bg_color||'#fafafa'%>;
  --text: <%=store.text_color||'#374151'%>;
  --footer-bg: <%=store.footer_bg||'#f3f4f6'%>;
  --footer-text: <%=store.footer_text||'#6b7280'%>;
  --title: <%=store.title_color||'#111827'%>;
  --label-bg: <%=store.label_bg||'#e5e7eb'%>;
}
*{margin:0;padding:0;box-sizing:border-box}
body{font-family:'Inter',sans-serif;background:var(--bg);color:var(--text);font-weight:300;line-height:1.8}
h1,h2,h3,h4,h5,h6{font-family:'Inter',sans-serif;font-weight:300;letter-spacing:-0.02em;color:var(--title)}
.section-title{font-weight:300;letter-spacing:0.05em;text-transform:uppercase;font-size:0.75rem;color:var(--text);opacity:0.5;margin-bottom:2.5rem}
.btn-primary{display:inline-flex;align-items:center;justify-content:center;font-family:'Inter',sans-serif;font-weight:400;letter-spacing:0.05em;text-transform:uppercase;font-size:0.75rem;padding:0.875rem 2.5rem;background:var(--primary);color:#fff;border-radius:2px;transition:all 0.2s ease}
.btn-primary:hover{opacity:0.8}
.product-card{border:none!important;background:transparent!important}
.product-card img{filter:grayscale(0.3);transition:all 0.5s ease}
.product-card:hover img{filter:grayscale(0)}
a{transition:opacity 0.2s ease}
a:hover{opacity:0.6}
.container-narrow{max-width:72rem;margin:0 auto;padding:0 2rem}
@media(max-width:640px){.container-narrow{padding:0 1.5rem}}
</style>
</head>
<body>
<!-- Flash messages -->
<%-include('../../partials/_flash',{order:locals.order||null})%>

<!-- Minimal Nav -->
<nav class="py-6 lg:py-10" style="background:var(--bg)">
  <div class="container-narrow">
    <div class="text-center">
      <a href="<%=storeBaseUrl%>" class="text-2xl lg:text-3xl" style="font-weight:200;letter-spacing:0.1em;color:var(--title);text-decoration:none"><%=store.name%></a>
    </div>
    <div class="flex justify-center gap-8 mt-5">
      <%- include('../../partials/_nav_links', {locals:{navLinkClass:'text-xs uppercase tracking-[0.15em]'}}); %>
    </div>
  </div>
</nav>

<!-- Floating Cart Button (bottom-right) -->
<button onclick="toggleCartDrawer()" class="fixed bottom-6 right-6 z-40 w-14 h-14 rounded-full flex items-center justify-center shadow-xl hover:shadow-2xl transition-all duration-300" style="background:var(--primary);color:#fff">
  <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M2.25 3h1.386c.51 0 .955.343 1.087.835l.383 1.437M7.5 14.25a3 3 0 00-3 3h15.75m-12.75-3h11.218c1.121-2.3 2.1-4.684 2.924-7.138a60.114 60.114 0 00-16.536-1.84M7.5 14.25L5.106 5.272"/></svg>
  <% if (cartCount > 0) { %>
    <span class="absolute -top-1 -right-1 w-5 h-5 rounded-full flex items-center justify-center text-[10px] font-bold" style="background:#fff;color:var(--primary)"><%= cartCount %></span>
  <% } %>
</button>

<!-- Mobile menu -->
<%- include('../../partials/_mobile_menu', { locals: { iconColor: 'text-gray-400' } }); %>

<main class="py-8 lg:py-12" style="background:var(--bg)">
  <% if (isHome) { %>
    <%- include('../../partials/_banner_carousel', { heroImages, store, storeBaseUrl }); %>
    <%- include('../../partials/_home_content', { store, storeBaseUrl, categories, products, featured, combos, locals }); %>
  <% } else if (isCategory) { %>
    <div class="container-narrow py-8">
      <h1 class="text-2xl font-light tracking-wider mb-8" style="color:var(--title)"><%= category.name %></h1>
      <% if (products.length > 0) { %>
        <div class="grid grid-cols-2 md:grid-cols-3 lg:grid-cols-4 gap-8 lg:gap-12">
          <% products.forEach(p => { %>
            <%- include('../../partials/_product_card', { product: p, store, locals }); %>
          <% }); %>
        </div>
      <% } else { %>
        <p class="text-sm opacity-40">No hay productos en esta categoría.</p>
      <% } %>
    </div>
  <% } else if (isProduct) { %>
    <%- include('../../partials/_product_detail', { product, productImages, category, variants, volumeDiscounts, related, store, storeBaseUrl, locals }); %>
  <% } else if (isCart) { %>
    <%- include('../../partials/_cart', { cartItems, cartTotal, store, storeBaseUrl, locals }); %>
  <% } else if (isCheckout) { %>
    <%- include('../../partials/_checkout', { cartItems, cartTotal, store, storeBaseUrl, locals }); %>
  <% } else { %>
    <%- include('../../partials/_page_content', { page, store, storeBaseUrl, categories, products, featured, combos, locals }); %>
  <% } %>
</main>

<!-- Minimal Footer -->
<footer class="py-10 text-center" style="background:var(--footer-bg);color:var(--footer-text)">
  <div class="container-narrow">
    <p class="text-xs uppercase tracking-[0.2em] opacity-40">&copy; <%= new Date().getFullYear() %> <%= store.name %></p>
  </div>
</footer>

<script>
async function addToCart(productId, variantId, qty) {
  const res = await fetch('/api/cart/add', {
    method: 'POST',
    headers: { 'Content-Type': 'application/json' },
    body: JSON.stringify({ product_id: productId, variant_id: variantId || null, quantity: qty || 1, store_id: '<%= store.id %>' })
  });
  const data = await res.json();
  if (data.success) { toggleCartDrawer(); } else { alert(data.error || 'Error al agregar al carrito'); }
}
async function addComboToCart(comboId) {
  const res = await fetch('/api/cart/add-combo', {
    method: 'POST',
    headers: { 'Content-Type': 'application/json' },
    body: JSON.stringify({ combo_id: comboId, store_id: '<%= store.id %>' })
  });
  const data = await res.json();
  if (data.success) { toggleCartDrawer(); } else { alert(data.error || 'Error al agregar combo'); }
}
</script>

<%- include('../../partials/_cart_drawer', { cartItems, cartTotal, store, storeBaseUrl }); %>
<%- include('../../partials/_order_success', { order: locals.order, whatsappLink: locals.whatsappLink, store, storeBaseUrl, locals }); %>
</body>
</html>
