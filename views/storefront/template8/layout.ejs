<%
const ts = store.theme_settings ? (typeof store.theme_settings === 'string' ? JSON.parse(store.theme_settings) : store.theme_settings) : {};
const gfMap = { 'Poppins': 'Poppins:wght@300;400;500;600;700&display=swap' };
const gf = gfMap[ts.heading_font] || 'Poppins:wght@300;400;500;600;700&display=swap';
const hFont = ts.heading_font || 'Poppins';
const bFont = ts.body_font || 'Poppins';
const isHome = !page || page === 'home';
const isShop = page === 'shop';
const isProduct = page === 'product';
const isCart = page === 'cart';
const isCheckout = page === 'checkout';
const isCategory = page === 'category';
%><!DOCTYPE html>
<html lang="es">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width,initial-scale=1.0">
<meta name="description" content="<%=store.description%>">
<title><%=store.name%><%=page&&page!=='home'?' | '+page:''%></title>
<script src="https://cdn.tailwindcss.com"></script>
<link rel="preconnect" href="https://fonts.googleapis.com">
<link href="https://fonts.googleapis.com/css2?family=<%=gf%>&display=swap" rel="stylesheet">
<script>tailwind.config={theme:{extend:{fontFamily:{sans:['Poppins','sans-serif'],body:['Poppins','sans-serif']}}}}</script>
<style>
:root {
  --primary: <%=store.primary_color||'#667eea'%>;
  --bg: <%=store.bg_color||'#0f0c29'%>;
  --text: <%=store.text_color||'#e0d4f5'%>;
  --footer-bg: <%=store.footer_bg||'#0a0815'%>;
  --footer-text: <%=store.footer_text||'#8b7db8'%>;
  --title: <%=store.title_color||'#ffffff'%>;
  --label-bg: <%=store.label_bg||'rgba(102,126,234,0.15)'%>;
}
*{margin:0;padding:0;box-sizing:border-box}
body{font-family:'Poppins',sans-serif;background:var(--bg);color:var(--text);font-weight:300;line-height:1.8;overflow-x:hidden}
body::before{content:'';position:fixed;inset:0;background:linear-gradient(135deg,rgba(102,126,234,0.08) 0%,rgba(118,75,162,0.08) 50%,rgba(15,12,41,0.95) 100%);pointer-events:none;z-index:-1}
h1,h2,h3,h4,h5,h6{font-family:'Poppins',sans-serif;font-weight:600;color:var(--title);letter-spacing:-0.02em}
.section-title{font-size:1.5rem;text-align:center;margin-bottom:2rem;font-weight:500;background:linear-gradient(135deg,var(--primary),#a78bfa);-webkit-background-clip:text;-webkit-text-fill-color:transparent;background-clip:text}
.btn-primary{display:inline-flex;align-items:center;justify-content:center;font-family:'Poppins',sans-serif;font-weight:500;font-size:0.85rem;padding:0.875rem 2.5rem;background:linear-gradient(135deg,var(--primary),#764ba2);color:#fff;border-radius:12px;border:1px solid rgba(255,255,255,0.1);backdrop-filter:blur(10px);transition:all 0.3s ease;box-shadow:0 4px 15px rgba(102,126,234,0.2)}
.btn-primary:hover{transform:translateY(-2px);box-shadow:0 8px 30px rgba(102,126,234,0.4)}
.glass{background:rgba(255,255,255,0.06);backdrop-filter:blur(20px);-webkit-backdrop-filter:blur(20px);border:1px solid rgba(255,255,255,0.08);border-radius:16px}
.glass-card{background:rgba(255,255,255,0.05);backdrop-filter:blur(16px);-webkit-backdrop-filter:blur(16px);border:1px solid rgba(255,255,255,0.08);border-radius:20px;transition:all 0.4s ease}
.glass-card:hover{background:rgba(255,255,255,0.08);border-color:rgba(255,255,255,0.15);transform:translateY(-4px)}
.product-card{border-radius:20px!important;overflow:hidden;background:rgba(255,255,255,0.05)!important;backdrop-filter:blur(12px)!important;-webkit-backdrop-filter:blur(12px)!important;border:1px solid rgba(255,255,255,0.08)!important;box-shadow:0 8px 32px rgba(0,0,0,0.2)!important;transition:all 0.4s ease!important}
.product-card:hover{background:rgba(255,255,255,0.08)!important;border-color:rgba(255,255,255,0.18)!important;transform:translateY(-6px)!important;box-shadow:0 16px 48px rgba(0,0,0,0.3)!important}
.product-card h3{color:var(--title);font-weight:500}
.product-card span[style*="price"]{background:linear-gradient(135deg,var(--primary),#a78bfa);-webkit-background-clip:text;-webkit-text-fill-color:transparent;background-clip:text}
.glass-nav{background:rgba(15,12,41,0.7);backdrop-filter:blur(24px);-webkit-backdrop-filter:blur(24px);border-bottom:1px solid rgba(255,255,255,0.06)}
@keyframes float-up{0%,100%{transform:translateY(0)}50%{transform:translateY(-10px)}}
@keyframes shimmer{0%{background-position:-200% 0}100%{background-position:200% 0}}
.float-anim{animation:float-up 4s ease-in-out infinite}
.gradient-border{position:relative;border-radius:16px}
.gradient-border::before{content:'';position:absolute;inset:-1px;border-radius:17px;background:linear-gradient(135deg,var(--primary),#a78bfa,var(--primary));z-index:-1;opacity:0.5}
</style>
</head>
<body>
<%-include('../../partials/_flash',{order:locals.order||null})%>

<!-- Glass Nav -->
<nav class="glass-nav sticky top-0 z-50">
  <div class="max-w-7xl mx-auto px-4 lg:px-8">
    <div class="flex items-center justify-between h-16 lg:h-18">
      <a href="<%=storeBaseUrl%>" class="text-lg font-semibold tracking-tight" style="color:var(--title);text-decoration:none;background:linear-gradient(135deg,var(--primary),#a78bfa);-webkit-background-clip:text;-webkit-text-fill-color:transparent;background-clip:text"><%=store.name%></a>
      <div class="hidden md:flex items-center gap-6">
        <%- include('../../partials/_nav_links', {locals:{navLinkClass:'text-sm text-white/60 hover:text-white transition-colors font-light'}}); %>
      </div>
      <div class="flex items-center gap-3">
        <button onclick="toggleCartDrawer()" class="p-2 relative glass" style="border-radius:50%;width:40px;height:40px;display:flex;align-items:center;justify-content:center">
          <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M2.25 3h1.386c.51 0 .955.343 1.087.835l.383 1.437M7.5 14.25a3 3 0 00-3 3h15.75m-12.75-3h11.218c1.121-2.3 2.1-4.684 2.924-7.138a60.114 60.114 0 00-16.536-1.84M7.5 14.25L5.106 5.272"/></svg>
          <% if (cartCount > 0) { %><span class="absolute -top-0.5 -right-0.5 w-5 h-5 rounded-full flex items-center justify-center text-[9px] font-bold text-white" style="background:linear-gradient(135deg,var(--primary),#764ba2)"><%= cartCount %></span><% } %>
        </button>
        <%- include('../../partials/_mobile_menu', { locals: { iconColor: 'text-white/60' } }); %>
      </div>
    </div>
  </div>
</nav>

<main>
  <% if (isHome) { %>
    <%- include('../../partials/_banner_carousel', { heroImages, store, storeBaseUrl }); %>
    <%- include('../../partials/_home_content', { store, storeBaseUrl, categories, products, featured, combos, locals }); %>
  <% } else if (isCategory) { %>
    <div class="max-w-7xl mx-auto px-4 lg:px-8 py-12">
      <h1 class="text-3xl font-semibold mb-8" style="background:linear-gradient(135deg,var(--primary),#a78bfa);-webkit-background-clip:text;-webkit-text-fill-color:transparent;background-clip:text"><%= category.name %></h1>
      <div class="grid grid-cols-2 lg:grid-cols-4 gap-4 lg:gap-6">
        <% products.forEach(p => { %>
          <%- include('../../partials/_product_card', { product: p, store, locals }); %>
        <% }); %>
      </div>
    </div>
  <% } else if (isProduct) { %>
    <%- include('../../partials/_product_detail', { product, productImages, category, variants, volumeDiscounts, related, store, storeBaseUrl, locals }); %>
  <% } else if (isCart) { %>
    <%- include('../../partials/_cart', { cartItems, cartTotal, store, storeBaseUrl, locals }); %>
  <% } else if (isCheckout) { %>
    <%- include('../../partials/_checkout', { cartItems, cartTotal, store, storeBaseUrl, locals }); %>
  <% } else { %>
    <%- include('../../partials/_page_content', { page, store, storeBaseUrl, categories, products, featured, combos, locals }); %>
  <% } %>
</main>

<!-- Glass Footer -->
<footer style="background:var(--footer-bg);border-top:1px solid rgba(102,126,234,0.1)">
  <div class="gradient-mesh">
    <div class="max-w-7xl mx-auto px-4 lg:px-8 py-16">
      <div class="grid lg:grid-cols-4 gap-8">
        <div class="lg:col-span-1">
          <h3 class="text-lg font-semibold mb-4" style="background:linear-gradient(135deg,var(--primary),#a78bfa);-webkit-background-clip:text;-webkit-text-fill-color:transparent;background-clip:text"><%=store.name%></h3>
          <p class="text-sm" style="color:rgba(255,255,255,0.35)"><%=store.description%></p>
        </div>
        <div>
          <h4 class="text-xs uppercase tracking-widest mb-5" style="color:rgba(255,255,255,0.25);font-weight:400">Links</h4>
          <div class="flex flex-col gap-2">
            <%- include('../../partials/_nav_links', {locals:{navLinkClass:'text-sm text-white/40 hover:text-white/80 transition-colors'}}); %>
          </div>
        </div>
        <div>
          <h4 class="text-xs uppercase tracking-widest mb-5" style="color:rgba(255,255,255,0.25);font-weight:400">Social</h4>
          <div class="flex flex-col gap-2">
            <% if (store.instagram) { %><a href="https://instagram.com/<%=store.instagram.replace('@','')%>" class="text-sm text-white/40 hover:text-white/80 transition-colors">Instagram</a><% } %>
            <% if (store.whatsapp) { %><a href="https://wa.me/<%=store.whatsapp%>" class="text-sm text-white/40 hover:text-white/80 transition-colors">WhatsApp</a><% } %>
          </div>
        </div>
        <div>
          <h4 class="text-xs uppercase tracking-widest mb-5" style="color:rgba(255,255,255,0.25);font-weight:400">Info</h4>
          <div class="flex flex-col gap-2 text-sm text-white/40">
            <span>Horarios: L a V</span>
            <% if (store.whatsapp) { %><a href="https://wa.me/<%=store.whatsapp%>" class="hover:text-white/80 transition-colors">Contacto</a><% } %>
          </div>
        </div>
      </div>
      <div class="mt-12 pt-8 text-center text-xs" style="color:rgba(255,255,255,0.15);border-top:1px solid rgba(255,255,255,0.04)">
        &copy; <%= new Date().getFullYear() %> <%= store.name %>
      </div>
    </div>
  </div>
</footer>

<script>
async function addToCart(productId, variantId, qty) {
  const res = await fetch('/api/cart/add', {
    method: 'POST',
    headers: { 'Content-Type': 'application/json' },
    body: JSON.stringify({ product_id: productId, variant_id: variantId || null, quantity: qty || 1, store_id: '<%= store.id %>' })
  });
  const data = await res.json();
  if (data.success) { toggleCartDrawer(); } else { alert(data.error || 'Error'); }
}
async function addComboToCart(comboId) {
  const res = await fetch('/api/cart/add-combo', {
    method: 'POST',
    headers: { 'Content-Type': 'application/json' },
    body: JSON.stringify({ combo_id: comboId, store_id: '<%= store.id %>' })
  });
  const data = await res.json();
  if (data.success) { toggleCartDrawer(); } else { alert(data.error || 'Error'); }
}
</script>

<%- include('../../partials/_cart_drawer', { cartItems, cartTotal, store, storeBaseUrl }); %>
<%- include('../../partials/_order_success', { order: locals.order, whatsappLink: locals.whatsappLink, store, storeBaseUrl, locals }); %>
</body>
</html>
