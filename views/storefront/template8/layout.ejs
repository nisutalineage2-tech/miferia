<% const t = store.theme_settings ? JSON.parse(store.theme_settings) : {}; const c = t.colors || {}; %>
<% const isHome = !page || page === 'home'; %>
<% const isShop = page === 'shop'; %>
<% const isProduct = page === 'product'; %>
<% const isCart = page === 'cart'; %>
<% const isCheckout = page === 'checkout'; %>
<% const isCategory = page === 'category'; %>
<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= store.name || 'Store' %><%= typeof pageTitle !== 'undefined' ? ' — ' + pageTitle : '' %></title>
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Poppins:wght@300;400;500;600;700&display=swap" rel="stylesheet">
  <script src="https://cdn.tailwindcss.com"></script>
  <script>
    tailwind.config = {
      theme: {
        extend: {
          fontFamily: {
            poppins: ['Poppins', 'sans-serif']
          },
          colors: {
            primary: 'var(--primary)',
            bg: 'var(--bg)',
            text: 'var(--text)',
            'glass-purple': '#667eea',
            'glass-violet': '#764ba2'
          }
        }
      }
    }
  </script>
  <style>
    :root {
      --primary: <%= c.btn_primary_bg || '#667eea' %>;
      --bg: <%= c.page_bg || '#f0f0f8' %>;
      --text: <%= c.text || '#2d2d3f' %>;
      --footer-bg: <%= c.footer_bg || '#1a1a2e' %>;
      --footer-text: <%= c.footer_text || '#a0a0b8' %>;
      --title: <%= c.heading_color || '#1a1a2e' %>;
      --label-bg: <%= c.label_bg || '#764ba2' %>;
    }
    * { font-family: 'Poppins', sans-serif; }
    h1,h2,h3,h4,h5,h6 { font-family: 'Poppins', sans-serif; color: var(--title); }
    body { background: var(--bg); color: var(--text); }
    .glass-nav {
      background: rgba(255,255,255,0.6);
      backdrop-filter: blur(20px);
      -webkit-backdrop-filter: blur(20px);
      border-bottom: 1px solid rgba(255,255,255,0.3);
    }
    .glass-card {
      background: rgba(255,255,255,0.55);
      backdrop-filter: blur(16px);
      -webkit-backdrop-filter: blur(16px);
      border: 1px solid rgba(255,255,255,0.4);
      border-radius: 1rem;
      transition: transform 0.3s ease, box-shadow 0.3s ease;
    }
    .glass-card:hover {
      transform: translateY(-4px);
      box-shadow: 0 12px 32px rgba(102,126,234,0.18);
    }
    .gradient-border {
      border: 2px solid transparent;
      background-clip: padding-box;
      position: relative;
    }
    .gradient-border::before {
      content: '';
      position: absolute;
      inset: -2px;
      border-radius: inherit;
      background: linear-gradient(135deg, #667eea, #764ba2);
      z-index: -1;
    }
    .glass-btn {
      background: linear-gradient(135deg, #667eea, #764ba2);
      color: white;
      border-radius: 9999px;
      padding: 10px 28px;
      font-weight: 500;
      transition: opacity 0.3s ease, transform 0.3s ease;
    }
    .glass-btn:hover { opacity: 0.9; transform: scale(1.03); }
    @keyframes subtle-float {
      0%,100% { transform: translateY(0); }
      50% { transform: translateY(-4px); }
    }
    .float-subtle { animation: subtle-float 4s ease-in-out infinite; }
  </style>
</head>
<body class="antialiased min-h-screen flex flex-col">
  <%- include('../../partials/_flash', { locals }); %>
  <%- include('../../partials/_cart_drawer', { store, storeBaseUrl }); %>
  <%- include('../../partials/_order_success', { locals }); %>

  <!-- NAV — Glassmorphism -->
  <nav class="glass-nav sticky top-0 z-40 rounded-b-2xl mx-2 mt-0">
    <div class="max-w-7xl mx-auto px-6 py-4 flex items-center justify-between">
      <a href="<%= storeBaseUrl || '/' %>" class="font-poppins text-xl font-bold" style="background: linear-gradient(135deg, #667eea, #764ba2); -webkit-background-clip: text; -webkit-text-fill-color: transparent;">
        <%= store.name || 'Store' %>
      </a>
      <div class="hidden md:flex items-center gap-7 text-sm font-medium" style="color: var(--text)">
        <%- include('../../partials/_nav_links', { store, storeBaseUrl, locals: { navLinkClass: 'hover:text-purple-600 transition-colors' } }); %>
      </div>
      <div class="flex items-center gap-4">
        <a href="<%= storeBaseUrl %>/carrito" class="relative" style="color: var(--text)">
          <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M3 3h2l.4 2M7 13h10l4-8H5.4M7 13L5.4 5M7 13l-2.3 2.3c-.4.4-.1 1.1.5 1.1H17m0 0a2 2 0 100 4 2 2 0 000-4zm-8 2a2 2 0 100 4 2 2 0 000-4z"/>
          </svg>
          <span class="cart-count absolute -top-2 -right-2 text-white text-[10px] w-4 h-4 rounded-full flex items-center justify-center font-bold" style="background: linear-gradient(135deg, #667eea, #764ba2);"><%= cartCount || 0 %></span>
        </a>
      </div>
    </div>
  </nav>

  <!-- MAIN -->
  <main class="flex-1">
    <% if (isHome) { %>
      <%- include('../../partials/_banner_carousel', { heroImages, store, storeBaseUrl }); %>
      <%- include('../../partials/_home_content', { store, storeBaseUrl, categories, products, featured, combos, locals }); %>
    <% } else if (isProduct) { %>
      <div class="max-w-7xl mx-auto px-6 py-12">
        <%- include('../../partials/_product_detail', { product, productImages, variants, volumeDiscounts, category, related, store, storeBaseUrl, locals }); %>
      </div>
    <% } else if (isCart) { %>
      <div class="max-w-4xl mx-auto px-6 py-12">
        <%- include('../../partials/_cart', { cartItems, cartTotal, store, storeBaseUrl, locals }); %>
      </div>
    <% } else if (isCheckout) { %>
      <div class="max-w-4xl mx-auto px-6 py-12">
        <%- include('../../partials/_checkout', { cartItems, cartTotal, store, storeBaseUrl, locals }); %>
      </div>
    <% } else if (isCategory) { %>
      <div class="max-w-7xl mx-auto px-6 py-12">
        <h1 class="text-2xl font-bold mb-6"><%= category.name %></h1>
        <div class="grid grid-cols-2 md:grid-cols-3 lg:grid-cols-4 gap-5">
          <% products.forEach(p => { %>
            <div class="glass-card p-0 overflow-hidden">
              <%- include('../../partials/_product_card', { product: p, store, locals }); %>
            </div>
          <% }); %>
        </div>
      </div>
    <% } else if (isShop) { %>
      <div class="max-w-7xl mx-auto px-6 py-12">
        <h1 class="text-2xl font-bold mb-6">Shop</h1>
        <div class="grid grid-cols-2 md:grid-cols-3 lg:grid-cols-4 gap-5">
          <% (products || []).forEach(p => { %>
            <div class="glass-card p-0 overflow-hidden">
              <%- include('../../partials/_product_card', { product: p, store, locals }); %>
            </div>
          <% }); %>
        </div>
      </div>
    <% } else { %>
      <%- include('../../partials/_page_content', { page, store, storeBaseUrl, categories, products, featured, combos, locals }); %>
    <% } %>
  </main>

  <!-- FOOTER — Dark gradient with glass cards -->
  <footer class="mt-20 pt-14 pb-10" style="background: linear-gradient(135deg, #1a1a2e, #16213e);">
    <div class="max-w-7xl mx-auto px-6 grid grid-cols-1 md:grid-cols-3 gap-8">
      <div class="glass-card p-6" style="background: rgba(255,255,255,0.08); border-color: rgba(255,255,255,0.1);">
        <h3 class="font-poppins text-lg font-bold text-white mb-2 float-subtle inline-block"><%= store.name || 'Store' %></h3>
        <p class="text-sm leading-relaxed" style="color: #a0a0b8;">Modern shopping, redefined.</p>
      </div>
      <div class="glass-card p-6" style="background: rgba(255,255,255,0.08); border-color: rgba(255,255,255,0.1);">
        <h3 class="font-poppins text-sm font-bold uppercase tracking-wider text-white mb-3">Links</h3>
        <div class="flex flex-col gap-2 text-sm" style="color: #a0a0b8;">
          <%- include('../../partials/_nav_links', { store, storeBaseUrl, locals: { navLinkClass: 'hover:text-white transition-colors' } }); %>
        </div>
      </div>
      <div class="glass-card p-6" style="background: rgba(255,255,255,0.08); border-color: rgba(255,255,255,0.1);">
        <h3 class="font-poppins text-sm font-bold uppercase tracking-wider text-white mb-3">Legal</h3>
        <p class="text-xs" style="color: #a0a0b8;">&copy; <%= new Date().getFullYear() %> <%= store.name || 'Store' %>. All rights reserved.</p>
      </div>
    </div>
  </footer>

  <!-- MOBILE MENU -->
  <%- include('../../partials/_mobile_menu', { store, storeBaseUrl, locals: { iconColor: '#667eea' } }); %>

  <script>
    function addToCart(productId, qty) {
      fetch((window.storeBaseUrl || '') + '/api/cart/add', {
        method: 'POST', headers: {'Content-Type':'application/x-www-form-urlencoded'},
        body: 'product_id=' + productId + '&qty=' + (qty||1)
      }).then(r=>r.json()).then(d=>{
        if(d.cartCount!==undefined) document.querySelectorAll('.cart-count').forEach(e=>e.textContent=d.cartCount);
        if(typeof toggleCartDrawer==='function') toggleCartDrawer();
      });
    }
    function addComboToCart(comboId) {
      fetch((window.storeBaseUrl || '') + '/api/combo/add', {
        method: 'POST', headers: {'Content-Type':'application/x-www-form-urlencoded'},
        body: 'combo_id=' + comboId + '&qty=1'
      }).then(r=>r.json()).then(d=>{
        if(d.cartCount!==undefined) document.querySelectorAll('.cart-count').forEach(e=>e.textContent=d.cartCount);
        if(typeof toggleCartDrawer==='function') toggleCartDrawer();
      });
    }
    window.storeBaseUrl = '<%= storeBaseUrl %>';
  </script>
</body>
</html>
