<!DOCTYPE html>
<html lang="es">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= (title || store.name || '') %></title>
  <script src="https://cdn.tailwindcss.com"></script>
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,300;0,400;0,500;0,600;0,700;1,400&family=Inter:wght@300;400;500;600&display=swap" rel="stylesheet">
  <style>
    <% let _tc8 = {}; try { _tc8 = JSON.parse(store.theme_settings || '{}'); } catch(e) {} const _col8 = _tc8.colors || {}; %>
    body { font-family: 'Inter', sans-serif; background: <%= _col8.body_bg || '#fafaf9' %>; color: <%= _col8.body_text || '#1c1917' %>; }
    h1,h2,h3,.serif { font-family: 'Cormorant Garamond', Georgia, serif; font-weight: 500; letter-spacing: 0.02em; }
    :root { --primary: <%= _col8.btn_primary_bg || store.primary_color || '#b8860b' %>; --accent: <%= _col8.btn_secondary_bg || store.accent_color || '#1c1917' %>; --footer-bg: <%= _col8.footer_bg || '#1c1917' %>; --footer-text: <%= _col8.footer_text || '#a8a29e' %>; }
    .product-card { background: #fff; border: 1px solid #e7e5e4; transition: all 0.4s ease; border-radius: 16px; overflow: hidden; }
    .product-card:hover { box-shadow: 0 20px 60px rgba(0,0,0,0.08); border-color: #d6d3d1; }
    .btn-primary { background: #1c1917; color: #fff; border-radius: 9999px; font-weight: 400; letter-spacing: 0.05em; font-size: 0.75rem; text-transform: uppercase; padding: 0.75rem 2rem; }
    .btn-primary:hover { background: #b8860b; }
    .luxury-divider { height: 1px; background: linear-gradient(90deg, transparent, #b8860b, transparent); width: 60px; margin: 0 auto 1.5rem; }
    .price-tag { font-family: 'Cormorant Garamond', serif; font-size: 1.5rem; color: #b8860b; }
  </style>
</head>
<body>
  <!-- Nav -->
  <nav class="bg-white/95 backdrop-blur-sm border-b border-stone-100 sticky top-0 z-40">
    <div class="max-w-6xl mx-auto px-6">
      <div class="flex items-center justify-between h-20">
        <a href="/<%= store.slug %>" class="flex items-center gap-2">
          <% if (store.logo) { %><img src="<%= store.logo %>" alt="<%= store.name %>" class="h-8 w-auto"><% } else { %><span class="text-2xl serif text-stone-900 tracking-wide"><%= store.name %></span><% } %>
        </a>
        <div class="hidden md:flex items-center gap-8">
          <%- include('../../partials/_nav_links', { locals: { navLinkClass: 'text-xs text-stone-500 hover:text-stone-900 tracking-[0.15em] uppercase' } }) %>
        </div>
        <a href="/<%= store.slug %>/carrito" class="relative"><svg class="w-5 h-5 text-stone-700" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.2" d="M15.75 10.5V6a3.75 3.75 0 10-7.5 0v4.5m11.356-1.993l1.263 12c.07.665-.45 1.243-1.119 1.243H4.25a1.125 1.125 0 01-1.12-1.243l1.264-12A1.125 1.125 0 015.513 7.5h12.974c.576 0 1.059.435 1.119 1.007zM8.625 10.5a.375.375 0 11-.75 0 .375.375 0 01.75 0zm7.5 0a.375.375 0 11-.75 0 .375.375 0 01.75 0z"/></svg><% if (cartCount > 0) { %><span class="absolute -top-2 -right-2 w-4 h-4 rounded-full text-[9px] font-medium text-white flex items-center justify-center bg-stone-900"><%= cartCount %></span><% } %></a>
      
            <%- include('../../partials/_mobile_menu', { locals: { iconColor: 'text-stone-500' } }) %>
</div>
    </div>
  </nav>

  <main>
    <%- include('../../partials/_flash', { locals }); %>
    <% if (page === 'home') { %>
      <!-- HERO LUXURY -->
      <div class="max-w-6xl mx-auto px-6 py-20 lg:py-28 text-center">
        <div class="max-w-3xl mx-auto">
          <div class="luxury-divider"></div>
          <h1 class="text-5xl lg:text-7xl serif text-stone-900 leading-tight mb-6 font-light"><%= store.name %></h1>
          <p class="text-stone-400 text-lg mb-8 font-light max-w-xl mx-auto"><%= store.description %></p>
          <%- include('../../partials/_hero_carousel', { images: heroImages, fallback: store.banner, className: 'rounded-3xl shadow-xl mb-8', height: 'h-72 lg:h-96' }); %>
          <a href="/<%= store.slug %>/tienda" class="btn-primary inline-block">Ver Colección</a>
        </div>
      </div>

      <div class="max-w-6xl mx-auto px-6 pb-16">
        <!-- Categories -->
        <% if (categories.length > 0) { %>
          <section class="mb-16 text-center">
            <div class="luxury-divider"></div>
            <h2 class="text-3xl serif text-stone-900 mb-8">Categorías</h2>
            <div class="flex flex-wrap justify-center gap-3">
              <% categories.forEach(c => { %>
                <a href="/<%= store.slug %>/categoria/<%= c.name.toLowerCase().replace(/ /g, '-') %>" class="px-6 py-3 rounded-full border border-stone-200 text-stone-600 text-sm hover:border-stone-900 transition-colors"><%= c.name %></a>
              <% }); %>
            </div>
          </section>
        <% } %>

        <!-- Featured -->
        <% if (featured.length > 0) { %>
          <section class="mb-16">
            <div class="text-center mb-10"><div class="luxury-divider"></div><h2 class="text-3xl serif text-stone-900">Selección</h2><p class="text-stone-400 text-sm mt-2">Piezas destacadas</p></div>
            <div class="grid grid-cols-2 md:grid-cols-3 lg:grid-cols-4 gap-6">
              <% featured.forEach(p => { %><%- include('../../partials/_product_card', { product: p, store, locals }); %><% }); %>
            </div>
          </section>
        <% } %>

        <!-- Products -->
        <section id="productos" class="mb-16">
          <div class="text-center mb-10"><div class="luxury-divider"></div><h2 class="text-3xl serif text-stone-900">Catálogo</h2></div>
          <% if (products.length > 0) { %><div class="grid grid-cols-2 md:grid-cols-3 lg:grid-cols-4 gap-6"><% products.forEach(p => { %><%- include('../../partials/_product_card', { product: p, store, locals }); %><% }); %></div><% } else { %><div class="text-center py-16 text-stone-300 serif text-lg">Próximamente</div><% } %>
        </section>

        <!-- Combos -->
        <% if (combos.length > 0) { %>
          <section class="mb-16">
            <div class="text-center mb-10"><div class="luxury-divider"></div><h2 class="text-3xl serif text-stone-900">Colecciones</h2></div>
            <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-8">
              <% combos.forEach(combo => { %>
                <div class="p-8 rounded-2xl bg-white border border-stone-100 text-center">
                  <div class="text-4xl mb-4">💎</div>
                  <h3 class="text-2xl serif text-stone-900 mb-2"><%= combo.name %></h3>
                  <p class="text-stone-400 text-sm mb-4"><%= combo.description %></p>
                  <p class="price-tag mb-4">$<%= combo.price.toFixed(2) %></p>
                  <button onclick="addComboToCart('<%= combo.id %>')" class="btn-primary">Agregar</button>
                </div>
              <% }); %>
            </div>
          </section>
        <% } %>
      </div>

    <% } else if (page === 'category') { %>
      <div class="max-w-6xl mx-auto px-6 py-12">
        <a href="/<%= store.slug %>" class="text-sm text-stone-400 hover:text-stone-700">← Volver</a>
        <h1 class="text-4xl serif text-stone-900 mt-6 mb-8"><%= category.name %></h1>
        <% if (products.length > 0) { %><div class="grid grid-cols-2 md:grid-cols-3 lg:grid-cols-4 gap-6"><% products.forEach(p => { %><%- include('../../partials/_product_card', { product: p, store, locals }); %><% }); %></div><% } else { %><div class="text-center py-16 text-stone-300 serif">Sin productos</div><% } %>
      </div>
    <% } else if (page === 'product') { %>
      <%- include('../../partials/_product_detail', { store, product, variants, productImages, categories, related, cartCount, cartTotal, locals }); %>
    <% } else if (page === 'cart') { %>
      <%- include('../../partials/_cart', { store, categories, cartItems, cartCount, cartTotal, locals }); %>
    <% } else if (page === 'checkout') { %>
      <%- include('../../partials/_checkout', { store, categories, cartItems, cartCount, cartTotal, locals }); %>
    <% } else if (['shop','subscriptions','about','contact','login','register','account'].includes(page)) { %>
      <%- include('../../partials/_page_content', { page, store, categories, products, featured, combos, cartItems, cartCount, cartTotal, query: typeof query !== 'undefined' ? query : {}, priceRange: typeof priceRange !== 'undefined' ? priceRange : null, filterSettings: typeof filterSettings !== 'undefined' ? filterSettings : {}, filterData: typeof filterData !== 'undefined' ? filterData : {}, error: typeof error !== 'undefined' ? error : null, msg: typeof msg !== 'undefined' ? msg : null, customer: typeof customer !== 'undefined' ? customer : null, orders: typeof orders !== 'undefined' ? orders : null }); %>
    <% } %>
  </main>

  <!-- Footer -->
  <footer class="bg-stone-900 text-stone-400 mt-16">
    <div class="max-w-6xl mx-auto px-6 py-16">
      <div class="text-center mb-10">
        <p class="serif text-2xl text-white mb-2"><%= store.name %></p>
        <div class="luxury-divider"></div>
      </div>
      <div class="flex flex-wrap justify-center gap-8 text-sm">
        <% if (store.instagram) { %><a href="https://instagram.com/<%= store.instagram.replace('@','') %>" target="_blank" class="hover:text-white tracking-wider uppercase text-xs">Instagram</a><% } %>
        <% if (store.whatsapp) { %><a href="https://wa.me/<%= store.whatsapp %>" target="_blank" class="hover:text-white tracking-wider uppercase text-xs">WhatsApp</a><% } %>
        <a href="/<%= store.slug %>/contacto" class="hover:text-white tracking-wider uppercase text-xs">Contacto</a>
      </div>
      <div class="border-t border-stone-800 mt-10 pt-10 text-center text-xs text-stone-600">© 2026 <%= store.name %>. TuFerIA</div>
    </div>
  </footer>

  <script>
    async function addToCart(pId, vId, qty) { const r = await fetch('/api/cart/add', { method:'POST', headers:{'Content-Type':'application/json'}, body:JSON.stringify({store_id:'<%= store.id %>',product_id:pId,variant_id:vId||null,quantity:qty||1})}); if((await r.json()).success) location.reload(); }
    async function addComboToCart(cId) { const r = await fetch('/api/cart/add', { method:'POST', headers:{'Content-Type':'application/json'}, body:JSON.stringify({store_id:'<%= store.id %>',combo_id:cId,quantity:1})}); if((await r.json()).success) location.reload(); }
  </script>
</body>
</html>
