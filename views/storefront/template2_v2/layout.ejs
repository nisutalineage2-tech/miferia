<!DOCTYPE html>
<html lang="es">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= (title || store.name || '') %></title>
  <script src="https://cdn.tailwindcss.com"></script>
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Playfair+Display:ital,wght@0,400;0,600;0,700;1,400&family=Inter:wght@300;400;500;600&display=swap" rel="stylesheet">
  <style>
    <% let tc = {}; try { tc = JSON.parse(store.theme_settings || '{}'); } catch(e) {} const col = tc.colors || {}; const fonts = tc.fonts || {}; const hdr = tc.header || {}; %>
    body { font-family: '<%= fonts.body || 'Inter' %>', sans-serif; background: <%= col.body_bg || '#f8f6f4' %>; color: <%= col.body_text || '#2d2a26' %>; }
    h1,h2,h3 { font-family: 'Playfair Display', Georgia, serif; font-weight: 600; line-height: 1.2; }
    :root { --primary: <%= col.btn_primary_bg || '#8b7355' %>; --accent: <%= col.btn_secondary_bg || '#e8dccc' %>; --body-bg: <%= col.body_bg || '#f8f6f4' %>; --body-text: <%= col.body_text || '#2d2a26' %>; --btn-primary-bg: <%= col.btn_primary_bg || '#8b7355' %>; --btn-primary-text: <%= col.btn_primary_text || '#ffffff' %>; --footer-bg: <%= col.footer_bg || '#2d2a26' %>; --footer-text: <%= col.footer_text || '#a8a09a' %>; }
    body { background-color: var(--body-bg); color: var(--body-text); }
    .product-card { background: #fff; border: none; border-radius: 0; transition: all 0.3s ease; overflow: hidden; }
    .product-card:hover { box-shadow: 0 8px 30px rgba(139,115,85,0.1); }
    .product-card img { transition: transform 0.4s ease; }
    .product-card:hover img { transform: scale(1.03); }
    .btn-primary { background: #8b7355; color: #fff; border-radius: 0; font-weight: 500; letter-spacing: 0.05em; font-size: 0.75rem; padding: 0.875rem 2rem; text-transform: uppercase; }
    .btn-primary:hover { background: #6d5a42; }
    .section-title-serif { font-family: 'Playfair Display', serif; font-weight: 700; font-size: 2rem; }
    .editorial-divider { width: 60px; height: 1px; background: #8b7355; }
    <% if (store.advanced_css) { %><%= store.advanced_css %><% } %>
  </style>
</head>
<body>
  <nav class="bg-[#f8f6f4]/95 backdrop-blur-sm border-b border-[#e8dccc] sticky top-0 z-40">
    <div class="max-w-7xl mx-auto px-4 lg:px-8">
      <div class="flex items-center justify-between h-20">
        <a href="/<%= store.slug %>" class="flex items-center gap-2">
          <% if (store.logo) { %><img src="<%= store.logo %>" alt="<%= store.name %>" class="h-8 w-auto"><% } else { %><span class="text-xl font-serif tracking-wide text-[#2d2a26]"><%= store.name %></span><% } %>
        </a>
        <div class="hidden md:flex items-center gap-8">
          <%- include('../../partials/_nav_links', { locals: { navLinkClass: 'text-sm text-gray-600 hover:text-[#8b7355] transition-colors' } }) %>
        </div>
        <a href="/<%= store.slug %>/carrito" class="relative p-2">
          <svg class="w-5 h-5 text-gray-600" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M15.75 10.5V6a3.75 3.75 0 10-7.5 0v4.5m11.356-1.993l1.263 12c.07.665-.45 1.243-1.119 1.243H4.25a1.125 1.125 0 01-1.12-1.243l1.264-12A1.125 1.125 0 015.513 7.5h12.974c.576 0 1.059.435 1.119 1.007zM8.625 10.5a.375.375 0 11-.75 0 .375.375 0 01.75 0zm7.5 0a.375.375 0 11-.75 0 .375.375 0 01.75 0z"/></svg>
          <% if (cartCount > 0) { %><span class="absolute -top-1 -right-1 w-5 h-5 rounded-full text-[10px] font-bold text-white bg-[#8b7355] flex items-center justify-center"><%= cartCount %></span><% } %>
        </a>
      
            <%- include('../../partials/_mobile_menu', { locals: { iconColor: 'text-gray-600' } }) %>
</div>
    </div>
  </nav>

  <main>
    <%- include('../../partials/_flash', { locals }); %>
    <% if (page === 'home') { %>
      <section class="py-24 lg:py-32 bg-white">
        <div class="max-w-7xl mx-auto px-4 lg:px-8">
          <div class="max-w-3xl">
            <div class="editorial-divider mb-6"></div>
            <h1 class="text-6xl lg:text-8xl font-serif text-[#2d2a26] mb-6 leading-[0.95]"><%= store.name %></h1>
            <p class="text-lg text-gray-500 mb-10 max-w-lg leading-relaxed"><%= store.description %></p>
            <a href="/<%= store.slug %>/tienda" class="btn-primary inline-flex items-center gap-2">Ver Colección <span>→</span></a>
          </div>
        </div>
        <% if (heroImages.length > 0 || store.banner) { %>
          <div class="max-w-7xl mx-auto px-4 lg:px-8 mt-12">
            <%- include('../../partials/_hero_carousel', { images: heroImages, fallback: store.banner, className: 'rounded-none', height: 'h-64 sm:h-80' }); %>
          </div>
        <% } %>
      </section>

      <div class="max-w-7xl mx-auto px-4 lg:px-8 py-20">
        <% if (store.about_text) { %>
          <div class="max-w-2xl mb-16">
            <div class="editorial-divider mb-4"></div>
            <p class="text-gray-600 leading-relaxed text-lg"><%= store.about_text %></p>
          </div>
        <% } %>

        <% if (categories.length > 0) { %>
          <div class="flex flex-wrap gap-3 mb-16 border-b border-[#e8dccc] pb-4">
            <a href="/<%= store.slug %>" class="text-sm uppercase tracking-widest text-[#8b7355] mr-2">Todos</a>
            <% categories.forEach(c => { %>
              <a href="/<%= store.slug %>/categoria/<%= c.name.toLowerCase().replace(/ /g, '-') %>" class="text-sm uppercase tracking-widest text-gray-400 hover:text-[#8b7355] transition-colors mr-2"><%= c.name %></a>
            <% }); %>
          </div>
        <% } %>

        <% if (products.length > 0) { %>
          <div class="grid grid-cols-2 md:grid-cols-3 lg:grid-cols-4 gap-8">
            <% products.forEach(p => { %><%- include('../../partials/_product_card', { product: p, store, locals }); %><% }); %>
          </div>
        <% } else { %>
          <div class="text-center py-16 text-gray-400 font-serif text-2xl">Próximamente...</div>
        <% } %>
      </div>
    <% } else if (page === 'category') { %>
      <div class="max-w-7xl mx-auto px-4 lg:px-8 py-12">
        <a href="/<%= store.slug %>" class="inline-flex items-center gap-2 text-sm uppercase tracking-widest text-gray-500 hover:text-[#8b7355] transition-colors mb-8"><svg class="w-3 h-3" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 12H5m7-7l-7 7 7 7"/></svg> Volver</a>
        <h1 class="text-4xl font-serif text-[#2d2a26] mb-8"><%= category.name %></h1>
        <div class="grid grid-cols-2 md:grid-cols-3 lg:grid-cols-4 gap-8"><% products.forEach(p => { %><%- include('../../partials/_product_card', { product: p, store, locals }); %><% }); %></div>
      </div>
    <% } else if (page === 'product') { %>
      <%- include('../../partials/_product_detail', { product, store, locals }); %>
    <% } else if (page === 'cart') { %>
      <%- include('../../partials/_cart', { store, locals }); %>
    <% } else if (page === 'checkout') { %>
      <%- include('../../partials/_checkout', { store, locals }); %>
    <% } else { %>
      <%- include('../../partials/_page_content', { store, locals }); %>
    <% } %>
  </main>

  <footer class="bg-[#2d2a26] py-16 mt-20">
    <div class="max-w-7xl mx-auto px-4 lg:px-8">
      <div class="flex flex-col md:flex-row items-center justify-between gap-6">
        <div>
          <h3 class="text-xl font-serif text-white tracking-wide"><%= store.name %></h3>
          <% if (store.description) { %><p class="text-sm text-gray-400 mt-2"><%= store.description %></p><% } %>
        </div>
        <div class="flex gap-6">
          <% if (store.instagram) { %><a href="https://instagram.com/<%= store.instagram %>" target="_blank" class="text-gray-400 hover:text-white transition-colors text-sm uppercase tracking-widest">Instagram</a><% } %>
          <% if (store.whatsapp) { %><a href="https://wa.me/<%= store.whatsapp %>" target="_blank" class="text-gray-400 hover:text-white transition-colors text-sm uppercase tracking-widest">WhatsApp</a><% } %>
        </div>
      </div>
      <p class="text-center text-xs text-gray-600 mt-10 uppercase tracking-widest">Powered by TuFerIA</p>
    </div>
  </footer>

  <script>
  async function addToCart(productId, variantId, quantity) {
    const q = quantity || 1; const v = variantId || null;
    const r = await fetch('/api/cart/add', { method: 'POST', headers: { 'Content-Type': 'application/json' }, body: JSON.stringify({ store_id: '<%= store.id %>', product_id: productId, variant_id: v, quantity: q }) });
    const d = await r.json(); if (d.success) { location.reload(); } else { alert(d.error || 'Error'); }
  }
  async function addComboToCart(comboId) {
    const r = await fetch('/api/cart/combo', { method: 'POST', headers: { 'Content-Type': 'application/json' }, body: JSON.stringify({ store_id: '<%= store.id %>', combo_id: comboId }) });
    const d = await r.json(); if (d.success) { location.reload(); } else { alert(d.error || 'Error'); }
  }
  </script>
</body>
</html>