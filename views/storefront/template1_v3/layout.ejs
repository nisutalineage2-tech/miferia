<!DOCTYPE html>
<html lang="es">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= (title || store.name || '') %></title>
  <script src="https://cdn.tailwindcss.com"></script>
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=DM+Sans:opsz,wght@9..40,300;9..40,400;9..40,500;9..40,600;9..40,700&family=DM+Serif+Display:ital@0;1&display=swap" rel="stylesheet">
  <style>
    <% let tc = {}; try { tc = JSON.parse(store.theme_settings || '{}'); } catch(e) {} const col = tc.colors || {}; const fonts = tc.fonts || {}; const hdr = tc.header || {}; %>
    body { font-family: '<%= fonts.body || 'DM Sans' %>', sans-serif; background: <%= col.body_bg || '#ffffff' %>; color: <%= col.body_text || '#1a1a1a' %>; }
    h1,h2,h3 { font-family: 'DM Serif Display', serif; font-weight: 400; letter-spacing: -0.01em; }
    :root { --primary: <%= col.btn_primary_bg || '#e8a0b4' %>; --accent: <%= col.btn_secondary_bg || '#f5e1e6' %>; --body-bg: <%= col.body_bg || '#ffffff' %>; --body-text: <%= col.body_text || '#1a1a1a' %>; --btn-primary-bg: <%= col.btn_primary_bg || '#e8a0b4' %>; --btn-primary-text: <%= col.btn_primary_text || '#ffffff' %>; --footer-bg: <%= col.footer_bg || '#faf5f6' %>; --footer-text: <%= col.footer_text || '#6b5b5e' %>; }
    body { background-color: var(--body-bg); color: var(--body-text); }
    .product-card { background: #faf5f6; border: none; border-radius: 20px; transition: all 0.3s ease; overflow: hidden; }
    .product-card:hover { transform: translateY(-4px); box-shadow: 0 12px 40px rgba(232,160,180,0.15); }
    .btn-primary { background: #e8a0b4; color: #fff; border-radius: 9999px; font-weight: 500; padding: 0.75rem 2rem; font-size: 0.875rem; }
    .btn-primary:hover { background: #d4899e; }
    .section-title-serif { font-family: 'DM Serif Display', serif; font-weight: 400; letter-spacing: -0.01em; font-size: 2rem; }
    .soft-shadow { box-shadow: 0 4px 20px rgba(232,160,180,0.08); }
    <% if (store.advanced_css) { %><%= store.advanced_css %><% } %>
  </style>
</head>
<body>
  <nav class="bg-white/90 backdrop-blur-sm border-b border-[#f0e6e8] sticky top-0 z-40">
    <div class="max-w-6xl mx-auto px-6">
      <div class="flex items-center justify-between h-20">
        <a href="/<%= store.slug %>" class="flex items-center gap-2">
          <% if (store.logo) { %><img src="<%= store.logo %>" alt="<%= store.name %>" class="h-8 w-auto"><% } else { %><span class="text-xl font-serif text-[#1a1a1a]"><%= store.name %></span><% } %>
        </a>
        <div class="hidden md:flex items-center gap-8">
          <%- include('../../partials/_nav_links', { locals: { navLinkClass: 'text-sm text-gray-500 hover:text-[#e8a0b4] transition-colors' } }) %>
        </div>
        <a href="/<%= store.slug %>/carrito" class="relative p-2">
          <svg class="w-5 h-5 text-gray-600" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M15.75 10.5V6a3.75 3.75 0 10-7.5 0v4.5m11.356-1.993l1.263 12c.07.665-.45 1.243-1.119 1.243H4.25a1.125 1.125 0 01-1.12-1.243l1.264-12A1.125 1.125 0 015.513 7.5h12.974c.576 0 1.059.435 1.119 1.007zM8.625 10.5a.375.375 0 11-.75 0 .375.375 0 01.75 0zm7.5 0a.375.375 0 11-.75 0 .375.375 0 01.75 0z"/></svg>
          <% if (cartCount > 0) { %><span class="absolute -top-1 -right-1 w-5 h-5 rounded-full text-[10px] font-bold text-white bg-[#e8a0b4] flex items-center justify-center"><%= cartCount %></span><% } %>
        </a>
      
            <%- include('../../partials/_mobile_menu', { locals: { iconColor: 'text-gray-600' } }) %>
</div>
    </div>
  </nav>

  <main>
    <%- include('../../partials/_flash', { locals }); %>
    <% if (page === 'home') { %>
      <section class="bg-[#faf5f6] py-24 lg:py-32">
        <div class="max-w-6xl mx-auto px-6">
          <div class="flex flex-col lg:flex-row items-center gap-12">
            <div class="flex-1">
              <span class="text-xs uppercase tracking-[0.15em] text-[#e8a0b4] mb-3 block">Belleza Natural</span>
              <h1 class="text-5xl lg:text-6xl font-serif text-[#1a1a1a] mb-6 leading-tight"><%= store.name %></h1>
              <p class="text-lg text-gray-500 mb-8 leading-relaxed"><%= store.description %></p>
              <a href="/<%= store.slug %>/tienda" class="btn-primary inline-flex items-center gap-2">Ver Colección <span>→</span></a>
            </div>
            <div class="flex-1 w-full max-w-lg">
              <%- include('../../partials/_hero_carousel', { images: heroImages, fallback: store.banner, className: 'rounded-3xl soft-shadow', height: 'h-72 sm:h-96' }); %>
            </div>
          </div>
        </div>
      </section>

      <div class="max-w-6xl mx-auto px-6 py-20">
        <% if (store.about_text) { %>
          <div class="max-w-xl mx-auto text-center mb-20">
            <p class="text-lg text-gray-500 leading-relaxed italic font-serif"><%= store.about_text %></p>
          </div>
        <% } %>

        <% if (categories.length > 0) { %>
          <div class="flex flex-wrap justify-center gap-2 mb-16">
            <a href="/<%= store.slug %>" class="px-6 py-2.5 text-sm rounded-full bg-[#faf5f6] text-gray-600 hover:bg-[#e8a0b4] hover:text-white transition-colors">Todos</a>
            <% categories.forEach(c => { %>
              <a href="/<%= store.slug %>/categoria/<%= c.name.toLowerCase().replace(/ /g, '-') %>" class="px-6 py-2.5 text-sm rounded-full bg-[#faf5f6] text-gray-600 hover:bg-[#e8a0b4] hover:text-white transition-colors"><%= c.name %></a>
            <% }); %>
          </div>
        <% } %>

        <% if (products.length > 0) { %>
          <div class="grid grid-cols-2 md:grid-cols-3 lg:grid-cols-4 gap-6">
            <% products.forEach(p => { %><%- include('../../partials/_product_card', { product: p, store, locals }); %><% }); %>
          </div>
        <% } else { %>
          <div class="text-center py-16 text-gray-400 font-serif text-xl">Próximamente...</div>
        <% } %>
      </div>
    <% } else if (page === 'category') { %>
      <div class="max-w-6xl mx-auto px-6 py-12">
        <a href="/<%= store.slug %>" class="inline-flex items-center gap-2 text-sm text-gray-500 hover:text-[#e8a0b4] transition-colors mb-8"><svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 12H5m7-7l-7 7 7 7"/></svg> Volver</a>
        <h1 class="text-3xl font-serif text-[#1a1a1a] mb-8"><%= category.name %></h1>
        <div class="grid grid-cols-2 md:grid-cols-3 lg:grid-cols-4 gap-6"><% products.forEach(p => { %><%- include('../../partials/_product_card', { product: p, store, locals }); %><% }); %></div>
      </div>
    <% } else if (page === 'product') { %>
      <%- include('../../partials/_product_detail', { product, store, locals }); %>
    <% } else if (page === 'cart') { %>
      <%- include('../../partials/_cart', { store, locals }); %>
    <% } else if (page === 'checkout') { %>
      <%- include('../../partials/_checkout', { store, locals }); %>
    <% } else { %>
      <%- include('../../partials/_page_content', { store, locals }); %>
    <% } %>
  </main>

  <footer class="bg-[#faf5f6] py-16">
    <div class="max-w-6xl mx-auto px-6">
      <div class="flex flex-col md:flex-row items-center justify-between gap-6">
        <div>
          <h3 class="text-xl font-serif text-[#1a1a1a]"><%= store.name %></h3>
          <% if (store.description) { %><p class="text-sm text-gray-500 mt-2"><%= store.description %></p><% } %>
        </div>
        <div class="flex gap-6">
          <% if (store.instagram) { %><a href="https://instagram.com/<%= store.instagram %>" target="_blank" class="text-gray-400 hover:text-[#e8a0b4] transition-colors text-sm">Instagram</a><% } %>
          <% if (store.whatsapp) { %><a href="https://wa.me/<%= store.whatsapp %>" target="_blank" class="text-gray-400 hover:text-[#e8a0b4] transition-colors text-sm">WhatsApp</a><% } %>
        </div>
      </div>
      <p class="text-center text-xs text-gray-400 mt-10">Powered by TuFerIA</p>
    </div>
  </footer>

  <script>
  async function addToCart(productId, variantId, quantity) {
    const q = quantity || 1; const v = variantId || null;
    const r = await fetch('/api/cart/add', { method: 'POST', headers: { 'Content-Type': 'application/json' }, body: JSON.stringify({ store_id: '<%= store.id %>', product_id: productId, variant_id: v, quantity: q }) });
    const d = await r.json(); if (d.success) { location.reload(); } else { alert(d.error || 'Error'); }
  }
  async function addComboToCart(comboId) {
    const r = await fetch('/api/cart/combo', { method: 'POST', headers: { 'Content-Type': 'application/json' }, body: JSON.stringify({ store_id: '<%= store.id %>', combo_id: comboId }) });
    const d = await r.json(); if (d.success) { location.reload(); } else { alert(d.error || 'Error'); }
  }
  </script>
</body>
</html>