<!DOCTYPE html>
<html lang="es">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= (title || store.name || '') %></title>
  <script src="https://cdn.tailwindcss.com"></script>
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Source+Serif+4:ital,wght@0,300;0,400;0,600;0,700;1,400&family=Inter:wght@300;400;500;600;700&display=swap" rel="stylesheet">
  <style>
    <% let tc = {}; try { tc = JSON.parse(store.theme_settings || '{}'); } catch(e) {} const col = tc.colors || {}; const fonts = tc.fonts || {}; const hdr = tc.header || {}; %>
    body { font-family: '<%= fonts.body || 'Inter' %>', sans-serif; background: <%= col.body_bg || '#1a1a2e' %>; color: <%= col.body_text || '#e2e8f0' %>; }
    h1,h2,h3 { font-family: 'Source Serif 4', Georgia, serif; font-weight: 600; }
    :root { --primary: <%= col.btn_primary_bg || '#e2b714' %>; --accent: <%= col.btn_secondary_bg || '#2d2d44' %>; --footer-bg: <%= col.footer_bg || '#1a1a2e' %>; --footer-text: <%= col.footer_text || '#7c7caa' %>; }
    .product-card { background: #22223a; border: 1px solid #2d2d44; border-radius: 8px; transition: all 0.3s ease; overflow: hidden; }
    .product-card:hover { border-color: #e2b714; box-shadow: 0 8px 30px rgba(226,183,20,0.04); }
    .btn-primary { background: #e2b714; color: #1a1a2e; border-radius: 4px; font-weight: 600; letter-spacing: 0.02em; padding: 0.75rem 1.75rem; }
    .btn-primary:hover { background: #f0c929; }
    .section-title-serif { font-family: 'Source Serif 4', Georgia, serif; font-weight: 600; font-size: 1.5rem; }
    .academic-divider { width: 60px; height: 1px; background: #e2b714; }
    .product-card .product-name { font-weight: 500; letter-spacing: 0.01em; }
    .product-card img { transition: opacity 0.3s ease; }
    .product-card:hover img { opacity: 0.9; }
    .section-label { font-style: italic; font-family: 'Source Serif 4', Georgia, serif; font-weight: 400; color: #7c7caa; }
    <% if (store.advanced_css) { %><%= store.advanced_css %><% } %>
  </style>
</head>
<body>
  <nav class="bg-[#1a1a2e]/90 border-b border-[#2d2d44] sticky top-0 z-40">
    <div class="max-w-7xl mx-auto px-4 lg:px-8">
      <div class="flex items-center justify-between h-20">
        <a href="/<%= store.slug %>" class="flex items-center gap-2">
          <% if (store.logo) { %><img src="<%= store.logo %>" alt="<%= store.name %>" class="h-8 w-auto"><% } else { %><span class="text-lg font-serif tracking-wide text-[#e2e8f0]"><%= store.name %></span><% } %>
        </a>
        <div class="hidden md:flex items-center gap-8">
          <%- include('../../partials/_nav_links', { locals: { navLinkClass: 'text-sm text-gray-500 hover:text-[#e2b714] transition-colors' } }) %>
        </div>
        <a href="/<%= store.slug %>/carrito" class="relative p-2">
          <svg class="w-5 h-5 text-gray-500" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M15.75 10.5V6a3.75 3.75 0 10-7.5 0v4.5m11.356-1.993l1.263 12c.07.665-.45 1.243-1.119 1.243H4.25a1.125 1.125 0 01-1.12-1.243l1.264-12A1.125 1.125 0 015.513 7.5h12.974c.576 0 1.059.435 1.119 1.007zM8.625 10.5a.375.375 0 11-.75 0 .375.375 0 01.75 0zm7.5 0a.375.375 0 11-.75 0 .375.375 0 01.75 0z"/></svg>
          <% if (cartCount > 0) { %><span class="absolute -top-1 -right-1 w-4 h-4 bg-[#e2b714] text-[#1a1a2e] text-[10px] font-bold rounded-full flex items-center justify-center"><%= cartCount %></span><% } %>
        </a>
      
            <%- include('../../partials/_mobile_menu', { locals: { iconColor: 'text-gray-600' } }) %>
</div>
    </div>
  </nav>

  <main>
    <%- include('../../partials/_flash', { locals }); %>
    <% if (page === 'home') { %>
      <section class="py-20 lg:py-28">
        <div class="max-w-7xl mx-auto px-4 lg:px-8">
          <div class="max-w-3xl">
            <span class="section-label text-sm mb-3 block">— Nuevo lanzamiento</span>
            <h1 class="text-5xl lg:text-7xl font-serif text-white mb-6 leading-[0.95]"><%= store.name %></h1>
            <div class="academic-divider mb-6"></div>
            <p class="text-gray-400 mb-10 text-lg leading-relaxed"><%= store.description %></p>
            <a href="/<%= store.slug %>/tienda" class="btn-primary inline-flex items-center gap-2">Explorar <span>→</span></a>
          </div>
          <div class="mt-12 max-w-4xl"><%- include('../../partials/_hero_carousel', { images: heroImages, fallback: store.banner, className: 'rounded-lg', height: 'h-56 sm:h-72' }); %></div>
        </div>
      </section>



      <div class="max-w-7xl mx-auto px-4 lg:px-8 py-20">
        <% if (categories.length > 0) { %>
          <div class="mb-16">
            <span class="section-label text-sm mb-3 block">— Categorías</span>
            <a href="/<%= store.slug %>" class="inline-block text-sm text-[#e2b714] mr-6 pb-2 border-b-2 border-[#e2b714]">Todos</a>
            <% categories.forEach(c => { %>
              <a href="/<%= store.slug %>/categoria/<%= c.name.toLowerCase().replace(/ /g, '-') %>" class="inline-block text-sm text-gray-500 hover:text-[#e2b714] transition-colors mr-6 pb-2"><%= c.name %></a>
            <% }); %>
          </div>
        <% } %>

        <% if (store.about_text) { %>
          <div class="max-w-2xl mb-20">
            <div class="academic-divider mb-4"></div>
            <p class="text-gray-400 leading-relaxed italic font-serif"><%= store.about_text %></p>
          </div>
        <% } %>

        <% if (products.length > 0) { %>
          <div class="grid grid-cols-2 md:grid-cols-3 lg:grid-cols-4 gap-6">
            <% products.forEach(p => { %><%- include('../../partials/_product_card', { product: p, store, locals }); %><% }); %>
          </div>
        <% } else { %>
          <div class="text-center py-16 text-gray-600 font-serif italic text-xl">Próximamente...</div>
        <% } %>
      </div>
    <% } else if (page === 'category') { %>
      <div class="max-w-7xl mx-auto px-4 lg:px-8 py-12">
        <a href="/<%= store.slug %>" class="inline-flex items-center gap-2 text-sm text-[#e2b714] hover:underline mb-8"><svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 12H5m7-7l-7 7 7 7"/></svg> Volver</a>
        <h1 class="text-4xl font-serif text-white mb-8"><%= category.name %></h1>
        <div class="grid grid-cols-2 md:grid-cols-3 lg:grid-cols-4 gap-6"><% products.forEach(p => { %><%- include('../../partials/_product_card', { product: p, store, locals }); %><% }); %></div>
      </div>
    <% } else if (page === 'product') { %>
      <%- include('../../partials/_product_detail', { product, store, locals }); %>
    <% } else if (page === 'cart') { %>
      <%- include('../../partials/_cart', { store, locals }); %>
    <% } else if (page === 'checkout') { %>
      <%- include('../../partials/_checkout', { store, locals }); %>
    <% } else { %>
      <%- include('../../partials/_page_content', { store, locals }); %>
    <% } %>
  </main>

  <footer class="border-t border-[#2d2d44] py-16 mt-20">
    <div class="max-w-7xl mx-auto px-4 lg:px-8">
      <div class="flex flex-col md:flex-row items-center justify-between gap-6">
        <div>
          <h3 class="text-lg font-serif text-white"><%= store.name %></h3>
          <% if (store.description) { %><p class="text-sm text-gray-500 mt-2"><%= store.description %></p><% } %>
        </div>
        <div class="flex gap-6">
          <% if (store.instagram) { %><a href="https://instagram.com/<%= store.instagram %>" target="_blank" class="text-sm text-gray-500 hover:text-[#e2b714] transition-colors">Instagram</a><% } %>
          <% if (store.whatsapp) { %><a href="https://wa.me/<%= store.whatsapp %>" target="_blank" class="text-sm text-gray-500 hover:text-[#e2b714] transition-colors">WhatsApp</a><% } %>
        </div>
      </div>
      <p class="text-center text-xs text-gray-600 mt-10">Powered by TuFerIA</p>
    </div>
  </footer>

  <script>
  async function addToCart(productId, variantId, quantity) {
    const q = quantity || 1; const v = variantId || null;
    const r = await fetch('/api/cart/add', { method: 'POST', headers: { 'Content-Type': 'application/json' }, body: JSON.stringify({ store_id: '<%= store.id %>', product_id: productId, variant_id: v, quantity: q }) });
    const d = await r.json(); if (d.success) { location.reload(); } else { alert(d.error || 'Error'); }
  }
  async function addComboToCart(comboId) {
    const r = await fetch('/api/cart/combo', { method: 'POST', headers: { 'Content-Type': 'application/json' }, body: JSON.stringify({ store_id: '<%= store.id %>', combo_id: comboId }) });
    const d = await r.json(); if (d.success) { location.reload(); } else { alert(d.error || 'Error'); }
  }
  </script>
</body>
</html>