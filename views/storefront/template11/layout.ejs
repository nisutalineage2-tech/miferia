<!DOCTYPE html><html lang="es"><head><meta charset="UTF-8"><meta name="viewport" content="width=device-width,initial-scale=1.0"><title><%= (title||store.name||'') %></title><script src="https://cdn.tailwindcss.com"></script><link rel="preconnect" href="https://fonts.googleapis.com"><link rel="preconnect" href="https://fonts.gstatic.com" crossorigin><% let _t={};try{_t=JSON.parse(store.theme_settings||'{}');}catch(e){}const _c=_t.colors||{};const _f=_t.fonts||{};const _gf={"Inter":"Inter:wght@300;400;500;600;700","Playfair Display":"Playfair+Display:ital,wght@0,400;0,600;0,700;1,400","Lora":"Lora:wght@400;500;600;700","Nunito":"Nunito:wght@300;400;600;700;800","Quicksand":"Quicksand:wght@300;400;500;600;700","Oswald":"Oswald:wght@300;400;500;600;700","Fredoka":"Fredoka:wght@300;400;500;600;700","Noto Serif":"Noto+Serif:wght@400;600;700","Poppins":"Poppins:wght@300;400;500;600;700;800"};const _fb=_f.body||'Inter';const _fh=_f.headings||'Lora';const _fl=[...new Set([_gf[_fb],_gf[_fh]].filter(Boolean))];%><link href="https://fonts.googleapis.com/css2?family=<%=_fl.join('&family=')%>&display=swap" rel="stylesheet"><style>body{font-family:'<%=_fb%>',sans-serif}h1,h2,h3{font-family:'<%=_fh%>',serif;font-weight:600}:root{--primary:<%=_c.btn_primary_bg||'#0d9488'%>;--bg:<%=_c.body_bg||'#f0fdfa'%>;--text:<%=_c.body_text||'#134e4a'%>;--footer-bg:<%=_c.footer_bg||'#134e4a'%>;--footer-text:<%=_c.footer_text||'#99f6e4'%>;--title:<%=_c.title_text||_c.body_text||'#134e4a'%>;--label-bg:<%=_c.label_bg||'#0d9488'%>}body{background:var(--bg);color:var(--text)}h1,h2,h3,h4,h5,h6{color:var(--title)!important}.product-badge{background:var(--label-bg);color:#fff}.section-title{font-family:'<%=_fh%>',serif;font-weight:600}.nav-link{color:#134e4a;transition:color .2s}.nav-link:hover{color:var(--primary)}footer{background:var(--footer-bg)!important;color:var(--footer-text)!important}footer a,footer p,footer span{color:var(--footer-text)!important}nav.sticky{background:#0a0a0f!important;border-bottom:1px solid #1f2937!important}<%if(store.advanced_css){%><%=store.advanced_css%><%}%></style></head><body>
<body>
<nav class="sticky top-0 z-40" style="background:#0a0a0f;border-bottom:1px solid #1f2937"><div class="max-w-7xl mx-auto px-4"><div class="flex items-center justify-between h-16"><a href="<%=storeBaseUrl || '/'%>" class="flex items-center gap-2 shrink-0"><%if(store.logo){%><img src="<%=store.logo%>" alt="<%=store.name%>" class="h-8 w-auto"><%}else{%><span class="text-xl font-bold" style="color:var(--primary)"><%=store.name%></span><%}%></a><div class="hidden md:flex items-center gap-6 nav-links"><%-include('../../partials/_nav_links',{locals:{navLinkClass:'nav-link text-sm font-medium'}})%></div><button type="button" onclick="toggleCartDrawer()" class="relative p-2"><svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M16 11V7a4 4 0 00-8 0v4M5 9h14l1 12H4L5 9z"/></svg><%if(cartCount>0){%><span class="absolute -top-1 -right-1 w-5 h-5 rounded-full text-xs font-bold text-white flex items-center justify-center" style="background:var(--primary)"><%=cartCount%></span><%}%></button><%-include('../../partials/_mobile_menu',{locals:{}})%></div></div></nav>
<%-include("../../partials/_banner_carousel",{heroImages:typeof heroImages!=='undefined'?heroImages:[],store})%>
<main><%-include('../../partials/_flash',{locals})%>
<%if(page==='home'){%>
<div class="relative" style="background:linear-gradient(135deg,rgb(255,255,255),#f0fdfa,rgb(230,243,240))"><div class="max-w-7xl mx-auto px-4 py-12 lg:py-16"><div class="text-center max-w-3xl mx-auto"><span class="inline-block px-3 py-1 rounded-full bg-white/60 text-xs font-semibold mb-4">Bienvenido</span><h1 class="text-4xl lg:text-5xl mb-4" style="font-family:'Lora',serif"><%=store.name%></h1><p class="text-lg mb-6 opacity-80"><%=store.description%></p><div class="flex flex-wrap justify-center gap-3 mb-8"><a href="<%=storeBaseUrl%>/shop" class="btn-primary inline-block px-8 py-3 text-base">Ver Catálogo</a></div><%-include('../../partials/_hero_carousel',{images:typeof heroImages!=='undefined'?heroImages:[],fallback:store.banner,className:'rounded-2xl shadow-lg',height:'h-48 lg:h-64'})%></div></div></div>
<div class="py-12 lg:py-16" style="background:rgb(173,255,248)"><div class="max-w-7xl mx-auto px-4"><div class="grid grid-cols-2 md:grid-cols-4 gap-8 text-center"><div><span class="text-3xl font-bold" style="color:#0d9488;font-family:'Lora',serif">10K+</span><p class="text-sm mt-1 opacity-70">Clientes felices</p></div><div><span class="text-3xl font-bold" style="color:#0d9488;font-family:'Lora',serif">500+</span><p class="text-sm mt-1 opacity-70">Productos</p></div><div><span class="text-3xl font-bold" style="color:#0d9488;font-family:'Lora',serif">99%</span><p class="text-sm mt-1 opacity-70">Satisfacción</p></div><div><span class="text-3xl font-bold" style="color:#0d9488;font-family:'Lora',serif">24/7</span><p class="text-sm mt-1 opacity-70">Soporte</p></div></div></div></div>
<div class="py-12 lg:py-16" style="background:#f0fdfa"><div class="max-w-7xl mx-auto px-4"><h2 class="text-2xl font-bold text-center mb-10 section-title">Todo lo que ofrecemos</h2><div class="grid grid-cols-1 md:grid-cols-3 gap-6"><%const ft=[{ico:'<svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M13 10V3L4 14h7v7l9-11h-7z"/></svg>',tit:'Envío Exprés',desc:'Recibí tu pedido en menos de 24 horas en zonas seleccionadas.'},{ico:'<svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M3 10h18M7 15h1m4 0h1m-7 4h12a3 3 0 003-3V8a3 3 0 00-3-3H6a3 3 0 00-3 3v8a3 3 0 003 3z"/></svg>',tit:'Pago en Cuotas',desc:'Financiación sin interés con todas las tarjetas de crédito.'},{ico:'<svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M3 9a2 2 0 012-2h.93a2 2 0 001.664-.89l.812-1.22A2 2 0 0110.07 4h3.86a2 2 0 011.664.89l.812 1.22A2 2 0 0018.07 7H19a2 2 0 012 2v9a2 2 0 01-2 2H5a2 2 0 01-2-2V9z"/></svg>',tit:'Programa de Puntos',desc:'Acumulá puntos con cada compra y canjeá por productos exclusivos.'},{ico:'<svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z"/></svg>',tit:'Garantía Extendida',desc:'Todos nuestros productos tienen garantía de hasta 12 meses.'},{ico:'<svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M18.364 5.636l-3.536 3.536m0 5.656l3.536 3.536M9.172 9.172L5.636 5.636m3.536 9.192l-3.536 3.536M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>',tit:'Atención Personalizada',desc:'Un asesor dedicado para acompañarte antes, durante y después de tu compra.'},{ico:'<svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M4 4v5h.582m15.356 2A8.001 8.001 0 004.582 9m0 0H9m11 11v-5h-.581m0 0a8.003 8.003 0 01-15.357-2m15.357 2H15"/></svg>',tit:'Cambio sin Cargo',desc:'Si no te gusta, lo cambiás sin costo. Priorizamos tu satisfacción.'}];ft.forEach(f=>{%><div class="flex gap-4 p-4 rounded-xl" style="background:#ffffff;border:1px solid #99f6e4;box-shadow:0 4px 6px -1px rgb(0 0 0 / 0.1)"><div class="shrink-0" style="color:#0d9488"><%=f.ico%></div><div><h3 class="font-semibold text-sm mb-1"><%=f.tit%></h3><p class="text-xs opacity-60"><%=f.desc%></p></div></div><%})%></div></div></div>
<div class="py-12 lg:py-16" style="background:#0d9488"><div class="max-w-3xl mx-auto px-4 text-center"><h2 class="text-2xl font-bold mb-3" style="color:#fff;font-family:'Lora',serif">No te pierdas nada</h2><p class="mb-6 opacity-90" style="color:#fff">Suscribite y recibí 10% OFF en tu primera compra + novedades exclusivas.</p><form class="flex flex-col sm:flex-row gap-3 max-w-md mx-auto" onsubmit="event.preventDefault();alert('Gracias por suscribirte!')"><input type="email" placeholder="tu@email.com" class="flex-1 px-4 py-3 rounded-lg border-0 text-sm" style="background:rgba(255,255,255,0.9);color:#111"><button type="submit" class="px-6 py-3 rounded-lg text-sm font-semibold whitespace-nowrap" style="background:#111;color:#fff">Quiero mi 10% OFF</button></form></div></div>
<div class="max-w-7xl mx-auto px-4 py-8 lg:py-12">
<%if(featured.length>0){%><h2 class="text-2xl font-bold mb-6 section-title">Destacados</h2>
<div class="grid grid-cols-2 md:grid-cols-3 lg:grid-cols-3 gap-4 lg:gap-6 mb-12">
<%featured.forEach(p=>{%><%-include('../../partials/_product_card',{product:p,store,locals})%><%})%></div><%}%>
<h2 class="text-2xl font-bold mb-6 section-title">Todos los Productos</h2>
<%if(products.length>0){%><div class="grid grid-cols-2 md:grid-cols-3 lg:grid-cols-3 gap-4 lg:gap-6">
<%products.forEach(p=>{%><%-include('../../partials/_product_card',{product:p,store,locals})%><%})%></div>
<%}else{%><div class="text-center py-16 opacity-50"><p>Proximamente estaremos agregando nuestros productos.</p></div><%}%>
<%if(combos.length>0){%><h2 class="text-2xl font-bold mb-6 mt-12 section-title">Combos Especiales</h2>
<div class="grid md:grid-cols-2 lg:grid-cols-3 gap-6">
<%combos.forEach(combo=>{%><div class="p-6 rounded-2xl border-2 border-dashed" style="border-color:var(--primary)"><h3 class="text-lg font-bold"><%=combo.name%></h3><p class="text-sm opacity-70 mb-3"><%=combo.description%></p><p class="text-2xl font-bold" style="color:var(--primary)">$$<%=combo.price.toFixed(2)%></p>
<button onclick="addComboToCart('<%=combo.id%>')" class="mt-3 w-full px-4 py-2.5 text-sm font-semibold text-white transition-all btn-primary">Agregar al Carrito</button></div><%})%></div><%}%>
</div>
<%}else if(page==='category'){%><div class="max-w-7xl mx-auto px-4 py-8"><div class="mb-6"><a href="<%=storeBaseUrl || '/'%>" class="text-sm opacity-60 hover:opacity-100">← Todos los productos</a><h1 class="text-3xl font-bold mt-2 section-title"><%=category.name%></h1><%if(category.description){%><p class="opacity-70 mt-1"><%=category.description%></p><%}%></div>
<%if(products.length>0){%><div class="grid grid-cols-2 md:grid-cols-3 lg:grid-cols-3 gap-4 lg:gap-6">
<%products.forEach(p=>{%><%-include('../../partials/_product_card',{product:p,store,locals})%><%})%></div><%}else{%><div class="text-center py-16 opacity-60"><p>No hay productos en esta categoria todavia.</p></div><%}%></div>
<%}else if(page==='product'){%><%-include('../../partials/_product_detail',{store,product,variants,productImages,categories,related,cartCount,cartTotal,locals})%>
<%}else if(page==='cart'){%><%-include('../../partials/_cart',{store,categories,cartItems,cartCount,cartTotal,locals})%>
<%}else if(page==='checkout'){%><%-include('../../partials/_checkout',{store,categories,cartItems,cartCount,cartTotal,locals})%>
<%}else if(['shop','subscriptions','about','contact','login','register','account'].includes(page)){%><%-include('../../partials/_page_content',{page,store,categories,products,featured,combos,cartItems,cartCount,cartTotal,query:typeof query!=='undefined'?query:{},priceRange:typeof priceRange!=='undefined'?priceRange:null,filterSettings:typeof filterSettings!=='undefined'?filterSettings:{},filterData:typeof filterData!=='undefined'?filterData:{},error:typeof error!=='undefined'?error:null,msg:typeof msg!=='undefined'?msg:null,customer:typeof customer!=='undefined'?customer:null,orders:typeof orders!=='undefined'?orders:null})%>
<%}%></main>
<footer class="mt-16"><div class="max-w-7xl mx-auto px-4 py-8"><div class="text-center text-sm opacity-50">&copy; 2026 <%=store.name%>. Powered by TuFerIA.</div></div></footer>
<style>.product-card{background:#ffffff;border:1px solid #99f6e4;border-radius:0.75rem;box-shadow:0 4px 6px -1px rgb(0 0 0 / 0.1);transition:.3s;overflow:hidden}.product-card:hover{transform:translateY(-6px);border-color:var(--primary);box-shadow:0 0 30px #0d948844}.btn-primary{background:var(--primary);color:#fff;border-radius:.5rem;font-weight:600;padding:.625rem 1.25rem;transition:.2s}.btn-primary:hover{opacity:.9}</style>
<script>
async function addToCart(pid,vid,qty){const r=await fetch('/api/cart/add',{method:'POST',headers:{'Content-Type':'application/json'},body:JSON.stringify({store_id:'<%=store.id%>',product_id:pid,variant_id:vid,quantity:qty||1})});const d=await r.json();if(d.success)location.reload()}
async function addComboToCart(cid){const r=await fetch('/api/cart/add',{method:'POST',headers:{'Content-Type':'application/json'},body:JSON.stringify({store_id:'<%=store.id%>',combo_id:cid,quantity:1})});const d=await r.json();if(d.success)location.reload()}
</script>
<%-include('../../partials/_cart_drawer',{store,cartItems,cartCount,cartTotal,locals})%>
<%-include('../../partials/_order_success',{order:typeof order!=='undefined'?order:null,whatsappLink:typeof whatsappLink!=='undefined'?whatsappLink:null})%>
</body></html>