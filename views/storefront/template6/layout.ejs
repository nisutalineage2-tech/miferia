<%
const ts = store.theme_settings ? (typeof store.theme_settings === 'string' ? JSON.parse(store.theme_settings) : store.theme_settings) : {};
const gfMap = { 'Fredoka': 'Fredoka:wght@300;400;500;600;700&display=swap', 'Nunito': 'Nunito:wght@300;400;500;600;700;800&display=swap' };
const hFont = ts.heading_font || 'Fredoka';
const bFont = ts.body_font || 'Nunito';
const gf = gfMap[hFont] || 'Fredoka:wght@300;400;500;600;700&display=swap';
const isHome = !page || page === 'home';
const isShop = page === 'shop';
const isProduct = page === 'product';
const isCart = page === 'cart';
const isCheckout = page === 'checkout';
const isCategory = page === 'category';
%><!DOCTYPE html>
<html lang="es">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width,initial-scale=1.0">
<meta name="description" content="<%=store.description%>">
<title><%=store.name%><%=page&&page!=='home'?' | '+page:''%></title>
<script src="https://cdn.tailwindcss.com"></script>
<link rel="preconnect" href="https://fonts.googleapis.com">
<link href="https://fonts.googleapis.com/css2?family=<%=gf%>&family=Nunito:wght@400;500;600;700&display=swap" rel="stylesheet">
<script>tailwind.config={theme:{extend:{fontFamily:{sans:['Fredoka','sans-serif'],body:['Nunito','sans-serif']}}}}</script>
<style>
:root {
  --primary: <%=store.primary_color||'#8b5cf6'%>;
  --bg: <%=store.bg_color||'#fef9ef'%>;
  --text: <%=store.text_color||'#444'%>;
  --footer-bg: <%=store.footer_bg||'#1e1b4b'%>;
  --footer-text: <%=store.footer_text||'#c4b5fd'%>;
  --title: <%=store.title_color||'#1e1b4b'%>;
  --label-bg: <%=store.label_bg||'#e8dfff'%>;
}
*{margin:0;padding:0;box-sizing:border-box}
body{font-family:'Nunito',sans-serif;background:var(--bg);color:var(--text);font-weight:500;line-height:1.7}
h1,h2,h3,h4,h5,h6{font-family:'Fredoka',sans-serif;font-weight:600;color:var(--title);letter-spacing:-0.01em}
.section-title{font-size:2rem;font-weight:600;text-align:center;margin-bottom:1.5rem;color:var(--title)}
.btn-primary{display:inline-flex;align-items:center;justify-content:center;font-family:'Fredoka',sans-serif;font-weight:500;font-size:0.95rem;padding:0.875rem 2.5rem;background:linear-gradient(135deg,var(--primary),#ec4899);color:#fff;border-radius:16px;border:2px dashed rgba(255,255,255,0.3);transition:all 0.3s ease}
.btn-primary:hover{transform:scale(1.05) rotate(-1deg);box-shadow:0 8px 30px rgba(139,92,246,0.3)}
.product-card{background:#fff!important;border:2px dashed #e8dfff!important;border-radius:20px!important;overflow:hidden;box-shadow:0 4px 0 #d4c8f0!important;transition:all 0.3s ease!important}
.product-card:hover{transform:translateY(-4px) rotate(0.5deg);border-color:var(--primary)!important;box-shadow:0 8px 0 var(--primary)!important}
.product-card .aspect-square{border-radius:18px 18px 0 0}
.product-card h3{font-family:'Fredoka',sans-serif;font-size:0.95rem}
.product-card span[style*="clip"]{display:inline-block;padding:0.2rem 0.6rem;font-family:'Fredoka',sans-serif;font-size:0.7rem;border-radius:8px;transform:rotate(-2deg)}
.retro-hero{background:linear-gradient(135deg,var(--primary),#ec4899,#fbbf24);position:relative;overflow:hidden}
.retro-hero::before{content:'';position:absolute;inset:0;background:radial-gradient(circle at 80% 20%,rgba(255,255,255,0.2) 0%,transparent 50%);pointer-events:none}
.retro-hero::after{content:'';position:absolute;bottom:0;left:0;right:0;height:30%;background:linear-gradient(transparent,var(--bg));pointer-events:none}
@keyframes float{0%,100%{transform:translateY(0)}50%{transform:translateY(-12px)}}
@keyframes pulse-soft{0%,100%{opacity:1}50%{opacity:0.7}}
@keyframes bounce-in{0%{opacity:0;transform:scale(0.7)}60%{transform:scale(1.05)}100%{opacity:1;transform:scale(1)}}
.animate-float{animation:float 3s ease-in-out infinite}
.animate-pulse-soft{animation:pulse-soft 2s ease-in-out infinite}
.animate-bounce-in{animation:bounce-in 0.6s ease-out forwards}
.sticker-badge{display:inline-block;padding:0.15rem 0.75rem;border-radius:8px;font-family:'Fredoka',sans-serif;font-size:0.65rem;font-weight:600;text-transform:uppercase;transform:rotate(-3deg)}
.sticker-badge:nth-child(odd){transform:rotate(2deg)}
.retro-nav{background:linear-gradient(90deg,var(--primary),#ec4899);border-bottom:3px solid #fbbf24}
</style>
</head>
<body>
<%-include('../../partials/_flash',{order:locals.order||null})%>

<!-- Retro Nav -->
<nav class="retro-nav sticky top-0 z-50">
  <div class="max-w-7xl mx-auto px-4 lg:px-8">
    <div class="flex items-center justify-between h-16">
      <div class="hidden md:flex items-center gap-4">
        <%- include('../../partials/_nav_links', {locals:{navLinkClass:'text-sm font-semibold text-white/90 hover:text-white transition-all hover:scale-105'}}); %>
      </div>
      <a href="<%=storeBaseUrl%>" class="text-xl font-bold text-white" style="font-family:'Fredoka',sans-serif;text-decoration:none;text-shadow:2px 2px 0 rgba(0,0,0,0.1)"><%=store.name%></a>
      <div class="flex items-center gap-3">
        <button onclick="toggleCartDrawer()" class="p-2 relative">
          <svg class="w-5 h-5 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M2.25 3h1.386c.51 0 .955.343 1.087.835l.383 1.437M7.5 14.25a3 3 0 00-3 3h15.75m-12.75-3h11.218c1.121-2.3 2.1-4.684 2.924-7.138a60.114 60.114 0 00-16.536-1.84M7.5 14.25L5.106 5.272"/></svg>
          <% if (cartCount > 0) { %><span class="absolute -top-0.5 -right-0.5 w-5 h-5 rounded-full flex items-center justify-center text-[10px] font-bold text-white" style="background:#fbbf24;color:#1e1b4b"><%= cartCount %></span><% } %>
        </button>
        <%- include('../../partials/_mobile_menu', { locals: { iconColor: 'text-white' } }); %>
      </div>
    </div>
  </div>
</nav>

<main>
  <% if (isHome) { %>
    <!-- Retro Hero -->
    <div class="retro-hero px-4 py-20 lg:py-28 text-center relative">
      <div class="max-w-3xl mx-auto relative z-10">
        <div class="inline-block sticker-badge mb-4 animate-float" style="background:#fbbf24;color:#1e1b4b">Nuevo</div>
        <h1 class="text-5xl lg:text-7xl font-bold text-white mb-4 animate-bounce-in" style="font-family:'Fredoka',sans-serif;text-shadow:3px 3px 0 rgba(0,0,0,0.1)"><%=store.name%></h1>
        <p class="text-lg lg:text-xl text-white/80 mb-8 max-w-lg mx-auto animate-pulse-soft"><%=store.description%></p>
        <div class="flex flex-wrap justify-center gap-4">
          <a href="<%=storeBaseUrl%>/tienda" class="inline-block px-8 py-4 font-bold text-lg rounded-2xl transition-all hover:scale-105" style="background:#fff;color:var(--primary);font-family:'Fredoka',sans-serif;box-shadow:0 4px 0 #ddd">Ver Tienda</a>
          <% if (store.whatsapp) { %><a href="https://wa.me/<%=store.whatsapp%>" class="inline-block px-8 py-4 font-bold text-lg rounded-2xl transition-all hover:scale-105" style="background:rgba(255,255,255,0.2);color:#fff;backdrop-filter:blur(4px);font-family:'Fredoka',sans-serif;border:2px dashed rgba(255,255,255,0.4)">WhatsApp</a><% } %>
        </div>
      </div>
    </div>
    <%- include('../../partials/_banner_carousel', { heroImages, store, storeBaseUrl }); %>
    <%- include('../../partials/_home_content', { store, storeBaseUrl, categories, products, featured, combos, locals }); %>
  <% } else if (isCategory) { %>
    <div class="max-w-7xl mx-auto px-4 lg:px-8 py-12">
      <h1 class="text-4xl mb-8" style="font-family:'Fredoka',sans-serif"><%= category.name %></h1>
      <div class="grid grid-cols-2 lg:grid-cols-4 gap-6">
        <% products.forEach(p => { %>
          <%- include('../../partials/_product_card', { product: p, store, locals }); %>
        <% }); %>
      </div>
    </div>
  <% } else if (isProduct) { %>
    <%- include('../../partials/_product_detail', { product, productImages, category, variants, volumeDiscounts, related, store, storeBaseUrl, locals }); %>
  <% } else if (isCart) { %>
    <%- include('../../partials/_cart', { cartItems, cartTotal, store, storeBaseUrl, locals }); %>
  <% } else if (isCheckout) { %>
    <%- include('../../partials/_checkout', { cartItems, cartTotal, store, storeBaseUrl, locals }); %>
  <% } else { %>
    <%- include('../../partials/_page_content', { page, store, storeBaseUrl, categories, products, featured, combos, locals }); %>
  <% } %>
</main>

<!-- Retro Footer -->
<footer style="background:var(--footer-bg);color:var(--footer-text)">
  <div class="max-w-7xl mx-auto px-4 lg:px-8 py-14">
    <div class="grid lg:grid-cols-3 gap-10">
      <div>
        <h3 class="text-2xl font-bold mb-4" style="font-family:'Fredoka',sans-serif;color:#fff"><%=store.name%></h3>
        <p class="text-sm opacity-60"><%=store.description%></p>
      </div>
      <div>
        <h4 class="text-sm font-bold uppercase tracking-wider mb-5 opacity-60" style="font-family:'Fredoka',sans-serif">Menú</h4>
        <div class="flex flex-col gap-2">
          <%- include('../../partials/_nav_links', {locals:{navLinkClass:'text-sm font-medium text-[var(--footer-text)] hover:text-white transition-all'}}); %>
        </div>
      </div>
      <div>
        <h4 class="text-sm font-bold uppercase tracking-wider mb-5 opacity-60" style="font-family:'Fredoka',sans-serif">Contacto</h4>
        <div class="flex flex-wrap gap-3">
          <% if (store.whatsapp) { %><a href="https://wa.me/<%=store.whatsapp%>" class="text-xs font-bold px-4 py-2 rounded-xl" style="background:rgba(255,255,255,0.1);color:#fff;border:1px dashed rgba(255,255,255,0.2)">WhatsApp</a><% } %>
          <% if (store.instagram) { %><a href="https://instagram.com/<%=store.instagram.replace('@','')%>" class="text-xs font-bold px-4 py-2 rounded-xl" style="background:rgba(255,255,255,0.1);color:#fff;border:1px dashed rgba(255,255,255,0.2)">Instagram</a><% } %>
        </div>
      </div>
    </div>
    <div class="mt-10 pt-6 text-center text-xs opacity-40" style="border-top:1px dashed rgba(255,255,255,0.1);font-family:'Fredoka',sans-serif">
      &copy; <%= new Date().getFullYear() %> <%= store.name %> ✨
    </div>
  </div>
</footer>

<script>
async function addToCart(productId, variantId, qty) {
  const res = await fetch('/api/cart/add', {
    method: 'POST',
    headers: { 'Content-Type': 'application/json' },
    body: JSON.stringify({ product_id: productId, variant_id: variantId || null, quantity: qty || 1, store_id: '<%= store.id %>' })
  });
  const data = await res.json();
  if (data.success) { toggleCartDrawer(); } else { alert(data.error || 'Error'); }
}
async function addComboToCart(comboId) {
  const res = await fetch('/api/cart/add-combo', {
    method: 'POST',
    headers: { 'Content-Type': 'application/json' },
    body: JSON.stringify({ combo_id: comboId, store_id: '<%= store.id %>' })
  });
  const data = await res.json();
  if (data.success) { toggleCartDrawer(); } else { alert(data.error || 'Error'); }
}
</script>

<%- include('../../partials/_cart_drawer', { cartItems, cartTotal, store, storeBaseUrl }); %>
<%- include('../../partials/_order_success', { order: locals.order, whatsappLink: locals.whatsappLink, store, storeBaseUrl, locals }); %>
</body>
</html>
