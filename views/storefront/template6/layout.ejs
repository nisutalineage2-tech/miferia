<% const t = store.theme_settings ? JSON.parse(store.theme_settings) : {}; const c = t.colors || {}; %>
<% const isHome = !page || page === 'home'; %>
<% const isShop = page === 'shop'; %>
<% const isProduct = page === 'product'; %>
<% const isCart = page === 'cart'; %>
<% const isCheckout = page === 'checkout'; %>
<% const isCategory = page === 'category'; %>
<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= store.name || 'Store' %><%= typeof pageTitle !== 'undefined' ? ' — ' + pageTitle : '' %></title>
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Fredoka:wght@300;400;500;600;700&family=Nunito:wght@300;400;500;600;700&display=swap" rel="stylesheet">
  <script src="https://cdn.tailwindcss.com"></script>
  <script>
    tailwind.config = {
      theme: {
        extend: {
          fontFamily: {
            fredoka: ['Fredoka', 'sans-serif'],
            nunito: ['Nunito', 'sans-serif']
          },
          colors: {
            primary: 'var(--primary)',
            bg: 'var(--bg)',
            text: 'var(--text)',
            'retro-pink': '#ec4899',
            'retro-yellow': '#fbbf24',
            'retro-purple': '#8b5cf6'
          }
        }
      }
    }
  </script>
  <style>
    :root {
      --primary: <%= c.btn_primary_bg || '#8b5cf6' %>;
      --bg: <%= c.page_bg || '#ffffff' %>;
      --text: <%= c.text || '#4a4a4a' %>;
      --footer-bg: <%= c.footer_bg || '#8b5cf6' %>;
      --footer-text: <%= c.footer_text || '#ffffff' %>;
      --title: <%= c.heading_color || '#1a1a1a' %>;
      --label-bg: <%= c.label_bg || '#ec4899' %>;
    }
    * { font-family: 'Nunito', sans-serif; }
    h1,h2,h3,h4,h5,h6 { font-family: 'Fredoka', sans-serif; color: var(--title); }
    body { background: var(--bg); color: var(--text); }
    @keyframes float {
      0%,100% { transform: translateY(0px); }
      50% { transform: translateY(-6px); }
    }
    @keyframes pulse-fun {
      0%,100% { transform: scale(1); }
      50% { transform: scale(1.05); }
    }
    @keyframes bounce-cart {
      0%,100% { transform: scale(1); }
      30% { transform: scale(1.2); }
    }
    .retro-card {
      border: 3px dashed var(--primary);
      border-radius: 1rem;
      background: white;
      transition: transform 0.25s ease, box-shadow 0.25s ease;
    }
    .retro-card:hover {
      transform: scale(1.03) rotate(-1deg);
      box-shadow: 0 8px 24px rgba(139,92,246,0.2);
    }
    .sticker-badge {
      display: inline-block;
      background: var(--label-bg);
      color: white;
      font-family: 'Fredoka', sans-serif;
      padding: 4px 14px;
      border-radius: 9999px;
      font-size: 0.75rem;
      font-weight: 600;
      transform: rotate(-3deg);
    }
    .cart-bounce:hover svg {
      animation: bounce-cart 0.4s ease;
    }
    .float-anim {
      animation: float 3s ease-in-out infinite;
    }
    .pulse-fun {
      animation: pulse-fun 2s ease-in-out infinite;
    }
  </style>
</head>
<body class="antialiased min-h-screen flex flex-col">
  <%- include('../../partials/_flash', { locals }); %>
  <%- include('../../partials/_cart_drawer', { store, storeBaseUrl }); %>
  <%- include('../../partials/_order_success', { locals }); %>

  <!-- NAV — Colorful Gradient Bar -->
  <nav class="sticky top-0 z-40" style="background: linear-gradient(135deg, #8b5cf6, #ec4899, #f97316); padding: 3px 0;">
    <div class="max-w-7xl mx-auto px-6 py-3 flex items-center justify-between" style="background: white; border-radius: 9999px; margin: 4px;">
      <a href="<%= storeBaseUrl || '/' %>" class="font-fredoka text-xl font-bold" style="background: linear-gradient(135deg, #8b5cf6, #ec4899); -webkit-background-clip: text; -webkit-text-fill-color: transparent;">
        <%= store.name || 'Store' %>
      </a>
      <div class="hidden md:flex items-center gap-6 text-sm font-semibold" style="color: var(--text)">
        <%- include('../../partials/_nav_links', { store, storeBaseUrl, locals: { navLinkClass: 'hover:text-purple-600 transition-colors font-nunito' } }); %>
      </div>
      <div class="flex items-center gap-4">
        <a href="<%= storeBaseUrl %>/carrito" class="relative cart-bounce" style="color: var(--text)">
          <svg xmlns="http://www.w3.org/2000/svg" class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M3 3h2l.4 2M7 13h10l4-8H5.4M7 13L5.4 5M7 13l-2.3 2.3c-.4.4-.1 1.1.5 1.1H17m0 0a2 2 0 100 4 2 2 0 000-4zm-8 2a2 2 0 100 4 2 2 0 000-4z"/>
          </svg>
          <span class="cart-count absolute -top-2 -right-2 text-white text-[10px] w-5 h-5 rounded-full flex items-center justify-center font-bold pulse-fun" style="background: #ec4899"><%= cartCount || 0 %></span>
        </a>
      </div>
    </div>
  </nav>

  <!-- MAIN -->
  <main class="flex-1">
    <% if (isHome) { %>
      <%- include('../../partials/_banner_carousel', { heroImages, store, storeBaseUrl }); %>
      <%- include('../../partials/_home_content', { store, storeBaseUrl, categories, products, featured, combos, locals }); %>
    <% } else if (isProduct) { %>
      <div class="max-w-7xl mx-auto px-6 py-12">
        <%- include('../../partials/_product_detail', { product, productImages, variants, volumeDiscounts, category, related, store, storeBaseUrl, locals }); %>
      </div>
    <% } else if (isCart) { %>
      <div class="max-w-4xl mx-auto px-6 py-12">
        <%- include('../../partials/_cart', { cartItems, cartTotal, store, storeBaseUrl, locals }); %>
      </div>
    <% } else if (isCheckout) { %>
      <div class="max-w-4xl mx-auto px-6 py-12">
        <%- include('../../partials/_checkout', { cartItems, cartTotal, store, storeBaseUrl, locals }); %>
      </div>
    <% } else if (isCategory) { %>
      <div class="max-w-7xl mx-auto px-6 py-12">
        <h1 class="text-3xl font-bold mb-2"><%= category.name %></h1>
        <span class="sticker-badge mb-6 inline-block">Browse all</span>
        <div class="grid grid-cols-2 md:grid-cols-3 lg:grid-cols-4 gap-5">
          <% products.forEach(p => { %>
            <div class="retro-card p-0 overflow-hidden">
              <%- include('../../partials/_product_card', { product: p, store, locals }); %>
            </div>
          <% }); %>
        </div>
      </div>
    <% } else if (isShop) { %>
      <div class="max-w-7xl mx-auto px-6 py-12">
        <h1 class="text-3xl font-bold mb-2">Shop</h1>
        <span class="sticker-badge mb-6 inline-block">All products</span>
        <div class="grid grid-cols-2 md:grid-cols-3 lg:grid-cols-4 gap-5">
          <% (products || []).forEach(p => { %>
            <div class="retro-card p-0 overflow-hidden">
              <%- include('../../partials/_product_card', { product: p, store, locals }); %>
            </div>
          <% }); %>
        </div>
      </div>
    <% } else { %>
      <%- include('../../partials/_page_content', { page, store, storeBaseUrl, categories, products, featured, combos, locals }); %>
    <% } %>
  </main>

  <!-- FOOTER — Colorful Gradient -->
  <footer class="mt-20 pt-14 pb-10" style="background: linear-gradient(135deg, #8b5cf6, #ec4899, #f97316);">
    <div class="max-w-7xl mx-auto px-6 grid grid-cols-1 md:grid-cols-3 gap-10">
      <div>
        <h3 class="font-fredoka text-xl font-bold text-white mb-3 float-anim inline-block">🎉 <%= store.name || 'Store' %></h3>
        <p class="text-sm leading-relaxed text-white/80">Where fun meets shopping!</p>
      </div>
      <div>
        <h3 class="font-fredoka text-lg font-bold text-white mb-3">Quick Links</h3>
        <div class="flex flex-col gap-2 text-sm font-semibold text-white/80">
          <%- include('../../partials/_nav_links', { store, storeBaseUrl, locals: { navLinkClass: 'hover:text-yellow-200 transition-colors' } }); %>
        </div>
      </div>
      <div>
        <h3 class="font-fredoka text-lg font-bold text-white mb-3">Legal</h3>
        <p class="text-xs text-white/70">&copy; <%= new Date().getFullYear() %> <%= store.name || 'Store' %>. All rights reserved.</p>
      </div>
    </div>
  </footer>

  <!-- MOBILE MENU -->
  <%- include('../../partials/_mobile_menu', { store, storeBaseUrl, locals: { iconColor: '#8b5cf6' } }); %>

  <script>
    function addToCart(productId, qty, variantId) {
      fetch((window.storeBaseUrl || '') + '/api/cart/add', {
        method: 'POST', headers: {'Content-Type':'application/x-www-form-urlencoded'},
        body: 'store_id=' + window.storeId + '&product_id=' + productId + (variantId ? '&variant_id=' + variantId : '') + '&quantity=' + (qty||1)
      }).then(r=>r.json()).then(d=>{
        if(d.cartCount!==undefined) document.querySelectorAll('.cart-count').forEach(e=>e.textContent=d.cartCount);
        if(typeof toggleCartDrawer==='function') toggleCartDrawer();
      });
    }
    function addComboToCart(comboId) {
      fetch((window.storeBaseUrl || '') + '/api/cart/add', {
        method: 'POST', headers: {'Content-Type':'application/x-www-form-urlencoded'},
        body: 'store_id=' + window.storeId + '&combo_id=' + comboId + '&quantity=1'
      }).then(r=>r.json()).then(d=>{
        if(d.cartCount!==undefined) document.querySelectorAll('.cart-count').forEach(e=>e.textContent=d.cartCount);
        if(typeof toggleCartDrawer==='function') toggleCartDrawer();
      });
    }
    window.storeBaseUrl = '<%= storeBaseUrl %>';
    window.storeId = '<%= store.id %>';
  </script>
</body>
</html>
