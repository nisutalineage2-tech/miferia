<!DOCTYPE html>
<html lang="es">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= (title || store.name || '') %></title>
  <script src="https://cdn.tailwindcss.com"></script>
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Fredoka:wght@400;500;600;700&family=Nunito:wght@400;600;700;800&display=swap" rel="stylesheet">
  <style>
    <% let tc = {}; try { tc = JSON.parse(store.theme_settings || '{}'); } catch(e) {} const col = tc.colors || {}; const fonts = tc.fonts || {}; const hdr = tc.header || {}; %>
    body { font-family: 'Nunito', sans-serif; background: <%= col.body_bg || '#fef9c3' %>; color: <%= col.body_text || '#422006' %>; }
    h1,h2,h3,.fun-font { font-family: 'Fredoka', sans-serif; font-weight: 600; letter-spacing: -0.01em; }
    :root { --primary: <%= col.btn_primary_bg || '#f43f5e' %>; --accent: <%= col.btn_secondary_bg || '#fbbf24' %>; --footer-bg: <%= col.footer_bg || '#422006' %>; --footer-text: <%= col.footer_text || '#fbbf24' %>; }
    .product-card { background: #fff; border: 3px solid #fde68a; border-radius: 20px; transition: all 0.3s ease; overflow: hidden; }
    .product-card:hover { border-color: #f43f5e; transform: rotate(-1deg); box-shadow: 0 8px 30px rgba(244,63,94,0.1); }
    .btn-primary { background: linear-gradient(135deg, #f43f5e, #fbbf24); color: #fff; border-radius: 9999px; font-weight: 700; padding: 0.75rem 2rem; }
    .btn-primary:hover { transform: scale(1.05); }
    .section-title { font-family: 'Fredoka', sans-serif; font-weight: 600; letter-spacing: -0.01em; font-size: 2rem; }
    .fun-gradient { background: linear-gradient(135deg, #fef3c7, #fce7f3, #e0f2fe); }
    .product-card img { transition: transform 0.3s ease; }
    .product-card:hover img { transform: scale(1.06) rotate(1deg); }
    .bounce { animation: bounce 2s ease-in-out infinite; }
    @keyframes bounce { 0%,100% { transform: translateY(0); } 50% { transform: translateY(-8px); } }
    <% if (store.advanced_css) { %><%= store.advanced_css %><% } %>
  </style>
</head>
<body>
  <nav class="bg-white/90 backdrop-blur-sm border-b border-[#fde68a] sticky top-0 z-40">
    <div class="max-w-6xl mx-auto px-6">
      <div class="flex items-center justify-between h-16">
        <a href="/<%= store.slug %>" class="flex items-center gap-2">
          <% if (store.logo) { %><img src="<%= store.logo %>" alt="<%= store.name %>" class="h-8 w-auto"><% } else { %><span class="text-xl fun-font text-[#422006]"><%= store.name %></span><% } %>
        </a>
        <div class="hidden md:flex items-center gap-6">
          <%- include('../../partials/_nav_links', { locals: { navLinkClass: 'text-sm font-semibold text-gray-500 hover:text-[#f43f5e] transition-colors' } }) %>
        </div>
        <a href="/<%= store.slug %>/carrito" class="relative p-2">
          <svg class="w-5 h-5 text-gray-600" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M15.75 10.5V6a3.75 3.75 0 10-7.5 0v4.5m11.356-1.993l1.263 12c.07.665-.45 1.243-1.119 1.243H4.25a1.125 1.125 0 01-1.12-1.243l1.264-12A1.125 1.125 0 015.513 7.5h12.974c.576 0 1.059.435 1.119 1.007zM8.625 10.5a.375.375 0 11-.75 0 .375.375 0 01.75 0zm7.5 0a.375.375 0 11-.75 0 .375.375 0 01.75 0z"/></svg>
          <% if (cartCount > 0) { %><span class="absolute -top-1 -right-1 w-5 h-5 bg-[#f43f5e] text-white text-[10px] font-bold rounded-full flex items-center justify-center"><%= cartCount %></span><% } %>
        </a>
      
            <%- include('../../partials/_mobile_menu', { locals: { iconColor: 'text-gray-600' } }) %>
</div>
    </div>
  </nav>

  <main>
    <%- include('../../partials/_flash', { locals }); %>
    <% if (page === 'home') { %>
      <section class="fun-gradient py-16 lg:py-24">
        <div class="max-w-6xl mx-auto px-6">
          <div class="flex flex-col lg:flex-row items-center gap-10">
            <div class="flex-1 text-center lg:text-left">
              <div class="bounce inline-block text-3xl mb-2">📚</div>
              <span class="fun-font text-sm text-[#f43f5e] mb-2 block">Lectura y Diversión</span>
              <h1 class="text-4xl lg:text-6xl fun-font text-[#422006] mb-4"><%= store.name %></h1>
              <p class="text-gray-500 mb-8 text-lg"><%= store.description %></p>
              <a href="/<%= store.slug %>/tienda" class="btn-primary inline-flex items-center gap-2">Ver Libros <span>→</span></a>
            </div>
            <div class="flex-1"><%- include('../../partials/_hero_carousel', { images: heroImages, fallback: store.banner, className: 'rounded-3xl shadow-lg', height: 'h-56 sm:h-72' }); %></div>
          </div>
        </div>
      </section>

      <div class="max-w-6xl mx-auto px-6 py-20">
        <% if (categories.length > 0) { %>
          <div class="flex flex-wrap justify-center gap-2 mb-16">
            <a href="/<%= store.slug %>" class="px-6 py-2.5 text-sm rounded-full bg-[#f43f5e] text-white">Todos</a>
            <% categories.forEach(c => { %>
              <a href="/<%= store.slug %>/categoria/<%= c.name.toLowerCase().replace(/ /g, '-') %>" class="px-6 py-2.5 text-sm rounded-full bg-white text-gray-600 border border-[#fde68a] hover:bg-[#f43f5e] hover:text-white hover:border-[#f43f5e] transition-colors"><%= c.name %></a>
            <% }); %>
          </div>
        <% } %>

        <% if (store.about_text) { %>
          <div class="max-w-xl mx-auto text-center mb-20">
            <p class="text-gray-500 leading-relaxed"><%= store.about_text %></p>
          </div>
        <% } %>

        <% if (products.length > 0) { %>
          <div class="grid grid-cols-2 md:grid-cols-3 lg:grid-cols-4 gap-6">
            <% products.forEach(p => { %><%- include('../../partials/_product_card', { product: p, store, locals }); %><% }); %>
          </div>
        <% } else { %>
          <div class="text-center py-16 text-gray-400 fun-font text-2xl">Próximamente...</div>
        <% } %>
      </div>
    <% } else if (page === 'category') { %>
      <div class="max-w-6xl mx-auto px-6 py-12">
        <a href="/<%= store.slug %>" class="inline-flex items-center gap-2 text-sm text-[#f43f5e] hover:underline mb-8"><svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 12H5m7-7l-7 7 7 7"/></svg> Volver</a>
        <h1 class="text-3xl fun-font text-[#422006] mb-8"><%= category.name %></h1>
        <div class="grid grid-cols-2 md:grid-cols-3 lg:grid-cols-4 gap-6"><% products.forEach(p => { %><%- include('../../partials/_product_card', { product: p, store, locals }); %><% }); %></div>
      </div>
    <% } else if (page === 'product') { %>
      <%- include('../../partials/_product_detail', { product, store, locals }); %>
    <% } else if (page === 'cart') { %>
      <%- include('../../partials/_cart', { store, locals }); %>
    <% } else if (page === 'checkout') { %>
      <%- include('../../partials/_checkout', { store, locals }); %>
    <% } else { %>
      <%- include('../../partials/_page_content', { store, locals }); %>
    <% } %>
  </main>

  <footer class="bg-[#422006] py-16 mt-20">
    <div class="max-w-6xl mx-auto px-6">
      <div class="flex flex-col md:flex-row items-center justify-between gap-6">
        <div>
          <h3 class="text-xl fun-font text-white"><%= store.name %></h3>
          <% if (store.description) { %><p class="text-sm text-[#fbbf24] mt-2"><%= store.description %></p><% } %>
        </div>
        <div class="flex gap-6">
          <% if (store.instagram) { %><a href="https://instagram.com/<%= store.instagram %>" target="_blank" class="text-[#fbbf24] hover:text-white transition-colors text-sm">Instagram</a><% } %>
          <% if (store.whatsapp) { %><a href="https://wa.me/<%= store.whatsapp %>" target="_blank" class="text-[#fbbf24] hover:text-white transition-colors text-sm">WhatsApp</a><% } %>
        </div>
      </div>
      <p class="text-center text-xs text-[#fbbf24] mt-10">Powered by TuFerIA</p>
    </div>
  </footer>

  <script>
  async function addToCart(productId, variantId, quantity) {
    const q = quantity || 1; const v = variantId || null;
    const r = await fetch('/api/cart/add', { method: 'POST', headers: { 'Content-Type': 'application/json' }, body: JSON.stringify({ store_id: '<%= store.id %>', product_id: productId, variant_id: v, quantity: q }) });
    const d = await r.json(); if (d.success) { location.reload(); } else { alert(d.error || 'Error'); }
  }
  async function addComboToCart(comboId) {
    const r = await fetch('/api/cart/combo', { method: 'POST', headers: { 'Content-Type': 'application/json' }, body: JSON.stringify({ store_id: '<%= store.id %>', combo_id: comboId }) });
    const d = await r.json(); if (d.success) { location.reload(); } else { alert(d.error || 'Error'); }
  }
  </script>
</body>
</html>