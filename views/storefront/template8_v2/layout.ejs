<!DOCTYPE html>
<html lang="es">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= (title || store.name || '') %></title>
  <script src="https://cdn.tailwindcss.com"></script>
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@200;300;400;500;600&display=swap" rel="stylesheet">
  <style>
    <% let tc = {}; try { tc = JSON.parse(store.theme_settings || '{}'); } catch(e) {} const col = tc.colors || {}; const fonts = tc.fonts || {}; const hdr = tc.header || {}; %>
    body { font-family: '<%= fonts.body || 'Inter' %>', sans-serif; background: <%= col.body_bg || '#fafafa' %>; color: <%= col.body_text || '#1a1a1a' %>; }
    h1,h2,h3 { font-weight: 200; letter-spacing: 0.05em; text-transform: uppercase; }
    :root { --primary: <%= col.btn_primary_bg || '#1a1a1a' %>; --accent: <%= col.btn_secondary_bg || '#f0f0f0' %>; --footer-bg: <%= col.footer_bg || '#1a1a1a' %>; --footer-text: <%= col.footer_text || '#a3a3a3' %>; }
    .product-card { background: #fff; border: none; border-radius: 0; transition: all 0.3s ease; overflow: hidden; }
    .product-card:hover { box-shadow: 0 20px 60px rgba(0,0,0,0.04); }
    .product-card img { transition: opacity 0.4s ease; }
    .product-card:hover img { opacity: 0.85; }
    .btn-primary { background: #1a1a1a; color: #fff; border-radius: 0; font-weight: 300; letter-spacing: 0.1em; font-size: 0.7rem; padding: 0.875rem 2rem; text-transform: uppercase; }
    .btn-primary:hover { background: #333; }
    .section-title { font-weight: 200; letter-spacing: 0.1em; text-transform: uppercase; font-size: 1.25rem; }
    .minimal-divider { width: 30px; height: 1px; background: #1a1a1a; }
    .product-card .product-name { font-weight: 300; letter-spacing: 0.05em; text-transform: uppercase; font-size: 0.65rem; }
    .product-card .product-price { font-weight: 400; letter-spacing: 0.05em; }
    .hero-minimal { padding-top: 8rem; padding-bottom: 4rem; }
    <% if (store.advanced_css) { %><%= store.advanced_css %><% } %>
  </style>
</head>
<body>
  <nav class="bg-white border-b border-[#e5e5e5] sticky top-0 z-40">
    <div class="max-w-7xl mx-auto px-4 lg:px-8">
      <div class="flex items-center justify-between h-20">
        <a href="/<%= store.slug %>" class="flex items-center gap-2">
          <% if (store.logo) { %><img src="<%= store.logo %>" alt="<%= store.name %>" class="h-6 w-auto opacity-70"><% } else { %><span class="text-xs uppercase tracking-[0.2em] text-[#1a1a1a] font-light"><%= store.name %></span><% } %>
        </a>
        <div class="hidden md:flex items-center gap-10">
          <%- include('../../partials/_nav_links', { locals: { navLinkClass: 'text-xs uppercase tracking-[0.15em] text-gray-400 hover:text-[#1a1a1a] transition-colors' } }) %>
        </div>
        <a href="/<%= store.slug %>/carrito" class="relative p-2">
          <svg class="w-4 h-4 text-gray-400" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1" d="M15.75 10.5V6a3.75 3.75 0 10-7.5 0v4.5m11.356-1.993l1.263 12c.07.665-.45 1.243-1.119 1.243H4.25a1.125 1.125 0 01-1.12-1.243l1.264-12A1.125 1.125 0 015.513 7.5h12.974c.576 0 1.059.435 1.119 1.007zM8.625 10.5a.375.375 0 11-.75 0 .375.375 0 01.75 0zm7.5 0a.375.375 0 11-.75 0 .375.375 0 01.75 0z"/></svg>
          <% if (cartCount > 0) { %><span class="absolute -top-0.5 -right-0.5 w-3.5 h-3.5 bg-[#1a1a1a] text-white text-[8px] font-light flex items-center justify-center"><%= cartCount %></span><% } %>
        </a>
      
            <%- include('../../partials/_mobile_menu', { locals: { iconColor: 'text-gray-600' } }) %>
</div>
    </div>
  </nav>

  <main>
    <%- include('../../partials/_flash', { locals }); %>
    <% if (page === 'home') { %>
      <section class="hero-minimal max-w-7xl mx-auto px-4 lg:px-8">
        <div class="grid grid-cols-1 lg:grid-cols-2 gap-16 items-end">
          <div>
            <div class="minimal-divider mb-6"></div>
            <h1 class="text-5xl lg:text-7xl font-light uppercase tracking-[0.05em] text-[#1a1a1a] mb-6 leading-[0.9]"><%= store.name %></h1>
            <p class="text-sm text-gray-400 mb-10 max-w-md leading-relaxed"><%= store.description %></p>
            <a href="/<%= store.slug %>/tienda" class="btn-primary inline-flex items-center gap-2">Ver Colección <span>→</span></a>
          </div>
          <div class="lg:pb-8"><%- include('../../partials/_hero_carousel', { images: heroImages, fallback: store.banner, className: 'rounded-none', height: 'h-72' }); %></div>
        </div>
      </section>

      <div class="max-w-7xl mx-auto px-4 lg:px-8 py-24">
        <% if (categories.length > 0) { %>
          <div class="mb-16">
            <a href="/<%= store.slug %>" class="text-xs uppercase tracking-[0.15em] text-[#1a1a1a] mr-8 pb-2 border-b border-[#1a1a1a]">Todos</a>
            <% categories.forEach(c => { %>
              <a href="/<%= store.slug %>/categoria/<%= c.name.toLowerCase().replace(/ /g, '-') %>" class="text-xs uppercase tracking-[0.15em] text-gray-400 hover:text-[#1a1a1a] transition-colors mr-8 pb-2"><%= c.name %></a>
            <% }); %>
          </div>
        <% } %>

        <% if (store.about_text) { %>
          <div class="max-w-xl mb-20">
            <div class="minimal-divider mb-6"></div>
            <p class="text-gray-500 leading-relaxed text-sm"><%= store.about_text %></p>
          </div>
        <% } %>

        <% if (products.length > 0) { %>
          <div class="grid grid-cols-2 md:grid-cols-3 lg:grid-cols-4 gap-x-10 gap-y-16">
            <% products.forEach(p => { %><%- include('../../partials/_product_card', { product: p, store, locals }); %><% }); %>
          </div>
        <% } else { %>
          <div class="text-center py-16 text-gray-300 uppercase tracking-[0.15em] text-sm">Próximamente</div>
        <% } %>
      </div>
    <% } else if (page === 'category') { %>
      <div class="max-w-7xl mx-auto px-4 lg:px-8 py-12">
        <a href="/<%= store.slug %>" class="inline-flex items-center gap-2 text-xs uppercase tracking-[0.15em] text-gray-400 hover:text-[#1a1a1a] transition-colors mb-8"><svg class="w-3 h-3" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 12H5m7-7l-7 7 7 7"/></svg> Volver</a>
        <h1 class="section-title text-[#1a1a1a] mb-8"><%= category.name %></h1>
        <div class="grid grid-cols-2 md:grid-cols-3 lg:grid-cols-4 gap-x-10 gap-y-16"><% products.forEach(p => { %><%- include('../../partials/_product_card', { product: p, store, locals }); %><% }); %></div>
      </div>
    <% } else if (page === 'product') { %>
      <%- include('../../partials/_product_detail', { product, store, locals }); %>
    <% } else if (page === 'cart') { %>
      <%- include('../../partials/_cart', { store, locals }); %>
    <% } else if (page === 'checkout') { %>
      <%- include('../../partials/_checkout', { store, locals }); %>
    <% } else { %>
      <%- include('../../partials/_page_content', { store, locals }); %>
    <% } %>
  </main>

  <footer class="bg-[#1a1a1a] py-20 mt-20">
    <div class="max-w-7xl mx-auto px-4 lg:px-8">
      <div class="flex flex-col md:flex-row items-center justify-between gap-6">
        <div>
          <h3 class="text-xs uppercase tracking-[0.2em] text-white font-light"><%= store.name %></h3>
          <% if (store.description) { %><p class="text-xs text-gray-500 mt-3 max-w-xs leading-relaxed"><%= store.description %></p><% } %>
        </div>
        <div class="flex gap-8">
          <% if (store.instagram) { %><a href="https://instagram.com/<%= store.instagram %>" target="_blank" class="text-xs uppercase tracking-[0.15em] text-gray-500 hover:text-white transition-colors">Instagram</a><% } %>
          <% if (store.whatsapp) { %><a href="https://wa.me/<%= store.whatsapp %>" target="_blank" class="text-xs uppercase tracking-[0.15em] text-gray-500 hover:text-white transition-colors">WhatsApp</a><% } %>
        </div>
      </div>
      <p class="text-center text-xs text-gray-600 mt-12 uppercase tracking-[0.15em]">Powered by TuFerIA</p>
    </div>
  </footer>

  <script>
  async function addToCart(productId, variantId, quantity) {
    const q = quantity || 1; const v = variantId || null;
    const r = await fetch('/api/cart/add', { method: 'POST', headers: { 'Content-Type': 'application/json' }, body: JSON.stringify({ store_id: '<%= store.id %>', product_id: productId, variant_id: v, quantity: q }) });
    const d = await r.json(); if (d.success) { location.reload(); } else { alert(d.error || 'Error'); }
  }
  async function addComboToCart(comboId) {
    const r = await fetch('/api/cart/combo', { method: 'POST', headers: { 'Content-Type': 'application/json' }, body: JSON.stringify({ store_id: '<%= store.id %>', combo_id: comboId }) });
    const d = await r.json(); if (d.success) { location.reload(); } else { alert(d.error || 'Error'); }
  }
  </script>
</body>
</html>