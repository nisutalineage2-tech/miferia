<!DOCTYPE html>
<html lang="es">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= title %></title>
  <script src="https://cdn.tailwindcss.com"></script>
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800&display=swap" rel="stylesheet">
  <style>
    body { font-family: 'Inter', sans-serif; }
    .hero-gradient { background: linear-gradient(135deg, #0f0f1a 0%, #1a1a2e 50%, #0f0f1a 100%); }
    .glow-card:hover { box-shadow: 0 0 40px rgba(99, 102, 241, 0.15); }
  </style>
</head>
<body class="hero-gradient min-h-screen text-gray-100">
  <!-- Nav -->
  <nav class="fixed top-0 w-full z-50 bg-[#0f0f1a]/80 backdrop-blur-xl border-b border-gray-800/30">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="flex items-center justify-between h-16">
        <a href="/" class="flex items-center gap-2">
          <div class="w-8 h-8 rounded-lg bg-gradient-to-br from-indigo-500 to-purple-600 flex items-center justify-center">
            <svg class="w-5 h-5 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 10V3L4 14h7v7l9-11h-7z"/>
            </svg>
          </div>
          <span class="text-xl font-bold text-white">TuFerIA</span>
        </a>
        <div class="flex items-center gap-4">
          <a href="/auth/login" class="text-sm font-medium text-gray-400 hover:text-white transition-colors">Iniciar Sesión</a>
          <a href="/auth/register"
            class="inline-flex items-center gap-2 px-5 py-2.5 text-sm font-semibold text-white bg-gradient-to-r from-indigo-600 to-purple-600 rounded-xl hover:from-indigo-500 hover:to-purple-500 transition-all shadow-lg shadow-indigo-600/25">
            Crear Tienda Gratis
          </a>
        </div>
      </div>
    </div>
  </nav>

  <!-- Hero -->
  <section class="relative pt-32 pb-20 lg:pt-40 lg:pb-32 overflow-hidden">
    <div class="absolute inset-0">
      <div class="absolute top-1/4 left-1/4 w-96 h-96 bg-indigo-500/10 rounded-full blur-[120px]"></div>
      <div class="absolute bottom-1/4 right-1/4 w-96 h-96 bg-purple-500/10 rounded-full blur-[120px]"></div>
    </div>
    <div class="relative max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
      <div class="inline-flex items-center gap-2 px-4 py-1.5 rounded-full bg-indigo-500/10 border border-indigo-500/20 text-sm text-indigo-300 mb-8">
        <span class="w-2 h-2 rounded-full bg-indigo-400 animate-pulse"></span>
        Creado por IA para emprendedores LATAM
      </div>
      <h1 class="text-4xl sm:text-5xl md:text-6xl lg:text-7xl font-extrabold tracking-tight leading-tight mb-6">
        <span class="text-white">Creá tu tienda online</span>
        <br>
        <span class="text-transparent bg-clip-text bg-gradient-to-r from-indigo-400 via-purple-400 to-pink-400">en segundos con IA</span>
      </h1>
      <p class="text-lg sm:text-xl text-gray-400 max-w-2xl mx-auto mb-10">
        Elegí un diseño, agregá tus productos y empezá a vender. Sin complicaciones, sin código, sin límites.
      </p>
      <a href="/auth/register"
        class="inline-flex items-center gap-2 px-8 py-4 text-base font-semibold text-white bg-gradient-to-r from-indigo-600 to-purple-600 rounded-xl hover:from-indigo-500 hover:to-purple-500 transition-all shadow-xl shadow-indigo-600/25 hover:-translate-y-0.5">
        Crear mi Tienda Gratis
        <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 7l5 5m0 0l-5 5m5-5H6"/>
        </svg>
      </a>
    </div>
  </section>

  <!-- Features -->
  <section class="py-20 lg:py-32 border-t border-gray-800/30">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center max-w-3xl mx-auto mb-16">
        <h2 class="text-3xl sm:text-4xl font-bold text-white mb-4">Todo lo que necesitás para vender online</h2>
        <p class="text-lg text-gray-400">Panel de control completo, 3 diseños profesionales, carrito de compras y más.</p>
      </div>
      <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-6">
        <% const features = [
          { icon: 'M4 16l4.586-4.586a2 2 0 012.828 0L16 16m-2-2l1.586-1.586a2 2 0 012.828 0L20 14m-6-6h.01M6 20h12a2 2 0 002-2V6a2 2 0 00-2-2H6a2 2 0 00-2 2v12a2 2 0 002 2z', title: '3 Diseños Profesionales', desc: 'Elegí entre Clásico, Moderno o Minimal. Todos responsive y optimizados.', color: 'indigo' },
          { icon: 'M20 7l-8-4-8 4m16 0l-8 4m8-4v10l-8 4m0-10L4 7m8 4v10M4 7v10l8 4', title: 'Productos + Variantes', desc: 'Agregá productos con precios, variantes de color/tamaño, stock y combos.', color: 'purple' },
          { icon: 'M3 3h2l.4 2M7 13h10l4-8H5.4M7 13L5.4 5M7 13l-2.293 2.293c-.63.63-.184 1.707.707 1.707H17m0 0a2 2 0 100 4 2 2 0 000-4zm-8 2a2 2 0 100 4 2 2 0 000-4z', title: 'Carrito + Pedidos', desc: 'Sistema de carrito completo con gestión de pedidos y actualización de estados.', color: 'pink' },
          { icon: 'M7 21a4 4 0 01-4-4V5a2 2 0 012-2h4a2 2 0 012 2v12a4 4 0 01-4 4zm0 0h12a2 2 0 002-2v-4a2 2 0 00-2-2h-2.343M11 7.343l1.657-1.657a2 2 0 012.828 0l2.829 2.829a2 2 0 010 2.828l-8.486 8.485M7 17h.01', title: 'Personalización Total', desc: 'Colores, logo, banner, redes sociales. Hacé tuya cada tienda.', color: 'amber' },
          { icon: 'M12 15v2m-6 4h12a2 2 0 002-2v-6a2 2 0 00-2-2H6a2 2 0 00-2 2v6a2 2 0 002 2zm10-10V7a4 4 0 00-8 0v4h8z', title: 'SSL + Seguridad', desc: 'Tu tienda segura con SSL incluido. Datos protegidos y backups automáticos.', color: 'emerald' },
          { icon: 'M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z', title: 'Soporte 24/7', desc: 'WhatsApp integrado para que tus clientes te contacten directo.', color: 'blue' },
        ]; %>
        <% features.forEach(f => { %>
          <div class="p-6 rounded-2xl bg-[#0f0f1a] border border-gray-800/50 hover:border-<%= f.color %>-500/30 transition-all glow-card">
            <div class="w-12 h-12 rounded-xl bg-<%= f.color %>-500/20 flex items-center justify-center mb-4">
              <svg class="w-6 h-6 text-<%= f.color %>-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="<%= f.icon %>"/>
              </svg>
            </div>
            <h3 class="text-lg font-semibold text-white mb-2"><%= f.title %></h3>
            <p class="text-sm text-gray-400"><%= f.desc %></p>
          </div>
        <% }); %>
      </div>
    </div>
  </section>

  <!-- Templates Preview -->
  <section class="py-20 border-t border-gray-800/30">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center max-w-3xl mx-auto mb-16">
        <h2 class="text-3xl sm:text-4xl font-bold text-white mb-4">Elegí tu diseño favorito</h2>
        <p class="text-lg text-gray-400">3 plantillas profesionales listas para usar. Todas responsive y optimizadas.</p>
      </div>
      <div class="grid md:grid-cols-3 gap-6">
        <div class="rounded-2xl overflow-hidden bg-[#0f0f1a] border border-gray-800/50">
          <div class="aspect-[4/3] bg-gradient-to-br from-blue-500/20 to-cyan-500/20 flex items-center justify-center p-8">
            <div class="text-center">
              <svg class="w-16 h-16 text-blue-400 mx-auto mb-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6a2 2 0 012-2h2a2 2 0 012 2v2a2 2 0 01-2 2H6a2 2 0 01-2-2V6z"/>
              </svg>
              <span class="text-xl font-bold text-white">Clásico</span>
              <p class="text-sm text-gray-400 mt-1">Moderno y limpio</p>
            </div>
          </div>
        </div>
        <div class="rounded-2xl overflow-hidden bg-[#0f0f1a] border border-gray-800/50">
          <div class="aspect-[4/3] bg-gradient-to-br from-purple-500/20 to-pink-500/20 flex items-center justify-center p-8">
            <div class="text-center">
              <svg class="w-16 h-16 text-purple-400 mx-auto mb-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 8h14M5 8a2 2 0 110-4h14a2 2 0 110 4M5 8v10a2 2 0 002 2h10a2 2 0 002-2V8m-9 4h4"/>
              </svg>
              <span class="text-xl font-bold text-white">Moderno</span>
              <p class="text-sm text-gray-400 mt-1">Grid y categorías</p>
            </div>
          </div>
        </div>
        <div class="rounded-2xl overflow-hidden bg-[#0f0f1a] border border-gray-800/50">
          <div class="aspect-[4/3] bg-gradient-to-br from-emerald-500/20 to-teal-500/20 flex items-center justify-center p-8">
            <div class="text-center">
              <svg class="w-16 h-16 text-emerald-400 mx-auto mb-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 17V7m0 10a2 2 0 01-2 2H5a2 2 0 01-2-2V7a2 2 0 012-2h2a2 2 0 012 2m0 10a2 2 0 002 2h2a2 2 0 002-2M9 7a2 2 0 012-2h2a2 2 0 012 2m0 10V7m0 10a2 2 0 002 2h2a2 2 0 002-2V7a2 2 0 00-2-2h-2a2 2 0 00-2 2"/>
              </svg>
              <span class="text-xl font-bold text-white">Minimal</span>
              <p class="text-sm text-gray-400 mt-1">Simple y elegante</p>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="py-20 border-t border-gray-800/30">
    <div class="max-w-4xl mx-auto px-4 text-center">
      <h2 class="text-3xl sm:text-4xl font-bold text-white mb-4">¿Listo para crear tu tienda?</h2>
      <p class="text-lg text-gray-400 mb-8">Registrate gratis y empezá a vender en minutos.</p>
      <a href="/auth/register"
        class="inline-flex items-center gap-2 px-8 py-4 text-base font-semibold text-white bg-gradient-to-r from-indigo-600 to-purple-600 rounded-xl hover:from-indigo-500 hover:to-purple-500 transition-all shadow-xl shadow-indigo-600/25">
        Crear mi Tienda Gratis
      </a>
    </div>
  </section>

  <!-- Footer -->
  <footer class="border-t border-gray-800/30 py-8">
    <div class="max-w-7xl mx-auto px-4 text-center">
      <p class="text-sm text-gray-600">© 2026 TuFerIA. Creado con ❤️ para emprendedores LATAM.</p>
    </div>
  </footer>
</body>
</html>
